@model IEnumerable<AlarganShipping.Models.Transporter>
@{
    ViewData["Title"] = Localizer["شركات النقل والريكفري"];
}

<style>
    .page-header-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: white;
        padding: 1.5rem;
        border-radius: 1.5rem;
        box-shadow: 0 5px 20px rgba(44, 62, 80, 0.03);
        border: 1px solid #f1f5f9;
        margin-bottom: 2rem;
    }

    .page-header-text h2 {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .page-header-text h2 i {
            color: var(--primary-gold);
        }

    .btn-add {
        background: linear-gradient(to right, var(--primary-navy), var(--secondary-navy));
        color: #ffffff;
        font-weight: 800;
        padding: 0.85rem 1.75rem;
        border-radius: 1rem;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(44, 62, 80, 0.3);
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(44, 62, 80, 0.4);
            background: linear-gradient(to right, var(--primary-gold), var(--secondary-gold));
            color: white;
        }

    .data-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        overflow-x: auto;
    }

    .table-enterprise {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }

        .table-enterprise th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            padding: 1.25rem 1rem;
            border-bottom: 2px solid #e2e8f0;
            text-align: start;
            white-space: nowrap;
        }

        .table-enterprise td {
            padding: 1.25rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-dark);
            font-weight: 700;
            vertical-align: middle;
        }

    .rating-stars {
        color: #f59e0b;
        font-size: 0.9rem;
    }
</style>

<div>
    <div class="page-header-container">
        <div class="page-header-text">
            <h2><i class="fa-solid fa-truck-fast"></i> @Localizer["شركات النقل الداخلي (Towing)"]</h2>
            <p style="color: var(--text-muted); font-weight: 600; margin-top: 5px;">• @Localizer["إدارة الموردين وشركات الريكفري في بلد التصدير"]</p>
        </div>
        <div class="header-actions">
            <a href="#" class="btn-add"><i class="fa-solid fa-plus"></i> @Localizer["إضافة ناقل جديد"]</a>
        </div>
    </div>

    <div class="data-card">
        <table id="transportersTable" class="table-enterprise display" style="width:100%">
            <thead>
                <tr>
                    <th>@Localizer["اسم الناقل"]</th>
                    <th>@Localizer["رقم الهاتف"]</th>
                    <th>@Localizer["رقم الترخيص (DOT)"]</th>
                    <th>@Localizer["التأمين"]</th>
                    <th>@Localizer["التقييم"]</th>
                    <th>@Localizer["إجراءات"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var trans in Model)
                    {
                        <tr>
                            <td style="font-weight: 900; color: var(--primary-navy);">
                                <i class="fa-solid fa-truck-pickup" style="color: var(--primary-gold); margin-inline-end: 8px;"></i> @trans.Name
                            </td>
                            <td dir="ltr" style="text-align: end; font-family: monospace;">@trans.Phone</td>
                            <td style="font-family: monospace; color: var(--text-muted);">@(string.IsNullOrEmpty(trans.DotNumber) ? "-" : trans.DotNumber)</td>
                            <td>
                                @if (trans.InsuranceExpiryDate.HasValue && trans.InsuranceExpiryDate.Value >= DateTime.Now)
                                {
                                    <span style="color: #16a34a;"><i class="fa-solid fa-shield-check"></i> ساري (@trans.InsuranceExpiryDate.Value.ToString("dd MMM yyyy"))</span>
                                }
                                else
                                {
                                    <span style="color: #ef4444;"><i class="fa-solid fa-shield-xmark"></i> منتهي/غير محدد</span>
                                }
                            </td>
                            <td class="rating-stars">
                                @for (int i = 0; i < trans.Rating; i++)
                                {
                                    <i class="fa-solid fa-star"></i>
                                }
                            </td>
                            <td>
                                <a href="#" style="color: var(--primary-gold); margin-inline-end: 15px;"><i class="fa-solid fa-pen-to-square"></i></a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var dir = $('html').attr('dir') === 'rtl';
            $('#transportersTable').DataTable({
                "language": { "url": dir ? "//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json" : "" },
                "pageLength": 10,
                "responsive": true
            });
        });
    </script>
}