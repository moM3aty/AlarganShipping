@model AlarganShipping.Models.PaymentVoucher
@{
    ViewData["Title"] = Localizer["طباعة سند صرف"];
    Layout = null; // إزالة التخطيط العام لضمان طباعة نظيفة لصفحة واحدة
}
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name" dir="@(System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <title>@Localizer["سند صرف رقم"] @Model.VoucherNumber</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;800;900&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        :root {
            --primary-navy: #1e293b;
            --primary-gold: #b45309;
            --bg-color: #e2e8f0;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background: var(--bg-color);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            flex-direction: column;
            align-items: center;
        }

        .voucher-wrapper {
            background: white;
            width: 100%;
            max-width: 800px;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            margin-top: 20px;
            position: relative;
            overflow: hidden;
        }

        /* العلامة المائية لسند الصرف */
        .watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-30deg);
            font-size: 8rem;
            color: rgba(184, 147, 90, 0.04);
            font-weight: 900;
            white-space: nowrap;
            z-index: 0;
            pointer-events: none;
        }

        /* رأس السند والشعار */
        .voucher-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 3px solid var(--primary-gold);
            padding-bottom: 20px;
            margin-bottom: 30px;
            position: relative;
            z-index: 1;
        }

        .logo-area img {
            max-height: 80px;
            width: auto;
        }

        .logo-area h1 {
            margin: 5px 0 0 0;
            color: var(--primary-navy);
            font-size: 1.6rem;
            font-weight: 900;
        }

        .logo-area p {
            margin: 0;
            color: var(--primary-gold);
            font-weight: 700;
            letter-spacing: 1px;
        }

        .title-area {
            text-align: left;
        }

            .title-area h2 {
                margin: 0;
                font-size: 2.2rem;
                color: var(--primary-navy);
                font-weight: 900;
            }

            .title-area .rcpt-no {
                font-family: monospace;
                font-size: 1.2rem;
                color: #ef4444;
                font-weight: bold;
                margin-top: 5px;
            }

        /* معلومات السند الأساسية */
        .top-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
            font-weight: 800;
            font-size: 1.1rem;
            color: var(--primary-navy);
            position: relative;
            z-index: 1;
        }

            .top-info div {
                background: #f8fafc;
                padding: 10px 20px;
                border-radius: 8px;
                border: 1px solid #e2e8f0;
            }

        /* تفاصيل الصرف الرئيسية */
        .voucher-details {
            margin-bottom: 40px;
            position: relative;
            z-index: 1;
        }

        .detail-row {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
            font-size: 1.2rem;
            line-height: 1.8;
            border-bottom: 1px dashed #e2e8f0;
            padding-bottom: 10px;
        }

        .detail-label {
            width: 180px;
            font-weight: 800;
            color: #64748b;
            flex-shrink: 0;
        }

        .detail-value {
            font-weight: 900;
            color: var(--primary-navy);
            flex: 1;
        }

        .amount-box {
            background: rgba(239, 68, 68, 0.05);
            color: #ef4444;
            padding: 10px 20px;
            border-radius: 8px;
            border: 1px dashed rgba(239, 68, 68, 0.3);
            font-family: monospace;
            font-size: 1.8rem;
            text-align: center;
            margin-top: 5px;
            margin-bottom: 20px;
            display: inline-block;
        }

        /* منطقة التوقيعات */
        .signatures-area {
            display: flex;
            justify-content: space-between;
            margin-top: 60px;
            padding-top: 20px;
            position: relative;
            z-index: 1;
        }

        .signature-box {
            text-align: center;
            width: 200px;
        }

        .signature-line {
            border-bottom: 2px solid var(--primary-navy);
            margin-bottom: 10px;
            height: 50px;
        }

        .signature-title {
            font-weight: 800;
            color: var(--primary-navy);
            font-size: 1.1rem;
        }

        /* أزرار التحكم */
        .controls {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
        }

        .btn-action {
            color: white;
            padding: 12px 25px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-family: inherit;
            font-weight: 900;
            font-size: 1.1rem;
            transition: 0.3s;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .btn-print {
            background: var(--primary-gold);
        }

            .btn-print:hover {
                background: #92400e;
                transform: translateY(-2px);
            }

        .btn-pdf {
            background: #ef4444;
        }

            .btn-pdf:hover {
                background: #dc2626;
                transform: translateY(-2px);
            }

        .btn-back {
            background: var(--primary-navy);
        }

            .btn-back:hover {
                background: #0f172a;
                transform: translateY(-2px);
            }

        /* ==================================
                            إعدادات الطباعة الدقيقة
                    ================================== */
        @@media print {
            body {
                background: white;
                padding: 0;
            }

            .voucher-wrapper {
                box-shadow: none;
                padding: 0;
                max-width: 100%;
                border: none;
                margin: 0;
            }

            .controls {
                display: none !important;
            }

            html, body {
                height: 99%;
                page-break-after: avoid;
                page-break-before: avoid;
            }

            .amount-box {
                background-color: rgba(239, 68, 68, 0.05) !important;
                border-color: rgba(239, 68, 68, 0.3) !important;
                color: #ef4444 !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            .watermark {
                color: rgba(184, 147, 90, 0.04) !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            .top-info div {
                background-color: #f8fafc !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }
    </style>
</head>
<body>
    <div style="width: 100%; max-width: 800px;">
        <div class="controls">
            <button class="btn-action btn-back" onclick="history.back()">العودة للسجل</button>
            <button class="btn-action btn-print" onclick="window.print()">طباعة السند</button>
        </div>

        <div class="voucher-wrapper" id="voucherContent">
            <div class="watermark">CASHED - صُرف</div>

            <div class="voucher-header">
                <div class="logo-area">
                    <img src="/images/logo.png" alt="Logo" onerror="this.style.display='none';" />
                    <h1>شركة الأرجان للشحن</h1>
                    <p>ALARGAN AUTO SHIPPING</p>
                </div>
                <div class="title-area">
                    <h2>سند صرف</h2>
                    <h2>PAYMENT VOUCHER</h2>
                    <div class="rcpt-no">No: @Model.VoucherNumber</div>
                </div>
            </div>

            <div class="top-info">
                <div>@Localizer["رقم السند:"] <span dir="ltr" style="color: var(--primary-gold); font-family: monospace;">@Model.VoucherNumber</span></div>
                <div>@Localizer["التاريخ:"] <span>@Model.VoucherDate.ToString("yyyy/MM/dd")</span></div>
            </div>

            <div class="voucher-details">
                <div class="detail-row">
                    <div class="detail-label">@Localizer["يصرف للسيد / الجهة:"]</div>
                    <div class="detail-value">@Model.BeneficiaryName</div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">@Localizer["مبلغاً وقدره:"]</div>
                    <div class="detail-value">
                        <div class="amount-box">@Model.Amount.ToString("N2") $</div>
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">@Localizer["وذلك عن (البيان):"]</div>
                    <div class="detail-value" style="color: #475569; font-weight: 700;">@Model.Description</div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">@Localizer["تصنيف المصروف:"]</div>
                    <div class="detail-value">@Model.Category</div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">@Localizer["طريقة الدفع:"]</div>
                    <div class="detail-value">@Model.PaymentMethod @(!string.IsNullOrEmpty(Model.ReferenceNumber) ? " (" + Localizer["رقم المرجع:"] + " " + Model.ReferenceNumber + ")" : "")</div>
                </div>

                @if (Model.Customer != null)
                {
                    <div class="detail-row" style="background: rgba(184, 147, 90, 0.05); padding: 10px 15px; border-radius: 8px; border: 1px solid rgba(184, 147, 90, 0.2);">
                        <div class="detail-label" style="color: var(--primary-gold);">@Localizer["مرتبط بالعميل:"]</div>
                        <div class="detail-value" style="color: var(--primary-gold);">@Model.Customer.Name <span style="font-size:0.9rem; color:#64748b;">(@Localizer["تم خصم المبلغ من رصيده المدفوع"])</span></div>
                    </div>
                }
            </div>

            <div class="signatures-area">
                <div class="signature-box">
                    <div class="signature-line"></div>
                    <div class="signature-title">@Localizer["المحاسب / أعد السند"]</div>
                </div>
                <div class="signature-box">
                    <div class="signature-line"></div>
                    <div class="signature-title">@Localizer["توقيع المستلم"]</div>
                </div>
                <div class="signature-box">
                    <div class="signature-line"></div>
                    <div class="signature-title">@Localizer["المدير المالي / الاعتماد"]</div>
                </div>
            </div>
        </div>
    </div>

    <!-- دالة تصدير الـ PDF التي كانت مفقودة -->
    <script>
        function downloadPDF() {
            var element = document.getElementById('voucherContent');
            var opt = {
                margin:       10,
                filename:     'Voucher_@Model.VoucherNumber .pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };
            html2pdf().set(opt).from(element).save();
        }
    </script>
</body>
</html>