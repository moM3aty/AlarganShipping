@model AlarganShipping.Models.PaymentVoucher
@using System.Text.Json
@inject IWebHostEnvironment Env
@{
    ViewData["Title"] = Localizer["طباعة سند صرف"];
    Layout = null;

    string settingsPath = System.IO.Path.Combine(Env.WebRootPath, "settings.json");
    string headerColor = "#1e293b"; string template = "Modern"; string vatNo = "00016800820"; string crNo = "0001425763"; string footerNote = "شكراً لتعاملكم مع شركة الأرجان للشحن.";
    if (System.IO.File.Exists(settingsPath)) {
        using var doc = JsonDocument.Parse(System.IO.File.ReadAllText(settingsPath)); var root = doc.RootElement;
        if (root.TryGetProperty("InvoiceHeaderColor", out var col)) headerColor = col.GetString() ?? headerColor;
        if (root.TryGetProperty("InvoiceTemplate", out var temp)) template = temp.GetString() ?? template;
        if (root.TryGetProperty("VatNumber", out var v)) vatNo = v.GetString() ?? vatNo;
        if (root.TryGetProperty("CrNumber", out var cr)) crNo = cr.GetString() ?? crNo;
        if (root.TryGetProperty("InvoiceFooterText", out var foot)) footerNote = foot.GetString() ?? footerNote;
    }
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>@Localizer["سند صرف رقم"] @Model.VoucherNumber</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;800;900&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        :root { --primary-navy: @headerColor; --primary-gold: #b45309; --bg-color: #e2e8f0; }
        body { font-family: 'Cairo', sans-serif; background: var(--bg-color); margin: 0; padding: 20px; display: flex; justify-content: center; flex-direction: column; align-items: center; }
        
        .voucher-wrapper {
            background: white; width: 100%; max-width: 800px; padding: 40px; border-radius: @(template == "Modern" ? "20px" : "0px");
            box-shadow: 0 10px 30px rgba(0,0,0,0.08); margin-top: 20px; position: relative; overflow: hidden;
            border-top: 10px solid var(--primary-navy); box-sizing: border-box;
        }

        .watermark { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-30deg); font-size: 8rem; color: rgba(0, 0, 0, 0.03); font-weight: 900; white-space: nowrap; z-index: 0; pointer-events: none; }
        .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #eee; padding-bottom: 20px; margin-bottom: 30px; position: relative; z-index: 1; flex-direction: @(template == "Classic" ? "row-reverse" : "row"); }
        .logo-area img { height: 85px; object-fit: contain; }
        .logo-area h1 { margin: 5px 0 0 0; color: var(--primary-navy); font-size: 1.5rem; font-weight: 900; }
        .title-area { text-align: @(template == "Modern" ? "left" : "right"); }
        .title-area h2 { margin: 0; font-size: 2rem; color: var(--primary-navy); font-weight: 900; }
        .rcpt-no { font-family: monospace; font-size: 1.2rem; color: #ef4444; font-weight: bold; }

        .top-info { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; position: relative; z-index: 1; }
        .info-box { border: 1px solid #e2e8f0; padding: 15px; border-radius: 10px; background: #fcfcfc; }
        .info-box span.label { display: block; color: #64748b; font-size: 0.85rem; font-weight: 800; margin-bottom: 5px; }
        .info-box span.value { display: block; color: var(--primary-navy); font-size: 1.1rem; font-weight: 900; }

        .amount-highlight { background: rgba(0, 0, 0, 0.02); border: 2px solid var(--primary-navy); text-align: center; padding: 25px; border-radius: 15px; margin-bottom: 30px; position: relative; z-index: 1; }
        .amount-highlight .val { color: var(--primary-navy); font-weight: 900; font-size: 2.5rem; font-family: monospace; margin: 5px 0; }

        .footer-note { text-align: center; margin-top: 30px; padding: 15px; border-top: 1px solid #eee; font-size: 0.9rem; color: #64748b; font-weight: bold; }
        .signatures { display: flex; justify-content: space-between; margin-top: 50px; position: relative; z-index: 1; }
        .sig-box { text-align: center; width: 180px; }
        .sig-line { border-bottom: 2px solid var(--primary-navy); margin-bottom: 8px; height: 40px; }
        .sig-title { font-weight: 800; color: var(--primary-navy); font-size: 0.95rem; }

        .controls { display: flex; gap: 15px; margin-bottom: 20px; }
        .btn-action { color: white; padding: 12px 25px; border: none; border-radius: 10px; cursor: pointer; font-weight: 900; font-size: 1rem; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .btn-print { background: var(--primary-gold); } .btn-pdf { background: #ef4444; } .btn-back { background: var(--primary-navy); }

        /* ========================================================
           كود الطباعة الموحد (One Page Magic)
           ======================================================== */
        @@media print {
            @@page { size: A4 portrait; margin: 5mm; }
            body, html { background: white !important; padding: 0 !important; margin: 0 !important; width: 100% !important; height: 100vh !important; overflow: hidden !important; }
            .controls { display: none !important; }
            .voucher-wrapper { 
                box-shadow: none !important; padding: 0 !important; max-width: 100% !important; border: none !important; margin: 0 !important; 
                border-top: 10px solid var(--primary-navy) !important;
                transform: scale(0.95); transform-origin: top center;
                page-break-after: avoid !important; page-break-inside: avoid !important;
            }
            * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important; }
            .amount-highlight { border: 2px solid var(--primary-navy) !important; background: rgba(0, 0, 0, 0.02) !important; }
            .sig-line { border-color: var(--primary-navy) !important; }
            img { display: inline-block !important; visibility: visible !important; }
        }
    </style>
</head>
<body>
    <div class="controls">
        <button class="btn-action btn-back" onclick="history.back()">@Localizer["العودة"]</button>
        <button class="btn-action btn-print" onclick="window.print()">@Localizer["طباعة السند"]</button>
    </div>

    <div class="voucher-wrapper" id="voucherContent">
        <div class="watermark">ALARGAN - الأرجان</div>
        <div class="header">
            <div class="logo-area">
                <img src="/images/logo.jpg" alt="Logo" onerror="this.src='/images/logo.png'; this.onerror=null;" />
                <h1>شركة الأرجان للشحن</h1>
                <div style="font-size: 0.8rem; font-weight: bold; color: #64748b;">VAT: @vatNo | CR: @crNo</div>
            </div>
            <div class="title-area">
                <h2>سند صرف</h2>
                <div class="rcpt-no">Voucher No: @Model.VoucherNumber</div>
            </div>
        </div>

        <div class="top-info">
            <div class="info-box"><span class="label">يصرف للسيد / الجهة:</span><span class="value">@Model.BeneficiaryName</span></div>
            <div class="info-box"><span class="label">تاريخ السند:</span><span class="value">@Model.VoucherDate.ToString("dd MMMM yyyy")</span></div>
        </div>

        <div class="amount-highlight">
            <span style="font-weight: 800; color: #64748b;">المبلغ المصروف (Amount)</span>
            <div class="val">@Model.Amount.ToString("N2") $</div>
            <div style="font-size: 0.9rem; font-weight: bold; color: var(--primary-gold);">@Model.PaymentMethod - @(Model.ReferenceNumber ?? "N/A")</div>
        </div>

        <div style="margin-bottom: 40px; padding: 0 10px;">
            <div style="font-weight: 800; color: #64748b; margin-bottom: 10px; border-bottom: 1px solid #eee; padding-bottom: 5px;">وذلك عن (البيان):</div>
            <div style="font-weight: 700; color: var(--primary-navy); line-height: 1.8;">@Model.Description</div>
        </div>

        <div class="signatures">
            <div class="sig-box"><div class="sig-line"></div><div class="sig-title">المحاسب</div></div>
            <div class="sig-box"><div class="sig-line"></div><div class="sig-title">المستلم</div></div>
            <div class="sig-box"><div class="sig-line"></div><div class="sig-title">الاعتماد</div></div>
        </div>
        <div class="footer-note">@footerNote</div>
    </div>

    <script>
        function downloadPDF() {
            var element = document.getElementById('voucherContent');
            html2pdf().set({
                margin: 5, filename: 'Voucher_@Model.VoucherNumber .pdf',
                image: { type: 'jpeg', quality: 1 },
                html2canvas: { scale: 2, useCORS: true, windowWidth: 850 }, 
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
            }).from(element).save();
        }
    </script>
</body>
</html>