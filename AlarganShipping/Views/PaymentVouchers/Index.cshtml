@model IEnumerable<AlarganShipping.Models.PaymentVoucher>
@{
    ViewData["Title"] = Localizer["سجل سندات الصرف (المصروفات)"];
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<style>
    /* --- الترويسة الرئيسية --- */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #ffffff;
        padding: 1.5rem;
        border-radius: 1.5rem;
        box-shadow: 0 5px 20px rgba(44, 62, 80, 0.03);
        margin-bottom: 2rem;
        border: 1px solid #f1f5f9;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .page-title i {
            color: var(--primary-gold);
        }

    .btn-add {
        background: var(--primary-navy);
        color: #ffffff;
        font-weight: 800;
        padding: 0.85rem 1.75rem;
        border-radius: 1rem;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(44, 62, 80, 0.3);
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(44, 62, 80, 0.4);
            color: white;
            background: var(--primary-gold);
        }

    /* --- بطاقة الجدول --- */
    .data-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
    }

    .table-enterprise {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }

        .table-enterprise th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            padding: 1.25rem 1rem;
            border-bottom: 2px solid #e2e8f0;
            text-align: start;
            white-space: nowrap;
        }

        .table-enterprise td {
            padding: 1.25rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-dark);
            font-weight: 700;
            vertical-align: middle;
        }

        .table-enterprise tbody tr:hover {
            background-color: #f8fafc;
            transition: 0.2s;
        }

    .vou-number {
        font-family: monospace;
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--primary-navy);
        background: rgba(44, 62, 80, 0.05);
        padding: 0.3rem 0.8rem;
        border-radius: 6px;
        white-space: nowrap;
    }

    /* تنسيق المبلغ ليظهر باللون الأحمر (كمصروف) */
    .vou-amount {
        font-family: monospace;
        font-size: 1.15rem;
        font-weight: 900;
        color: #ef4444;
        background: rgba(239, 68, 68, 0.05);
        padding: 0.4rem 1rem;
        border-radius: 8px;
        border: 1px solid rgba(239, 68, 68, 0.1);
        white-space: nowrap;
    }

    .category-badge {
        background: white;
        color: var(--primary-navy);
        padding: 0.4rem 1rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        white-space: nowrap;
    }

        .category-badge i {
            color: var(--primary-gold);
        }

    /* --- أزرار الإجراءات --- */
    .actions-wrapper {
        display: flex;
        gap: 8px;
        justify-content: center;
    }

    .action-btn-pro {
        width: 40px;
        height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        transition: 0.3s;
        text-decoration: none;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        cursor: pointer;
        font-size: 1.1rem;
    }

    .btn-print-pro {
        color: var(--primary-navy);
    }

        .btn-print-pro:hover {
            background: var(--primary-navy);
            color: white;
            border-color: var(--primary-navy);
            transform: scale(1.1);
        }

    .btn-delete-pro {
        color: #ef4444;
    }

        .btn-delete-pro:hover {
            background: #ef4444;
            color: white;
            border-color: #ef4444;
            transform: scale(1.1);
        }

    /* ========================================================
                   تعديلات الموبايل
                   ======================================================== */
    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: stretch;
            text-align: center;
            padding: 1.5rem;
        }

        .page-title {
            justify-content: center;
        }

        .btn-add {
            width: 100%;
            justify-content: center;
        }

        .data-card {
            padding: 1rem;
            border-radius: 1.2rem;
        }
    }
</style>

<div class="vouchers-index-page">
    @Html.AntiForgeryToken()

    <div class="page-header">
        <h2 class="page-title"><i class="fa-solid fa-money-bill-transfer"></i> @Localizer["سجل سندات الصرف والمصروفات"]</h2>
        <a href="@Url.Action("Create", "PaymentVouchers")" class="btn-add"><i class="fa-solid fa-plus"></i> @Localizer["إصدار سند صرف جديد"]</a>
    </div>

    <div class="data-card">
        <div style="overflow-x: auto; width: 100%;">
            <table id="vouchersDataTable" class="table-enterprise display" style="width:100%">
                <thead>
                    <tr>
                        <th>@Localizer["رقم السند"]</th>
                        <th>@Localizer["التاريخ"]</th>
                        <th>@Localizer["المستفيد / الجهة"]</th>
                        <th>@Localizer["التصنيف"]</th>
                        <th>@Localizer["المبلغ المصروف"]</th>
                        <th style="text-align: center;">@Localizer["إجراءات"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var vou in Model)
                        {
                            <tr>
                                <td><span class="vou-number">@vou.VoucherNumber</span></td>
                                <td style="color: var(--text-muted); font-weight: 800; white-space: nowrap;">
                                    @vou.VoucherDate.ToString("dd MMM yyyy")
                                </td>
                                <td>
                                    <div style="font-weight: 900; color: var(--primary-navy);">@vou.BeneficiaryName</div>
                                    @if (vou.Customer != null)
                                    {
                                        <div style="font-size: 0.8rem; color: var(--primary-gold); font-weight: 800;">
                                            <i class="fa-solid fa-link"></i> مرتبطة بالعميل: @vou.Customer.Name
                                        </div>
                                    }
                                </td>
                                <td>
                                    <span class="category-badge">
                                        <i class="fa-solid fa-tag"></i> @vou.Category
                                    </span>
                                </td>
                                <td><span class="vou-amount">-$@vou.Amount.ToString("N2")</span></td>
                                <td>
                                    <div class="actions-wrapper">
                                        <a href="@Url.Action("Print", "PaymentVouchers", new { id = vou.Id })" class="action-btn-pro btn-print-pro" title="@Localizer["طباعة السند"]">
                                            <i class="fa-solid fa-print"></i>
                                        </a>
                                        <button type="button" class="action-btn-pro btn-delete-pro" onclick="confirmDelete(@vou.Id)" title="@Localizer["حذف وإلغاء"]">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: "@Html.Raw(Localizer["هل أنت متأكد؟"])",
                text: "@Html.Raw(Localizer["عند حذف السند، سيتم التراجع عنه محاسبياً. هل تود الاستمرار؟"])",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#ef4444",
                cancelButtonColor: "var(--primary-navy)",
                confirmButtonText: "@Html.Raw(Localizer["نعم، احذفه!"])",
                cancelButtonText: "@Html.Raw(Localizer["إلغاء"])"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "PaymentVouchers")',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    title: "@Html.Raw(Localizer["تم الحذف!"])",
                                    text: "@Html.Raw(Localizer["تم حذف السند بنجاح."])",
                                    icon: "success",
                                    timer: 2000,
                                    showConfirmButton: false,
                                    confirmButtonColor: "var(--primary-gold)"
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire("@Html.Raw(Localizer["خطأ!"])", response.message || "@Html.Raw(Localizer["حدث خطأ أثناء الحذف."])", "error");
                            }
                        },
                        error: function () {
                            Swal.fire("@Html.Raw(Localizer["خطأ!"])", "@Html.Raw(Localizer["لا يمكن الاتصال بالخادم."])", "error");
                        }
                    });
                }
            });
        }

        $(document).ready(function () {
            var dir = $('html').attr('dir') === 'rtl';
            $('#vouchersDataTable').DataTable({
                "language": { "url": dir ? "//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json" : "" },
                "pageLength": 10,
                "ordering": true,
                "order": [[ 1, "desc" ]],
                "responsive": true,
                "dom": '<"top"f>rt<"bottom"lp><"clear">'
            });
        });
    </script>
}