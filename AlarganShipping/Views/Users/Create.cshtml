@model AlarganShipping.Models.User
@{
    ViewData["Title"] = Localizer["إضافة موظف جديد"];
}

<style>
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.6rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-back {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        padding: 0.6rem 1.2rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: var(--primary-navy);
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(44, 62, 80, 0.03);
        border: 1px solid #f1f5f9;
        padding: 3rem;
        position: relative;
        overflow: hidden;
        max-width: 850px;
        margin: 0 auto;
    }

        .premium-form-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            left: 0;
            height: 6px;
            background: linear-gradient(to right, var(--primary-navy), var(--primary-gold));
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    @@media (min-width: 768px) {
        .form-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-label {
        font-weight: 800;
        color: var(--primary-navy);
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-control {
        padding: 1rem 1.25rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 1rem;
        color: var(--text-dark);
        background-color: #f8fafc;
        transition: 0.3s;
        outline: none;
        font-weight: 700;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

    .permissions-container {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 1.2rem;
        padding: 1.5rem;
        margin-top: 1.5rem;
    }

    .permissions-title {
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 1rem;
        border-bottom: 2px solid #e2e8f0;
        padding-bottom: 10px;
    }

    .switch-group {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px dashed #cbd5e1;
    }

        .switch-group:last-child {
            border-bottom: none;
        }

    .switch-label {
        font-weight: 800;
        color: var(--text-dark);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* Custom Switch Toggle */
    .switch {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 26px;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #cbd5e1;
        transition: .4s;
        border-radius: 34px;
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 4px;
            bottom: 4px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

    input:checked + .slider {
        background-color: var(--primary-gold);
    }

        input:checked + .slider:before {
            transform: translateX(24px);
        }

    .form-actions {
        margin-top: 2.5rem;
        border-top: 1px solid #f1f5f9;
        padding-top: 1.5rem;
        display: flex;
        justify-content: flex-end;
    }

    .btn-submit {
        background: var(--primary-navy);
        color: #ffffff;
        border: none;
        padding: 1rem 3rem;
        border-radius: 1rem;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 4px 15px rgba(44, 62, 80, 0.3);
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-submit:hover {
            background: var(--primary-gold);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(184, 147, 90, 0.4);
        }

    @@media (max-width: 768px) {
        .form-page-header {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
        }

        .premium-form-card {
            padding: 1.5rem;
        }

        .btn-submit {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<div class="form-page-header">
    <h2 class="form-page-title"><i class="fa-solid fa-user-plus" style="color: var(--primary-gold);"></i> @Localizer["إضافة موظف جديد"]</h2>
    <a href="@Url.Action("Index", "Users")" class="btn-back">@Localizer["إلغاء والعودة"]</a>
</div>

<div class="premium-form-card">
    <form asp-action="Create" method="post" id="userForm">
        @Html.AntiForgeryToken()

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="FullName" class="form-label">@Localizer["الاسم الكامل"] *</label>
                <input asp-for="FullName" class="form-control" required />
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">@Localizer["البريد الإلكتروني (لتسجيل الدخول)"] *</label>
                <input asp-for="Email" type="email" class="form-control" dir="ltr" required />
            </div>

            <div class="form-group">
                <label asp-for="PasswordHash" class="form-label">@Localizer["كلمة المرور"] *</label>
                <input asp-for="PasswordHash" type="text" class="form-control" dir="ltr" required />
            </div>

            <div class="form-group">
                <label asp-for="Role" class="form-label">@Localizer["الدور وصلاحية النظام"] *</label>
                <select asp-for="Role" class="form-control" id="roleSelect" required>
                    <option value="Staff">@Localizer["موظف (مخصص)"]</option>
                    <option value="Admin">@Localizer["مدير نظام (وصول كامل)"]</option>
                </select>
            </div>

            <div class="form-group">
                <label asp-for="JobTitle" class="form-label">@Localizer["المسمى الوظيفي"]</label>
                <input asp-for="JobTitle" class="form-control" />
            </div>
        </div>

        <div class="permissions-container" id="permsContainer">
            <div class="permissions-title">@Localizer["تخصيص صلاحيات الموظف"]</div>

            <div class="switch-group">
                <span class="switch-label"><i class="fa-solid fa-car" style="color: #64748b;"></i> @Localizer["إدارة السيارات والمزادات وأوامر النقل"]</span>
                <label class="switch"><input type="checkbox" asp-for="CanManageCars"><span class="slider"></span></label>
            </div>

            <div class="switch-group">
                <span class="switch-label"><i class="fa-solid fa-users" style="color: #64748b;"></i> @Localizer["إدارة وتعديل بيانات العملاء"]</span>
                <label class="switch"><input type="checkbox" asp-for="CanManageCustomers"><span class="slider"></span></label>
            </div>

            <div class="switch-group">
                <span class="switch-label"><i class="fa-solid fa-calculator" style="color: #64748b;"></i> @Localizer["إدارة المالية (فواتير وسندات وتقارير)"]</span>
                <label class="switch"><input type="checkbox" asp-for="CanManageFinance"><span class="slider"></span></label>
            </div>

            <div class="switch-group">
                <span class="switch-label"><i class="fa-solid fa-gear" style="color: #64748b;"></i> @Localizer["التحكم في إعدادات النظام"]</span>
                <label class="switch"><input type="checkbox" asp-for="CanManageSettings"><span class="slider"></span></label>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit" id="btnSubmit">
                <i class="fa-solid fa-save"></i> @Localizer["حفظ بيانات الموظف"]
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>

    <script>
        $(document).ready(function() {
            // إخفاء الصلاحيات لو كان الدور مدير (لأنه يملك كل شيء افتراضياً)
            $('#roleSelect').on('change', function() {
                if($(this).val() === 'Admin') {
                    $('#permsContainer').slideUp();
                } else {
                    $('#permsContainer').slideDown();
                }
            });

            $('#userForm').on('submit', function(e) {
                e.preventDefault();
                var form = $(this);
                if (!form[0].checkValidity()) { form[0].reportValidity(); return; }

                var btn = $('#btnSubmit');
                var originalText = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin"></i> @Html.Raw(Localizer["جاري الحفظ..."])').prop('disabled', true);

                $.ajax({
                    url: form.attr('action'), type: form.attr('method'), data: form.serialize(),
                    success: function (res) {
                        if (res.success) {
                            Swal.fire({
                                title: '@Html.Raw(Localizer["تم الحفظ!"])', icon: 'success', confirmButtonColor: 'var(--primary-gold)'
                            }).then(() => { window.location.href = '@Url.Action("Index", "Users")'; });
                        } else {
                            var errorMsg = res.errors ? res.errors.join('\n') : '@Html.Raw(Localizer["تأكد من البيانات"])';
                            Swal.fire('@Html.Raw(Localizer["خطأ!"])', errorMsg, 'error');
                            btn.html(originalText).prop('disabled', false);
                        }
                    }
                });
            });
        });
    </script>
}