@model IEnumerable<AlarganShipping.Models.User>
@{
    ViewData["Title"] = Localizer["إدارة الموظفين"];
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        background: white;
        padding: 1.5rem;
        border-radius: 1.5rem;
        border: 1px solid #f1f5f9;
        box-shadow: 0 5px 20px rgba(0,0,0,0.02);
    }

    .page-title {
        font-size: 1.6rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
    }

    .btn-add {
        background: var(--primary-navy);
        color: white;
        padding: 0.8rem 1.5rem;
        border-radius: 1rem;
        text-decoration: none;
        font-weight: 800;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add:hover {
            background: var(--primary-gold);
            transform: translateY(-2px);
            color: white;
        }

    .data-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        border: 1px solid #f1f5f9;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        overflow-x: auto;
    }

    .user-table {
        width: 100%;
        border-collapse: collapse;
    }

        .user-table th {
            text-align: start;
            padding: 1.2rem;
            color: var(--text-muted);
            font-weight: 800;
            border-bottom: 2px solid #f1f5f9;
            white-space: nowrap;
        }

        .user-table td {
            padding: 1.2rem;
            border-bottom: 1px solid #f8fafc;
            vertical-align: middle;
        }

    .user-info-cell {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .user-avatar {
        width: 45px;
        height: 45px;
        background: rgba(44, 62, 80, 0.05);
        color: var(--primary-navy);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1.2rem;
    }

    .role-badge {
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 800;
        background: #f1f5f9;
        color: var(--text-muted);
    }

    .role-admin {
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
    }

    .perm-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
        background: #f0fdf4;
        color: #16a34a;
        margin: 2px;
    }

    .action-btn {
        color: var(--text-muted);
        transition: 0.3s;
        font-size: 1.1rem;
        padding: 5px;
    }

        .action-btn:hover {
            color: var(--primary-gold);
        }

    .btn-delete:hover {
        color: #ef4444;
    }
</style>

<div class="page-header">
    <h2 class="page-title"><i class="fa-solid fa-users-gear" style="color: var(--primary-gold); margin-inline-end: 10px;"></i> @Localizer["إدارة موظفي النظام"]</h2>
    <a href="@Url.Action("Create", "Users")" class="btn-add"><i class="fa-solid fa-plus"></i> @Localizer["إضافة موظف جديد"]</a>
</div>

<div class="data-card">
    <table class="user-table">
        <thead>
            <tr>
                <th>@Localizer["الموظف"]</th>
                <th>@Localizer["الدور الوظيفي"]</th>
                <th>@Localizer["صلاحيات الوصول"]</th>
                <th>@Localizer["الحالة"]</th>
                <th>@Localizer["إجراءات"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>
                        <div class="user-info-cell">
                            <div class="user-avatar">@user.FullName.Substring(0, 1).ToUpper()</div>
                            <div>
                                <div style="font-weight: 900; color: var(--primary-navy);">@user.FullName</div>
                                <div style="font-size: 0.85rem; color: var(--text-muted);" dir="ltr">@user.Email</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="role-badge @(user.Role == "Admin" ? "role-admin" : "")">@user.Role</span>
                        @if (user.ShowOnContactPage)
                        {
                            <div style="font-size: 0.75rem; color: var(--primary-gold); margin-top: 8px; font-weight: 700;"><i class="fa-solid fa-eye"></i> @Localizer["يظهر للعملاء"]</div>
                        }
                    </td>
                    <td>
                        <div style="max-width: 320px; display: flex; flex-wrap: wrap;">
                            @if (user.CanManageCars)
                            {
                                <span class="perm-pill">إدارة السيارات</span>
                            }
                            @if (user.CanManageCustomers)
                            {
                                <span class="perm-pill">العملاء</span>
                            }
                            @if (user.CanManageFinance)
                            {
                                <span class="perm-pill">المالية</span>
                            }
                            @if (user.CanManageSettings)
                            {
                                <span class="perm-pill">الإعدادات</span>
                            }
                            @if (user.Role == "Admin")
                            {
                                <span class="perm-pill" style="background: #eff6ff; color: #3b82f6;">كامل الصلاحيات (Admin)</span>
                            }
                        </div>
                    </td>
                    <td>
                        <span style="color: @(user.IsActive ? "#16a34a" : "#ef4444"); font-weight: 800; font-size: 0.9rem;">
                            <i class="fa-solid fa-circle" style="font-size: 0.6rem; margin-inline-end: 4px;"></i> @(user.IsActive ? "نشط" : "معطل")
                        </span>
                    </td>
                    <td>
                        <div style="display: flex; gap: 12px;">
                            <a href="@Url.Action("Edit", "Users", new { id = user.Id })" class="action-btn" title="تعديل"><i class="fa-solid fa-pen-to-square"></i></a>
                            @if (user.Email != "admin@alargan.com")
                            {
                                <button type="button" onclick="confirmDelete(@user.Id)" class="action-btn btn-delete" title="حذف" style="background: transparent; border: none; cursor: pointer;"><i class="fa-solid fa-trash-can"></i></button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: 'هل أنت متأكد؟',
                text: "سيتم إيقاف وصول هذا الموظف للنظام نهائياً.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'نعم، احذف الحساب',
                cancelButtonText: 'إلغاء'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("Delete", "Users")/' + id, function(res) {
                        if(res.success) location.reload();
                    });
                }
            });
        }
    </script>
}