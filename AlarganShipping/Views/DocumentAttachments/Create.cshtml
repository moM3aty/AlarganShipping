<!-- مسار الملف في المشروع: Views/DocumentAttachments/Create.cshtml -->
@model AlarganShipping.Models.DocumentAttachment
@{
    ViewData["Title"] = Localizer["أرشفة ورفع ملف"];
}

<style>
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--primary-navy);
        margin: 0;
    }

    .btn-back {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: var(--primary-navy);
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        padding: 3rem;
        position: relative;
        overflow: hidden;
    }

        .premium-form-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            left: 0;
            height: 6px;
            background: linear-gradient(to right, var(--primary-navy), var(--primary-gold));
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-label {
        font-weight: 800;
        color: var(--primary-navy);
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-control {
        padding: 1rem 1.25rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 1rem;
        color: var(--text-dark);
        background-color: #f8fafc;
        transition: 0.3s;
        outline: none;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(195, 154, 92, 0.1);
        }

    /* Select2 Styling */
    .select2-container--default .select2-selection--single {
        background-color: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        height: 50px;
        display: flex;
        align-items: center;
        transition: 0.3s;
    }

        .select2-container--default .select2-selection--single:focus, .select2-container--focus .select2-selection--single {
            border-color: var(--primary-gold);
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(195, 154, 92, 0.1);
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            color: var(--text-dark);
            font-weight: 600;
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 48px;
            right: 10px;
        }

    html[dir="rtl"] .select2-container--default .select2-selection--single .select2-selection__arrow {
        left: 10px;
        right: auto;
    }

    /* File Upload Styling */
    .file-upload-wrapper {
        border: 2px dashed #cbd5e1;
        border-radius: 1rem;
        padding: 3rem;
        text-align: center;
        background: #f8fafc;
        transition: all 0.3s ease;
        cursor: pointer;
        position: relative;
    }

        .file-upload-wrapper:hover, .file-upload-wrapper.dragover {
            border-color: var(--primary-gold);
            background: rgba(195, 154, 92, 0.05);
        }

    .file-input {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
    }

    .upload-icon {
        font-size: 3rem;
        color: var(--primary-gold);
        margin-bottom: 1rem;
        display: block;
    }

    .upload-text {
        font-weight: 800;
        color: var(--primary-navy);
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
    }

    .upload-hint {
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .file-name-display {
        margin-top: 1rem;
        font-weight: 800;
        color: #16a34a;
        display: none;
    }

    .form-actions {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
    }

    .btn-submit {
        background: var(--primary-navy);
        color: #ffffff;
        border: none;
        padding: 1rem 3rem;
        border-radius: 1rem;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 4px 15px rgba(26, 42, 58, 0.3);
        font-family: inherit;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-submit:hover {
            background: var(--secondary-navy);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(26, 42, 58, 0.4);
        }

    .text-danger {
        color: #ef4444;
        font-size: 0.85rem;
        font-weight: 700;
        margin-top: 0.4rem;
    }
</style>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<div>
    <div class="form-page-header">
        <h2 class="form-page-title"><i class="fa-solid fa-file-arrow-up" style="color: var(--primary-gold); margin-inline-end: 10px;"></i> @Localizer["أرشفة ورفع ملف"]</h2>
        <a href="javascript:history.back()" class="btn-back">@Localizer["رجوع"]</a>
    </div>

    <div class="premium-form-card">
        <form asp-action="Create" method="post" enctype="multipart/form-data" id="documentForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="CarId" class="form-label">@Localizer["السيارة المرتبطة بالملف"]</label>
                    <select asp-for="CarId" class="form-control select2-search" asp-items="ViewBag.CarId">
                        <option value="">-- @Localizer["اختر السيارة (اختياري)"] --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="DocumentType" class="form-label">@Localizer["نوع المستند"]</label>
                    <select asp-for="DocumentType" class="form-control" required>
                        <option value="CarImage">@Localizer["صورة للسيارة (Car Image)"]</option>
                        <option value="Title">@Localizer["ملكية السيارة (Title)"]</option>
                        <option value="BillOfLading">@Localizer["بوليصة شحن (B/L)"]</option>
                        <option value="CustomerID">@Localizer["صورة هوية / جواز سفر العميل"]</option>
                        <option value="CustomsDoc">@Localizer["مستند جمركي / ضريبي"]</option>
                    </select>
                </div>

                <div class="form-group" style="grid-column: 1 / -1; margin-top: 1rem;">
                    <label class="form-label">@Localizer["اختر الملف المراد رفعه (صورة أو PDF)"]</label>
                    <div class="file-upload-wrapper" id="dropZone">
                        <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>
                        <div class="upload-text">@Localizer["اضغط هنا لاختيار الملف أو اسحبه وأفلته"]</div>
                        <div class="upload-hint">@Localizer["يدعم الملفات بصيغة JPG, PNG, PDF بحد أقصى 5 ميجابايت."]</div>
                        <input type="file" name="uploadedFile" class="file-input" accept="image/*,.pdf" required id="fileInput" />
                        <div class="file-name-display" id="fileNameDisplay"><i class="fa-solid fa-check-circle"></i> <span></span></div>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit" id="btnSubmit">
                    <i class="fa-solid fa-upload"></i> @Localizer["رفع وحفظ المستند"]
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>

    <script>
        $(document).ready(function() {
            var dir = $('html').attr('dir');
            $('.select2-search').select2({ dir: dir, width: '100%' });

            // File input display name logic
            $('#fileInput').on('change', function() {
                var fileName = $(this).val().split('\\').pop();
                if(fileName) {
                    $('#fileNameDisplay span').text(fileName);
                    $('#fileNameDisplay').show();
                    $('.upload-text, .upload-hint').hide();
                } else {
                    $('#fileNameDisplay').hide();
                    $('.upload-text, .upload-hint').show();
                }
            });

            // AJAX Submission with FormData for File Uploads
            $('#documentForm').on('submit', function(e) {
                e.preventDefault();
                var form = this;
                if (!form.checkValidity()) { form.reportValidity(); return; }

                var btn = $('#btnSubmit');
                var originalText = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin"></i> @Localizer["جاري الرفع..."]').prop('disabled', true);

                var formData = new FormData(form);

                $.ajax({
                    url: $(form).attr('action'),
                    type: $(form).attr('method'),
                    data: formData,
                    processData: false, // أساسي لرفع الملفات عبر AJAX
                    contentType: false, // أساسي لرفع الملفات عبر AJAX
                    success: function () {
                        Swal.fire({
                            title: '@Localizer["تم الرفع بنجاح!"]',
                            icon: 'success',
                            confirmButtonColor: 'var(--primary-gold)',
                            confirmButtonText: '@Localizer["موافق"]'
                        }).then((result) => {
                            if ($('#CarId').val()) {
                                window.location.href = '@Url.Action("Details", "Cars")/' + $('#CarId').val();
                            } else {
                                form.reset();
                                $('#fileNameDisplay').hide();
                                $('.upload-text, .upload-hint').show();
                                $('.select2-search').val(null).trigger('change');
                                btn.html(originalText).prop('disabled', false);
                            }
                        });
                    },
                    error: function () {
                        Swal.fire({ title: '@Localizer["خطأ!"]', text: '@Localizer["حدث خطأ أثناء رفع الملف."]', icon: 'error', confirmButtonColor: 'var(--primary-navy)' });
                        btn.html(originalText).prop('disabled', false);
                    }
                });
            });
        });
    </script>
}