@model AlarganShipping.Models.DocumentAttachment
@{
    ViewData["Title"] = "أرشفة ورفع ملف";
}

<style>
    /* Premium Form CSS specific to File Upload */
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: #2b3f56;
        margin: 0;
    }

    .btn-back {
        background-color: #f1f5f9;
        color: #475569;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .btn-back:hover {
            background-color: #e2e8f0;
            color: #1e293b;
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.25rem;
        box-shadow: 0 10px 30px rgba(43, 63, 86, 0.05);
        border: 1px solid #f8fafc;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
    }

        .premium-form-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(to left, #8b5cf6, #a855f7);
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-label {
        font-weight: 700;
        color: #2b3f56;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-control {
        padding: 0.85rem 1.25rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: 'Cairo', sans-serif;
        font-size: 1rem;
        color: #1e293b;
        background-color: #f8fafc;
        transition: all 0.3s ease;
        outline: none;
    }

        .form-control:focus {
            border-color: #8b5cf6;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1);
        }

    /* Custom File Input Styling */
    .file-upload-wrapper {
        border: 2px dashed #cbd5e1;
        border-radius: 1rem;
        padding: 3rem;
        text-align: center;
        background: #f8fafc;
        transition: all 0.3s ease;
        cursor: pointer;
        position: relative;
    }

        .file-upload-wrapper:hover {
            border-color: #8b5cf6;
            background: #f5f3ff;
        }

    .file-input {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
    }

    .upload-icon {
        font-size: 3rem;
        color: #8b5cf6;
        margin-bottom: 1rem;
        display: block;
    }

    .upload-text {
        font-weight: 800;
        color: #2b3f56;
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
    }

    .upload-hint {
        color: #64748b;
        font-size: 0.9rem;
    }

    .form-actions {
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
    }

    .btn-submit {
        background: linear-gradient(to right, #8b5cf6, #a855f7);
        color: #ffffff;
        border: none;
        padding: 0.85rem 2.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        font-family: 'Cairo', sans-serif;
        box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
        transition: all 0.3s ease;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(139, 92, 246, 0.4);
        }

    .text-danger {
        color: #dc2626;
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 0.25rem;
    }
</style>

<div>
    <div class="form-page-header">
        <h2 class="form-page-title">أرشفة المرفقات والمستندات</h2>
        <a href="javascript:history.back()" class="btn-back">رجوع</a>
    </div>

    <div class="premium-form-card">
        <!-- إعداد enctype ضروري جداً لرفع الملفات -->
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="CarId" class="form-label">السيارة المرتبطة بالملف</label>
                    <select asp-for="CarId" class="form-control" asp-items="ViewBag.CarId">
                        <option value="">-- اختر السيارة (اختياري) --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="DocumentType" class="form-label">نوع المستند</label>
                    <select asp-for="DocumentType" class="form-control">
                        <option value="صورة للسيارة">صورة للسيارة (Car Image)</option>
                        <option value="ملكية السيارة">ملكية السيارة (Title)</option>
                        <option value="بوليصة شحن">بوليصة شحن (B/L)</option>
                        <option value="هوية عميل">صورة هوية / جواز سفر العميل</option>
                        <option value="مستند جمركي">مستند جمركي / ضريبي</option>
                    </select>
                </div>

                <div class="form-group" style="grid-column: 1 / -1; margin-top: 1rem;">
                    <label class="form-label">اختر الملف المراد رفعه (صورة أو PDF)</label>
                    <div class="file-upload-wrapper">
                        <span class="upload-icon">&#128194;</span>
                        <div class="upload-text">اضغط هنا لاختيار الملف أو اسحبه وأفلته</div>
                        <div class="upload-hint">يدعم الملفات بصيغة JPG, PNG, PDF بحد أقصى 5 ميجابايت.</div>
                        <input type="file" name="uploadedFile" class="file-input" accept="image/*,.pdf" required />
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">رفع وحفظ المستند</button>
            </div>
        </form>
    </div>
</div>