@model AlarganShipping.Controllers.SettingsViewModel
@{
    ViewData["Title"] = Localizer["إعدادات النظام والقواعد"];
}

<style>
    /* --- الهيدر الرئيسي --- */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
    }

    .btn-save-settings {
        background: var(--primary-gold);
        color: white;
        border: none;
        padding: 0.85rem 2.5rem;
        border-radius: 1rem;
        font-weight: 800;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        box-shadow: 0 4px 15px rgba(184, 147, 90, 0.2);
    }

        .btn-save-settings:hover {
            transform: translateY(-2px);
            background: var(--secondary-gold);
            box-shadow: 0 6px 20px rgba(184, 147, 90, 0.3);
        }

    /* --- شبكة الإعدادات --- */
    .settings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 2rem;
    }

    .settings-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    }

    .settings-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .settings-card-title {
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
    }

    .form-control {
        width: 100%;
        padding: 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 1rem;
        background: #f8fafc;
        font-weight: 800;
        color: var(--primary-navy);
        transition: 0.3s;
        font-family: inherit;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            background: white;
            outline: none;
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

    /* --- حقل اختيار اللون --- */
    .color-picker-wrapper {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 1rem;
        padding: 0.5rem 1rem;
    }

        .color-picker-wrapper input[type="color"] {
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            cursor: pointer;
            padding: 0;
            background: transparent;
        }

    /* --- منطقة الصيانة --- */
    .maintenance-options {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .danger-zone {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 1.25rem;
        padding: 2rem;
        text-align: center;
    }

    .btn-danger {
        background: #ef4444;
        color: white;
        border: none;
        padding: 1rem;
        border-radius: 0.75rem;
        font-weight: 800;
        width: 100%;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-danger:hover {
            background: #dc2626;
            transform: scale(1.02);
        }

    .btn-pdf {
        background: white;
        color: var(--primary-navy);
        border: 2px solid #e2e8f0;
        padding: 1rem;
        border-radius: 0.75rem;
        font-weight: 800;
        width: 100%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: 0.3s;
    }

        .btn-pdf:hover {
            border-color: var(--primary-gold);
            color: var(--primary-gold);
            background: #f8fafc;
        }

    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: stretch;
            text-align: center;
        }

        .page-title {
            justify-content: center;
        }

        .btn-save-settings {
            width: 100%;
            padding: 1rem;
        }

        .settings-grid {
            grid-template-columns: 1fr;
        }

        .settings-card {
            padding: 1.5rem;
        }

        .maintenance-options {
            grid-template-columns: 1fr;
        }

        .danger-zone {
            padding: 1.5rem;
        }
    }

    /* تنسيق التقرير المخفي للـ PDF */
    #pdfReportTemplate {
        display: none;
    }

    .pdf-header {
        text-align: center;
        padding-bottom: 20px;
        border-bottom: 2px solid var(--primary-gold);
        margin-bottom: 30px;
    }

    .pdf-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

        .pdf-table td, .pdf-table th {
            padding: 12px;
            border: 1px solid #e2e8f0;
            text-align: right;
        }

    html[dir="ltr"] .pdf-table td, html[dir="ltr"] .pdf-table th {
        text-align: left;
    }

    .pdf-table th {
        background-color: #f8fafc;
        color: var(--primary-navy);
        font-weight: 900;
    }
</style>

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<div class="settings-page-container">
    <form id="settingsForm" asp-action="SaveSettings" method="post">
        @Html.AntiForgeryToken()

        <div class="page-header">
            <div>
                <h2 class="page-title">@Localizer["إعدادات النظام والقواعد"]</h2>
                <div style="color: var(--text-muted); font-weight: 600; margin-top: 5px;">@Localizer["إدارة الثوابت المالية ونماذج الطباعة"]</div>
            </div>
            <button type="submit" class="btn-save-settings" id="btnSave">
                <i class="fa-solid fa-floppy-disk"></i> @Localizer["حفظ الإعدادات"]
            </button>
        </div>

        <div class="settings-grid">
            <!-- كرت أسعار الصرف والتواصل -->
            <div class="settings-card">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">@Localizer["إعدادات التواصل والصرف"]</h3>
                    <div style="color: #16a34a; font-size: 1.5rem;"><i class="fa-solid fa-coins"></i></div>
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <label class="form-label" style="display:block; margin-bottom:0.5rem; font-weight:800; color: var(--text-muted); font-size: 0.85rem;">@Localizer["سعر الدولار مقابل الريال (OMR/USD)"]</label>
                    <input asp-for="UsdExchangeRate" type="number" step="0.001" class="form-control" dir="ltr" style="font-family: monospace;" />
                </div>
                <div>
                    <label class="form-label" style="display:block; margin-bottom:0.5rem; font-weight:800; color: var(--text-muted); font-size: 0.85rem;">@Localizer["رقم الواتساب للاستفسارات (مع كود الدولة)"]</label>
                    <input asp-for="InquiryPhoneNumber" type="text" class="form-control" dir="ltr" placeholder="968xxxxxxx" style="font-family: monospace;" />
                </div>
            </div>

            <!-- كرت الضرائب والعمولات -->
            <div class="settings-card">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">@Localizer["الضرائب والعمولات"]</h3>
                    <div style="color: var(--primary-navy); font-size: 1.5rem;"><i class="fa-solid fa-percent"></i></div>
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <label class="form-label" style="display:block; margin-bottom:0.5rem; font-weight:800; color: var(--text-muted); font-size: 0.85rem;">@Localizer["نسبة الجمارك العمانية (%)"]</label>
                    <input asp-for="CustomsPercentage" type="number" step="0.1" class="form-control" dir="ltr" style="font-family: monospace;" />
                </div>
                <div>
                    <label class="form-label" style="display:block; margin-bottom:0.5rem; font-weight:800; color: var(--text-muted); font-size: 0.85rem;">@Localizer["عمولة الشركة الافتراضية (OMR/USD)"]</label>
                    <input asp-for="DefaultCommission" type="number" class="form-control" dir="ltr" style="font-family: monospace;" />
                </div>
            </div>

            <!-- كرت إعدادات الفواتير (الجديد) -->
            <div class="settings-card" style="grid-column: 1 / -1;">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">@Localizer["إعدادات الطباعة ونماذج الفواتير"]</h3>
                    <div style="color: var(--primary-gold); font-size: 1.5rem;"><i class="fa-solid fa-file-invoice"></i></div>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
                    <div>
                        <label class="form-label" style="display:block; margin-bottom:0.5rem; font-weight:800; color: var(--text-muted); font-size: 0.85rem;">@Localizer["نموذج الفاتورة المفضل"]</label>
                        <select asp-for="InvoiceTemplate" class="form-control">
                            <option value="Modern">@Localizer["نموذج عصري (Modern)"]</option>
                            <option value="Classic">@Localizer["نموذج كلاسيكي (Classic)"]</option>
                            <option value="Simple">@Localizer["نموذج مبسط (Simple)"]</option>
                        </select>
                    </div>

                    <div>
                        <label class="form-label" style="display:block; margin-bottom:0.5rem; font-weight:800; color: var(--text-muted); font-size: 0.85rem;">@Localizer["اللون الرئيسي للفواتير"]</label>
                        <div class="color-picker-wrapper">
                            <input asp-for="InvoiceHeaderColor" type="color" id="colorPicker" />
                            <span id="colorHexDisplay" style="font-family: monospace; font-weight: bold; color: var(--primary-navy);">@Model.InvoiceHeaderColor</span>
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
                    <div>
                        <label class="form-label" style="display:block; margin-bottom:0.5rem; font-weight:800; color: var(--text-muted); font-size: 0.85rem;">@Localizer["الرقم الضريبي (VAT No)"]</label>
                        <input asp-for="VatNumber" type="text" class="form-control" dir="ltr" style="font-family: monospace;" />
                    </div>

                    <div>
                        <label class="form-label" style="display:block; margin-bottom:0.5rem; font-weight:800; color: var(--text-muted); font-size: 0.85rem;">@Localizer["رقم السجل التجاري (CR No)"]</label>
                        <input asp-for="CrNumber" type="text" class="form-control" dir="ltr" style="font-family: monospace;" />
                    </div>
                </div>

                <div>
                    <label class="form-label" style="display:block; margin-bottom:0.5rem; font-weight:800; color: var(--text-muted); font-size: 0.85rem;">@Localizer["ملاحظات وشروط الفاتورة (Footer)"]</label>
                    <textarea asp-for="InvoiceFooterText" class="form-control" rows="3" placeholder="@Localizer["البضاعة المباعة لا ترد ولا تستبدل..."]"></textarea>
                </div>
            </div>
        </div>
    </form>

    <!-- منطقة صيانة النظام -->
    <div class="settings-card" style="margin-top: 2rem;">
        <h3 class="settings-card-title" style="margin-bottom: 2rem; display: flex; align-items: center; gap: 10px;">
            <i class="fa-solid fa-shield-halved" style="color: var(--primary-gold);"></i>
            @Localizer["صيانة النظام والتقارير"]
        </h3>

        <div class="maintenance-options">
            <div class="danger-zone" style="background: #f8fafc; border-color: #e2e8f0;">
                <h4 style="margin-bottom: 0.5rem; color: var(--primary-navy);">@Localizer["تقرير حالة النظام"]</h4>
                <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 1.5rem; font-weight: 600;">@Localizer["توليد ملف PDF رسمي يحتوي على كافة الإحصائيات"]</p>
                <button type="button" class="btn-pdf" onclick="generatePDF()">
                    <i class="fa-solid fa-file-pdf" style="color: #ef4444; font-size: 1.2rem;"></i> @Localizer["تصدير تقرير PDF"]
                </button>
            </div>

            <div class="danger-zone">
                <h4 style="color: #ef4444; margin-bottom: 0.5rem;">@Localizer["تصفير البيانات"]</h4>
                <p style="font-size: 0.85rem; color: #991b1b; margin-bottom: 1.5rem; font-weight: 600;">@Localizer["حذف جميع البيانات (سيارات، عملاء، فواتير) والبدء من جديد"]</p>
                <button type="button" class="btn-danger" onclick="confirmWipe()">
                    <i class="fa-solid fa-triangle-exclamation"></i> @Localizer["تصفير النظام بالكامل"]
                </button>
            </div>
        </div>
    </div>
</div>

<!-- قالب التقرير للـ PDF -->
<div id="pdfReportTemplate" dir="@(System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft ? "rtl" : "ltr")" style="font-family: 'Cairo', sans-serif; padding: 20px;">
    <div class="pdf-header">
        <h1 style="color: #1e293b; margin: 0; font-size: 28px;">ALARGAN AUTO SHIPPING</h1>
        <p style="color: #b45309; font-weight: bold; letter-spacing: 2px; font-size: 18px; margin: 5px 0;">@Localizer["نظام الإدارة اللوجستية - تقرير حالة النظام"]</p>
        <p style="font-size: 14px; color: #64748b;">@Localizer["تاريخ التقرير:"] @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</p>
    </div>

    <h3 style="color: #1e293b; border-bottom: 2px solid #f1f5f9; padding-bottom: 10px; margin-top: 20px;">@Localizer["أولاً: الإحصائيات الحالية"]</h3>
    <table class="pdf-table">
        <tr>
            <th style="width: 30%;">@Localizer["إجمالي العملاء"]</th>
            <td style="width: 20%;">@ViewBag.TotalCustomers</td>
            <th style="width: 30%;">@Localizer["إجمالي السيارات"]</th>
            <td style="width: 20%;">@ViewBag.TotalCars</td>
        </tr>
        <tr>
            <th>@Localizer["عدد الفواتير"]</th>
            <td>@ViewBag.TotalInvoices</td>
            <th>@Localizer["إجمالي الديون"]</th>
            <td style="color: #ef4444; font-weight: bold;">@ViewBag.TotalBalance.ToString("N2")</td>
        </tr>
    </table>

    <h3 style="color: #1e293b; border-bottom: 2px solid #f1f5f9; padding-bottom: 10px; margin-top: 30px;">@Localizer["ثانياً: القواعد المالية المطبقة"]</h3>
    <table class="pdf-table">
        <tr>
            <th>@Localizer["سعر صرف الدولار المعتمد"]</th>
            <td dir="ltr" style="text-align: left;">@Model.UsdExchangeRate OMR/USD</td>
        </tr>
        <tr>
            <th>@Localizer["نسبة الجمارك المطبقة"]</th>
            <td dir="ltr" style="text-align: left;">@Model.CustomsPercentage %</td>
        </tr>
        <tr>
            <th>@Localizer["عمولة الشركة الثابتة"]</th>
            <td dir="ltr" style="text-align: left;">@Model.DefaultCommission</td>
        </tr>
        <tr>
            <th>@Localizer["رقم تواصل الاستفسارات"]</th>
            <td dir="ltr" style="text-align: left;">@Model.InquiryPhoneNumber</td>
        </tr>
    </table>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <script>
        function generatePDF() {
            const element = document.getElementById('pdfReportTemplate');
            element.style.display = 'block';

            const options = {
                margin: 15,
                filename: 'Alargan_System_Report.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            html2pdf().set(options).from(element).save().then(() => {
                element.style.display = 'none';
            });
        }

        $(document).ready(function() {
            // تحديث نص اللون عند تغييره
            $('#colorPicker').on('input', function() {
                $('#colorHexDisplay').text($(this).val().toUpperCase());
            });

            $('#settingsForm').on('submit', function(e) {
                e.preventDefault();
                var btn = $('#btnSave');
                var originalHtml = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin"></i> @Html.Raw(Localizer["جاري الحفظ..."])').prop('disabled', true);

                $.ajax({
                    url: $(this).attr('action'),
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function(res) {
                        if(res.success) {
                            Swal.fire({
                                title: "@Html.Raw(Localizer["تم الحفظ!"])",
                                text: "@Html.Raw(Localizer["تم تحديث الإعدادات ونماذج الفواتير بنجاح."])",
                                icon: 'success',
                                confirmButtonColor: 'var(--primary-gold)'
                            });
                        }
                        btn.html(originalHtml).prop('disabled', false);
                    },
                    error: function() {
                        Swal.fire({ title: "@Html.Raw(Localizer["خطأ!"])", icon: 'error' });
                        btn.html(originalHtml).prop('disabled', false);
                    }
                });
            });
        });

        function confirmWipe() {
            Swal.fire({
                title: "@Html.Raw(Localizer["هل أنت متأكد؟"])",
                text: "@Html.Raw(Localizer["حذف جميع البيانات والبدء من جديد (لا يمكن التراجع)"])",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: 'var(--primary-navy)',
                confirmButtonText: "@Html.Raw(Localizer["نعم، امسح كل شيء"])"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("WipeData", "Settings")', {
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    }, function(res) {
                        if(res.success) {
                            Swal.fire({ title: "@Html.Raw(Localizer["تم التصفير!"])", icon: 'success', confirmButtonColor: 'var(--primary-gold)' }).then(() => location.reload());
                        }
                    });
                }
            });
        }
    </script>
}