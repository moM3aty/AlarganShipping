@model IEnumerable<AlarganShipping.Models.Invoice>
@{
    ViewData["Title"] = Localizer["إدارة الفواتير"];
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        background: white;
        padding: 1.5rem;
        border-radius: 1.5rem;
        border: 1px solid #f1f5f9;
        box-shadow: 0 5px 20px rgba(0,0,0,0.02);
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 1.6rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-add {
        background: var(--primary-navy);
        color: white;
        padding: 0.8rem 1.5rem;
        border-radius: 1rem;
        text-decoration: none;
        font-weight: 800;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add:hover {
            background: var(--primary-gold);
            transform: translateY(-2px);
            color: white;
            box-shadow: 0 5px 15px rgba(184, 147, 90, 0.3);
        }

    .data-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        border: 1px solid #f1f5f9;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        overflow-x: auto;
    }

    .action-btn {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        transition: 0.3s;
        text-decoration: none;
        cursor: pointer;
    }

    .btn-edit:hover {
        background: var(--primary-gold);
        color: white;
        border-color: var(--primary-gold);
    }

    .btn-print:hover {
        background: var(--primary-navy);
        color: white;
        border-color: var(--primary-navy);
    }

    .btn-delete:hover {
        background: #ef4444;
        color: white;
        border-color: #ef4444;
    }

    .badge-shipping-only {
        background: #eff6ff;
        color: #3b82f6;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 800;
        border: 1px solid #bfdbfe;
        display: inline-block;
        margin-top: 5px;
    }

    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            text-align: center;
        }

        .btn-add {
            width: 100%;
            justify-content: center;
        }

        .data-card {
            padding: 1rem;
        }
    }
</style>

<div class="page-header">
    <h2 class="page-title"><i class="fa-solid fa-file-invoice-dollar" style="color: var(--primary-gold);"></i> @Localizer["إدارة الفواتير"]</h2>
    <a href="@Url.Action("Create", "Invoices")" class="btn-add"><i class="fa-solid fa-plus"></i> @Localizer["إصدار فاتورة جديدة"]</a>
</div>

<div class="data-card">
    <table id="invoicesTable" class="table-enterprise display" style="width:100%">
        <thead>
            <tr>
                <th>@Localizer["رقم الفاتورة"]</th>
                <th>@Localizer["تاريخ الإصدار"]</th>
                <th>@Localizer["العميل"]</th>
                <th>@Localizer["السيارة"]</th>
                <th>@Localizer["الإجمالي ($)"]</th>
                <th style="text-align: center;">@Localizer["إجراءات"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var inv in Model)
            {
                <tr>
                    <td style="font-weight: 900; color: var(--primary-navy); font-family: monospace;">
                        @inv.InvoiceNumber
                        @if (inv.IsShippingOnly)
                        {
                            <br />
                    
                            <span class="badge-shipping-only">شحن فقط</span>
                        }
                    </td>
                    <td>@inv.IssueDate.ToString("yyyy-MM-dd")</td>
                    <td style="font-weight: 700;">@(inv.Customer?.Name)</td>
                    <td><span dir="ltr" style="font-family: monospace;">@(inv.Car?.VIN)</span></td>
                    <td style="color: var(--primary-gold); font-weight: 900; font-family: monospace;">$@inv.TotalAmount.ToString("N2")</td>
                    <td style="text-align: center;">
                        <div style="display: flex; gap: 8px; justify-content: center;">
                            <a href="@Url.Action("Details", "Invoices", new { id = inv.Id })" class="action-btn btn-print" title="@Localizer["طباعة الفاتورة"]">
                                <i class="fa-solid fa-print"></i>
                            </a>
                            <a href="@Url.Action("Edit", "Invoices", new { id = inv.Id })" class="action-btn btn-edit" title="@Localizer["تعديل"]">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </a>
                            <button type="button" onclick="confirmDelete(@inv.Id)" class="action-btn btn-delete" title="@Localizer["حذف"]">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script>
        $(document).ready(function() {
            var isRtl = $('html').attr('dir') === 'rtl';
            $('#invoicesTable').DataTable({
                "language": isRtl ? { "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json" } : {},
                "order": [[ 1, "desc" ]],
                "pageLength": 10,
                "responsive": true
            });
        });

        function confirmDelete(id) {
            Swal.fire({
                title: '@Html.Raw(Localizer["هل أنت متأكد؟"])',
                text: '@Html.Raw(Localizer["لن تتمكن من استرجاع هذه الفاتورة وسيتم تحديث مديونية العميل."])',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: 'var(--primary-navy)',
                confirmButtonText: '@Html.Raw(Localizer["نعم، احذف!"])',
                cancelButtonText: '@Html.Raw(Localizer["إلغاء"])'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Invoices")/' + id,
                        type: 'POST',
                        data: { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function (res) {
                            if (res.success) {
                                location.reload();
                            } else {
                                Swal.fire('@Html.Raw(Localizer["خطأ!"])', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }
    </script>
}