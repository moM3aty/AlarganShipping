@model IEnumerable<AlarganShipping.Models.Invoice>
@{
    ViewData["Title"] = Localizer["المالية والفواتير"];
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<style>
    /* --- الهيدر الرئيسي --- */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #ffffff;
        padding: 1.5rem;
        border-radius: 1.5rem;
        box-shadow: 0 5px 20px rgba(44, 62, 80, 0.03);
        margin-bottom: 2rem;
        border: 1px solid #f1f5f9;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .page-title i {
            color: var(--primary-gold);
        }

    .btn-add {
        background: linear-gradient(to right, var(--primary-navy), var(--secondary-navy));
        color: #ffffff;
        font-weight: 800;
        padding: 0.85rem 1.75rem;
        border-radius: 1rem;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(44, 62, 80, 0.3);
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(44, 62, 80, 0.4);
            color: white;
            background: linear-gradient(to right, var(--primary-gold), var(--secondary-gold));
        }

    /* --- بطاقة البيانات والجدول --- */
    .data-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
    }

    .table-enterprise {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }

        .table-enterprise th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            padding: 1.25rem 1rem;
            border-bottom: 2px solid #e2e8f0;
            text-align: start;
            white-space: nowrap;
        }

        .table-enterprise td {
            padding: 1.25rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-dark);
            font-weight: 700;
            vertical-align: middle;
        }

        .table-enterprise tbody tr:hover {
            background-color: #f8fafc;
            transition: 0.2s;
        }

    .inv-number {
        font-family: monospace;
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--primary-navy);
        background: rgba(44, 62, 80, 0.05);
        padding: 0.3rem 0.8rem;
        border-radius: 6px;
        white-space: nowrap;
    }

    .inv-amount {
        font-family: monospace;
        font-size: 1.15rem;
        font-weight: 900;
        color: #16a34a;
        background: rgba(22, 163, 74, 0.05);
        padding: 0.4rem 1rem;
        border-radius: 8px;
        border: 1px solid rgba(22, 163, 74, 0.1);
        white-space: nowrap;
    }

    /* --- أزرار الإجراءات الاحترافية --- */
    .actions-wrapper {
        display: flex;
        gap: 8px;
    }

    .action-btn-pro {
        width: 40px;
        height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        transition: 0.3s;
        text-decoration: none;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        cursor: pointer;
        font-size: 1.1rem;
    }

    .btn-print-pro {
        color: var(--primary-navy);
    }

        .btn-print-pro:hover {
            background: var(--primary-navy);
            color: white;
            border-color: var(--primary-navy);
            transform: scale(1.1);
        }

    .btn-edit-pro {
        color: var(--primary-gold);
    }

        .btn-edit-pro:hover {
            background: var(--primary-gold);
            color: white;
            border-color: var(--primary-gold);
            transform: scale(1.1);
        }

    .btn-delete-pro {
        color: #ef4444;
    }

        .btn-delete-pro:hover {
            background: #ef4444;
            color: white;
            border-color: #ef4444;
            transform: scale(1.1);
        }

    /* ========================================================
           تعديلات الموبايل (الميديا كويري)
           ======================================================== */
    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: stretch;
            text-align: center;
            padding: 1.5rem;
        }

        .page-title {
            justify-content: center;
        }

        .btn-add {
            width: 100%;
            justify-content: center;
        }

        .data-card {
            padding: 1rem;
            border-radius: 1.2rem;
        }

        .actions-wrapper {
            justify-content: center;
        }
    }
</style>

<div class="invoices-index-page">
    @Html.AntiForgeryToken()

    <!-- الترويسة -->
    <div class="page-header">
        <h2 class="page-title"><i class="fa-solid fa-file-invoice-dollar"></i> @Localizer["سجل الفواتير الضريبية"]</h2>
        <a href="@Url.Action("Create", "Invoices")" class="btn-add"><i class="fa-solid fa-plus"></i> @Localizer["إصدار فاتورة جديدة"]</a>
    </div>

    <!-- بطاقة الجدول -->
    <div class="data-card">
        <div style="overflow-x: auto; width: 100%;">
            <table id="invoicesDataTable" class="table-enterprise display" style="width:100%">
                <thead>
                    <tr>
                        <th>@Localizer["رقم الفاتورة"]</th>
                        <th>@Localizer["تاريخ الإصدار"]</th>
                        <th>@Localizer["العميل"]</th>
                        <th>@Localizer["السيارة المرتبطة"]</th>
                        <th>@Localizer["الإجمالي"]</th>
                        <th style="text-align: center;">@Localizer["إجراءات"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var inv in Model)
                        {
                            <tr>
                                <td><span class="inv-number">@inv.InvoiceNumber</span></td>
                                <td style="color: var(--text-muted); font-weight: 800; white-space: nowrap;">@inv.IssueDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <i class="fa-solid fa-user-tie" style="color: #cbd5e1;"></i>
                                        <span style="white-space: nowrap;">@(inv.Customer?.Name ?? "-")</span>
                                    </div>
                                </td>
                                <td>
                                    <div style="color: var(--text-muted); white-space: nowrap;">
                                        <i class="fa-solid fa-car" style="color: #cbd5e1; margin-inline-end: 5px;"></i>
                                        @(inv.Car?.Make) @(inv.Car?.Model)
                                    </div>
                                </td>
                                <td><span class="inv-amount">$@inv.TotalAmount.ToString("N2")</span></td>
                                <td>
                                    <div class="actions-wrapper">
                                        <a href="@Url.Action("Details", "Invoices", new { id = inv.Id })" class="action-btn-pro btn-print-pro" title="@Localizer["طباعة وعرض الفاتورة"]">
                                            <i class="fa-solid fa-print"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", "Invoices", new { id = inv.Id })" class="action-btn-pro btn-edit-pro" title="@Localizer["تعديل الفاتورة"]">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <button type="button" class="action-btn-pro btn-delete-pro" onclick="confirmDelete(@inv.Id)" title="@Localizer["حذف الفاتورة"]">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script>
        // دالة الحذف المصلحة والآمنة
        function confirmDelete(id) {
            Swal.fire({
                title: "@Html.Raw(Localizer["هل أنت متأكد؟"])",
                text: "@Html.Raw(Localizer["عند حذف الفاتورة، سيتم خصم مبلغها من المديونية الحالية للعميل تلقائياً."])",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#ef4444",
                cancelButtonColor: "var(--primary-navy)",
                confirmButtonText: "@Html.Raw(Localizer["نعم، احذفها!"])",
                cancelButtonText: "@Html.Raw(Localizer["إلغاء"])"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Invoices")',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    title: "@Html.Raw(Localizer["تم الحذف!"])",
                                    text: "@Html.Raw(Localizer["تم حذف الفاتورة وتعديل حساب العميل بنجاح."])",
                                    icon: "success",
                                    timer: 2000,
                                    showConfirmButton: false,
                                    confirmButtonColor: "var(--primary-gold)"
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire("@Html.Raw(Localizer["خطأ!"])", response.message || "@Html.Raw(Localizer["حدث خطأ أثناء الحذف."])", "error");
                            }
                        },
                        error: function () {
                            Swal.fire("@Html.Raw(Localizer["خطأ!"])", "@Html.Raw(Localizer["لا يمكن الاتصال بالخادم."])", "error");
                        }
                    });
                }
            });
        }

        $(document).ready(function () {
            var dir = $('html').attr('dir') === 'rtl';
            $('#invoicesDataTable').DataTable({
                "language": { "url": dir ? "//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json" : "" },
                "pageLength": 10,
                "ordering": true,
                "order": [[ 1, "desc" ]], // ترتيب افتراضي من الأحدث للأقدم بناءً على التاريخ
                "responsive": true,
                "dom": '<"top"f>rt<"bottom"lp><"clear">'
            });
        });
    </script>
}