@model IEnumerable<AlarganShipping.Models.Invoice>
@{
    ViewData["Title"] = "إدارة الفواتير";
}

<style>
    /* Premium Pure CSS for Invoices Grid */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #ffffff;
        padding: 1.25rem 1.5rem;
        border-radius: 1rem;
        box-shadow: 0 4px 6px -1px rgba(43, 63, 86, 0.05);
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: #2b3f56;
        margin: 0;
    }

    .btn-add {
        display: inline-block;
        background: linear-gradient(to right, #be955b, #d4af7a);
        color: #ffffff;
        font-weight: 700;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(190, 149, 91, 0.3);
        transition: all 0.3s ease;
        border: none;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(190, 149, 91, 0.4);
        }

    .invoices-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @@media (min-width: 1024px) {
        .invoices-grid

    {
        grid-template-columns: repeat(3, 1fr);
    }

    }

    .invoice-card {
        background-color: #ffffff;
        border-radius: 1.25rem;
        box-shadow: 0 10px 25px rgba(43, 63, 86, 0.05);
        border: 1px solid #f1f5f9;
        position: relative;
        overflow: hidden;
        transition: transform 0.3s ease;
    }

        .invoice-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(43, 63, 86, 0.1);
        }

    .card-accent-line {
        position: absolute;
        top: 0;
        right: 0;
        width: 6px;
        height: 100%;
        background-color: #2b3f56;
    }

    .invoice-header {
        padding: 1.5rem 1.5rem 1rem 1.5rem;
        border-bottom: 1px dashed #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .inv-number {
        font-size: 1.1rem;
        font-weight: 900;
        color: #2b3f56;
        margin: 0;
        font-family: monospace;
    }

    .inv-date {
        color: #64748b;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .invoice-body {
        padding: 1.5rem;
    }

    .inv-customer {
        font-size: 1.1rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 0.25rem;
    }

    .inv-car {
        color: #64748b;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
    }

    .inv-total-box {
        background: #f8fafc;
        padding: 1rem;
        border-radius: 0.75rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid #e2e8f0;
    }

    .inv-total-label {
        color: #475569;
        font-weight: 800;
    }

    .inv-total-value {
        color: #be955b;
        font-weight: 900;
        font-size: 1.5rem;
    }

    .invoice-footer {
        padding: 1rem 1.5rem;
        background: #f8fafc;
        border-top: 1px solid #f1f5f9;
        text-align: center;
    }

    .btn-print {
        color: #2b3f56;
        font-weight: 800;
        text-decoration: none;
        font-size: 0.95rem;
        transition: color 0.3s;
    }

        .btn-print:hover {
            color: #be955b;
        }
</style>

<div>
    <div class="page-header">
        <h2 class="page-title">إدارة الفواتير والماليات</h2>
        <a href="@Url.Action("Create", "Invoices")" class="btn-add">إصدار فاتورة جديدة</a>
    </div>

    <div class="invoices-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var inv in Model)
            {
                <div class="invoice-card">
                    <div class="card-accent-line"></div>
                    <div class="invoice-header">
                        <h3 class="inv-number">@inv.InvoiceNumber</h3>
                        <span class="inv-date">@inv.IssueDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="invoice-body">
                        <div class="inv-customer">العميل: @inv.Customer?.Name</div>
                        <div class="inv-car">السيارة: @inv.Car?.Make @inv.Car?.Model</div>
                        <div class="inv-total-box">
                            <span class="inv-total-label">إجمالي الفاتورة</span>
                            <span class="inv-total-value">$@inv.TotalAmount</span>
                        </div>
                    </div>
                    <div class="invoice-footer">
                        <a href="@Url.Action("Details", "Invoices", new { id = inv.Id })" class="btn-print">استعراض وطباعة الفاتورة &larr;</a>
                    </div>
                </div>
            }
        }
    </div>
</div>