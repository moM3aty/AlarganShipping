@model AlarganShipping.Models.Invoice
@{
    ViewData["Title"] = Localizer["تعديل الفاتورة"];
}

<style>
    /* نفس تنسيقات الـ Create بالضبط لضمان توحيد المظهر */
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 10px;
    }

    .form-page-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
    }

    .btn-back {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        padding: 0.6rem 1.2rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: var(--primary-navy);
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(44, 62, 80, 0.03);
        border: 1px solid #f1f5f9;
        padding: 2.5rem;
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--primary-navy);
        border-bottom: 2px solid #f1f5f9;
        padding-bottom: 10px;
        margin-bottom: 1.5rem;
        margin-top: 2.5rem;
    }

        .section-title:first-child {
            margin-top: 0;
        }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-label {
        font-weight: 800;
        color: var(--text-muted);
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
    }

    .form-control {
        padding: 0.85rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 0.95rem;
        font-weight: 700;
        transition: 0.3s;
        outline: none;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

    .input-money {
        font-family: monospace;
        text-align: end;
        font-size: 1.1rem;
        color: var(--primary-navy);
    }

    .total-box {
        background: rgba(184, 147, 90, 0.05);
        border: 2px dashed var(--primary-gold);
        border-radius: 1rem;
        padding: 1.5rem;
        margin-top: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .total-label {
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--primary-navy);
    }

    .total-amount {
        font-size: 2rem;
        font-weight: 900;
        color: var(--primary-gold);
        font-family: monospace;
    }

    .form-actions {
        margin-top: 2.5rem;
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn-submit {
        background: var(--primary-navy);
        color: white;
        border: none;
        padding: 1rem 2.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: 0.3s;
        flex: 1;
        min-width: 250px;
    }

        .btn-submit:hover {
            background: var(--primary-gold);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(184, 147, 90, 0.2);
        }

    .btn-cancel {
        background: #f8fafc;
        color: var(--text-dark);
        border: 1px solid #e2e8f0;
        padding: 1rem 2.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        text-decoration: none;
        text-align: center;
        transition: 0.3s;
        flex: 1;
        min-width: 150px;
    }

        .btn-cancel:hover {
            background: #e2e8f0;
        }

    .switch-wrapper {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        padding: 1rem;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 1.5rem;
        cursor: pointer;
    }

        .switch-wrapper input {
            width: 20px;
            height: 20px;
            accent-color: #3b82f6;
            cursor: pointer;
        }

        .switch-wrapper label {
            font-weight: 800;
            color: #1e3a8a;
            cursor: pointer;
            margin: 0;
            flex: 1;
        }

    .select2-container--default .select2-selection--single {
        background-color: white;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        height: 45px;
        display: flex;
        align-items: center;
        transition: 0.3s;
    }

        .select2-container--default .select2-selection--single:focus {
            border-color: var(--primary-gold);
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            color: var(--primary-navy);
            font-weight: 700;
            padding-left: 1rem;
            padding-right: 1rem;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 43px;
            right: 10px;
        }

    html[dir="rtl"] .select2-container--default .select2-selection--single .select2-selection__arrow {
        left: 10px;
        right: auto;
    }

    @@media (max-width: 768px) {
        .premium-form-card

    {
        padding: 1.5rem;
    }

    .form-page-header {
        flex-direction: column;
        text-align: center;
    }

    .btn-back {
        width: 100%;
        justify-content: center;
        display: flex;
    }

    }
</style>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<div class="form-page-header">
    <h2 class="form-page-title"><i class="fa-solid fa-pen-to-square" style="color: var(--primary-gold);"></i> @Localizer["تعديل الفاتورة"] @Model.InvoiceNumber</h2>
    <a href="@Url.Action("Index", "Invoices")" class="btn-back"><i class="fa-solid fa-arrow-right-long"></i> @Localizer["العودة للقائمة"]</a>
</div>

<div class="premium-form-card">
    <form asp-action="Edit" method="post" id="invoiceEditForm">
        @Html.AntiForgeryToken()

        <!-- حقول مخفية للحفاظ على البيانات الأساسية -->
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="InvoiceNumber" />
        <input type="hidden" asp-for="IssueDate" />

        <div class="section-title"><i class="fa-solid fa-circle-info" style="color: var(--primary-gold);"></i> البيانات الأساسية</div>
        <div class="form-grid" style="margin-bottom: 2rem;">
            <div class="form-group">
                <label asp-for="CustomerId" class="form-label">@Localizer["العميل"] *</label>
                <select asp-for="CustomerId" class="form-control select2" asp-items="ViewBag.CustomerId" required></select>
            </div>
            <div class="form-group">
                <label asp-for="CarId" class="form-label">@Localizer["السيارة المرتبطة"] *</label>
                <select asp-for="CarId" class="form-control select2" asp-items="ViewBag.CarId" required></select>
            </div>
        </div>

        <div class="section-title"><i class="fa-solid fa-money-bills" style="color: var(--primary-gold);"></i> نوع الفاتورة والرسوم</div>

        <label class="switch-wrapper">
            <input type="checkbox" asp-for="IsShippingOnly" id="IsShippingOnly" />
            <span style="font-weight: 800; color: #1e3a8a;">@Localizer["فاتورة شحن وجمارك فقط (استثناء قيمة السيارة والمزاد لأن العميل دفعها بنفسه)"]</span>
        </label>

        <div class="form-grid">
            <div class="form-group car-cost-group">
                <label asp-for="CarPrice" class="form-label">@Localizer["سعر بيع السيارة للعميل ($)"]</label>
                <input asp-for="CarPrice" class="form-control input-money calc-field" type="number" step="0.01" />
            </div>
            <div class="form-group car-cost-group">
                <label asp-for="AuctionFees" class="form-label">@Localizer["رسوم المزاد والبوابة ($)"]</label>
                <input asp-for="AuctionFees" class="form-control input-money calc-field" type="number" step="0.01" />
            </div>

            <!-- الحقول الثلاثة الجديدة -->
            <div class="form-group">
                <label asp-for="TransferFees" class="form-label">@Localizer["رسوم التحويل ($)"]</label>
                <input asp-for="TransferFees" class="form-control input-money calc-field" type="number" step="0.01" />
            </div>
            <div class="form-group">
                <label asp-for="CarSizeFees" class="form-label">@Localizer["رسوم حجم السيارة ($)"]</label>
                <input asp-for="CarSizeFees" class="form-control input-money calc-field" type="number" step="0.01" />
            </div>

            <div class="form-group">
                <label asp-for="InlandTowing" class="form-label">@Localizer["النقل الداخلي بأمريكا (Towing) ($)"]</label>
                <input asp-for="InlandTowing" class="form-control input-money calc-field" type="number" step="0.01" />
            </div>
            <div class="form-group">
                <label asp-for="SeaFreight" class="form-label">@Localizer["الشحن البحري ($)"]</label>
                <input asp-for="SeaFreight" class="form-control input-money calc-field" type="number" step="0.01" />
            </div>
            <div class="form-group">
                <label asp-for="CustomsAndTaxes" class="form-label">@Localizer["رسوم التخليص الجمركي ($)"]</label>
                <input asp-for="CustomsAndTaxes" class="form-control input-money calc-field" type="number" step="0.01" />
            </div>

            <!-- الحقل الجديد: النقل داخل عمان -->
            <div class="form-group">
                <label asp-for="OmanTowingFees" class="form-label">@Localizer["رسوم النقل داخل عمان ($)"]</label>
                <input asp-for="OmanTowingFees" class="form-control input-money calc-field" type="number" step="0.01" />
            </div>

            <div class="form-group">
                <label asp-for="StorageFees" class="form-label" style="color: #ef4444;">@Localizer["غرامات تأخير / أرضيات ($)"]</label>
                <input asp-for="StorageFees" class="form-control input-money calc-field" type="number" step="0.01" style="border-color: #fca5a5;" />
            </div>
            <div class="form-group">
                <label asp-for="CompanyCommission" class="form-label" style="color: var(--primary-gold);">@Localizer["عمولة الشركة (الأتعاب الإدارية) ($)"]</label>
                <input asp-for="CompanyCommission" class="form-control input-money calc-field" type="number" step="0.01" />
            </div>
        </div>

        <div class="section-title"><i class="fa-solid fa-hand-holding-dollar" style="color: var(--primary-gold);"></i> الدفعات والاستلام</div>
        <div class="form-grid">
            <div class="form-group">
                <label asp-for="AmountPaid" class="form-label" style="color: #16a34a;">@Localizer["المبلغ المدفوع مقدماً (عربون / دفعة) ($)"]</label>
                <input asp-for="AmountPaid" class="form-control input-money calc-field" type="number" step="0.01" style="border-color: #86efac;" />
            </div>
        </div>

        <div class="total-box">
            <div>
                <div class="total-label">@Localizer["الإجمالي المستحق على العميل:"]</div>
                <div style="font-size: 0.9rem; color: var(--text-muted); font-weight: 700; margin-top: 5px;">
                    @Localizer["المتبقي عند الاستلام:"] <span id="lblRemaining" style="color: #ef4444; font-family: monospace; font-size: 1.2rem;">$0.00</span>
                </div>
            </div>
            <div class="total-amount">$<span id="lblTotal">0.00</span></div>
            <input type="hidden" asp-for="TotalAmount" id="TotalAmountHidden" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit" id="btnSubmit">
                <i class="fa-solid fa-save"></i> @Localizer["حفظ التعديلات"]
            </button>
            <a href="@Url.Action("Index", "Invoices")" class="btn-cancel">@Localizer["إلغاء"]</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>

    <script>
        $(document).ready(function() {
            var dir = $('html').attr('dir');
            $('.select2').select2({ dir: dir, width: '100%' });

            function calculateTotals() {
                var isShippingOnly = $('#IsShippingOnly').is(':checked');

                if(isShippingOnly) {
                    $('.car-cost-group').css({ 'opacity': '0.4', 'pointer-events': 'none' });
                    $('#CarPrice').val(0);
                    $('#AuctionFees').val(0);
                } else {
                    $('.car-cost-group').css({ 'opacity': '1', 'pointer-events': 'auto' });
                }

                var carPrice = parseFloat($('#CarPrice').val()) || 0;
                var auction = parseFloat($('#AuctionFees').val()) || 0;
                var transfer = parseFloat($('#TransferFees').val()) || 0;
                var sizeFee = parseFloat($('#CarSizeFees').val()) || 0;
                var towing = parseFloat($('#InlandTowing').val()) || 0;
                var sea = parseFloat($('#SeaFreight').val()) || 0;
                var customs = parseFloat($('#CustomsAndTaxes').val()) || 0;
                var omanTowing = parseFloat($('#OmanTowingFees').val()) || 0;
                var storage = parseFloat($('#StorageFees').val()) || 0;
                var comm = parseFloat($('#CompanyCommission').val()) || 0;

                var paid = parseFloat($('#AmountPaid').val()) || 0;

                var total = carPrice + auction + transfer + sizeFee + towing + sea + customs + omanTowing + storage + comm;
                var remaining = total - paid;

                $('#lblTotal').text(total.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));
                $('#TotalAmountHidden').val(total);
                $('#lblRemaining').text('$' + remaining.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));
            }

            $('.calc-field').on('input', calculateTotals);
            $('#IsShippingOnly').on('change', calculateTotals);
            calculateTotals();

            $('#invoiceEditForm').on('submit', function(e) {
                e.preventDefault();
                var form = $(this);
                if (!form[0].checkValidity()) { form[0].reportValidity(); return; }

                var btn = $('#btnSubmit');
                var originalText = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin"></i>').prop('disabled', true);

                $.ajax({
                    url: form.attr('action'),
                    type: form.attr('method'),
                    data: form.serialize(),
                    success: function(res) {
                        if (res.success) {
                            Swal.fire({ title: '@Html.Raw(Localizer["تم التحديث بنجاح!"])', icon: 'success', confirmButtonColor: 'var(--primary-gold)' })
                            .then(() => window.location.href = '@Url.Action("Index", "Invoices")');
                        } else {
                            var errorMsg = res.errors ? res.errors.join('\n') : '@Html.Raw(Localizer["تأكد من البيانات"])';
                            Swal.fire('@Html.Raw(Localizer["خطأ!"])', errorMsg, 'error');
                            btn.html(originalText).prop('disabled', false);
                        }
                    },
                    error: function() {
                        Swal.fire('@Html.Raw(Localizer["خطأ!"])', '@Html.Raw(Localizer["حدث خطأ بالاتصال بالسيرفر"])', 'error');
                        btn.html(originalText).prop('disabled', false);
                    }
                });
            });
        });
    </script>
}