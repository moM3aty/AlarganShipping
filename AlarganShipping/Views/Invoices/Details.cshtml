@model AlarganShipping.Models.Invoice
@{
    ViewData["Title"] = Localizer["طباعة الفاتورة"];
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>فاتورة @Model.InvoiceNumber</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        :root {
            --primary-navy: #1e293b;
            --primary-gold: #b45309;
            --bg-gray: #f1f5f9;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background: #e2e8f0;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .controls-wrapper {
            width: 100%;
            max-width: 800px;
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 10px 25px;
            border: none;
            border-radius: 8px;
            font-family: 'Cairo', sans-serif;
            font-weight: 900;
            font-size: 0.9rem;
            cursor: pointer;
            color: white;
            transition: transform 0.2s;
        }

            .btn:hover {
                transform: translateY(-2px);
            }

        .btn-back {
            background: #475569;
        }

        .btn-print {
            background: var(--primary-gold);
        }

        .invoice {
            background: white;
            width: 210mm;
            min-height: 297mm;
            box-sizing: border-box;
            padding: 15mm;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            display: flex;
            flex-direction: column;
        }

        .header {
            text-align: center;
            border-bottom: 3px solid var(--primary-navy);
            padding-bottom: 10px;
            margin-bottom: 20px;
            flex-shrink: 0;
        }

            .header img {
                height: 70px;
                margin-bottom: 5px;
            }

            .header h1 {
                margin: 0;
                color: var(--primary-navy);
                font-size: 24px;
                font-weight: 900;
            }

            .header p {
                margin: 3px 0 0;
                color: #64748b;
                font-weight: 700;
                font-size: 14px;
            }

        .meta-info {
            display: flex;
            justify-content: space-between;
            background: var(--bg-gray);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            border: 1px solid #cbd5e1;
            flex-shrink: 0;
        }

            .meta-info div p {
                margin: 4px 0;
                font-weight: 700;
                color: #334155;
                font-size: 13px;
            }

            .meta-info span {
                color: var(--primary-gold);
                font-family: monospace;
                font-size: 14px;
            }

        .highlight-badge {
            background: #fef2f2;
            color: #dc2626;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 11px;
            margin-top: 5px;
            display: inline-block;
            font-weight: 900;
            border: 1px solid #fecaca;
        }

        .table-wrapper {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
            margin-bottom: 20px;
        }

        th {
            background: var(--primary-navy);
            color: white;
            padding: 10px;
            text-align: right;
            font-weight: 700;
            border-radius: 4px 4px 0 0;
        }

        td {
            padding: 10px;
            border-bottom: 1px solid #e2e8f0;
            font-weight: 700;
        }

            td.price {
                text-align: left;
                font-family: monospace;
                font-size: 15px;
                color: var(--primary-navy);
            }

        .desc-sub {
            display: block;
            font-size: 10px;
            color: #94a3b8;
            font-weight: normal;
            margin-top: 2px;
        }

        .summary {
            display: flex;
            justify-content: flex-start;
            margin-top: 10px;
            flex-shrink: 0;
        }

        .summary-box {
            width: 280px;
            border: 2px solid var(--primary-navy);
            border-radius: 6px;
            overflow: hidden;
        }

        .row {
            display: flex;
            justify-content: space-between;
            padding: 8px 12px;
            border-bottom: 1px solid #e2e8f0;
            font-weight: 800;
            font-size: 14px;
        }

            .row.total {
                background: var(--primary-navy);
                color: white;
                font-size: 16px;
                font-weight: 900;
                border: none;
            }

            .row.paid {
                color: #16a34a;
            }

            .row.due {
                background: #fef2f2;
                color: #dc2626;
                font-size: 15px;
                border: none;
            }

        .footer {
            text-align: center;
            border-top: 2px dashed #cbd5e1;
            padding-top: 15px;
            margin-top: auto;
        }

        .bank-card {
            display: inline-block;
            background: rgba(255,255,255,0.5);
            border: 2px dashed var(--primary-gold);
            padding: 10px 25px;
            border-radius: 6px;
            text-align: right;
        }

            .bank-card h4 {
                margin: 0 0 4px;
                color: var(--primary-gold);
                font-size: 13px;
            }

            .bank-card p {
                margin: 2px 0;
                font-size: 12px;
            }

        .bank-num {
            font-family: monospace;
            font-size: 15px;
            font-weight: 900;
            color: var(--primary-navy);
            letter-spacing: 1px;
        }

        @@media print {
            body

        {
            background: none;
            padding: 0;
            margin: 0;
        }

        .controls-wrapper, .btn {
            display: none !important;
        }

        .invoice {
            box-shadow: none;
            margin: 0;
            width: 100%;
            height: auto;
            padding: 0;
        }

        * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            color-adjust: exact !important;
        }

        .header {
            border-bottom-color: var(--primary-navy) !important;
        }

        .meta-info {
            background-color: var(--bg-gray) !important;
        }

        th {
            background-color: var(--primary-navy) !important;
        }

        .row.total {
            background-color: var(--primary-navy) !important;
        }

        .row.due {
            background-color: #fef2f2 !important;
        }

        }
    </style>
</head>
<body>

    <div class="controls-wrapper">
        <button class="btn btn-back" onclick="history.back()">رجوع</button>
        <button class="btn btn-print" onclick="window.print()">طباعة الفاتورة</button>
    </div>

    <div class="invoice" id="invoice-area">
        <div class="header">
            <img src="/images/logo.jpg" alt="Logo" onerror="this.style.display='none'">
            <h1>ALARGAN AUTO SHIPPING</h1>
            <p>فاتورة ضريبية - Tax Invoice</p>
        </div>

        <div class="meta-info">
            <div>
                <p>العميل: <span>@(Model.Customer?.Name ?? "-")</span></p>
                <p>السيارة: <span style="color:var(--primary-navy)">@(Model.Car?.Make ?? "-") @(Model.Car?.VehicleType ?? "-")</span></p>
                <p>رقم الشاصي: <span style="color:var(--primary-navy)">@(Model.Car?.VIN ?? "-")</span></p>
            </div>
            <div style="text-align:left">
                <p>رقم الفاتورة: <span>@Model.InvoiceNumber</span></p>
                <p>التاريخ: <span>@Model.IssueDate.ToString("yyyy/MM/dd")</span></p>
                @if (Model.IsShippingOnly)
                {
                    <div class="highlight-badge">شحن وجمارك فقط</div>
                }
            </div>
        </div>

        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>البيان (Description)</th>
                        <th style="width: 30%; text-align: left;">المبلغ (USD)</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.IsShippingOnly)
                    {
                        <tr>
                            <td>قيمة السيارة (Car Price)</td>
                            <td class="price">@Model.CarPrice.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td>رسوم المزاد (Auction Fees)</td>
                            <td class="price">@Model.AuctionFees.ToString("N2")</td>
                        </tr>
                    }

                    @if (Model.TransferFees > 0)
                    {
                        <tr>
                            <td>رسوم التحويل (Transfer Fees)</td>
                            <td class="price">@Model.TransferFees.ToString("N2")</td>
                        </tr>
                    }

                    @if (Model.CarSizeFees > 0)
                    {
                        <tr>
                            <td>رسوم حجم السيارة (Car Size Surcharge)</td>
                            <td class="price">@Model.CarSizeFees.ToString("N2")</td>
                        </tr>
                    }

                    <tr>
                        <td>النقل الداخلي بأمريكا (Inland Towing)</td>
                        <td class="price">@Model.InlandTowing.ToString("N2")</td>
                    </tr>

                    <tr>
                        <td>الشحن البحري (Sea Freight)</td>
                        <td class="price">@Model.SeaFreight.ToString("N2")</td>
                    </tr>

                    @if (Model.OmanTowingFees > 0)
                    {
                        <tr>
                            <td>رسوم النقل داخل عمان (Oman Towing)</td>
                            <td class="price">@Model.OmanTowingFees.ToString("N2")</td>
                        </tr>
                    }

                    <tr>
                        <td>رسوم التخليص الجمركي (Customs Clearance)</td>
                        <td class="price">@Model.CustomsAndTaxes.ToString("N2")</td>
                    </tr>

                    <tr>
                        <td>الضريبة (VAT)</td>
                        <td class="price">@Model.TaxAmount.ToString("N2")</td>
                    </tr>

                    <tr>
                        <td>الجمارك (Customs Duty)</td>
                        <td class="price">@Model.CustomsAmount.ToString("N2")</td>
                    </tr>

                    @if (Model.StorageFees > 0)
                    {
                        <tr style="color:#dc2626">
                            <td>غرامات تأخير / أرضيات (Storage/Penalties)</td>
                            <td class="price" style="color:#dc2626">@Model.StorageFees.ToString("N2")</td>
                        </tr>
                    }

                    <tr>
                        <td>عمولة الشركة والأتعاب الإدارية (Admin Fees)</td>
                        <td class="price">@Model.CompanyCommission.ToString("N2")</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="summary">
            <div class="summary-box">
                <div class="row total">
                    <span>الإجمالي (Total)</span>
                    <span>$@Model.TotalAmount.ToString("N2")</span>
                </div>
                <div class="row paid">
                    <span>المدفوع (Paid)</span>
                    <span>$@Model.AmountPaid.ToString("N2")</span>
                </div>
                <div class="row due">
                    <span>المتبقي للتحصيل (Due)</span>
                    <span>$@Model.RemainingAmount.ToString("N2")</span>
                </div>
            </div>
        </div>

        <div class="footer">
            <div class="bank-card">
                <h4>تفاصيل الحساب البنكي</h4>
                <p>بنك مسقط - Bank Muscat</p>
                <p class="bank-num">0000 0000 0000 0000</p>
            </div>
        </div>
    </div>

    <script>
        function generatePDF() {
            const element = document.getElementById('invoice-area');
            const opt = {
                margin: 0,
                filename: 'Invoice_@(Model.InvoiceNumber).pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true, scrollX: 0, scrollY: 0, windowWidth: 794 },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            var btns = document.querySelector('.controls-wrapper');
            btns.style.display = 'none';

            html2pdf().set(opt).from(element).toPdf().get('pdf').then(function (pdf) {
                pdf.save('Invoice_@(Model.InvoiceNumber).pdf');
            }).then(function() {
                btns.style.display = 'flex';
            });
        }
    </script>
</body>
</html>