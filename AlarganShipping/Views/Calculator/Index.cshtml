@{
    ViewData["Title"] = Localizer["حاسبة تكاليف الشحن الذكية"];
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
}

<style>
    .calc-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem 0;
    }

    .calc-header {
        text-align: center;
        margin-bottom: 3rem;
    }

        .calc-header h1 {
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--primary-navy);
            margin-bottom: 0.5rem;
        }

        .calc-header p {
            color: var(--text-muted);
            font-size: 1.1rem;
            font-weight: 600;
        }

    .calc-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 2rem;
        align-items: flex-start;
    }

    .calc-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
    }

    .mode-switch {
        display: flex;
        background: #f1f5f9;
        border-radius: 1rem;
        padding: 0.5rem;
        margin-bottom: 2rem;
    }

    .mode-btn {
        flex: 1;
        text-align: center;
        padding: 0.8rem;
        font-weight: 800;
        border-radius: 0.75rem;
        cursor: pointer;
        transition: 0.3s;
        color: var(--text-muted);
    }

        .mode-btn.active {
            background: white;
            color: var(--primary-navy);
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }

    .input-group {
        margin-bottom: 1.5rem;
    }

    .input-label {
        display: block;
        font-weight: 800;
        color: var(--primary-navy);
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .calc-input {
        width: 100%;
        padding: 1rem 1.25rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-size: 1.1rem;
        font-weight: 900;
        transition: 0.3s;
        outline: none;
        background: #f8fafc;
    }

        .calc-input:focus {
            border-color: var(--primary-gold);
            background: white;
        }

    .calc-input-ltr {
        text-align: end;
        font-family: monospace;
    }

    .calc-input[readonly] {
        background-color: #e2e8f0;
        cursor: not-allowed;
        color: var(--primary-gold);
    }

    .fee-details-text {
        display: block;
        margin-top: 5px;
        font-size: 0.8rem;
        color: #16a34a;
        font-weight: 700;
    }

    /* Summary Card */
    .summary-card {
        background: linear-gradient(135deg, var(--primary-navy) 0%, var(--secondary-navy) 100%);
        color: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 15px 40px rgba(26, 42, 58, 0.2);
        position: sticky;
        top: 100px;
    }

    .summary-title {
        font-size: 1.5rem;
        font-weight: 900;
        margin: 0 0 2rem 0;
        color: var(--primary-gold);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
        font-weight: 700;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

        .summary-row:last-of-type {
            border-bottom: none;
            margin-bottom: 0;
        }

    .summary-val {
        font-family: monospace;
        font-size: 1.2rem;
    }

    .grand-total-box {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 1rem;
        padding: 1.5rem;
        margin-top: 2rem;
        text-align: center;
    }

    .grand-total-label {
        display: block;
        font-size: 1rem;
        font-weight: 800;
        color: #cbd5e1;
        margin-bottom: 0.5rem;
    }

    .grand-total-val {
        font-size: 2.5rem;
        font-weight: 900;
        color: var(--primary-gold);
        font-family: monospace;
    }

    .btn-print {
        width: 100%;
        background: var(--primary-gold);
        color: white;
        border: none;
        padding: 1rem;
        border-radius: 0.75rem;
        font-weight: 900;
        font-size: 1.1rem;
        margin-top: 1.5rem;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .btn-print:hover {
            background: var(--secondary-gold);
        }

    @@media (max-width: 992px) {
        .calc-grid {
            grid-template-columns: 1fr;
        }

        .summary-card {
            position: relative;
            top: 0;
        }
    }
</style>

<div class="calc-container">
    <div class="calc-header">
        <h1><i class="fa-solid fa-calculator" style="color: var(--primary-gold); margin-inline-end: 10px;"></i> @Localizer["حاسبة تكاليف الشحن الذكية"]</h1>
        <p>@Localizer["احسب التكاليف المتوقعة مباشرة بناءً على بيانات المزادات والموانئ في النظام"]</p>
    </div>

    <div class="calc-grid">
        <!-- قسم الإدخال -->
        <div class="calc-card">
            <div class="mode-switch">
                <div class="mode-btn active" id="modeExport" onclick="setMode('export')">@Localizer["شراء سيارة (Export)"]</div>
                <div class="mode-btn" id="modeImport" onclick="setMode('import')">@Localizer["شحن فقط (Import)"]</div>
            </div>

            <div class="input-group" id="carPriceGroup">
                <label class="input-label">@Localizer["سعر شراء السيارة المتوقع (USD)"]</label>
                <input type="number" class="calc-input calc-input-ltr" id="carPrice" placeholder="مثال: 1500" value="0" />
            </div>

            <!-- حقل رسوم المزاد المحسوب تلقائياً -->
            <div class="input-group" id="auctionFeeGroup">
                <label class="input-label">@Localizer["رسوم المزاد الإجمالية (تُحسب تلقائياً) USD"]</label>
                <input type="number" class="calc-input calc-input-ltr" id="auctionFeeInput" value="0" readonly />
                <span class="fee-details-text" id="auctionFeeDetails"></span>
            </div>

            <div class="input-group">
                <label class="input-label">@Localizer["تكلفة النقل الداخلي (Towing) USD"]</label>
                <input type="number" class="calc-input calc-input-ltr" id="towingFee" value="350" />
            </div>

            <div class="input-group">
                <label class="input-label">@Localizer["تكلفة الشحن البحري (Ocean Freight) USD"]</label>
                <input type="number" class="calc-input calc-input-ltr" id="oceanFreightFee" value="1200" />
            </div>

            <hr style="border: none; border-top: 2px dashed #e2e8f0; margin: 2rem 0;" />

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="input-group">
                    <label class="input-label">@Localizer["الجمارك (%)"]</label>
                    <input type="number" class="calc-input calc-input-ltr" id="customsPercent" value="5" step="0.1" />
                </div>
                <div class="input-group">
                    <label class="input-label">@Localizer["عمولة الشركة ($)"]</label>
                    <input type="number" class="calc-input calc-input-ltr" id="companyComm" value="150" />
                </div>
            </div>

            <p style="font-size: 0.85rem; color: #94a3b8; font-weight: 700; margin-top: 1rem;">
                <i class="fa-solid fa-circle-info"></i> @Localizer["ملاحظات هامة: التكاليف المعروضة قابلة للتعديل وتتغير النتائج فوراً. الجمارك والضرائب تحسب تلقائياً كنسبة من (سعر السيارة + أجور الشحن)."]
            </p>
        </div>

        <!-- قسم الملخص -->
        <div class="summary-card">
            <h3 class="summary-title"><i class="fa-solid fa-receipt"></i> @Localizer["ملخص التسعيرة"]</h3>

            <div class="summary-row" id="sumRowCar">
                <span>@Localizer["سعر السيارة"]</span>
                <span class="summary-val" id="sumCarPrice">$0.00</span>
            </div>
            <div class="summary-row" id="sumRowAuction">
                <span>@Localizer["رسوم المزاد"]</span>
                <span class="summary-val" id="sumAuctionFee">$0.00</span>
            </div>
            <div class="summary-row">
                <span>@Localizer["النقل الداخلي والشحن"]</span>
                <span class="summary-val" id="sumShipping">$0.00</span>
            </div>
            <div class="summary-row">
                <span>@Localizer["الجمارك والضرائب"]</span>
                <span class="summary-val" id="sumCustoms">$0.00</span>
            </div>
            <div class="summary-row">
                <span>@Localizer["عمولة الشركة"]</span>
                <span class="summary-val" id="sumComm">$0.00</span>
            </div>

            <div class="grand-total-box">
                <span class="grand-total-label">@Localizer["الإجمالي المتوقع"]</span>
                <div class="grand-total-val" id="grandTotalUSD">$0.00</div>
            </div>

            <button class="btn-print" onclick="window.print()">
                <i class="fa-solid fa-print"></i> @Localizer["طباعة عرض السعر للعميل"]
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- استدعاء ملف حساب المزاد الذي أنشأناه -->
    <script src="~/js/auctionCalculator.js"></script>

    <script>
        var currentMode = 'export';

        function setMode(mode) {
            currentMode = mode;
            if(mode === 'export') {
                $('#modeExport').addClass('active');
                $('#modeImport').removeClass('active');
                $('#carPriceGroup, #auctionFeeGroup, #sumRowCar, #sumRowAuction').show();
            } else {
                $('#modeImport').addClass('active');
                $('#modeExport').removeClass('active');
                $('#carPriceGroup, #auctionFeeGroup, #sumRowCar, #sumRowAuction').hide();
                $('#carPrice, #auctionFeeInput').val(0); // تصفير القيم عند إخفائها
            }
            calculateTotal();
        }

        function calculateTotal() {
            var carPrice = currentMode === 'export' ? (parseFloat($('#carPrice').val()) || 0) : 0;

            // --- الربط مع ملف auctionCalculator.js ---
            if (currentMode === 'export' && carPrice > 0) {
                var auctionFees = calculateTotalAuctionFees(carPrice);
                $('#auctionFeeInput').val(auctionFees.totalFees);
                $('#auctionFeeDetails').text(`(رسوم المشتري: $${auctionFees.buyerFee} + رسوم ثابتة: $${auctionFees.fixedFees})`);
            } else {
                $('#auctionFeeInput').val(0);
                $('#auctionFeeDetails').text('');
            }

            var auctionFee = parseFloat($('#auctionFeeInput').val()) || 0;
            var towingFee = parseFloat($('#towingFee').val()) || 0;
            var oceanFreightFee = parseFloat($('#oceanFreightFee').val()) || 0;
            var customsPercent = parseFloat($('#customsPercent').val()) || 0;
            var companyComm = parseFloat($('#companyComm').val()) || 0;

            // الجمارك تحسب على (قيمة السيارة + الشحن البحري)
            var customsAmount = (carPrice + oceanFreightFee) * (customsPercent / 100);

            var totalShipping = towingFee + oceanFreightFee;
            var grandTotal = carPrice + auctionFee + totalShipping + customsAmount + companyComm;

            // تحديث العرض
            $('#sumCarPrice').text('$' + carPrice.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));
            $('#sumAuctionFee').text('$' + auctionFee.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));
            $('#sumShipping').text('$' + totalShipping.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));
            $('#sumCustoms').text('$' + customsAmount.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));
            $('#sumComm').text('$' + companyComm.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));

            $('#grandTotalUSD').text('$' + grandTotal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));
        }

        $(document).ready(function() {
            // الاستماع لأي تغيير في الحقول لتحديث الحسابات فوراً
            $('.calc-input').on('input change', calculateTotal);
            calculateTotal(); // حساب مبدئي عند تحميل الصفحة
        });
    </script>
}