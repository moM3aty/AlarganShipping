@model AlarganShipping.Models.Invoice
@{
    ViewData["Title"] = Localizer["الحاسبة الذكية لتكلفة الاستيراد"];
    Layout = "_Layout";

    string errorMessage = ViewBag.ErrorMessage as string;
}

<style>
    /* =========================================================
                       تصميم الحاسبة الذكية (Pixel-Perfect) للعميل
                       ========================================================= */

    :root {
        --calc-navy: #1e293b;
        --calc-gold: #B88E44;
        --calc-bg: #f8fafc;
        --calc-text-muted: #94a3b8;
        --calc-border: #f1f5f9;
    }

    body {
        background-color: #f1f5f9; /* خلفية خفيفة للصفحة كلها */
    }


    .smart-calc-master-container {
        font-family: 'Cairo', sans-serif;
        background-color: var(--calc-bg);
        border-radius: 30px;
        padding: 2.5rem;
        box-shadow: 0 10px 40px rgba(0,0,0,0.02);
        margin-bottom: 3rem;
        border: 1px solid white;
        max-width: 1400px;
        margin-left: auto;
        margin-right: auto;
    }

    /* --- هيدر الحاسبة --- */
    .calc-top-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
        flex-wrap: wrap;
        gap: 15px;
    }

    .calc-brand-area {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .calc-logo-box {
        width: 60px;
        height: 60px;
        background-color: var(--calc-navy);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--calc-gold);
        font-weight: 900;
        font-size: 0.75rem;
        text-align: center;
        line-height: 1.1;
        letter-spacing: 1px;
    }

    .calc-title-texts h1 {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--calc-navy);
        margin: 0 0 2px 0;
        letter-spacing: -0.5px;
    }

    .calc-title-texts p {
        color: var(--calc-gold);
        font-size: 0.8rem;
        font-weight: 800;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .calc-header-buttons {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-calc-outline {
        background: white;
        border: 1px solid #e2e8f0;
        color: var(--calc-navy);
        padding: 0.7rem 1.2rem;
        border-radius: 10px;
        font-weight: 800;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        text-decoration: none;
    }

        .btn-calc-outline:hover {
            border-color: var(--calc-gold);
            color: var(--calc-gold);
        }

        .btn-calc-outline i {
            color: var(--calc-gold);
        }

    /* --- التخطيط العام للحاسبة --- */
    .calc-main-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        align-items: start;
    }

    /* سطح المكتب: النتائج يمين، المدخلات يسار (RTL) */
    @@media(min-width: 1024px) {
        .calc-main-layout {
            grid-template-columns: 1fr 380px;
        }
        /* لضبط الترتيب: النتائج (يسار في الكود) تصبح يمين، والمدخلات (يمين في الكود) تصبح يسار */
        .calc-results-main {
            order: 1;
        }

        .calc-inputs-sidebar {
            order: 2;
        }
    }

    /* ==================== القسم الأيسر (المدخلات) ==================== */
    .calc-inputs-sidebar {
        background: white;
        border-radius: 2rem;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid var(--calc-border);
    }

    .inputs-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .inputs-title {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--calc-navy);
    }

    .icon-car-small {
        background: rgba(184, 147, 90, 0.1);
        color: var(--calc-gold);
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    .btn-refresh {
        background: transparent;
        border: none;
        color: #ef4444;
        cursor: pointer;
        font-size: 1.2rem;
        transition: 0.3s;
        padding: 5px;
    }

        .btn-refresh:hover {
            transform: rotate(180deg);
        }

    .calc-form-group {
        margin-bottom: 1.5rem;
    }

    .calc-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--calc-text-muted);
        margin-bottom: 8px;
        text-align: right;
    }

    .calc-input-wrapper {
        position: relative;
    }

        .calc-input-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--calc-gold);
            font-size: 1.2rem;
        }

    /* حقول الإدخال */
    .calc-input {
        width: 100%;
        background: var(--calc-bg);
        border: 2px solid var(--calc-border);
        border-radius: 1rem;
        padding: 1rem 1rem 1rem 2.5rem;
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--calc-navy);
        text-align: center;
        direction: ltr;
        font-family: monospace;
        transition: 0.3s;
        outline: none;
        box-sizing: border-box;
    }

        .calc-input:focus {
            border-color: var(--calc-gold);
            background: white;
        }

    .calc-input-sm {
        width: 100%;
        background: var(--calc-bg);
        border: 2px solid var(--calc-border);
        border-radius: 1rem;
        padding: 1rem 0.5rem;
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--calc-navy);
        text-align: center;
        transition: 0.3s;
        outline: none;
        box-sizing: border-box;
    }

        .calc-input-sm:focus {
            border-color: var(--calc-gold);
            background: white;
        }

    /* شبكة الحقول الصغيرة */
    .calc-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-bottom: 1.5rem;
    }

    .calc-grid-3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 10px;
        margin-bottom: 1.5rem;
    }

    /* أزرار الراديو (نوع السيارة) */
    .radio-grid-4 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
    }

    .radio-wrap {
        position: relative;
    }

        .radio-wrap input[type="radio"] {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

    .radio-box {
        background: white;
        border: 2px solid var(--calc-border);
        border-radius: 1rem;
        padding: 12px 5px;
        text-align: center;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        height: 100%;
        justify-content: center;
    }

    .radio-icon {
        width: 35px;
        height: 35px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        transition: 0.3s;
    }

    .radio-box span {
        font-size: 0.75rem;
        font-weight: 900;
        color: #64748b;
        transition: 0.3s;
    }

    /* ألوان أيقونات السيارات */
    .ic-elec {
        background: #fefce8;
        color: #eab308;
    }

    .ic-small {
        background: var(--calc-navy);
        color: white;
    }

    .ic-mid {
        background: #eef2ff;
        color: #6366f1;
    }

    .ic-big {
        background: #eff6ff;
        color: #3b82f6;
    }

    /* تأثير التحديد للسيارات */
    .radio-wrap input[type="radio"]:checked + .radio-box {
        background: var(--calc-navy);
        border-color: var(--calc-navy);
        box-shadow: 0 8px 20px rgba(30, 41, 59, 0.2);
        transform: translateY(-2px);
    }

        .radio-wrap input[type="radio"]:checked + .radio-box .radio-icon {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .radio-wrap input[type="radio"]:checked + .radio-box span {
            color: white;
        }

    /* أزرار الراديو (بلد المنشأ) */
    .radio-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .origin-box {
        background: white;
        border: 2px solid var(--calc-border);
        border-radius: 1rem;
        padding: 15px;
        text-align: center;
        cursor: pointer;
        transition: 0.3s;
    }

        .origin-box span {
            display: block;
            font-size: 0.85rem;
            font-weight: 900;
            color: #64748b;
        }

        .origin-box small {
            display: block;
            font-size: 0.65rem;
            font-weight: 800;
            color: var(--calc-text-muted);
            margin-top: 4px;
        }

    .radio-wrap input[type="radio"]:checked + .origin-box {
        background: var(--calc-bg);
        border-color: var(--calc-navy);
    }

        .radio-wrap input[type="radio"]:checked + .origin-box span {
            color: var(--calc-navy);
        }

    /* إعدادات متقدمة */
    .adv-settings-btn {
        width: 100%;
        background: white;
        border: 1px solid var(--calc-border);
        padding: 15px;
        border-radius: 1rem;
        text-align: right;
        font-weight: 800;
        color: var(--calc-navy);
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1rem;
        cursor: pointer;
        font-size: 0.85rem;
    }

    .adv-settings-panel {
        display: none;
        background: var(--calc-bg);
        padding: 15px;
        border-radius: 1rem;
        margin-top: 10px;
        border: 1px solid var(--calc-border);
    }

    /* =========================================================
                       إصلاحات Select2 ودعم التمرير
                       ========================================================= */
    .select2-container {
        width: 314px !important;
        display: block;
        background: #FFF !important;
    }

    .select2-selection__placeholder span {
        font-size: small;
    }

    .select2-container ul {
        list-style: none !important;
    }

    .select2-container--default .select2-selection--single {
        background-color: var(--calc-bg) !important;
        border: 2px solid var(--calc-border) !important;
        border-radius: 1rem !important;
        height: 60px !important;
        display: flex !important;
        align-items: center;
        padding: 0 10px;
        transition: 0.3s;
        outline: none;
    }

    .select2-container--default.select2-container--open .select2-selection--single {
        border-color: var(--calc-gold) !important;
        background: white !important;
        box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1) !important;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        width: 100%;
        padding-inline-end: 10px;
        font-size: small;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 58px !important;
        right: 15px !important;
    }

    html[dir="rtl"] .select2-container--default .select2-selection--single .select2-selection__arrow {
        left: 15px !important;
        right: auto !important;
    }

    /* القائمة المنسدلة - إصلاح التمرير */
    .select2-dropdown {
        border: 1px solid #e2e8f0 !important;
        border-radius: 1rem !important;
        overflow: hidden;
    }

    .select2-results__options {
        max-height: 300px !important; /* تحديد ارتفاع لتفعيل الاسكرول */
        overflow-y: auto !important; /* تفعيل التمرير العمودي */
    }

    .select2-search--dropdown {
        background-color: #ffffff !important;
        padding: 15px !important;
        border-bottom: 1px solid #f1f5f9;
    }

        .select2-search--dropdown .select2-search__field {
            border: 2px solid #e2e8f0 !important;
            border-radius: 0.75rem !important;
            padding: 10px 15px !important;
            outline: none !important;
            font-family: inherit;
            font-weight: 700;
            color: var(--calc-navy);
            width: 100%;
            box-sizing: border-box;
        }

            .select2-search--dropdown .select2-search__field:focus {
                border-color: var(--calc-gold) !important;
            }

    .select2-results__option {
        background-color: #ffffff;
        border-bottom: 1px solid #f1f5f9;
        padding: 10px 15px;
        transition: 0.2s;
    }

        .select2-results__option:hover,
        .select2-results__option--highlighted[aria-selected] {
            background-color: #f8fafc !important;
        }

    /* ==================== القسم الأيمن (النتائج) ==================== */
    .calc-results-main {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* 1. الشريط الكحلي (Navy Banner) */
    .navy-banner {
        background: var(--calc-navy);
        border-radius: 2rem;
        padding: 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
        flex-wrap: wrap;
        gap: 20px;
        box-shadow: 0 15px 35px rgba(30, 41, 59, 0.2);
    }

        .navy-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 60%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 70%);
            pointer-events: none;
        }

    .banner-right {
        display: flex;
        gap: 15px;
        z-index: 2;
        flex-wrap: wrap;
    }

    .banner-box {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 1.5rem;
        padding: 1.5rem;
        text-align: center;
        min-width: 150px;
        backdrop-filter: blur(10px);
        flex: 1;
    }

        .banner-box .lbl {
            display: block;
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--calc-gold);
            margin-bottom: 10px;
        }

        .banner-box .val-wrap {
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 5px;
        }

        .banner-box .val {
            font-size: 1.6rem;
            font-weight: 900;
            color: white;
            font-family: monospace;
        }

        .banner-box .curr {
            font-size: 0.8rem;
            color: var(--calc-gold);
            font-weight: bold;
        }

    .banner-left {
        text-align: left;
        z-index: 2;
        width: 100%;
    }

        .banner-left .lbl {
            display: block;
            font-size: 0.85rem;
            font-weight: 800;
            color: #94a3b8;
            margin-bottom: 5px;
            text-align: right;
        }

        .banner-left .val-wrap {
            display: flex;
            align-items: baseline;
            gap: 8px;
            justify-content: flex-end;
        }

        .banner-left .val {
            font-size: 3.5rem;
            font-weight: 900;
            color: white;
            font-family: monospace;
            letter-spacing: -1px;
            line-height: 1;
        }

        .banner-left .curr {
            font-size: 1.2rem;
            color: var(--calc-gold);
            font-weight: 900;
        }

    /* 2. كروت التفاصيل */
    .res-cards-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    .res-card {
        background: white;
        border-radius: 2rem;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        border: 1px solid var(--calc-border);
        display: flex;
        flex-direction: column;
    }

    .res-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        border-bottom: 2px dashed var(--calc-border);
        padding-bottom: 1rem;
    }

        .res-card-header h4 {
            font-size: 1.1rem;
            font-weight: 900;
            color: var(--calc-navy);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .res-card-header h4 i {
                color: #94a3b8;
                font-size: 1rem;
            }

    .res-card-badge {
        font-size: 0.6rem;
        font-weight: 900;
        color: #94a3b8;
        background: var(--calc-bg);
        padding: 5px 10px;
        border-radius: 8px;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .res-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-bottom: 2rem;
    }

    .res-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.95rem;
        font-weight: 800;
        color: var(--calc-gold);
    }

        .res-item .val-wrap {
            display: flex;
            align-items: baseline;
            gap: 4px;
        }

        .res-item .val {
            font-size: 1.1rem;
            font-weight: 900;
            color: var(--calc-navy);
            font-family: monospace;
        }

        .res-item .curr {
            font-size: 0.8rem;
            color: #94a3b8;
            font-family: 'Cairo', sans-serif;
        }

    .res-card-footer {
        margin-top: auto;
        border-top: 2px dashed var(--calc-border);
        padding-top: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

        .res-card-footer .lbl-box {
            display: flex;
            flex-direction: column;
            text-align: right;
        }

        .res-card-footer .lbl {
            font-size: 0.85rem;
            font-weight: 800;
            color: #94a3b8;
            line-height: 1.4;
        }

        .res-card-footer .sub-lbl {
            font-size: 0.75rem;
            color: #3b82f6;
            font-weight: 800;
            font-family: monospace;
            margin-top: 3px;
        }

        .res-card-footer .val-wrap {
            display: flex;
            align-items: baseline;
            gap: 6px;
        }

        .res-card-footer .val {
            font-size: 2rem;
            font-weight: 900;
            color: var(--calc-gold);
            font-family: monospace;
            line-height: 1;
        }

        .res-card-footer .curr {
            font-size: 1rem;
            color: var(--calc-gold);
            font-weight: bold;
        }

    /* 3. الملاحظات */
    .notes-card {
        background: white;
        border-radius: 1.5rem;
        padding: 1.5rem 2rem;
        border: 1px solid var(--calc-border);
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .notes-header {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #3b82f6;
        font-weight: 900;
        font-size: 0.95rem;
        margin-bottom: 5px;
    }

    .notes-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

        .notes-list li {
            font-size: 0.8rem;
            font-weight: 700;
            color: #64748b;
            position: relative;
            padding-right: 15px;
        }

            .notes-list li::before {
                content: '•';
                position: absolute;
                right: 0;
                color: #3b82f6;
                font-weight: bold;
            }

    /* ==================== تجاوب الشاشات (Media Queries) ==================== */

    @@media (max-width: 1024px) {
        .calc-main-layout {
            grid-template-columns: 1fr;
        }

        .calc-results-main {
            order: 2; /* النتائج أسفل المدخلات في الجوال */
        }

        .calc-inputs-sidebar {
            order: 1;
        }
    }

    @@media (max-width: 768px) {
        .smart-calc-master-container {
            padding: 1rem;
            border-radius: 1rem;
        }

        .calc-top-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .calc-title-texts h1 {
            font-size: 1.4rem;
        }

        .res-cards-grid {
            grid-template-columns: 1fr;
        }

        .navy-banner {
            padding: 1.5rem;
        }

        .banner-left .val {
            font-size: 2.5rem;
        }

        .notes-list {
            grid-template-columns: 1fr;
        }

        .calc-grid-3 {
            grid-template-columns: 1fr;
        }
    }

    @@media print {
        .calc-header-buttons, .adv-settings-btn, .btn-refresh {
            display: none !important;
        }

        body {
            background: white !important;
        }

        .smart-calc-master-container {
            border: none !important;
            box-shadow: none !important;
        }
    }
</style>

<div class="accounting-dashboard-page">
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div style="background: #fef2f2; color: #ef4444; padding: 1rem; border-radius: 1rem; margin-bottom: 1rem; font-weight: bold; border: 1px solid #fecaca;">
            <i class="fa-solid fa-triangle-exclamation"></i> @errorMessage
        </div>
    }

    <div class="smart-calc-master-container" id="calculatorArea">

        <!-- هيدر الحاسبة -->
        <div class="calc-top-header">

            <div class="calc-brand-area">
                <div class="calc-title-texts">
                    <h1>@Localizer["الحاسبة الذكية"]</h1>
                    <p>Al Argan Auto Shipping</p>
                </div>
                <div class="calc-logo-box">AL ARGAN</div>
            </div>

            <!-- أزرار الهيدر -->
           
        </div>

        <!-- التخطيط الجانبي -->
        <div class="calc-main-layout">

            <!-- كارت النتائج -->
            <div class="calc-results-main">

                <!-- الشريط الكحلي العلوي -->
                <div class="navy-banner">
                    <div class="banner-right">
                        <div class="banner-box">
