@{
    ViewData["Title"] = "حاسبة تكاليف الشحن";
}

<style>
    /* Premium Calculator Pure CSS */
    .calc-layout {
        display: flex;
        gap: 2rem;
        padding: 2rem 0;
    }

    .calc-summary-sidebar {
        width: 380px;
        background: #111827;
        border-radius: 2.5rem;
        padding: 2.5rem;
        color: white;
        display: flex;
        flex-direction: column;
    }

    .summary-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
    }

        .summary-header h2 {
            font-size: 1.75rem;
            font-weight: 900;
        }

    .summary-icon {
        background: #3b82f6;
        width: 45px;
        height: 45px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .cost-item {
        display: flex;
        justify-content: space-between;
        padding: 1.25rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .cost-label {
        color: #94a3b8;
        font-weight: 700;
        font-size: 0.85rem;
    }

    .cost-value {
        font-weight: 800;
        font-size: 1.1rem;
    }

    .total-cost-section {
        margin-top: auto;
        padding-top: 2rem;
    }

    .total-display {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2rem;
    }

    .total-amount {
        font-size: 3rem;
        font-weight: 900;
        color: white;
    }

    .total-label {
        color: #3b82f6;
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .btn-quote {
        width: 100%;
        background: #3b82f6;
        color: white;
        padding: 1.25rem;
        border-radius: 1.25rem;
        font-weight: 800;
        border: none;
        cursor: pointer;
    }

    .calc-inputs-main {
        flex: 1;
        background: white;
        border-radius: 2.5rem;
        padding: 3rem;
        box-shadow: 0 10px 40px rgba(0,0,0,0.02);
    }

    .input-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .field-box label {
        display: block;
        color: #94a3b8;
        font-weight: 800;
        font-size: 0.75rem;
        margin-bottom: 0.75rem;
        text-align: center;
    }

    .input-control {
        width: 100%;
        padding: 1.25rem;
        border-radius: 1.25rem;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        font-weight: 800;
        text-align: center;
        outline: none;
        font-family: inherit;
    }

    .btn-toggle-group {
        display: flex;
        background: #f1f5f9;
        padding: 0.4rem;
        border-radius: 1.25rem;
    }

    .toggle-opt {
        flex: 1;
        padding: 0.85rem;
        border-radius: 1rem;
        border: none;
        font-weight: 800;
        cursor: pointer;
    }

        .toggle-opt.active {
            background: #3b82f6;
            color: white;
        }

    .notice-box {
        background: #eff6ff;
        padding: 1.5rem;
        border-radius: 1.5rem;
        margin-top: 3rem;
        display: flex;
        gap: 1rem;
        align-items: center;
        color: #1e40af;
        font-weight: 700;
        font-size: 0.9rem;
    }
</style>

<div class="calc-layout" dir="rtl">
    <div class="calc-summary-sidebar">
        <div class="summary-header">
            <div class="summary-icon">📱</div>
            <h2>ملخص التكاليف</h2>
        </div>
        <div class="cost-item"><span class="cost-value">$5,000</span><span class="cost-label">سعر السيارة</span></div>
        <div class="cost-item"><span class="cost-value">$700</span><span class="cost-label">رسوم المزاد</span></div>
        <div class="cost-item"><span class="cost-value">$150</span><span class="cost-label">النقل الداخلي</span></div>
        <div class="cost-item"><span class="cost-value">$850</span><span class="cost-label">الشحن البحري</span></div>
        <div class="total-cost-section">
            <div class="total-display"><div class="total-amount">$6,700</div><div class="total-label">الإجمالي التقديري</div></div>
            <button class="btn-quote">طلب عرض سعر رسمي</button>
        </div>
    </div>

    <div class="calc-inputs-main">
        <div style="text-align: left; margin-bottom: 2rem;">
            <h2 style="font-weight: 900; color: #1a2634;">حاسبة تكاليف الشحن</h2>
            <p style="color: #3b82f6; font-weight: 700; font-size: 0.85rem;">نظام الإدارة اللوجستية التقني</p>
        </div>
        <div class="input-row">
            <div class="field-box"><label>موقع المزاد</label><div class="btn-toggle-group"><button class="toggle-opt">IAAI</button><button class="toggle-opt active">Copart</button></div></div>
            <div class="field-box"><label>سعر السيارة المتوقع ($)</label><input type="text" class="input-control" value="5000" /></div>
        </div>
        <div class="input-row">
            <div class="field-box"><label>موقع السيارة في أمريكا</label><select class="input-control"><option>New Jersey</option></select></div>
            <div class="field-box"><label>نوع المركبة</label><select class="input-control"><option>Sedan</option></select></div>
        </div>
        <div class="notice-box"><div><p style="font-weight: 900;">ملاحظات هامة</p><p style="font-size: 0.8rem;">هذه الأسعار تقديرية وقد تختلف بناءً على حالة السيارة.</p></div></div>
    </div>
</div>