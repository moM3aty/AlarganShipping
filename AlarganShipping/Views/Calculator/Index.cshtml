@{
    ViewData["Title"] = Localizer["حاسبة تكاليف الشحن"];
}

<style>
    .calc-page-wrapper {
        max-width: 1400px;
        margin: 0 auto;
    }

    .calc-header {
        text-align: center;
        margin-bottom: 2rem;
    }

        .calc-header h2 {
            font-size: 2rem;
            font-weight: 900;
            color: var(--primary-navy);
            margin-bottom: 0.5rem;
        }

        .calc-header p {
            color: var(--text-muted);
            font-size: 1rem;
            font-weight: 600;
        }

    .calc-layout {
        display: flex;
        flex-direction: column-reverse;
        gap: 2rem;
    }

    @@media (min-width: 1024px) {
        .calc-layout {
            flex-direction: row;
            align-items: flex-start;
        }
    }

    /* Summary Card (Navy Blue Background) */
    .summary-card {
        background: linear-gradient(135deg, var(--secondary-navy) 0%, var(--primary-navy) 100%);
        color: white;
        border-radius: 1.5rem;
        padding: 2rem;
        flex: 1;
        min-width: 320px;
        box-shadow: 0 15px 40px rgba(26, 37, 47, 0.2);
        position: sticky;
        top: 20px;
    }

    .summary-title {
        font-size: 1.3rem;
        font-weight: 900;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding-bottom: 1rem;
        margin-bottom: 1.5rem;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1.2rem;
        font-size: 0.95rem;
        font-weight: 600;
        color: #cbd5e1;
    }

        .summary-row span.val {
            font-weight: 900;
            color: white;
            font-family: monospace;
        }

    .summary-total {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .summary-total span.label {
            font-size: 1.1rem;
            font-weight: 800;
            color: #cbd5e1;
        }

        .summary-total span.total-val {
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--primary-gold);
        }

        .summary-total span.currency {
            font-size: 1rem;
            color: #94a3b8;
            margin-inline-start: 5px;
        }

    .btn-share {
        width: 100%;
        background: linear-gradient(to right, var(--primary-gold), var(--secondary-gold));
        color: white;
        border: none;
        padding: 1rem;
        border-radius: 1rem;
        font-weight: 900;
        font-size: 1.1rem;
        margin-top: 2rem;
        cursor: pointer;
        transition: 0.3s;
        font-family: inherit;
        box-shadow: 0 5px 15px rgba(184, 147, 90, 0.3);
    }

        .btn-share:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(184, 147, 90, 0.4);
        }

    /* Form Card (White) */
    .form-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        flex: 2;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    }

    .tabs-wrapper {
        display: flex;
        background: #f1f5f9;
        border-radius: 1rem;
        padding: 0.4rem;
        margin-bottom: 2rem;
    }

    .tab-btn {
        flex: 1;
        text-align: center;
        padding: 0.8rem;
        font-weight: 800;
        color: var(--text-muted);
        cursor: pointer;
        border-radius: 0.8rem;
        transition: 0.3s;
    }

        .tab-btn.active {
            background: var(--primary-navy);
            color: white;
            box-shadow: 0 4px 10px rgba(44, 62, 80, 0.2);
        }

    .calc-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media (min-width: 768px) {
        .calc-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

        .input-group.full {
            grid-column: 1 / -1;
        }

    .input-label {
        font-size: 0.85rem;
        font-weight: 800;
        color: var(--primary-navy);
        text-align: end;
    }

    .calc-input {
        padding: 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.8rem;
        font-family: inherit;
        font-size: 1rem;
        font-weight: 700;
        color: var(--primary-navy);
        outline: none;
        transition: 0.3s;
        background: #f8fafc;
        text-align: end;
    }

        .calc-input:focus {
            border-color: var(--primary-gold);
            background: white;
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

    .location-box {
        border: 2px solid #e2e8f0;
        border-radius: 0.8rem;
        max-height: 200px;
        overflow-y: auto;
        padding: 0.5rem;
    }

    .loc-item {
        display: flex;
        justify-content: space-between;
        padding: 1rem;
        border-bottom: 1px solid #f1f5f9;
        cursor: pointer;
        transition: 0.2s;
        border-radius: 0.5rem;
    }

        .loc-item:hover {
            background: #f8fafc;
        }

        .loc-item.selected {
            background: rgba(184, 147, 90, 0.05);
            border-color: var(--primary-gold);
        }

    .loc-name {
        font-weight: 800;
        color: var(--primary-navy);
    }

    .loc-price {
        font-weight: 900;
        color: var(--text-muted);
        font-family: monospace;
    }

    .info-alert {
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
        padding: 1rem 1.5rem;
        border-radius: 1rem;
        font-size: 0.85rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 2rem;
        border: 1px solid rgba(184, 147, 90, 0.2);
    }
</style>

<div class="calc-page-wrapper">
    <div class="calc-header">
        <h2>@Localizer["حاسبة تكاليف الشحن"]</h2>
        <p>@Localizer["احسب التكاليف بناءً على قوائم الأسعار الرسمية لشركة الأرجان"]</p>
    </div>

    <div class="calc-layout">
        <!-- 1. نموذج الإدخال -->
        <div class="form-card">
            <div class="tabs-wrapper">
                <div class="tab-btn">@Localizer["شحن فقط (Import)"]</div>
                <div class="tab-btn active">@Localizer["سيارة (Export)"]</div>
            </div>

            <div class="calc-grid">
                <div class="input-group">
                    <label class="input-label">@Localizer["سعر السيارة المتوقع (USD)"]</label>
                    <input type="number" class="calc-input" id="carPrice" value="5000" />
                </div>
                <div class="input-group">
                    <label class="input-label">@Localizer["أدخل رقم الشاصي..."]</label>
                    <input type="text" class="calc-input" placeholder="@Localizer["رقم الشاصي (اختياري)"]" />
                </div>

                <div class="input-group full">
                    <label class="input-label">@Localizer["حدد موقع السيارة في أمريكا"]</label>
                    <input type="text" class="calc-input" placeholder="@Localizer["ابحث بالولاية، المدينة، أو اسم المزاد..."]" style="margin-bottom: 0.5rem; text-align: start;" />
                    <div class="location-box">
                        <label class="loc-item selected">
                            <div><input type="radio" name="loc" checked style="margin-inline-end: 10px;"> <span class="loc-name">Birmingham, Alabama</span><br><small style="color: #94a3b8; margin-inline-start: 25px;">Copart - 300 Miles</small></div>
                            <div class="loc-price">$350</div>
                        </label>
                        <label class="loc-item">
                            <div><input type="radio" name="loc" style="margin-inline-end: 10px;"> <span class="loc-name">Houston, Texas</span><br><small style="color: #94a3b8; margin-inline-start: 25px;">IAAI - 50 Miles</small></div>
                            <div class="loc-price">$150</div>
                        </label>
                        <label class="loc-item">
                            <div><input type="radio" name="loc" style="margin-inline-end: 10px;"> <span class="loc-name">Los Angeles, CA</span></div>
                            <div class="loc-price">$400</div>
                        </label>
                    </div>
                </div>

                <div class="input-group">
                    <label class="input-label">@Localizer["نوع السيارة"]</label>
                    <select class="calc-input" style="text-align: start;">
                        <option>@Localizer["صالون (Sedan)"]</option>
                        <option>@Localizer["دفع رباعي (SUV)"]</option>
                    </select>
                </div>
                <div class="input-group">
                    <label class="input-label">@Localizer["ولاية الوصول (المستودع)"]</label>
                    <select class="calc-input" style="text-align: start;">
                        <option>Georgia</option>
                        <option>New Jersey</option>
                        <option>Texas</option>
                    </select>
                </div>

                <div class="input-group full" style="margin-top: 1rem; border-top: 1px solid #f1f5f9; padding-top: 1rem;">
                    <label class="input-label" style="text-align: start;">@Localizer["إضافة تكاليف مخصصة"]</label>
                    <div class="calc-grid" style="grid-template-columns: repeat(3, 1fr);">
                        <input type="number" class="calc-input" id="customCommission" placeholder="@Localizer["العمولة"]" />
                        <input type="number" class="calc-input" id="customCustoms" placeholder="@Localizer["الجمارك (%)"]" />
                        <input type="number" class="calc-input" id="customVat" placeholder="@Localizer["الضريبة (%)"]" />
                    </div>
                </div>
            </div>

            <div class="info-alert">
                <i class="fa-solid fa-circle-info" style="font-size: 1.5rem;"></i>
                @Localizer["ملاحظات هامة: الأسعار المعروضة تشمل النقل الداخلي في أمريكا والشحن البحري إلى ميناء صلالة/صحار. رسوم الجمارك والضرائب تقريبية."]
            </div>
        </div>

        <!-- 2. ملخص التكاليف -->
        <div class="summary-card">
            <div class="summary-title">
                <span>@Localizer["ملخص التكاليف"]</span>
                <i class="fa-solid fa-calculator" style="color: var(--primary-gold);"></i>
            </div>

            <div class="summary-row">
                <span>@Localizer["سعر السيارة"]</span>
                <span class="val">$<span id="sumCar">5,000</span></span>
            </div>
            <div class="summary-row">
                <span>@Localizer["رسوم المزاد (متوقعة)"]</span>
                <span class="val">$<span id="sumAuction">650</span></span>
            </div>
            <div class="summary-row">
                <span>@Localizer["النقل الداخلي + الشحن"]</span>
                <span class="val">$<span id="sumShipping">1,350</span></span>
            </div>
            <div class="summary-row">
                <span>@Localizer["الجمارك والضرائب (10%)"]</span>
                <span class="val">$<span id="sumTax">565</span></span>
            </div>
            <div class="summary-row" style="color: var(--primary-gold);">
                <span>@Localizer["عمولة الشركة"]</span>
                <span class="val">$<span id="sumComm">150</span></span>
            </div>

            <div class="summary-total">
                <span class="label">@Localizer["الإجمالي المتوقع"]</span>
                <div>
                    <span class="total-val" id="finalTotal">2,970.00</span>
                    <span class="currency">ر.ع</span>
                    <div style="font-size: 0.75rem; color: #94a3b8; text-align: end; margin-top: 5px;">~ $<span id="finalTotalUsd">7,715.00</span> USD</div>
                </div>
            </div>

            <button class="btn-share"><i class="fa-brands fa-whatsapp"></i> @Localizer["حفظ ومشاركة التسعيرة"]</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#carPrice').on('input', function() {
                var price = parseFloat($(this).val()) || 0;
                $('#sumCar').text(price.toLocaleString());

                // حساب تقريبي للجمارك (10% من قيمة السيارة والشحن)
                var tax = (price + 1350) * 0.10;
                $('#sumTax').text(tax.toLocaleString());

                var totalUsd = price + 650 + 1350 + tax + 150;
                var totalOmr = totalUsd * 0.385; // التحويل للريال العماني

                $('#finalTotal').text(totalOmr.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));
                $('#finalTotalUsd').text(totalUsd.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));
            });
        });
    </script>
}