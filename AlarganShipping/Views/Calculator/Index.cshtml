@{
    ViewData["Title"] = Localizer["حاسبة التكاليف الشاملة"];
}

<style>
    .calc-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        max-width: 1300px;
        margin: 0 auto;
    }
    @@media(min-width: 1024px) { .calc-container { grid-template-columns: 400px 1fr; } }

    /* --- قسم الإدخال --- */
    .input-card {
        background: white; border-radius: 1.5rem; padding: 2rem; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid #f1f5f9; align-self: start;
    }
    .input-card h3 { font-size: 1.3rem; font-weight: 900; color: var(--primary-navy); margin-bottom: 1.5rem; border-bottom: 2px solid #f1f5f9; padding-bottom: 10px; }
    
    .form-group { margin-bottom: 1.2rem; }
    .form-label { display: block; font-weight: 800; color: var(--text-dark); margin-bottom: 0.5rem; font-size: 0.85rem; }
    .form-control {
        width: 100%; padding: 0.7rem 1rem; border: 2px solid #e2e8f0; border-radius: 0.75rem;
        font-size: 1.1rem; font-family: monospace; font-weight: bold; background: #f8fafc; transition: 0.3s;
        text-align: left; direction: ltr; color: var(--primary-navy);
    }
    .form-control:focus { border-color: #2563eb; background: white; outline: none; }

    .radio-group { display: flex; gap: 8px; background: #f8fafc; padding: 5px; border-radius: 0.75rem; border: 1px solid #e2e8f0; }
    .radio-btn { flex: 1; text-align: center; }
    .radio-btn input { display: none; }
    .radio-btn label {
        display: block; padding: 8px 5px; cursor: pointer; font-weight: 800; font-size: 0.85rem;
        border-radius: 0.5rem; transition: 0.3s; color: var(--text-muted);
    }
    .radio-btn input:checked + label { background: var(--primary-navy); color: white; box-shadow: 0 2px 8px rgba(0,0,0,0.2); }

    /* قسم المتغيرات الديناميكية */
    .dynamic-vars-section {
        margin-top: 2rem; padding-top: 1.5rem; border-top: 2px dashed #e2e8f0;
    }
    .dynamic-vars-section h4 {
        font-size: 1rem; font-weight: 900; color: var(--primary-gold); margin-bottom: 1rem;
    }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

    /* --- قسم النتائج (مطابق للإكسل) --- */
    .results-area { 
        display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: flex-start;
    }
    .tables-wrapper {
        flex: 1; min-width: 350px; border: 3px solid #000080; background: white;
    }
    
    .summary-wrapper {
        flex: 1; min-width: 300px; display: flex; flex-direction: column; justify-content: flex-start; gap: 1.5rem; padding: 1.5rem 0;
    }

    .excel-table { width: 100%; border-collapse: collapse; font-family: 'Segoe UI', Tahoma, sans-serif; font-weight: bold; }
    .excel-table td { padding: 5px 10px; border: 1px solid #000080; font-size: 0.95rem; }
    .excel-table td:first-child { text-transform: uppercase; width: 60%; }
    .excel-table td:nth-child(2) { text-align: center; width: 10%; border-right: none; color: var(--primary-navy); }
    .excel-table td:nth-child(3) { text-align: right; width: 30%; border-left: none; font-family: monospace; font-size: 0.95rem; }

    /* ألوان الإكسل المحددة */
    .bg-auction-header { background-color: #dbeafe; color: black; font-size: 1.4rem; text-align: center; border-bottom: 2px solid #000080; }
    .bg-yellow { background-color: #fef08a; color: #1e3a8a; }
    .bg-green { background-color: #4ade80; color: white; }
    .bg-blue { background-color: #93c5fd; color: #1e3a8a; font-size: 1rem; }
    .bg-shipping-header { background-color: #e2e8f0; text-align: center; font-size: 1.4rem; border-top: 3px solid #000080; border-bottom: 2px solid #000080; }
    .bg-gray-dark { background-color: #94a3b8; color: white; }
    .bg-gray-light { background-color: #cbd5e1; }
    
    .text-blue { color: #1d4ed8 !important; }
    .text-red { color: #ef4444 !important; }

    /* الإجمالي النهائي الأحمر */
    .row-final { border-top: 3px solid #000080; }
    .row-final td { padding: 12px 10px; }
    .row-final td:first-child { font-size: 1.3rem; color: red; text-transform: lowercase; font-weight: 900; }
    .row-final td:last-child { font-size: 1.6rem; color: red;  font-family: monospace; font-weight: 900; }

    /* الملخص الجانبي */
    .summary-box { 
        text-align: right; font-family: 'Cairo', sans-serif; font-weight: bold; background: white;
        padding: 1.5rem; border-radius: 1rem; border: 1px solid #e2e8f0; box-shadow: 0 5px 15px rgba(0,0,0,0.02);
    }
    .summary-box .lbl { font-size: 1.1rem; color: #334155; font-weight: 800; display: block; margin-bottom: 5px; }
    .summary-box .val { font-size: 1.6rem; color: var(--primary-navy); font-weight: 900; font-family: monospace; }
</style>

<div class="page-header-container" style="background: white; padding: 1.5rem; border-radius: 1.5rem; box-shadow: 0 5px 20px rgba(0,0,0,0.03); margin-bottom: 2rem;">
    <h2><i class="fa-solid fa-calculator" style="color: var(--primary-gold);"></i> حاسبة التكاليف الشاملة </h2>
</div>

<div class="calc-container">
    
    <!-- لوحة الإدخال والمتغيرات -->
    <div class="input-card">
        <h3>البيانات الأساسية (Inputs)</h3>
        
        <div class="form-group">
            <label class="form-label">SALE PRICE ($)</label>
            <input type="number" id="inpSalePrice" class="form-control" value="1500" style="border-color: var(--primary-gold);" />
        </div>

        <div class="form-group">
            <label class="form-label">SUV / Car Type</label>
            <div class="radio-group">
                <div class="radio-btn">
                    <input type="radio" name="carType" id="typeSmall" value="3">
                    <label for="typeSmall">Small</label>
                </div>
                <div class="radio-btn">
                    <input type="radio" name="carType" id="typeMid" value="2">
                    <label for="typeMid">Mid</label>
                </div>
                <div class="radio-btn">
                    <input type="radio" name="carType" id="typeBig" value="1" checked>
                    <label for="typeBig">Big</label>
                </div>
            </div>
        </div>

        <!-- المتغيرات القابلة للتعديل -->
        <div class="dynamic-vars-section">
            <h4><i class="fa-solid fa-sliders"></i> المتغيرات (Dynamic Variables)</h4>
            
            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">سعر الصرف (OMR/USD)</label>
                    <input type="number" id="inpExchangeRate" class="form-control" value="0.386" step="0.001" />
                </div>
                <div class="form-group">
                    <label class="form-label">الشحن البحري (+ OMR)</label>
                    <input type="number" id="inpOceanFreight" class="form-control" value="300" />
                </div>
            </div>

            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">نسبة الضريبة (Tax %)</label>
                    <input type="number" id="inpTaxPerc" class="form-control" value="5" step="0.1" />
                </div>
                <div class="form-group">
                    <label class="form-label">خدمة الدفع (Payment Svc)</label>
                    <input type="number" id="inpPaymentSvc" class="form-control" value="15.48" step="0.01" />
                </div>
            </div>

            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">عمولة المكتب (Office Comm)</label>
                    <input type="number" id="inpOfficeComm" class="form-control" value="50" />
                </div>
                <div class="form-group">
                    <label class="form-label">رسوم سيارة كبيرة (Big Car)</label>
                    <input type="number" id="inpFeeBig" class="form-control" value="120" />
                </div>
            </div>
            
            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">رسوم سيارة وسط (Mid Car)</label>
                    <input type="number" id="inpFeeMid" class="form-control" value="60" />
                </div>
            </div>

        </div>
    </div>

    <!-- لوحة النتائج -->
    <div class="results-area">
        
        <!-- جداول الإكسل -->
        <div class="tables-wrapper" dir="ltr">
            <table class="excel-table">
                <tr><td colspan="3" class="bg-auction-header">Auction</td></tr>
                <tr>
                    <td class="text-blue">SALE PRICE</td><td>$</td>
                    <td class="text-blue" id="tdSalePrice">0.00</td>
                </tr>
                <tr class="bg-yellow">
                    <td class="text-blue">BUYER FEE</td><td>$</td>
                    <td class="text-blue" id="tdBuyerFee">0.00</td>
                </tr>
                <tr class="bg-yellow">
                    <td class="text-blue">ENVIRONMENTAL FEE</td><td>$</td>
                    <td class="text-blue" id="tdEnvFee">0.00</td>
                </tr>
                <tr class="bg-yellow">
                    <td class="text-blue">VIRTUAL BID FEE</td><td>$</td>
                    <td class="text-blue" id="tdVirtualFee">0.00</td>
                </tr>
                <tr class="bg-yellow">
                    <td class="text-blue">GATE</td><td>$</td>
                    <td class="text-blue" id="tdGateFee">0.00</td>
                </tr>
                <tr class="bg-yellow">
                    <td class="text-blue">TITLE PICKUP FEE</td><td>$</td>
                    <td class="text-blue" id="tdTitleFee">0.00</td>
                </tr>
                <tr class="bg-green">
                    <td style="color: white;">Total IN Auction</td><td style="color: white;">$</td>
                    <td style="color: white;" id="tdTotalAuctionUSD">0.00</td>
                </tr>
                <tr class="bg-blue">
                    <td class="text-blue">TOTAL</td><td></td>
                    <td class="text-blue" id="tdTotalOMR">0.00 .ر.ع</td>
                </tr>
                <tr>
                    <td>SEA SHIPPING</td><td>$</td>
                    <td id="tdSeaShipping">0.00</td>
                </tr>
                
                <tr><td colspan="3" class="bg-shipping-header">Shipping</td></tr>
                
                <tr class="bg-gray-dark">
                    <td>TAX CARD</td><td></td>
                    <td id="tdTaxCard">0.00 .ر.ع</td>
                </tr>
                <tr class="bg-gray-light">
                    <td>Payment Service</td><td></td>
                    <td id="tdPaymentService">0.00 .ر.ع</td>
                </tr>
                <tr>
                    <td class="text-red">TAX</td><td></td>
                    <td id="tdTax">0.00 .ر.ع</td>
                </tr>
                <tr class="bg-gray-light">
                    <td class="text-red">customs</td><td></td>
                    <td id="tdCustoms">0.00 .ر.ع</td>
                </tr>
                <tr class="bg-gray-light">
                    <td>customs VAT</td><td></td>
                    <td id="tdCustomsVat">0.00 .ر.ع</td>
                </tr>
                <tr class="bg-gray-light">
                    <td class="text-red">Shipping COST</td><td></td>
                    <td id="tdShippingCost">0.00 .ر.ع</td>
                </tr>
                <tr class="bg-gray-light">
                    <td>office commission</td><td></td>
                    <td id="tdOfficeComm">0.00 .ر.ع</td>
                </tr>
                <tr class="bg-gray-dark">
                    <td>SUV / big car</td><td></td>
                    <td id="tdCarTypeFee">0.00 .ر.ع</td>
                </tr>
                <tr class="bg-gray-dark">
                    <td>TOTAL Shipping</td><td></td>
                    <td  id="tdTotalShipping">0.00 .ر.ع</td>
                </tr>
                
                <tr class="row-final">
                    <td>final total</td>
                    <td colspan="2" id="tdFinalTotal">0.00 .ر.ع</td>
                </tr>
            </table>
        </div>

        <!-- ملخص الدفع (اليمين) -->
        <div class="summary-wrapper" dir="rtl">
            <div class="summary-box" style="border-left: 5px solid var(--primary-gold);">
                <span class="lbl">الإجمـــــالي المستحق (ر.ع)</span>
                <span class="val" id="tdDueNow">0.00</span>
            </div>
            <div class="summary-box" style="border-left: 5px solid #16a34a;">
                <span class="lbl">عنـــــــــــــد الوصـــــــــــول (ر.ع)</span>
                <span class="val" id="tdDueArrival">0.00</span>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        $(document).ready(function () {
            
            // دالة التقريب لضمان التطابق مع الإكسل
            function round(num) {
                return Math.round((num + Number.EPSILON) * 100) / 100;
            }

            // دالة Buyer Fee مطابقة للإكسل تماماً
            function getBuyerFee(p) {
                if (p < 0) return 0;
                if (p <= 99.99) return 1;
                if (p <= 199.99) return 25;
                if (p <= 299.99) return 60;
                if (p <= 349.99) return 85;
                if (p <= 399.99) return 100;
                if (p <= 449.99) return 125;
                if (p <= 499.99) return 135;
                if (p <= 549.99) return 145;
                if (p <= 599.99) return 155;
                if (p <= 699.99) return 170;
                if (p <= 799.99) return 195;
                if (p <= 899.99) return 215;
                if (p <= 999.99) return 230;
                if (p <= 1199.99) return 250;
                if (p <= 1299.99) return 270;
                if (p <= 1399.99) return 285;
                if (p <= 1499.99) return 300;
                if (p <= 1599.99) return 315;
                if (p <= 1699.99) return 330;
                if (p <= 1799.99) return 350;
                if (p <= 1999.99) return 370;
                if (p <= 2399.99) return 390;
                if (p <= 2499.99) return 425;
                if (p <= 2999.99) return 460;
                if (p <= 3499.99) return 505;
                if (p <= 3999.99) return 555;
                if (p <= 4499.99) return 600;
                if (p <= 4999.99) return 625;
                if (p <= 5499.99) return 650;
                if (p <= 5999.99) return 675;
                if (p <= 6499.99) return 700;
                if (p <= 6999.99) return 720;
                if (p <= 7499.99) return 755;
                if (p <= 7999.99) return 775;
                if (p <= 8499.99) return 800;
                if (p <= 8999.99) return 820;
                if (p <= 9999.99) return 820;
                if (p <= 11499.99) return 850;
                if (p <= 11999.99) return 860;
                if (p <= 12499.99) return 875;
                if (p <= 14999.99) return 890;
                return round(p * 6 / 100);
            }

            // دالة Virtual Bid Fee
            function getVirtualBidFee(p) {
                if (p < 0) return 0;
                if (p <= 99.99) return 0;
                if (p <= 499.99) return 50;
                if (p <= 999.99) return 65;
                if (p <= 1499.99) return 85;
                if (p <= 1999.99) return 95;
                if (p <= 3999.99) return 110;
                if (p <= 5999.99) return 125;
                if (p <= 7999.99) return 145;
                return 160;
            }

            // الدالة الديناميكية لحساب كل شيء فورياً بالـ JS
            function calculateLocal() {
                // 1. جلب المدخلات
                var salePrice = parseFloat($('#inpSalePrice').val()) || 0;
                var carType = parseInt($('input[name="carType"]:checked').val()); // 1=Big, 2=Mid, 3=Small
                
                // 2. جلب المتغيرات الديناميكية
                var exRate = parseFloat($('#inpExchangeRate').val()) || 0;
                var oceanFreightOMR = parseFloat($('#inpOceanFreight').val()) || 0;
                var taxPerc = parseFloat($('#inpTaxPerc').val()) || 0;
                var paymentSvc = parseFloat($('#inpPaymentSvc').val()) || 0;
                var officeComm = parseFloat($('#inpOfficeComm').val()) || 0;
                var feeBig = parseFloat($('#inpFeeBig').val()) || 0;
                var feeMid = parseFloat($('#inpFeeMid').val()) || 0;

                // --- 3. حساب المزاد (Auction) ---
                var envFee = 15.00;
                var gateFee = 95.00;
                var titleFee = 40.00;
                var buyerFee = getBuyerFee(salePrice);
                var virtualFee = getVirtualBidFee(salePrice);
                
                var totalAuctionUSD = salePrice + buyerFee + envFee + virtualFee + gateFee + titleFee;
                var totalOMR = round(totalAuctionUSD * exRate); // B8 * 0.386

                // --- 4. حساب الشحن (Shipping) ---
                var seaShipping = round(totalOMR + oceanFreightOMR); // B9 + 300
                var taxCard = 0.00;
                var tax = round(seaShipping * (taxPerc / 100));
                var customs = 0.00;
                var customsVat = round(customs * (5 / 100)); // B15 * 5%
                var shippingCost = 0.00;
                var carTypeFee = carType === 1 ? feeBig : (carType === 2 ? feeMid : 0);

                var totalShipping = round(taxCard + paymentSvc + tax + customs + customsVat + shippingCost + officeComm + carTypeFee);

                // --- 5. الإجماليات (Totals) ---
                var finalTotal = round(totalShipping + totalOMR); // B21 + B9
                var dueNow = round(totalOMR + paymentSvc + officeComm); // B9 + B13 + B18
                var dueArrival = round(finalTotal - dueNow); // B24 - C16

                // --- 6. تحديث الواجهة (UI) مع التنسيق للأرقام ---
                const fmt = (num) => num.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
                
                $('#tdSalePrice').text(fmt(salePrice));
                $('#tdBuyerFee').text(fmt(buyerFee));
                $('#tdEnvFee').text(fmt(envFee));
                $('#tdVirtualFee').text(fmt(virtualFee));
                $('#tdGateFee').text(fmt(gateFee));
                $('#tdTitleFee').text(fmt(titleFee));
                $('#tdTotalAuctionUSD').text(fmt(totalAuctionUSD));
                $('#tdTotalOMR').text(fmt(totalOMR) + ' .ر.ع');

                $('#tdSeaShipping').text(fmt(seaShipping));
                $('#tdTaxCard').text(fmt(taxCard) + ' .ر.ع');
                $('#tdPaymentService').text(fmt(paymentSvc) + ' .ر.ع');
                $('#tdTax').text(fmt(tax) + ' .ر.ع');
                $('#tdCustoms').text(fmt(customs) + ' .ر.ع');
                $('#tdCustomsVat').text(fmt(customsVat) + ' .ر.ع');
                $('#tdShippingCost').text(fmt(shippingCost) + ' .ر.ع');
                $('#tdOfficeComm').text(fmt(officeComm) + ' .ر.ع');
                $('#tdCarTypeFee').text(fmt(carTypeFee) + ' .ر.ع');
                $('#tdTotalShipping').text(fmt(totalShipping) + ' .ر.ع');

                $('#tdFinalTotal').text(fmt(finalTotal) + ' .ر.ع');
                $('#tdDueNow').text(fmt(dueNow));
                $('#tdDueArrival').text(fmt(dueArrival));
            }

            // تشغيل الحساب عند كتابة أو تغيير أي شيء في المدخلات أو المتغيرات الديناميكية
            $('.form-control, input[type="radio"]').on('input change', calculateLocal);

            // تشغيل الدالة مرة واحدة عند تحميل الصفحة
            calculateLocal();
        });
    </script>
}