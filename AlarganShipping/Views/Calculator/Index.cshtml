              function round(num) {
                  return Math.round((num + Number.EPSILON) * 100) / 100;
              }

              function getBuyerFee(price) {
                  if (price < 100) return 1;
                  if (price < 200) return 25;
                  if (price < 300) return 60;
                  if (price < 350) return 85;
                  if (price < 400) return 100;
                  if (price < 450) return 125;
                  if (price < 500) return 135;
                  if (price < 550) return 145;
                  if (price < 600) return 155;
                  if (price < 700) return 170;
                  if (price < 800) return 195;
                  if (price < 900) return 215;
                  if (price < 1000) return 230;
                  if (price < 1200) return 250;
                  if (price < 1300) return 270;
                  if (price < 1400) return 285;
                  if (price < 1500) return 300;
                  if (price < 1600) return 315;
                  if (price < 1700) return 330;
                  if (price < 1800) return 350;
                  if (price < 2000) return 370;
                  if (price < 2400) return 390;
                  if (price < 2500) return 425;
                  if (price < 3000) return 460;
                  if (price < 3500) return 505;
                  if (price < 4000) return 555;
                  if (price < 4500) return 600;
                  if (price < 5000) return 625;
                  if (price < 5500) return 650;
                  if (price < 6000) return 675;
                  if (price < 6500) return 700;
                  if (price < 7000) return 720;
                  if (price < 7500) return 755;
                  if (price < 8000) return 775;
                  if (price < 8500) return 800;
                  if (price < 9000) return 820;
                  if (price < 10000) return 820;
                  if (price < 11500) return 850;
                  if (price < 12000) return 860;
                  if (price < 12500) return 875;
                  if (price < 15000) return 890;
                  return round(price * 0.06);
              }

              function getVirtualBidFee(p) {
                  if (p < 0) return 0;
                  if (p <= 99.99) return 0;
                  if (p <= 499.99) return 50;
                  if (p <= 999.99) return 65;
                  if (p <= 1499.99) return 85;
                  if (p <= 1999.99) return 95;
                  if (p <= 3999.99) return 110;
                  if (p <= 5999.99) return 125;
                  if (p <= 7999.99) return 145;
                  return 160;
              }

              $(document).ready(function() {
                  // تهيئة Select2
                  $('#selAuction').select2({
                      placeholder: "🔍 @Html.Raw(Localizer["ابحث عن المزاد، المدينة، أو الولاية..."])",
                      allowClear: true,
                      data: SHIPPING_RATES.map(r => ({ id: r.id, text: r.auctionLocation, city: r.city, state: r.state, price: r.price })),
                      dir: $('html').attr('dir'),
                      matcher: function(params, data) {
                          if ($.trim(params.term) === '') return data;
                          if (typeof data.text === 'undefined') return null;
                          var q = params.term.toLowerCase();
                          if (data.text.toLowerCase().indexOf(q) > -1 ||
                              (data.city && data.city.toLowerCase().indexOf(q) > -1) ||
                              (data.state && data.state.toLowerCase().indexOf(q) > -1)) {
                              return data;
                          }
                          return null;
                      },
                      templateResult: function(data) {
                          if (!data.id) return data.text;
                          return $(`
                              <div style="display:flex; justify-content:space-between; align-items:center;">
                                  <div style="text-align: right;">
                                      <div style="font-weight:900; color:var(--calc-navy); font-size:0.9rem;">${data.text}</div>
                                      <div style="font-size:0.65rem; color:#94a3b8; text-transform:uppercase;">${data.city}, ${data.state}</div>
                                  </div>
                                  <div style="font-weight:900; color:var(--calc-gold); direction: ltr;">${data.price} @Html.Raw(Localizer["ر.ع"])</div>
                              </div>
                          `);
                      },
                      templateSelection: function(data) {
                          if (!data.id) return $(`<span style="color:#94a3b8; font-weight:800;">${data.text}</span>`);
                          return $(`<div style="font-weight:900; width:100%; display:flex; justify-content:space-between; align-items:center;"><span>${data.text}</span> <span style="color:var(--calc-gold); direction:ltr; font-size:0.9rem;">${data.price} @Html.Raw(Localizer["ر.ع"])</span></div>`);
                      }
                  });

                  // التركيز التلقائي على حقل البحث عند فتح القائمة المنسدلة
                  $('#selAuction').on('select2:open', function () {
                      setTimeout(function() {
                          document.querySelector('.select2-search__field').focus();
                      }, 50);
                  });

                  $('#selAuction').val(1).trigger('change'); // تعيين قيمة مبدئية لـ Birmingham

                  function calculateLocal() {
                      var salePrice = parseFloat($('#inpSalePrice').val()) || 0;

                      var selectedAuctionId = $('#selAuction').val();
                      var selectedAuction = SHIPPING_RATES.find(r => r.id == selectedAuctionId);
                      var oceanPrice = selectedAuction ? selectedAuction.price : 604;

                      var comm = parseFloat($('#inpComm').val()) || 0;
                      var transport = parseFloat($('#inpTransport').val()) || 0;
                      var extraFees = parseFloat($('#inpExtraFees').val()) || 0;

                      var carType = $('input[name="carType"]:checked').val(); // 'Electric', 'Small', 'Mid', 'Big'
                      var origin = $('input[name="origin"]:checked').val(); // 'NON_US', 'US_EXEMPT'

                      var exRate = parseFloat($('#inpExRate').val()) || 0.386;
                      var paymentSvc = parseFloat($('#inpPaymentSvc').val()) || 15.48;

                      // ثوابت المزاد
                      var envFee = 15.00;
                      var virtualFee = getVirtualBidFee(salePrice);
                      var gateFee = 95.00;
                      var titleFee = 40.00;
                      var buyerFee = getBuyerFee(salePrice);

                      // 1. حساب المزاد
                      var auctionTotalUSD = salePrice + buyerFee + envFee + virtualFee + gateFee + titleFee;
                      var auctionTotalOMR = round(auctionTotalUSD * exRate);

                      // 2. حساب الشحن الأساسي
                      // نضيف رسوم الحجم بناءً على الاختيار
                      var carSizeSurcharge = 0;
                      if (carType === 'Mid') carSizeSurcharge = 60; // يمكنك تعديلها
                      if (carType === 'Big') carSizeSurcharge = 120;

                      var shippingTotalOMR = oceanPrice + comm + transport + extraFees + paymentSvc + carSizeSurcharge;

                      // 3. حساب الضرائب والجمارك
                      var taxOMR = (auctionTotalOMR + 300) * 0.05; // الـ 300 هي رسوم شحن تقديرية تضاف قبل حساب الضريبة
                      var customsOMR = (origin === 'NON_US') ? (taxOMR + (taxOMR * 0.05)) : 0;

                      var isElectric = (carType === 'Electric');
                      var finalTaxOMR = isElectric ? 0 : taxOMR;
                      var finalCustomsOMR = isElectric ? 0 : customsOMR;

                      // 4. المجاميع النهائية
                      var grandTotal = auctionTotalOMR + shippingTotalOMR + finalCustomsOMR + finalTaxOMR;
                      var initialDue = auctionTotalOMR + comm;
                      var arrivalDue = grandTotal - initialDue;

                      // 5. التحديث في الشاشة
                      const fmt = (num) => num.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});

                      $('#resBuyerFee').text(fmt(buyerFee));
                      $('#resEnvFee').text(fmt(envFee));
                      $('#resVirtualFee').text(fmt(virtualFee));
                      $('#resGateFee').text(fmt(gateFee));
                      $('#resTitleFee').text(fmt(titleFee));
                      $('#resAuctionUSD').text('$' + fmt(auctionTotalUSD));
                      $('#resAuctionOMR').text(fmt(auctionTotalOMR));

                      $('#resOceanFreight').text(fmt(oceanPrice));
                      $('#resCommission').text(fmt(comm));
                      $('#resTransport').text(fmt(transport));

                      if (extraFees > 0) {
                          $('#extraFeesContainer').show();
                          $('#resExtraFees').text(fmt(extraFees));
                      } else {
                          $('#extraFeesContainer').hide();
                      }

                      if(isElectric) {
                          $('#resTaxContainer').html('<span style="color:#16a34a; background:#f0fdf4; padding:2px 8px; border-radius:6px; font-size:0.8rem; font-weight:800;">@Html.Raw(Localizer["معفية تماماً"])</span>');
                          $('#resCustomsContainer').html('<span style="color:#16a34a; background:#f0fdf4; padding:2px 8px; border-radius:6px; font-size:0.8rem; font-weight:800;">@Html.Raw(Localizer["معفية تماماً"])</span>');
                      } else {
                          $('#resTaxContainer').html('<span class="val">' + fmt(finalTaxOMR) + '</span> <span class="curr">@Html.Raw(Localizer["ر.ع"])</span>');
                          $('#resCustomsContainer').html('<span class="val">' + fmt(finalCustomsOMR) + '</span> <span class="curr">@Html.Raw(Localizer["ر.ع"])</span>');
                      }

                      $('#resShippingTotal').text(fmt(shippingTotalOMR + finalTaxOMR + finalCustomsOMR - paymentSvc));

                      $('#resGrandTotal').text(fmt(grandTotal));
                      $('#resInitialDue').text(fmt(initialDue));
                      $('#resArrivalDue').text(fmt(arrivalDue));
                  }

                  $('.form-control, input[type="radio"]').on('input change', calculateLocal);
                  $('#selAuction').on('change', calculateLocal);

                  calculateLocal();
              });
    </script>
}