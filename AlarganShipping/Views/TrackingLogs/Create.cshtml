@model AlarganShipping.Models.TrackingLog
@{
    ViewData["Title"] = Localizer["إضافة تحديث تتبع"];
}

<style>
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--primary-navy);
        margin: 0;
    }

    .btn-back {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: var(--primary-navy);
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(44, 62, 80, 0.03);
        border: 1px solid #f1f5f9;
        padding: 3rem;
        position: relative;
        overflow: hidden;
    }

        .premium-form-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            left: 0;
            height: 6px;
            background: linear-gradient(to right, var(--primary-navy), var(--primary-gold));
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media (min-width: 768px) {
        .form-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-group-full {
        grid-column: 1 / -1;
    }

    .form-label {
        font-weight: 800;
        color: var(--primary-navy);
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-control {
        padding: 1rem 1.25rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 1rem;
        color: var(--text-dark);
        background-color: #f8fafc;
        transition: 0.3s;
        outline: none;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

    .select2-container--default .select2-selection--single {
        background-color: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        height: 50px;
        display: flex;
        align-items: center;
        transition: 0.3s;
    }

        .select2-container--default .select2-selection--single:focus, .select2-container--focus .select2-selection--single {
            border-color: var(--primary-gold);
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            color: var(--text-dark);
            font-weight: 600;
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 48px;
            right: 10px;
        }

    html[dir="rtl"] .select2-container--default .select2-selection--single .select2-selection__arrow {
        left: 10px;
        right: auto;
    }

    .form-actions {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
    }

    .btn-submit {
        background: var(--primary-navy);
        color: #ffffff;
        border: none;
        padding: 1rem 3rem;
        border-radius: 1rem;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 4px 15px rgba(44, 62, 80, 0.3);
        font-family: inherit;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-submit:hover {
            background: var(--primary-gold);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(184, 147, 90, 0.4);
        }
</style>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<div>
    <div class="form-page-header">
        <h2 class="form-page-title"><i class="fa-solid fa-satellite-dish" style="color: var(--primary-gold); margin-inline-end: 10px;"></i> @Localizer["إضافة تحديث تتبع لسيارة"]</h2>
        <a href="@Url.Action("Index", "Cars")" class="btn-back">@Localizer["العودة للسيارات"]</a>
    </div>

    <div class="premium-form-card">
        <form asp-action="Create" method="post" id="trackingForm">
            @Html.AntiForgeryToken()
            <div class="form-grid">
                <div class="form-group form-group-full">
                    <label asp-for="CarId" class="form-label">@Localizer["ابحث برقم الشاصي (VIN) أو اختر السيارة"]</label>
                    <select asp-for="CarId" class="form-control select2-search" asp-items="ViewBag.CarId" required>
                        <option value="">-- @Localizer["اضغط للبحث عن سيارة..."] --</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="Title" class="form-label">@Localizer["عنوان التحديث"]</label>
                    <select asp-for="Title" class="form-control">
                        <option value="تم الشراء من المزاد">@Localizer["تم الشراء من المزاد"]</option>
                        <option value="تم دفع قيمة السيارة">@Localizer["تم دفع قيمة السيارة"]</option>
                        <option value="السيارة قيد النقل الداخلي">@Localizer["السيارة قيد النقل الداخلي"]</option>
                        <option value="السيارة في المستودع">@Localizer["السيارة في المستودع"]</option>
                        <option value="تم التحميل في الحاوية">@Localizer["تم التحميل في الحاوية"]</option>
                        <option value="أبحرت السفينة">@Localizer["أبحرت السفينة"]</option>
                        <option value="وصلت إلى الميناء الوجهة">@Localizer["وصلت إلى الميناء الوجهة"]</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="ProgressPercentage" class="form-label">@Localizer["نسبة الإنجاز (لتحريك شريط التقدم)"]</label>
                    <select asp-for="ProgressPercentage" class="form-control">
                        <option value="10">@Localizer["10% - إجراءات الشراء"]</option>
                        <option value="33">@Localizer["33% - وصلت المستودع"]</option>
                        <option value="66">@Localizer["66% - أبحرت"]</option>
                        <option value="100">@Localizer["100% - وصلت وتخصلت"]</option>
                    </select>
                </div>
                <div class="form-group form-group-full">
                    <label asp-for="Location" class="form-label">@Localizer["الموقع الحالي"]</label>
                    <input asp-for="Location" class="form-control" placeholder="New Jersey, Salalah Port..." />
                </div>
                <div class="form-group form-group-full">
                    <label asp-for="Description" class="form-label">@Localizer["تفاصيل إضافية للعميل (اختياري)"]</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="@Localizer["أضف أي تفاصيل تطمئن العميل..."]"></textarea>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-submit" id="btnSubmit">
                    <i class="fa-solid fa-paper-plane"></i> @Localizer["نشر التحديث"]
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script>
        $(document).ready(function() {
            var dir = $('html').attr('dir');
            $('.select2-search').select2({ dir: dir, placeholder: '@Html.Raw(Localizer["اضغط للبحث عن سيارة..."])', allowClear: true, width: '100%' });

            $('#trackingForm').on('submit', function(e) {
                e.preventDefault();
                var form = $(this);
                if (!form[0].checkValidity()) { form[0].reportValidity(); return; }

                var btn = $('#btnSubmit');
                var originalText = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin"></i> @Html.Raw(Localizer["جاري النشر..."])').prop('disabled', true);

                $.ajax({
                    url: form.attr('action'),
                    type: form.attr('method'),
                    data: form.serialize(),
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                title: '@Html.Raw(Localizer["تم النشر بنجاح!"])',
                                text: '@Html.Raw(Localizer["تم إضافة تحديث التتبع لسيارة العميل ويمكنه رؤيته الآن عبر بوابته."])',
                                icon: 'success',
                                confirmButtonColor: 'var(--primary-gold)',
                                confirmButtonText: '@Html.Raw(Localizer["العودة لتفاصيل السيارة"])',
                                showCancelButton: true,
                                cancelButtonText: '@Html.Raw(Localizer["إضافة تحديث آخر"])',
                                cancelButtonColor: 'var(--primary-navy)'
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    window.location.href = '@Url.Action("Details", "Cars")/' + $('#CarId').val();
                                } else {
                                    form[0].reset();
                                    $('.select2-search').val(null).trigger('change');
                                    btn.html(originalText).prop('disabled', false);
                                }
                            });
                        } else {
                            var errorMsg = response.errors ? response.errors.join('\n') : '@Html.Raw(Localizer["حدث خطأ أثناء الحفظ."])';
                            Swal.fire({ title: '@Html.Raw(Localizer["خطأ!"])', text: errorMsg, icon: 'error', confirmButtonColor: 'var(--primary-navy)' });
                            btn.html(originalText).prop('disabled', false);
                        }
                    },
                    error: function () {
                        Swal.fire({ title: '@Html.Raw(Localizer["خطأ!"])', text: '@Html.Raw(Localizer["حدث خطأ أثناء الاتصال بالخادم."])', icon: 'error', confirmButtonColor: 'var(--primary-navy)' });
                        btn.html(originalText).prop('disabled', false);
                    }
                });
            });
        });
    </script>
}