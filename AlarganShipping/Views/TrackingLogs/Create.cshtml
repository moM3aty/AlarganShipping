@model AlarganShipping.Models.TrackingLog
@{
    ViewData["Title"] = "إضافة تحديث تتبع";
}

<style>
    /* Premium Form CSS specific to Tracking */
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: #2b3f56;
        margin: 0;
    }

    .btn-back {
        background-color: #f1f5f9;
        color: #475569;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .btn-back:hover {
            background-color: #e2e8f0;
            color: #1e293b;
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.25rem;
        box-shadow: 0 10px 30px rgba(43, 63, 86, 0.05);
        border: 1px solid #f8fafc;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
    }

        .premium-form-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(to left, #2563eb, #3b82f6);
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @@media (min-width: 768px) {
        .form-grid

    {
        grid-template-columns: repeat(2, 1fr);
    }

    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-group-full {
        grid-column: 1 / -1;
    }

    .form-label {
        font-weight: 700;
        color: #2b3f56;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-control {
        padding: 0.85rem 1.25rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: 'Cairo', sans-serif;
        font-size: 1rem;
        color: #1e293b;
        background-color: #f8fafc;
        transition: all 0.3s ease;
        outline: none;
    }

        .form-control:focus {
            border-color: #2563eb;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
        }

    .form-actions {
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
    }

    .btn-submit {
        background: linear-gradient(to right, #2563eb, #3b82f6);
        color: #ffffff;
        border: none;
        padding: 0.85rem 2.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        font-family: 'Cairo', sans-serif;
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
        transition: all 0.3s ease;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.4);
        }

    .text-danger {
        color: #dc2626;
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 0.25rem;
    }
</style>

<div>
    <div class="form-page-header">
        <h2 class="form-page-title">إضافة تحديث تتبع لسيارة</h2>
        <a href="@Url.Action("Index", "Cars")" class="btn-back">العودة للسيارات</a>
    </div>

    <div class="premium-form-card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">
                <div class="form-group form-group-full">
                    <label asp-for="CarId" class="form-label">رقم الشاصي (VIN) للسيارة</label>
                    <select asp-for="CarId" class="form-control" asp-items="ViewBag.CarId"></select>
                </div>

                <div class="form-group">
                    <label asp-for="Title" class="form-label">عنوان التحديث</label>
                    <select asp-for="Title" class="form-control">
                        <option value="تم الشراء من المزاد">تم الشراء من المزاد</option>
                        <option value="السيارة في المستودع">السيارة في المستودع</option>
                        <option value="تم التحميل في الحاوية">تم التحميل في الحاوية</option>
                        <option value="أبحرت السفينة">أبحرت السفينة</option>
                        <option value="وصلت إلى الميناء الوجهة">وصلت إلى الميناء الوجهة</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="ProgressPercentage" class="form-label">نسبة الإنجاز (لتحريك شريط التقدم)</label>
                    <select asp-for="ProgressPercentage" class="form-control">
                        <option value="10">10% - إجراءات الشراء</option>
                        <option value="33">33% - وصلت المستودع</option>
                        <option value="66">66% - أبحرت</option>
                        <option value="100">100% - وصلت وتخصلت</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="Location" class="form-label">الموقع الحالي</label>
                    <input asp-for="Location" class="form-control" placeholder="مثال: مستودع نيوجيرسي، ميناء صلالة..." />
                </div>

                <div class="form-group form-group-full">
                    <label asp-for="Description" class="form-label">تفاصيل إضافية للعميل (اختياري)</label>
                    <textarea asp-for="Description" class="form-control" rows="2" placeholder="أضف أي تفاصيل تطمئن العميل..."></textarea>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">نشر التحديث</button>
            </div>
        </form>
    </div>
</div>