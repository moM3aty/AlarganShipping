@{
    ViewData["Title"] = Localizer["المحاسبة والتقارير المالية"];
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
    }

    .page-subtitle {
        color: var(--text-muted);
        font-size: 0.9rem;
        font-weight: 600;
    }

    /* تبويبات المحاسبة */
    .accounting-tabs {
        display: flex;
        gap: 10px;
        background: white;
        padding: 0.5rem;
        border-radius: 1rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        overflow-x: auto;
        border: 1px solid #e2e8f0;
    }

    .acc-tab {
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        font-size: 0.9rem;
        color: var(--text-muted);
        text-decoration: none;
        white-space: nowrap;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        border: none;
        background: transparent;
    }

        .acc-tab:hover {
            background: #f8fafc;
            color: var(--primary-navy);
        }

        .acc-tab.active {
            background: var(--primary-navy);
            color: white;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .fin-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    }

    .fin-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .fin-card-title {
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
    }

    .fin-icon {
        width: 40px;
        height: 40px;
        background: rgba(184, 147, 90, 0.1);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-gold);
        font-size: 1.2rem;
    }

    .fin-data-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        text-align: center;
    }

    .fin-data-box {
        padding: 1rem;
        background: #f8fafc;
        border-radius: 1rem;
        border: 1px solid #f1f5f9;
    }

    .fin-label {
        display: block;
        font-size: 0.8rem;
        color: var(--text-muted);
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .fin-value {
        font-size: 1.4rem;
        font-weight: 900;
        color: var(--primary-navy);
        font-family: monospace;
    }

        .fin-value.green {
            color: #16a34a;
        }

        .fin-value.red {
            color: #ef4444;
        }

    .chart-container {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        margin-top: 1.5rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    }

    .chart-title {
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 1.5rem;
    }
</style>

<div>
    <div class="page-header">
        <div>
            <h2 class="page-title">@Localizer["المحاسبة والتقارير المالية"]</h2>
            <div class="page-subtitle">@Localizer["نظام الإدارة المحاسبية الذكي"] - @ViewBag.CurrentYear</div>
        </div>
    </div>

    <!-- الأقسام المحاسبية الأساسية (أصبحت روابط حقيقية ديناميكية) -->
    <div class="accounting-tabs">
        <a href="@Url.Action("Index", "Accounting")" class="acc-tab active"><i class="fa-solid fa-chart-pie"></i> @Localizer["نظرة عامة"]</a>
        <a href="@Url.Action("Index", "Cars")" class="acc-tab"><i class="fa-solid fa-cart-shopping"></i> @Localizer["المشتريات (السيارات)"]</a>
        <a href="@Url.Action("Index", "Invoices")" class="acc-tab"><i class="fa-solid fa-tags"></i> @Localizer["المبيعات (فواتير العملاء)"]</a>
        <a href="@Url.Action("Index", "DispatchOrders")" class="acc-tab"><i class="fa-solid fa-truck-fast"></i> @Localizer["مصاريف النقل الداخلي"]</a>
        <a href="@Url.Action("Index", "PaymentReceipts")" class="acc-tab"><i class="fa-solid fa-arrow-down-to-line"></i> @Localizer["سندات القبض"]</a>
    </div>

    <div class="stats-grid">
        <!-- بطاقة المبيعات (العملاء) -->
        <div class="fin-card">
            <div class="fin-card-header">
                <h3 class="fin-card-title">@Localizer["المبيعات والإيرادات"]</h3>
                <div class="fin-icon"><i class="fa-solid fa-arrow-trend-up"></i></div>
            </div>
            <div class="fin-data-grid">
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["إجمالي المبيعات"]</span>
                    <span class="fin-value" dir="ltr">OMR @(((decimal)ViewBag.TotalSales).ToString("N2"))</span>
                </div>
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["المستلم (سندات قبض)"]</span>
                    <span class="fin-value green" dir="ltr">OMR @(((decimal)ViewBag.TotalPaid).ToString("N2"))</span>
                </div>
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["المتأخرات (ذمم)"]</span>
                    <span class="fin-value red" dir="ltr">OMR @(((decimal)ViewBag.PendingCollections).ToString("N2"))</span>
                </div>
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["عدد الفواتير"]</span>
                    <span class="fin-value" style="font-family: 'Cairo';">@ViewBag.InvoicesCount</span>
                </div>
            </div>
        </div>

        <!-- بطاقة المشتريات (مزادات وشحن) -->
        <div class="fin-card">
            <div class="fin-card-header">
                <h3 class="fin-card-title">@Localizer["المشتريات والتكاليف"]</h3>
                <div class="fin-icon"><i class="fa-solid fa-arrow-trend-down"></i></div>
            </div>
            <div class="fin-data-grid">
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["إجمالي قيمة الشراء"]</span>
                    <span class="fin-value" dir="ltr">$ @(((decimal)ViewBag.TotalPurchases).ToString("N2"))</span>
                </div>
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["تكاليف النقل (Towing)"]</span>
                    <span class="fin-value" dir="ltr" style="color: #f59e0b;">$ @(((decimal)ViewBag.TotalExpenses).ToString("N2"))</span>
                </div>
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["إجمالي التكاليف"]</span>
                    <span class="fin-value red" dir="ltr">$ @(((decimal)(ViewBag.TotalPurchases + ViewBag.TotalExpenses)).ToString("N2"))</span>
                </div>
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["سيارات مشتراة"]</span>
                    <span class="fin-value" style="font-family: 'Cairo';">@ViewBag.PurchasedCarsCount</span>
                </div>
            </div>
        </div>
    </div>

    <!-- رسم بياني للمحاسبة (Chart.js) - ديناميكي بالكامل -->
    <div class="chart-container">
        <h3 class="chart-title">@Localizer["نظرة عامة على التدفقات النقدية لعام"] @ViewBag.CurrentYear</h3>
        <canvas id="financeChart" height="100"></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // استقبال البيانات الديناميكية من السيرفر باستخدام Html.Raw و Json.Serialize
        const salesData = @Html.Raw(Json.Serialize(ViewBag.MonthlySales));
        const purchasesData = @Html.Raw(Json.Serialize(ViewBag.MonthlyPurchases));

        // مصفوفة الشهور المترجمة ديناميكياً
        const monthLabels = [
            '@Html.Raw(Localizer["يناير"])', '@Html.Raw(Localizer["فبراير"])', '@Html.Raw(Localizer["مارس"])',
            '@Html.Raw(Localizer["أبريل"])', '@Html.Raw(Localizer["مايو"])', '@Html.Raw(Localizer["يونيو"])',
            '@Html.Raw(Localizer["يوليو"])', '@Html.Raw(Localizer["أغسطس"])', '@Html.Raw(Localizer["سبتمبر"])',
            '@Html.Raw(Localizer["أكتوبر"])', '@Html.Raw(Localizer["نوفمبر"])', '@Html.Raw(Localizer["ديسمبر"])'
        ];

        // تهيئة الرسم البياني ليطابق ألوان الهوية البصرية
        const rootStyles = getComputedStyle(document.documentElement);
        const goldColor = rootStyles.getPropertyValue('--primary-gold').trim();
        const navyColor = rootStyles.getPropertyValue('--primary-navy').trim();

        const ctx = document.getElementById('financeChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: monthLabels,
                datasets: [
                    {
                        label: '@Html.Raw(Localizer["المبيعات (إيرادات الفواتير OMR)"])',
                        data: salesData,
                        borderColor: navyColor,
                        backgroundColor: navyColor + '20', // لون شفاف للتعبئة أسفل الخط
                        tension: 0.4,
                        borderWidth: 3,
                        fill: true
                    },
                    {
                        label: '@Html.Raw(Localizer["المشتريات (تكلفة السيارات USD)"])',
                        data: purchasesData,
                        borderColor: goldColor,
                        backgroundColor: goldColor + '20',
                        tension: 0.4,
                        borderWidth: 3,
                        fill: true
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'top', labels: { font: { family: 'Cairo', weight: 'bold' } } } },
                scales: { y: { beginAtZero: true } },
                interaction: { mode: 'index', intersect: false }
            }
        });
    </script>
}