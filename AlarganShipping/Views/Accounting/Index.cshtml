@{
    ViewData["Title"] = Localizer["المحاسبة والتقارير المالية"];
}

<style>
    /* --- التنسيقات الأساسية --- */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
    }

    .page-subtitle {
        color: var(--text-muted);
        font-size: 0.9rem;
        font-weight: 600;
        margin-top: 5px;
    }

    .accounting-tabs {
        display: flex;
        gap: 10px;
        background: white;
        padding: 0.5rem;
        border-radius: 1rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        overflow-x: auto;
        border: 1px solid #e2e8f0;
        scrollbar-width: none;
    }

        .accounting-tabs::-webkit-scrollbar {
            display: none;
        }

    .acc-tab {
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        font-size: 0.9rem;
        color: var(--text-muted);
        text-decoration: none;
        white-space: nowrap;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        border: none;
        background: transparent;
    }

        .acc-tab:hover {
            background: #f8fafc;
            color: var(--primary-navy);
        }

        .acc-tab.active {
            background: var(--primary-navy);
            color: white;
            box-shadow: 0 4px 12px rgba(44, 62, 80, 0.2);
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .fin-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        display: flex;
        flex-direction: column;
    }

    .fin-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .fin-card-title {
        font-size: 1.25rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
    }

    .fin-icon {
        width: 45px;
        height: 45px;
        background: rgba(184, 147, 90, 0.1);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-gold);
        font-size: 1.3rem;
    }

    .fin-data-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
    }

    .fin-data-box {
        padding: 1.25rem;
        background: #f8fafc;
        border-radius: 1.25rem;
        border: 1px solid #f1f5f9;
        text-align: center;
        transition: 0.3s;
    }

        .fin-data-box:hover {
            border-color: var(--primary-gold);
            background: white;
        }

    .fin-label {
        display: block;
        font-size: 0.8rem;
        color: var(--text-muted);
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .fin-value {
        font-size: 1.3rem;
        font-weight: 900;
        color: var(--primary-navy);
        font-family: monospace;
    }

        .fin-value.green {
            color: #16a34a;
        }

        .fin-value.red {
            color: #ef4444;
        }

    .chart-container {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        margin-top: 2rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    }

    .chart-title {
        font-size: 1.3rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* تنسيقات قسم التصدير والتقارير */
    .report-container {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        margin-top: 2rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    }

    .export-btns {
        display: flex;
        gap: 10px;
    }

    .btn-export {
        border: none;
        padding: 0.6rem 1.2rem;
        border-radius: 0.75rem;
        font-weight: 800;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
        color: white;
    }

    .btn-excel {
        background: #10b981;
    }

        .btn-excel:hover {
            background: #059669;
        }

    .btn-pdf {
        background: #ef4444;
    }

        .btn-pdf:hover {
            background: #dc2626;
        }

    .table-enterprise {
        width: 100%;
        border-collapse: collapse;
        text-align: start;
        margin-top: 1rem;
    }

        .table-enterprise th {
            padding: 1rem;
            background: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            border-bottom: 2px solid #e2e8f0;
        }

        .table-enterprise td {
            padding: 1rem;
            border-bottom: 1px solid #f1f5f9;
            font-weight: 700;
            color: var(--text-dark);
        }

    @@media (max-width: 768px) {
        .page-header

    {
        text-align: center;
        justify-content: center;
    }

    .stats-grid {
        grid-template-columns: 1fr;
    }

    .fin-data-grid {
        grid-template-columns: 1fr;
    }

    .report-container {
        padding: 1.5rem;
    }

    }
</style>

<div class="accounting-dashboard-page">
    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
    {
        <div style="background: #fef2f2; color: #ef4444; padding: 1rem; border-radius: 1rem; margin-bottom: 1rem; font-weight: bold; border: 1px solid #fecaca;">
            <i class="fa-solid fa-triangle-exclamation"></i> @ViewBag.ErrorMessage
        </div>
    }

    <div class="page-header">
        <div>
            <h2 class="page-title">@Localizer["المحاسبة والتقارير المالية"]</h2>
            <div class="page-subtitle">@Localizer["نظام الإدارة المحاسبية الذكي"] - @ViewBag.CurrentYear</div>
        </div>
    </div>

    <div class="accounting-tabs">
        <a href="@Url.Action("Index", "Accounting")" class="acc-tab active"><i class="fa-solid fa-chart-pie"></i> @Localizer["نظرة عامة"]</a>
        <a href="@Url.Action("Index", "Invoices")" class="acc-tab"><i class="fa-solid fa-file-invoice-dollar"></i> @Localizer["المبيعات والفواتير"]</a>
        <a href="@Url.Action("Index", "PaymentReceipts")" class="acc-tab"><i class="fa-solid fa-hand-holding-dollar"></i> @Localizer["سندات القبض"]</a>
        <a href="@Url.Action("Index", "PaymentVouchers")" class="acc-tab"><i class="fa-solid fa-money-bill-transfer"></i> @Localizer["سندات الصرف"]</a>
    </div>

    <div class="stats-grid">
        <div class="fin-card">
            <div class="fin-card-header">
                <h3 class="fin-card-title">@Localizer["المبيعات والإيرادات"]</h3>
                <div class="fin-icon"><i class="fa-solid fa-arrow-trend-up"></i></div>
            </div>
            <div class="fin-data-grid">
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["إجمالي المبيعات"]</span>
                    <span class="fin-value" dir="ltr">$@(((decimal)ViewBag.TotalSales).ToString("N2"))</span>
                </div>
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["المستلم (سندات قبض)"]</span>
                    <span class="fin-value green" dir="ltr">$@(((decimal)ViewBag.TotalPaid).ToString("N2"))</span>
                </div>
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["المتأخرات (ذمم)"]</span>
                    <span class="fin-value red" dir="ltr">$@(((decimal)ViewBag.PendingCollections).ToString("N2"))</span>
                </div>
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["عدد الفواتير"]</span>
                    <span class="fin-value" style="font-family: 'Cairo';">@ViewBag.InvoicesCount</span>
                </div>
            </div>
        </div>

        <div class="fin-card">
            <div class="fin-card-header">
                <h3 class="fin-card-title">@Localizer["المشتريات والتكاليف"]</h3>
                <div class="fin-icon"><i class="fa-solid fa-arrow-trend-down"></i></div>
            </div>
            <div class="fin-data-grid">
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["إجمالي قيمة الشراء"]</span>
                    <span class="fin-value" dir="ltr">$@(((decimal)ViewBag.TotalPurchases).ToString("N2"))</span>
                </div>
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["تكاليف النقل (Towing)"]</span>
                    <span class="fin-value" dir="ltr" style="color: #f59e0b;">$@(((decimal)ViewBag.TotalExpenses).ToString("N2"))</span>
                </div>
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["إجمالي التكاليف"]</span>
                    <span class="fin-value red" dir="ltr">$@(((decimal)(ViewBag.TotalPurchases + ViewBag.TotalExpenses)).ToString("N2"))</span>
                </div>
                <div class="fin-data-box">
                    <span class="fin-label">@Localizer["سيارات مشتراة"]</span>
                    <span class="fin-value" style="font-family: 'Cairo';">@ViewBag.PurchasedCarsCount</span>
                </div>
            </div>
        </div>
    </div>

    <!-- الرسم البياني (Chart.js) -->
    <div class="chart-container">
        <h3 class="chart-title"><i class="fa-solid fa-chart-line" style="color: var(--primary-gold);"></i> @Localizer["نظرة عامة على التدفقات النقدية لعام"] @ViewBag.CurrentYear</h3>
        <div style="width: 100%; position: relative;">
            <canvas id="financeChart" height="250"></canvas>
        </div>
    </div>

    <!-- جدول التقارير المحاسبية والتصدير -->
    <div class="report-container">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
            <h3 class="chart-title" style="margin: 0;"><i class="fa-solid fa-file-invoice" style="color: var(--primary-gold);"></i> @Localizer["التقرير المالي الشهري التفصيلي"]</h3>
            <div class="export-btns">
                <button onclick="exportToExcel()" class="btn-export btn-excel"><i class="fa-solid fa-file-excel"></i> @Localizer["تصدير Excel"]</button>
                <button onclick="exportToPDF()" class="btn-export btn-pdf"><i class="fa-solid fa-file-pdf"></i> @Localizer["تصدير PDF"]</button>
            </div>
        </div>
        <div style="overflow-x: auto;" id="pdfContentArea">
            <h2 style="display: none; text-align: center; color: var(--primary-navy);" id="pdfReportTitle">تقرير التدفقات النقدية - @ViewBag.CurrentYear</h2>
            <table id="accountingReportTable" class="table-enterprise">
                <thead>
                    <tr>
                        <th>@Localizer["الشهر"]</th>
                        <th>@Localizer["إجمالي المبيعات (الإيرادات)"]</th>
                        <th>@Localizer["إجمالي المشتريات (المصروفات)"]</th>
                        <th>@Localizer["صافي التدفق النقدي"]</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        decimal grandSales = 0;
                        decimal grandPurchases = 0;
                        // تم الاستغناء عن CultureInfo واستخدام مصفوفة نصوص ثابتة لمنع خطأ 500 في السيرفرات
                        string[] arabicMonths = { "يناير", "فبراير", "مارس", "أبريل", "مايو", "يونيو", "يوليو", "أغسطس", "سبتمبر", "أكتوبر", "نوفمبر", "ديسمبر" };
                    }
                    @for (int i = 0; i < 12; i++)
                    {
                        decimal mSales = ((decimal[])ViewBag.MonthlySales)[i];
                        decimal mPurchases = ((decimal[])ViewBag.MonthlyPurchases)[i];
                        decimal mNet = mSales - mPurchases;
                        grandSales += mSales;
                        grandPurchases += mPurchases;

                        string monthName = arabicMonths[i];
                        <tr>
                            <td style="font-weight: 900; color: var(--primary-navy);">@monthName</td>
                            <td style="color: #16a34a; font-family: monospace; font-size: 1.1rem;">$@mSales.ToString("N2")</td>
                            <td style="color: #ef4444; font-family: monospace; font-size: 1.1rem;">$@mPurchases.ToString("N2")</td>
                            <td style="font-family: monospace; font-weight: 900; font-size: 1.1rem; color: @(mNet >= 0 ? "#16a34a" : "#ef4444")">
                                $@mNet.ToString("N2")
                            </td>
                        </tr>
                    }
                    <tr style="background: rgba(184, 147, 90, 0.1);">
                        <td style="font-weight: 900; color: var(--primary-navy); font-size: 1.1rem;">@Localizer["الإجمالي السنوي"]</td>
                        <td style="color: #16a34a; font-family: monospace; font-size: 1.2rem; font-weight: 900;">$@grandSales.ToString("N2")</td>
                        <td style="color: #ef4444; font-family: monospace; font-size: 1.2rem; font-weight: 900;">$@grandPurchases.ToString("N2")</td>
                        <td style="font-family: monospace; font-weight: 900; font-size: 1.2rem; color: @((grandSales - grandPurchases) >= 0 ? "#16a34a" : "#ef4444")">
                            $@((grandSales - grandPurchases).ToString("N2"))
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- مكتبات التصدير -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <script>
        // --- دوال التصدير ---
        function exportToExcel() {
            var table = document.getElementById("accountingReportTable");
            var wb = XLSX.utils.table_to_book(table, {sheet: "التقرير المالي"});
            XLSX.writeFile(wb, "Accounting_Report_@(ViewBag.CurrentYear).xlsx");
        }

        function exportToPDF() {
            $('#pdfReportTitle').show();
            var element = document.getElementById('pdfContentArea');
            var opt = {
              margin:       10,
              filename:     'Accounting_Report_@(ViewBag.CurrentYear).pdf',
              image:        { type: 'jpeg', quality: 0.98 },
              html2canvas:  { scale: 2, useCORS: true },
              jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };
            html2pdf().set(opt).from(element).save().then(function(){
                $('#pdfReportTitle').hide();
            });
        }

        // --- تهيئة الرسم البياني بطريقة آمنة تماماً تمنع أخطاء الـ Syntax الخاصة بالجافاسكربت ---
        const salesData = [@Html.Raw(string.Join(",", ((decimal[])ViewBag.MonthlySales).Select(m => m.ToString(System.Globalization.CultureInfo.InvariantCulture))))];
        const purchasesData = [@Html.Raw(string.Join(",", ((decimal[])ViewBag.MonthlyPurchases).Select(m => m.ToString(System.Globalization.CultureInfo.InvariantCulture))))];

        const monthLabels = [
            '@Html.Raw(Localizer["يناير"])', '@Html.Raw(Localizer["فبراير"])', '@Html.Raw(Localizer["مارس"])',
            '@Html.Raw(Localizer["أبريل"])', '@Html.Raw(Localizer["مايو"])', '@Html.Raw(Localizer["يونيو"])',
            '@Html.Raw(Localizer["يوليو"])', '@Html.Raw(Localizer["أغسطس"])', '@Html.Raw(Localizer["سبتمبر"])',
            '@Html.Raw(Localizer["أكتوبر"])', '@Html.Raw(Localizer["نوفمبر"])', '@Html.Raw(Localizer["ديسمبر"])'
        ];

        const rootStyles = getComputedStyle(document.documentElement);
        const goldColor = rootStyles.getPropertyValue('--primary-gold').trim();
        const navyColor = rootStyles.getPropertyValue('--primary-navy').trim();

        const ctx = document.getElementById('financeChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: monthLabels,
                datasets: [
                    {
                        label: '@Html.Raw(Localizer["إيرادات الفواتير"])',
                        data: salesData,
                        borderColor: navyColor,
                        backgroundColor: navyColor + '10',
                        tension: 0.4, borderWidth: 3, pointRadius: 4, fill: true
                    },
                    {
                        label: '@Html.Raw(Localizer["المصروفات والمشتريات"])',
                        data: purchasesData,
                        borderColor: goldColor,
                        backgroundColor: goldColor + '10',
                        tension: 0.4, borderWidth: 3, pointRadius: 4, fill: true
                    }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'top', labels: { usePointStyle: true, font: { family: 'Cairo', weight: 'bold' } } } },
                scales: { y: { beginAtZero: true, ticks: { font: { family: 'monospace', weight: 'bold' } } }, x: { ticks: { font: { family: 'Cairo', weight: 'bold' } } } },
                interaction: { mode: 'index', intersect: false }
            }
        });
    </script>
}