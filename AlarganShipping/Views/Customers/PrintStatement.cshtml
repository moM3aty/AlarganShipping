@model AlarganShipping.Models.Customer
@{
    ViewData["Title"] = Localizer["كشف حساب عميل"];
    Layout = null;

    // سعر الصرف المعتمد للتحويل من دولار إلى ريال عماني
    decimal exchangeRate = 0.386m;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>كشف حساب - @Model.Name</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <link href="~/images/logo.jpg" rel="icon" type="image/jpeg" />

    <style>
        :root {
            --primary-navy: #1e293b;
            --primary-gold: #b45309;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background: #e2e8f0;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            flex-direction: column;
            align-items: center;
        }

        .report-wrapper {
            background: white;
            width: 100%;
            max-width: 900px;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            margin-top: 20px;
            box-sizing: border-box;
        }

        /* الهيدر */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 3px solid var(--primary-gold);
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .logo-area img {
            height: 80px;
            object-fit: contain;
        }

        .logo-area h1 {
            margin: 5px 0 0 0;
            color: var(--primary-navy);
            font-size: 1.6rem;
            font-weight: 900;
        }

        .logo-area p {
            margin: 0;
            color: var(--primary-gold);
            font-weight: 700;
            letter-spacing: 1px;
        }

        .title-area {
            text-align: left;
        }

            .title-area h2 {
                margin: 0;
                font-size: 2.2rem;
                color: var(--primary-navy);
                font-weight: 900;
            }

            .title-area p {
                margin: 5px 0 0 0;
                font-weight: 700;
                color: #64748b;
            }

        /* معلومات العميل */
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .info-box {
            border: 2px solid #e2e8f0;
            padding: 15px;
            border-radius: 8px;
            background: #f8fafc;
        }

            .info-box span.label {
                display: block;
                color: #64748b;
                font-size: 0.9rem;
                font-weight: 800;
                margin-bottom: 5px;
            }

            .info-box span.value {
                display: block;
                color: var(--primary-navy);
                font-size: 1.2rem;
                font-weight: 900;
            }

        /* البطاقات المالية */
        .financial-summary {
            display: flex;
            justify-content: space-between;
            gap: 15px;
            margin-bottom: 40px;
        }

        .fin-card {
            flex: 1;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            border: 1px solid #e2e8f0;
        }

            .fin-card .lbl {
                font-size: 1rem;
                font-weight: 800;
                display: block;
                margin-bottom: 10px;
            }

            .fin-card .val {
                font-size: 1.8rem;
                font-weight: 900;
                font-family: monospace;
            }

        .card-total {
            background: rgba(30, 41, 59, 0.05);
            border-color: var(--primary-navy);
        }

            .card-total .lbl, .card-total .val {
                color: var(--primary-navy);
            }

        .card-paid {
            background: rgba(22, 163, 74, 0.05);
            border-color: #16a34a;
        }

            .card-paid .lbl, .card-paid .val {
                color: #16a34a;
            }

        .card-debt {
            background: rgba(239, 68, 68, 0.05);
            border-color: #ef4444;
        }

            .card-debt .lbl, .card-debt .val {
                color: #ef4444;
            }

        /* الجداول */
        .section-title {
            color: var(--primary-navy);
            font-size: 1.4rem;
            font-weight: 900;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 10px;
            margin-bottom: 15px;
            margin-top: 30px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        th {
            background: var(--primary-navy);
            color: white;
            padding: 10px;
            text-align: right;
            font-size: 1rem;
        }

        td {
            padding: 10px;
            border-bottom: 1px solid #e2e8f0;
            font-weight: 700;
            font-size: 0.95rem;
            color: var(--primary-navy);
        }

        .money-col {
            font-family: monospace;
            font-weight: 900;
        }

        /* التوقيع */
        .signatures {
            display: flex;
            justify-content: space-between;
            margin-top: 60px;
            padding-top: 20px;
            page-break-inside: avoid;
        }

        .sig-box {
            text-align: center;
            width: 250px;
        }

        .sig-line {
            border-bottom: 2px solid #1e293b;
            margin-bottom: 10px;
            height: 40px;
        }

        .sig-title {
            font-weight: 800;
            color: #1e293b;
        }

        /* أزرار التحكم */
        .controls {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
        }

        .btn-action {
            color: white;
            padding: 12px 25px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 900;
            font-size: 1.1rem;
            text-decoration: none;
            font-family: 'Cairo', sans-serif;
        }

        .btn-print {
            background: var(--primary-gold);
        }

        .btn-pdf {
            background: #ef4444;
        }

        .btn-back {
            background: var(--primary-navy);
        }

        /* ========================================================
                            كود الطباعة المحسن (Print Optimized)
                   ======================================================== */
        @@media print {
            @@page {
                size: A4 portrait;
                margin: 0;
            }

            body, html {
                background: white !important;
                padding: 0 !important;
                margin: 0 !important;
                width: 100% !important;
                height: auto !important;
            }

            .controls {
                display: none !important;
            }

            .report-wrapper {
                box-shadow: none !important;
                border: none !important;
                margin: 0 !important;
                padding: 15mm !important; /* هامش مناسب للطباعة */
                width: 210mm !important; /* عرض A4 */
                max-width: 100% !important;
                min-height: 297mm !important;
                box-sizing: border-box !important;
                transform: scale(0.95);
                transform-origin: top center;
            }
            /* ضمان ظهور الألوان والخلفيات */
            * {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
                color-adjust: exact !important;
            }

            th {
                color: white !important;
                background-color: var(--primary-navy) !important;
            }

            .fin-card.card-total {
                background-color: #f1f5f9 !important;
                border-color: var(--primary-navy) !important;
            }

            .fin-card.card-paid {
                background-color: #f0fdf4 !important;
                border-color: #16a34a !important;
            }

            .fin-card.card-debt {
                background-color: #fef2f2 !important;
                border-color: #ef4444 !important;
            }

            .info-box {
                background-color: #f8fafc !important;
                border: 2px solid #e2e8f0 !important;
            }

            img {
                display: inline-block !important;
                visibility: visible !important;
            }
        }
    </style>
</head>
<body>
    <div class="controls">
        <!-- تم تعديل زر الرجوع ليعمل سواء كان في نفس الصفحة أو في تبويب جديد (New Tab) -->
        <a href="@Url.Action("Details", "Customers", new { id = Model.Id })" class="btn-action btn-back" onclick="if(window.history.length <= 1) { window.close(); return false; }">إغلاق / عودة</a>
        <button class="btn-action btn-print" onclick="window.print()">طباعة الكشف</button>
    </div>

    <div class="report-wrapper" id="reportContent">
        <div class="header">
            <div class="logo-area">
                <img src="/images/logo.jpg" alt="Logo" onerror="this.src='/images/logo.png'; this.onerror=null;" />
                <h1>شركة الأرجان للشحن</h1>
                <p>ALARGAN AUTO SHIPPING</p>
            </div>
            <div class="title-area">
                <h2>كشف حساب عميل</h2>
                <p>تاريخ المستند: @DateTime.Now.ToString("yyyy/MM/dd")</p>
            </div>
        </div>

        <div class="info-grid">
            <div class="info-box"><span class="label">اسم العميل (Customer Name):</span><span class="value">@Model.Name</span></div>
            <div class="info-box"><span class="label">كود العميل (Customer Code):</span><span class="value" style="font-family: monospace;">@Model.CustomerCode</span></div>
            <div class="info-box"><span class="label">رقم الهاتف (Phone):</span><span class="value" dir="ltr" style="text-align: right;">@Model.Phone</span></div>
            <div class="info-box"><span class="label">الرقم المدني / السجل التجاري:</span><span class="value">@(string.IsNullOrEmpty(Model.CivilId) ? "-" : Model.CivilId)</span></div>
        </div>

        <div class="section-title">الخلاصة المالية (Financial Summary)</div>
        <div class="financial-summary">
            <div class="fin-card card-total">
                <span class="lbl">إجمالي المبالغ المطلوبة</span>
                @{
                    decimal totalBilled = Model.TotalBalance + Model.TotalPaid;
                    decimal totalBilledOMR = totalBilled * exchangeRate;
                }
                <div class="val">@totalBilledOMR.ToString("N2") OMR</div>
            </div>
            <div class="fin-card card-paid">
                <span class="lbl">إجمالي ما تم سداده</span>
                <div class="val">@((Model.TotalPaid * exchangeRate).ToString("N2")) OMR</div>
            </div>
            <div class="fin-card card-debt">
                <span class="lbl">الرصيد المتبقي (المطلوب)</span>
                <div class="val">@((Model.TotalBalance * exchangeRate).ToString("N2")) OMR</div>
            </div>
        </div>

        <!-- جدول الفواتير / السيارات -->
        <div class="section-title">تفاصيل مبيعات السيارات (Invoices & Cars)</div>
        <table>
            <thead>
                <tr><th>التاريخ</th><th>رقم الفاتورة</th><th>البيان (السيارة)</th><th>المبلغ الكلي</th></tr>
            </thead>
            <tbody>
                @if (Model.Invoices != null && Model.Invoices.Any())
                {
                    foreach (var inv in Model.Invoices.OrderBy(i => i.IssueDate))
                    {
                        var carInfo = Model.Cars?.FirstOrDefault(c => c.Id == inv.CarId);
                        string desc = carInfo != null ? $"{carInfo.Make} {carInfo.Model} {carInfo.Year} (VIN: {carInfo.VIN})" : "فاتورة عامة";
                        <tr>
                            <td>@inv.IssueDate.ToString("yyyy/MM/dd")</td>
                            <td class="money-col">@inv.InvoiceNumber</td>
                            <td style="font-size: 0.85rem;">@desc</td>
                            <td class="money-col" style="color: #b45309;">@((inv.TotalAmount * exchangeRate).ToString("N2")) OMR</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="4" style="text-align:center; color:#64748b;">لا توجد فواتير أو سيارات مسجلة للعميل</td></tr>
                }
            </tbody>
        </table>

        <!-- جدول الدفعات (السندات + المدفوع داخل الفاتورة) -->
        <div class="section-title">سجل الدفعات المسددة (Payments History)</div>
        <table>
            <thead>
                <tr><th>التاريخ</th><th>رقم السند / الفاتورة</th><th>طريقة الدفع / البيان</th><th>المبلغ المدفوع</th></tr>
            </thead>
            <tbody>
                @{
                    bool hasPayments = false;
                }

                <!-- 1. عرض الدفعات المقدمة المسجلة داخل الفواتير -->
                @if (Model.Invoices != null && Model.Invoices.Any(i => i.AmountPaid > 0))
                {
                    hasPayments = true;
                    foreach (var inv in Model.Invoices.Where(i => i.AmountPaid > 0).OrderBy(i => i.IssueDate))
                    {
                        <tr>
                            <td>@inv.IssueDate.ToString("yyyy/MM/dd")</td>
                            <td class="money-col">@inv.InvoiceNumber</td>
                            <td>دفعة مقدمة (مدرجة ضمن الفاتورة)</td>
                            <td class="money-col" style="color: #16a34a;">@((inv.AmountPaid * exchangeRate).ToString("N2")) OMR</td>
                        </tr>
                    }
                }

                <!-- 2. عرض السندات العادية (الإيصالات) المضافة يدوياً -->
                @if (Model.PaymentReceipts != null && Model.PaymentReceipts.Any())
                {
                    hasPayments = true;
                    foreach (var rec in Model.PaymentReceipts.OrderBy(r => r.PaymentDate))
                    {
                        <tr>
                            <td>@rec.PaymentDate.ToString("yyyy/MM/dd")</td>
                            <td class="money-col">@rec.ReceiptNumber</td>
                            <td>@rec.PaymentMethod @(!string.IsNullOrEmpty(rec.ReferenceNumber) ? " - " + rec.ReferenceNumber : "")</td>
                            <td class="money-col" style="color: #16a34a;">@((rec.TotalDeducted * exchangeRate).ToString("N2")) OMR</td>
                        </tr>
                    }
                }

                <!-- 3. في حال عدم وجود أي دفعات -->
                @if (!hasPayments)
                {
                    <tr><td colspan="4" style="text-align:center; color:#64748b;">لا توجد دفعات مسجلة</td></tr>
                }
            </tbody>
        </table>

        <div class="signatures">
            <div class="sig-box"><div class="sig-line"></div><div class="sig-title">توقيع المحاسب<br />Accountant Signature</div></div>
            <div class="sig-box"><div class="sig-line"></div><div class="sig-title">ختم الشركة<br />Company Stamp</div></div>
        </div>
    </div>

    <script>
        function downloadPDF() {
            var element = document.getElementById('reportContent');
            var opt = {
                margin:       [10, 10, 10, 10],
                filename:     'Customer_Statement_@Model.CustomerCode .pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true, windowWidth: 1024 },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' },
                pagebreak:    { mode: ['avoid-all', 'css', 'legacy'] }
            };

            document.querySelector('.controls').style.display = 'none';
            html2pdf().set(opt).from(element).save().then(() => {
                document.querySelector('.controls').style.display = 'flex';
            });
        }
    </script>
</body>
</html>