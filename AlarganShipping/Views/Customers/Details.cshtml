@model AlarganShipping.Models.Customer
@{
    ViewData["Title"] = Localizer["كشف حساب وتفاصيل العميل"];
}

<style>
    .details-header {
        background: linear-gradient(135deg, var(--secondary-navy) 0%, var(--primary-navy) 100%);
        color: white;
        padding: 3rem;
        border-radius: 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 15px 30px rgba(44, 62, 80, 0.15);
        position: relative;
        overflow: hidden;
    }

        .details-header::before {
            content: '';
            position: absolute;
            top: -50px;
            inset-inline-end: -50px;
            width: 250px;
            height: 250px;
            background: radial-gradient(circle, rgba(184, 147, 90, 0.15) 0%, transparent 70%);
            border-radius: 50%;
        }

    .customer-name-large {
        font-size: 2.25rem;
        font-weight: 900;
        margin: 0 0 1rem 0;
        color: var(--primary-gold);
        position: relative;
        z-index: 2;
    }

    .customer-badge {
        background-color: rgba(255,255,255,0.1);
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        letter-spacing: 1px;
        position: relative;
        z-index: 2;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-inline-end: 1rem;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .btn-outline-light {
        background: rgba(255,255,255,0.1);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,0.2);
        transition: 0.3s;
        position: relative;
        z-index: 2;
    }

        .btn-outline-light:hover {
            background: white;
            color: var(--primary-navy);
        }

    .finance-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }

    @@media (min-width: 768px) {
        .finance-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .finance-card {
        background: white;
        padding: 2rem;
        border-radius: 1.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        border: 1px solid #e2e8f0;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .finance-title {
        color: var(--text-muted);
        font-size: 1rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .finance-value {
        font-size: 2.5rem;
        font-weight: 900;
    }

    .val-paid {
        color: #16a34a;
    }

    .val-debt {
        color: #ef4444;
    }

    .val-total {
        color: var(--primary-navy);
    }

    .section-container {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        margin-bottom: 2.5rem;
        border: 1px solid #e2e8f0;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-title i {
            color: var(--primary-gold);
        }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        text-align: start;
    }

        .data-table th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            padding: 1rem;
            border-bottom: 2px solid #e2e8f0;
        }

        .data-table td {
            padding: 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-dark);
            font-weight: 600;
        }

        .data-table tr:hover {
            background-color: #f8fafc;
        }

    .btn-sm-gold {
        color: var(--primary-gold);
        font-weight: 800;
        text-decoration: none;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        background: rgba(184, 147, 90, 0.1);
        transition: 0.3s;
    }

        .btn-sm-gold:hover {
            background: var(--primary-gold);
            color: white;
        }
</style>

<div>
    <div class="details-header">
        <div>
            <h1 class="customer-name-large">@Model.Name</h1>
            <span class="customer-badge"><i class="fa-solid fa-phone"></i> <span dir="ltr">@Model.Phone</span></span>
            <span class="customer-badge"><i class="fa-solid fa-id-card"></i> @(string.IsNullOrEmpty(Model.CivilId) ? Localizer["غير مسجل"] : Model.CivilId)</span>
        </div>
        <div>
            <a href="@Url.Action("Index", "Customers")" class="btn-outline-light">@Localizer["العودة للعملاء"]</a>
        </div>
    </div>

    <div class="finance-grid">
        <div class="finance-card" style="border-bottom: 4px solid var(--primary-navy);">
            <h3 class="finance-title">@Localizer["إجمالي المبالغ المطلوبة"]</h3>
            <div class="finance-value val-total">$@(Model.TotalPaid + Model.TotalBalance)</div>
        </div>
        <div class="finance-card" style="border-bottom: 4px solid #16a34a;">
            <h3 class="finance-title">@Localizer["إجمالي المدفوع"]</h3>
            <div class="finance-value val-paid">$@Model.TotalPaid</div>
        </div>
        <div class="finance-card" style="border-bottom: 4px solid #ef4444;">
            <h3 class="finance-title">@Localizer["المبالغ المتبقية (الديون)"]</h3>
            <div class="finance-value val-debt">$@Model.TotalBalance</div>
        </div>
    </div>

    <div class="section-container">
        <h2 class="section-title"><i class="fa-solid fa-car-rear"></i> @Localizer["سيارات العميل"]</h2>
        <div style="overflow-x: auto;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>@Localizer["السيارة"]</th>
                        <th>@Localizer["رقم الشاصي"] (VIN)</th>
                        <th>@Localizer["سعر الشراء"]</th>
                        <th>@Localizer["إجراءات"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Cars != null && Model.Cars.Any())
                    {
                        foreach (var car in Model.Cars)
                        {
                            <tr>
                                <td>@car.Make @car.Model @car.Year</td>
                                <td style="font-family: monospace; color: var(--text-muted);">@car.VIN</td>
                                <td>$@car.PurchasePrice</td>
                                <td><a href="@Url.Action("Details", "Cars", new { id = car.Id })" class="btn-sm-gold">@Localizer["عرض السيارة"]</a></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" style="text-align: center; color: var(--text-muted); padding: 2rem;">@Localizer["لا توجد سيارات مسجلة لهذا العميل."]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>