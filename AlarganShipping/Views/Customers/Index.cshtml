@model IEnumerable<AlarganShipping.Models.Customer>
@{
    ViewData["Title"] = "إدارة شؤون العملاء";
}

<style>
    /* Premium Customer Cards (Based on Image 2026-02-26 at 1.27.12 PM.jpeg) */
    .cust-card-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    .premium-cust-card {
        background: white;
        border-radius: 2rem;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
        position: relative;
    }

    .cust-badge-id {
        position: absolute;
        top: 2rem;
        left: 2rem;
        background: #f0f7ff;
        color: #3b82f6;
        padding: 0.25rem 0.75rem;
        border-radius: 6px;
        font-weight: 800;
        font-family: monospace;
    }

    .portal-toggle {
        position: absolute;
        top: 2rem;
        right: 2rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        font-weight: 700;
        color: #3b82f6;
    }

    .cust-header-center {
        text-align: center;
        margin-top: 1rem;
        margin-bottom: 2rem;
    }

    .avatar-box {
        width: 80px;
        height: 80px;
        background: #f8fafc;
        border-radius: 50%;
        margin: 0 auto 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: #cbd5e1;
        border: 2px solid #f1f5f9;
    }

    .cust-name-main {
        font-size: 1.5rem;
        font-weight: 900;
        color: #1a2634;
        margin: 0;
    }

    .cust-phone-main {
        color: #64748b;
        font-weight: 700;
        margin-top: 0.25rem;
    }

    .finance-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .fin-item label {
        display: block;
        color: #94a3b8;
        font-size: 0.75rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
    }

    .fin-item span {
        font-size: 1.25rem;
        font-weight: 900;
    }

    .val-success {
        color: #22c55e;
    }

    .val-danger {
        color: #ef4444;
    }

    .portal-access-box {
        background: #f8fafc;
        border-radius: 1rem;
        padding: 1.25rem;
        margin-top: 2rem;
    }

    .access-row {
        display: flex;
        gap: 1rem;
    }

    .access-field {
        flex: 1;
    }

        .access-field label {
            display: block;
            font-size: 0.65rem;
            color: #94a3b8;
            margin-bottom: 0.25rem;
            text-align: center;
        }

        .access-field div {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 0.5rem;
            padding: 0.5rem;
            text-align: center;
            font-family: monospace;
            font-size: 0.85rem;
            color: #3b82f6;
        }

    .btn-statement {
        width: 100%;
        background: #1a2634;
        color: white;
        padding: 0.85rem;
        border-radius: 0.75rem;
        margin-top: 1.5rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
</style>

<div class="cust-card-grid">
    @foreach (var customer in Model)
    {
        <div class="premium-cust-card">
            <div class="cust-badge-id">@customer.CustomerCode</div>
            <div class="portal-toggle">
                <span>البوابة نشطة</span>
                <div style="width: 40px; height: 20px; background: #3b82f6; border-radius: 20px; position: relative;">
                    <div style="width: 16px; height: 16px; background: white; border-radius: 50%; position: absolute; right: 2px; top: 2px;"></div>
                </div>
            </div>

            <div class="cust-header-center">
                <div class="avatar-box">👤</div>
                <h3 class="cust-name-main">@customer.Name</h3>
                <p class="cust-phone-main" dir="ltr">@customer.Phone</p>
            </div>

            <div class="finance-row">
                <div class="fin-item">
                    <label>إجمالي المدفوع</label>
                    <span class="val-success">@customer.TotalPaid <small>ر.ع</small></span>
                </div>
                <div class="fin-item" style="text-align: left;">
                    <label>المتبقي</label>
                    <span class="val-danger">@customer.TotalBalance <small>ر.ع</small></span>
                </div>
            </div>

            <div class="progress-bar-bg" style="height: 6px; background: #f1f5f9; border-radius: 10px; margin-bottom: 2rem;">
                <div style="width: 50%; height: 100%; background: #22c55e; border-radius: 10px;"></div>
            </div>

            <div class="portal-access-box">
                <label style="display: block; text-align: center; font-weight: 800; font-size: 0.75rem; margin-bottom: 1rem; color: #64748b;">بيانات الوصول الآمن</label>
                <div class="access-row">
                    <div class="access-field">
                        <label>المستخدم</label>
                        <div>@customer.PortalUsername</div>
                    </div>
                    <div class="access-field">
                        <label>كلمة المرور</label>
                        <div>@customer.PortalPassword</div>
                    </div>
                </div>
            </div>

            <button class="btn-statement">📄 إصدار كشف حساب</button>
        </div>
    }
</div>