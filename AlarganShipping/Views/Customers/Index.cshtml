@model IEnumerable<AlarganShipping.Models.Customer>
@{
    ViewData["Title"] = Localizer["إدارة شؤون العملاء"];
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<style>
    /* --- التنسيقات المشتركة للهيدر --- */
    .page-header-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: white;
        padding: 1.5rem;
        border-radius: 1.5rem;
        box-shadow: 0 5px 20px rgba(26, 38, 52, 0.03);
        border: 1px solid #f1f5f9;
        margin-bottom: 2rem;
    }

    .page-header-text h2 {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .page-header-text h2 i {
            color: var(--primary-gold);
        }

    .page-header-text p {
        color: var(--text-muted);
        font-size: 0.9rem;
        font-weight: 600;
        margin: 0;
        margin-top: 5px;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .btn-add {
        background: linear-gradient(to right, var(--primary-gold), var(--secondary-gold));
        color: #ffffff;
        font-weight: 800;
        padding: 0.85rem 1.75rem;
        border-radius: 1rem;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(184, 147, 90, 0.3);
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(184, 147, 90, 0.4);
            color: white;
        }

    /* --- أزرار التبديل (Grid/List) --- */
    .view-toggle-wrapper {
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        display: inline-flex;
        padding: 4px;
        gap: 4px;
    }

    .view-toggle-btn {
        background: transparent;
        border: none;
        color: var(--text-muted);
        width: 42px;
        height: 42px;
        border-radius: 10px;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

        .view-toggle-btn.active {
            background: white;
            color: var(--primary-navy);
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }

    /* --- ستايل الأيقونات والأزرار الموحد (Premium Icons) --- */
    .action-btn-pro {
        width: 40px;
        height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        transition: 0.3s;
        text-decoration: none;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        cursor: pointer;
        font-size: 1.1rem;
    }

    .btn-details-pro {
        color: var(--primary-navy);
    }

        .btn-details-pro:hover {
            background: var(--primary-navy);
            color: white;
            border-color: var(--primary-navy);
            transform: scale(1.1);
        }

    .btn-edit-pro {
        color: var(--primary-gold);
    }

        .btn-edit-pro:hover {
            background: var(--primary-gold);
            color: white;
            border-color: var(--primary-gold);
            transform: scale(1.1);
        }

    .btn-delete-pro {
        color: #ef4444;
    }

        .btn-delete-pro:hover {
            background: #ef4444;
            color: white;
            border-color: #ef4444;
            transform: scale(1.1);
        }

    /* --- تنسيق البطاقات (Grid View) --- */
    .cust-grid-modern {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
        gap: 2rem;
    }

    .cust-card-pro {
        background: white;
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        display: flex;
        flex-direction: column;
        transition: 0.3s;
        position: relative;
    }

        .cust-card-pro:hover {
            box-shadow: 0 15px 40px rgba(26, 38, 52, 0.08);
            transform: translateY(-5px);
            border-color: var(--primary-gold);
        }

    .cust-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .portal-status {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.8rem;
        font-weight: 800;
        padding: 5px 12px;
        border-radius: 50px;
    }

    .status-online {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #dcfce7;
    }

    .status-offline {
        background: #fef2f2;
        color: #ef4444;
        border: 1px solid #fee2e2;
    }

    .cust-code {
        background: rgba(184, 147, 90, 0.05);
        color: var(--primary-gold);
        padding: 5px 12px;
        border-radius: 10px;
        font-family: monospace;
        font-weight: 900;
        font-size: 0.85rem;
        border: 1px solid rgba(184, 147, 90, 0.2);
    }

    .cust-profile-main {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .cust-avatar-large {
        width: 65px;
        height: 65px;
        background: #f8fafc;
        border: 2px solid #f1f5f9;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: #cbd5e1;
        flex-shrink: 0;
    }

    .cust-name-info h3 {
        font-size: 1.35rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0 0 4px 0;
    }

    .cust-name-info p {
        color: var(--text-muted);
        font-weight: 700;
        margin: 0;
        font-family: monospace;
        font-size: 1rem;
    }

    .fin-stats {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        background: #f8fafc;
        padding: 1.25rem;
        border-radius: 1.25rem;
        border: 1px solid #f1f5f9;
    }

    .fin-item label {
        display: block;
        font-size: 0.75rem;
        color: var(--text-muted);
        font-weight: 800;
        margin-bottom: 4px;
    }

    .fin-item .amount {
        font-size: 1.2rem;
        font-weight: 900;
    }

    .amt-green {
        color: #16a34a;
    }

    .amt-red {
        color: #ef4444;
    }

    .progress-bar-bg {
        width: 100%;
        height: 8px;
        background: #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }

    .progress-bar-fill {
        height: 100%;
        background: var(--primary-gold);
        border-radius: 10px;
        transition: 1s ease;
    }

    .card-actions-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: auto;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
    }

    /* --- تنسيق الجدول --- */
    .data-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        display: none;
    }

    .table-enterprise {
        width: 100%;
        border-collapse: collapse;
    }

        .table-enterprise th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            padding: 1.2rem 1rem;
            border-bottom: 2px solid #e2e8f0;
            text-align: start;
        }

        .table-enterprise td {
            padding: 1.2rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-dark);
            font-weight: 700;
            vertical-align: middle;
        }

    /* ========================================================
           تعديلات الموبايل (الميديا كويري)
           ======================================================== */
    @@media (max-width: 768px) {
        .page-header-container {
            flex-direction: column;
            align-items: stretch;
            text-align: center;
            gap: 1.5rem;
            padding: 1.25rem;
        }

        .header-actions {
            flex-direction: column;
            width: 100%;
            gap: 1rem;
        }

        .view-toggle-wrapper {
            width: 100%;
            display: flex;
        }

        .view-toggle-btn {
            flex: 1;
        }

        .btn-add {
            width: 100%;
            justify-content: center;
        }

        .cust-grid-modern {
            grid-template-columns: 1fr;
        }

        .cust-profile-main {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
        }

        .cust-name-info {
            margin: 0;
            text-align: center;
        }

        .cust-avatar-large {
            margin: 0 auto;
        }

        .card-actions-row {
            flex-direction: column;
            gap: 1rem;
        }

            .card-actions-row > div {
                width: 100%;
                display: flex;
                justify-content: center;
                gap: 15px;
            }

        .btn-action-dark {
            width: 100%;
        }
    }
</style>

<div class="customers-index-page">
    @Html.AntiForgeryToken()

    <!-- الهيدر الرئيسي -->
    <div class="page-header-container">
        <div class="page-header-text">
            <h2><i class="fa-solid fa-users"></i> @Localizer["إدارة شؤون العملاء"]</h2>
            <p>• @Localizer["النظام الهجين للبطاقات والجداول"]</p>
        </div>
        <div class="header-actions">
            <div class="view-toggle-wrapper">
                <button class="view-toggle-btn active" id="btnGridView" onclick="switchView('grid')" title="@Localizer["عرض البطاقات"]">
                    <i class="fa-solid fa-border-all"></i>
                </button>
                <button class="view-toggle-btn" id="btnListView" onclick="switchView('list')" title="@Localizer["عرض الجدول"]">
                    <i class="fa-solid fa-list-ul"></i>
                </button>
            </div>
            <a href="@Url.Action("Create", "Customers")" class="btn-add"><i class="fa-solid fa-user-plus"></i> @Localizer["إضافة عميل"]</a>
        </div>
    </div>

    <!-- 1. عرض البطاقات (Grid View) -->
    <div id="customersGridView" class="cust-grid-modern">
        @if (Model != null && Model.Any())
        {
            foreach (var customer in Model)
            {
                decimal totalRequired = customer.TotalPaid + customer.TotalBalance;
                decimal payPercentage = totalRequired > 0 ? (customer.TotalPaid / totalRequired) * 100 : 0;

                <div class="cust-card-pro">
                    <div class="cust-card-header">
                        <div class="portal-status @(customer.IsPortalActive ? "status-online" : "status-offline")">
                            <i class="fa-solid @(customer.IsPortalActive ? "fa-circle-check" : "fa-circle-xmark")"></i>
                            <span>@(customer.IsPortalActive? Localizer["البوابة نشطة"] : Localizer["البوابة معطلة"])</span>
                        </div>
                        <div class="cust-code">@customer.CustomerCode</div>
                    </div>

                    <div class="cust-profile-main">
                        <div class="cust-avatar-large"><i class="fa-solid fa-user"></i></div>
                        <div class="cust-name-info">
                            <h3>@customer.Name</h3>
                            <p dir="ltr">@customer.Phone</p>
                        </div>
                    </div>

                    <div class="fin-stats">
                        <div class="fin-item">
                            <label>@Localizer["المتبقي"]</label>
                            <div class="amount amt-red">@customer.TotalBalance.ToString("N0") <span>ر.ع</span></div>
                        </div>
                        <div class="fin-item" style="text-align: left;">
                            <label>@Localizer["إجمالي المدفوع"]</label>
                            <div class="amount amt-green">@customer.TotalPaid.ToString("N0") <span>ر.ع</span></div>
                        </div>
                    </div>

                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: @((int)payPercentage)%;"></div>
                    </div>

                    <div class="card-actions-row">
                        <a href="@Url.Action("Details", "Customers", new { id = customer.Id })" class="btn-action-dark" style="background: var(--primary-navy); color: white; padding: 0.8rem 1.5rem; border-radius: 12px; text-decoration: none; font-weight: 800; flex: 1; text-align: center; margin-inline-end: 10px;">
                            <i class="fa-solid fa-file-invoice"></i> @Localizer["كشف حساب"]
                        </a>
                        <div style="display: flex; gap: 8px;">
                            <a href="@Url.Action("Edit", "Customers", new { id = customer.Id })" class="action-btn-pro btn-edit-pro" title="@Localizer["تعديل"]">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </a>
                            <button type="button" class="action-btn-pro btn-delete-pro" onclick="confirmDelete(@customer.Id)" title="@Localizer["حذف"]">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1 / -1; text-align: center; padding: 5rem; background: white; border-radius: 2rem; color: var(--text-muted); border: 2px dashed #f1f5f9;">
                <i class="fa-solid fa-users-slash" style="font-size: 4rem; margin-bottom: 1.5rem; color: #cbd5e1;"></i>
                <h3 style="font-weight: 900; color: var(--primary-navy);">@Localizer["لا يوجد عملاء مسجلين حالياً."]</h3>
            </div>
        }
    </div>

    <!-- 2. عرض الجدول (List View) -->
    <div id="customersTableView" class="data-card">
        <div style="overflow-x: auto; width: 100%;">
            <table id="customersDataTable" class="table-enterprise display" style="width:100%">
                <thead>
                    <tr>
                        <th>@Localizer["كود العميل"]</th>
                        <th>@Localizer["بيانات العميل"]</th>
                        <th>@Localizer["رقم الهاتف"]</th>
                        <th>@Localizer["إجمالي المدفوع"]</th>
                        <th>@Localizer["الرصيد المتبقي"]</th>
                        <th style="text-align: center;">@Localizer["إجراءات"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (var cust in Model)
                        {
                            <tr>
                                <td style="font-family: monospace; font-weight: 900; color: var(--primary-gold);">@cust.CustomerCode</td>
                                <td>
                                    <div class="cust-info-td">
                                        <div class="cust-avatar">@(string.IsNullOrEmpty(cust.Name) ? "C" : cust.Name.Substring(0, 1))</div>
                                        <div>
                                            <div style="font-weight: 900; color: var(--primary-navy); font-size: 1.05rem;">@cust.Name</div>
                                            <div style="color: var(--text-muted); font-size: 0.8rem;">@cust.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td dir="ltr" style="text-align: end; font-weight: 800;">@cust.Phone</td>
                                <td><span style="color: #16a34a; font-weight: 900;">@cust.TotalPaid.ToString("N0") <span>ر.ع</span></span></td>
                                <td><span style="color: #ef4444; font-weight: 900;">@cust.TotalBalance.ToString("N0") <span>ر.ع</span></span></td>
                                <td>
                                    <div style="display: flex; gap: 8px; justify-content: center;">
                                        <a href="@Url.Action("Details", "Customers", new { id = cust.Id })" class="action-btn-pro btn-details-pro" title="@Localizer["كشف حساب"]"><i class="fa-solid fa-file-invoice"></i></a>
                                        <a href="@Url.Action("Edit", "Customers", new { id = cust.Id })" class="action-btn-pro btn-edit-pro" title="@Localizer["تعديل"]"><i class="fa-solid fa-pen-to-square"></i></a>
                                        <button type="button" class="action-btn-pro btn-delete-pro" onclick="confirmDelete(@cust.Id)" title="@Localizer["حذف"]"><i class="fa-solid fa-trash-can"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script>
        // دالة الحذف المصلحة والمحمية من تعارض النصوص
        function confirmDelete(id) {
            Swal.fire({
                title: "@Html.Raw(Localizer["هل أنت متأكد؟"])",
                text: "@Html.Raw(Localizer["لن تتمكن من التراجع عن عملية الحذف!"])",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#ef4444",
                cancelButtonColor: "var(--primary-navy)",
                confirmButtonText: "@Html.Raw(Localizer["نعم، احذفه!"])",
                cancelButtonText: "@Html.Raw(Localizer["إلغاء"])"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Customers")/' + id,
                        type: "POST",
                        data: {
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({
                                    title: "@Html.Raw(Localizer["تم الحذف!"])",
                                    text: "@Html.Raw(Localizer["تم حذف بيانات العميل بنجاح."])",
                                    icon: "success",
                                    timer: 2000,
                                    showConfirmButton: false
                                }).then(() => location.reload());
                            } else {
                                Swal.fire("@Html.Raw(Localizer["خطأ!"])", res.message, "error");
                            }
                        }
                    });
                }
            });
        }

        function switchView(viewType) {
            if (viewType === 'list') {
                $('#customersGridView').hide();
                $('#customersTableView').fadeIn(300);
                $('#btnListView').addClass('active');
                $('#btnGridView').removeClass('active');
                localStorage.setItem('preferredCustomerView', 'list');
                if ($.fn.DataTable.isDataTable('#customersDataTable')) {
                    $('#customersDataTable').DataTable().columns.adjust().responsive.recalc();
                }
            } else {
                $('#customersTableView').hide();
                $('#customersGridView').fadeIn(300);
                $('#btnGridView').addClass('active');
                $('#btnListView').removeClass('active');
                localStorage.setItem('preferredCustomerView', 'grid');
            }
        }

        $(document).ready(function () {
            var dir = $('html').attr('dir') === 'rtl';
            $('#customersDataTable').DataTable({
                "language": { "url": dir ? "//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json" : "" },
                "pageLength": 10,
                "responsive": true,
                "dom": '<"top"f>rt<"bottom"lp><"clear">'
            });
            switchView(localStorage.getItem('preferredCustomerView') || 'grid');
        });
    </script>
}