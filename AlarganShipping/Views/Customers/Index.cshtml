<!-- مسار الملف في المشروع: Views/Customers/Index.cshtml -->
@model IEnumerable<AlarganShipping.Models.Customer>
@{
    ViewData["Title"] = Localizer["إدارة شؤون العملاء"];
}

<style>
    .page-header-container {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .page-header-text h2 {
        font-size: 1.8rem;
        font-weight: 900;
        color: #1a2634;
        margin: 0;
    }

    .page-header-text p {
        color: #64748b;
        font-size: 0.9rem;
        font-weight: 600;
        margin: 0;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .btn-add {
        background: linear-gradient(to right, #be955b, #d4af7a);
        color: #ffffff;
        font-weight: 800;
        padding: 0.85rem 1.75rem;
        border-radius: 1rem;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(190, 149, 91, 0.3);
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(190, 149, 91, 0.4);
            color: white;
        }

    .cust-grid-modern {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 2rem;
    }

    .cust-card-pro {
        background: white;
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        display: flex;
        flex-direction: column;
        transition: 0.3s;
    }

        .cust-card-pro:hover {
            box-shadow: 0 15px 40px rgba(26, 38, 52, 0.08);
            transform: translateY(-5px);
            border-color: #be955b;
        }

    .cust-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .portal-switch {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.8rem;
        font-weight: 800;
        color: #16a34a;
    }

    .switch-icon {
        width: 36px;
        height: 20px;
        background: #be955b;
        border-radius: 20px;
        position: relative;
    }

        .switch-icon::after {
            content: '';
            position: absolute;
            top: 2px;
            inset-inline-end: 2px;
            width: 16px;
            height: 16px;
            background: white;
            border-radius: 50%;
        }

    .cust-code {
        background: rgba(190, 149, 91, 0.1);
        color: #be955b;
        padding: 5px 12px;
        border-radius: 8px;
        font-family: monospace;
        font-weight: 900;
        font-size: 0.85rem;
        border: 1px solid rgba(190, 149, 91, 0.2);
    }

    .cust-profile-area {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .cust-name-info {
        text-align: right;
        flex: 1;
        margin-inline-end: 1rem;
    }

        .cust-name-info h3 {
            font-size: 1.4rem;
            font-weight: 900;
            color: #1a2634;
            margin: 0 0 0.5rem 0;
        }

        .cust-name-info p {
            color: #64748b;
            font-weight: 700;
            margin: 0;
            font-family: monospace;
            font-size: 1.1rem;
        }

    .cust-avatar-large {
        width: 70px;
        height: 70px;
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: #cbd5e1;
        flex-shrink: 0;
    }

    .fin-stats {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .fin-item {
        text-align: right;
    }

        .fin-item label {
            display: block;
            font-size: 0.8rem;
            color: #64748b;
            font-weight: 800;
            margin-bottom: 0.25rem;
        }

        .fin-item .amount {
            font-size: 1.4rem;
            font-weight: 900;
        }

            .fin-item .amount span {
                font-size: 0.8rem;
                font-weight: 700;
            }

    .amt-green {
        color: #16a34a;
    }

    .amt-red {
        color: #ef4444;
    }

    .progress-wrapper {
        margin-bottom: 2rem;
    }

    .progress-bar-bg {
        width: 100%;
        height: 8px;
        background: #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 0.5rem;
    }

    .progress-bar-fill {
        height: 100%;
        background: #be955b;
        border-radius: 10px;
    }

    .progress-labels {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        color: #94a3b8;
        font-weight: 700;
    }

    .credentials-box {
        background: #f8fafc;
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        border: 1px solid #f1f5f9;
    }

    .cred-title {
        text-align: center;
        font-size: 0.75rem;
        font-weight: 800;
        color: #94a3b8;
        margin-bottom: 1rem;
    }

    .cred-row {
        display: flex;
        gap: 1rem;
    }

    .cred-field {
        flex: 1;
        text-align: center;
    }

        .cred-field label {
            display: block;
            font-size: 0.7rem;
            color: #64748b;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .cred-field .cred-val {
            background: white;
            border: 1px solid #e2e8f0;
            padding: 0.5rem;
            border-radius: 8px;
            color: #1a2634;
            font-family: monospace;
            font-weight: 800;
            font-size: 0.9rem;
        }

    .btn-action-dark {
        background: #1a2634;
        color: white;
        border: none;
        padding: 1.2rem;
        border-radius: 16px;
        font-weight: 800;
        font-size: 1rem;
        font-family: inherit;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        transition: 0.3s;
        width: 100%;
    }

        .btn-action-dark:hover {
            background: #2b3f56;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(26,38,52,0.2);
            color: white;
        }
</style>

<div>
    <div class="page-header-container">
        <div class="page-header-text">
            <h2>@Localizer["إدارة شؤون العملاء"]</h2>
            <p>• @Localizer["نظام الإدارة اللوجستية الذكي"]</p>
        </div>
        <div class="header-actions">
            <a href="@Url.Action("Create", "Customers")" class="btn-add"><i class="fa-solid fa-plus"></i> @Localizer["إضافة عميل"]</a>
        </div>
    </div>

    <div class="cust-grid-modern">
        @if (Model != null && Model.Any())
        {
            foreach (var customer in Model)
            {
                decimal totalRequired = customer.TotalPaid + customer.TotalBalance;
                decimal payPercentage = totalRequired > 0 ? (customer.TotalPaid / totalRequired) * 100 : 0;

                <div class="cust-card-pro">
                    <div class="cust-card-header">
                        <div class="portal-switch">
                            <div class="switch-icon"></div>
                            <span>@Localizer["البوابة نشطة"]</span>
                        </div>
                        <div class="cust-code">@customer.CustomerCode</div>
                    </div>

                    <div class="cust-profile-area">
                        <div class="cust-name-info">
                            <h3>@customer.Name</h3>
                            <p dir="ltr">@customer.Phone</p>
                        </div>
                        <div class="cust-avatar-large"><i class="fa-solid fa-user"></i></div>
                    </div>

                    <div class="fin-stats">
                        <div class="fin-item">
                            <label>@Localizer["المتبقي"]</label>
                            <div class="amount amt-red">@customer.TotalBalance <span>ر.ع</span></div>
                        </div>
                        <div class="fin-item" style="text-align: left;">
                            <label>@Localizer["إجمالي المدفوع"]</label>
                            <div class="amount amt-green">@customer.TotalPaid <span>ر.ع</span></div>
                        </div>
                    </div>

                    <div class="progress-wrapper">
                        <div class="progress-bar-bg">
                            <div class="progress-bar-fill" style="width: @((int)payPercentage)%;"></div>
                        </div>
                        <div class="progress-labels">
                            <span>@Localizer["الإجمالي:"] @totalRequired ر.ع</span>
                            <span>@Localizer["نسبة السداد:"] @((int)payPercentage)%</span>
                        </div>
                    </div>

                    <div class="credentials-box">
                        <div class="cred-title">@Localizer["بيانات الوصول الآمن"]</div>
                        <div class="cred-row">
                            <div class="cred-field">
                                <label>@Localizer["كلمة المرور"]</label>
                                <div class="cred-val">@customer.PortalPassword</div>
                            </div>
                            <div class="cred-field">
                                <label>@Localizer["المستخدم"]</label>
                                <div class="cred-val">@customer.PortalUsername</div>
                            </div>
                        </div>
                    </div>

                    <a href="@Url.Action("Details", "Customers", new { id = customer.Id })" class="btn-action-dark">
                        <i class="fa-solid fa-file-invoice"></i> @Localizer["إصدار كشف حساب"]
                    </a>
                </div>
            }
        }
    </div>
</div>