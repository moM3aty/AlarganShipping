@model AlarganShipping.Models.Customer
@{
    ViewData["Title"] = "إضافة عميل جديد";
}

<style>
    /* Premium Pure CSS - Same core logic as Car Create to maintain UI consistency */
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: #2b3f56;
        margin: 0;
    }

    .btn-back {
        background-color: #f1f5f9;
        color: #475569;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .btn-back:hover {
            background-color: #e2e8f0;
            color: #1e293b;
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.25rem;
        box-shadow: 0 10px 30px rgba(43, 63, 86, 0.05);
        border: 1px solid #f8fafc;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
    }

        .premium-form-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(to left, #be955b, #d4af7a);
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @@media (min-width: 768px) {
        .form-grid

    {
        grid-template-columns: repeat(2, 1fr);
    }

    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-label {
        font-weight: 700;
        color: #2b3f56;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-control {
        padding: 0.85rem 1.25rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: 'Cairo', sans-serif;
        font-size: 1rem;
        color: #1e293b;
        background-color: #f8fafc;
        transition: all 0.3s ease;
        outline: none;
    }

        .form-control:focus {
            border-color: #be955b;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(190, 149, 91, 0.1);
        }

    .form-control-full {
        grid-column: 1 / -1;
    }

    .form-actions {
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
    }

    .btn-submit {
        background: linear-gradient(to right, #be955b, #d4af7a);
        color: #ffffff;
        border: none;
        padding: 0.85rem 2.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        font-family: 'Cairo', sans-serif;
        box-shadow: 0 4px 15px rgba(190, 149, 91, 0.3);
        transition: all 0.3s ease;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(190, 149, 91, 0.4);
        }

    .text-danger {
        color: #dc2626;
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 0.25rem;
    }
</style>

<div>
    <div class="form-page-header">
        <h2 class="form-page-title">إضافة عميل جديد</h2>
        <a href="@Url.Action("Index", "Customers")" class="btn-back">عودة للقائمة</a>
    </div>

    <div class="premium-form-card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Name" class="form-label">الاسم الكامل</label>
                    <input asp-for="Name" class="form-control" placeholder="اسم العميل الرباعي أو اسم الشركة" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Phone" class="form-label">رقم الهاتف</label>
                    <input asp-for="Phone" class="form-control" dir="ltr" style="text-align: right;" placeholder="+968 0000 0000" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">البريد الإلكتروني</label>
                    <input asp-for="Email" type="email" class="form-control" dir="ltr" style="text-align: right;" placeholder="example@domain.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="CivilId" class="form-label">الرقم المدني / رقم السجل التجاري</label>
                    <input asp-for="CivilId" class="form-control" placeholder="رقم الهوية للخليجيين أو الإقامة" />
                    <span asp-validation-for="CivilId" class="text-danger"></span>
                </div>

                <div class="form-group form-control-full">
                    <label asp-for="Address" class="form-label">العنوان التفصيلي</label>
                    <textarea asp-for="Address" class="form-control" rows="3" placeholder="الدولة، المدينة، المنطقة، الشارع..."></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">حفظ بيانات العميل</button>
            </div>
        </form>
    </div>
</div>