<!-- مسار الملف في المشروع: Views/Customers/Create.cshtml -->
@model AlarganShipping.Models.Customer
@{
    ViewData["Title"] = Localizer["إضافة عميل جديد"];
}

<style>
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.75rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
    }

    .btn-back {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: var(--primary-navy);
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        padding: 3rem;
        position: relative;
        overflow: hidden;
    }

        .premium-form-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            left: 0;
            height: 6px;
            background: linear-gradient(to right, var(--primary-navy), var(--primary-gold));
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media (min-width: 768px) {
        .form-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-group-full {
        grid-column: 1 / -1;
    }

    .form-label {
        font-weight: 800;
        color: var(--primary-navy);
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-control {
        padding: 1rem 1.25rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 1rem;
        color: var(--text-dark);
        background-color: #f8fafc;
        transition: 0.3s;
        outline: none;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(195, 154, 92, 0.1);
        }

    .form-actions {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
    }

    .btn-submit {
        background: var(--primary-navy);
        color: #ffffff;
        border: none;
        padding: 1rem 3rem;
        border-radius: 1rem;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 4px 15px rgba(26, 42, 58, 0.3);
        font-family: inherit;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-submit:hover {
            background: var(--secondary-navy);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(26, 42, 58, 0.4);
        }

    .text-danger {
        color: #ef4444;
        font-size: 0.85rem;
        font-weight: 700;
        margin-top: 0.4rem;
    }
</style>

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<div>
    <div class="form-page-header">
        <h2 class="form-page-title"><i class="fa-solid fa-user-plus" style="color: var(--primary-gold); margin-inline-end: 10px;"></i> @Localizer["إضافة عميل جديد"]</h2>
        <a href="@Url.Action("Index", "Customers")" class="btn-back">@Localizer["عودة للقائمة"]</a>
    </div>

    <div class="premium-form-card">
        <form asp-action="Create" method="post" id="customerForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Name" class="form-label">@Localizer["الاسم الكامل"]</label>
                    <input asp-for="Name" class="form-control" placeholder="@Localizer["اسم العميل أو الشركة"]" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Phone" class="form-label">@Localizer["رقم الهاتف"]</label>
                    <input asp-for="Phone" class="form-control" dir="ltr" placeholder="+968 0000 0000" required />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">@Localizer["البريد الإلكتروني"]</label>
                    <input asp-for="Email" type="email" class="form-control" dir="ltr" placeholder="example@domain.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="CivilId" class="form-label">@Localizer["الرقم المدني / رقم السجل التجاري"]</label>
                    <input asp-for="CivilId" class="form-control" placeholder="@Localizer["رقم الهوية أو الإقامة"]" />
                    <span asp-validation-for="CivilId" class="text-danger"></span>
                </div>

                <div class="form-group form-group-full">
                    <label asp-for="Address" class="form-label">@Localizer["العنوان التفصيلي"]</label>
                    <textarea asp-for="Address" class="form-control" rows="3" placeholder="@Localizer["الدولة، المدينة، المنطقة، الشارع..."]"></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit" id="btnSubmit">
                    <i class="fa-solid fa-save"></i> @Localizer["حفظ بيانات العميل"]
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#customerForm').on('submit', function(e) {
                e.preventDefault();
                var form = $(this);
                if (!form[0].checkValidity()) { form[0].reportValidity(); return; }

                var btn = $('#btnSubmit');
                var originalText = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin"></i> @Localizer["جاري الحفظ..."]').prop('disabled', true);

                $.ajax({
                    url: form.attr('action'), type: form.attr('method'), data: form.serialize(),
                    success: function () {
                        Swal.fire({
                            title: '@Localizer["تم الحفظ بنجاح!"]',
                            icon: 'success',
                            confirmButtonColor: 'var(--primary-gold)',
                            confirmButtonText: '@Localizer["العودة للقائمة"]',
                            showCancelButton: true,
                            cancelButtonText: '@Localizer["إضافة عميل آخر"]',
                            cancelButtonColor: 'var(--primary-navy)'
                        }).then((result) => {
                            if (result.isConfirmed) { window.location.href = '@Url.Action("Index", "Customers")'; }
                            else { form[0].reset(); btn.html(originalText).prop('disabled', false); }
                        });
                    },
                    error: function () {
                        Swal.fire({ title: '@Localizer["خطأ!"]', text: '@Localizer["حدث خطأ أثناء الحفظ."]', icon: 'error', confirmButtonColor: 'var(--primary-navy)' });
                        btn.html(originalText).prop('disabled', false);
                    }
                });
            });
        });
    </script>
}