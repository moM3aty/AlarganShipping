@model IEnumerable<AlarganShipping.Models.Car>
@using AlarganShipping.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Context

@{
    ViewData["Title"] = Localizer["لوحة التحكم الشاملة"];

    // حساب الإحصائيات الديناميكية من قاعدة البيانات
    var totalCars = Context.Cars.Count();
    var activeShipments = Context.Shipments.Count(s => s.Status != "Arrived" && s.Status != "Cleared");

    var totalSales = Context.Invoices.Sum(i => (decimal?)i.TotalAmount) ?? 0;
    var totalPaid = Context.PaymentReceipts.Sum(p => (decimal?)p.Amount) ?? 0;
    var pendingAmounts = totalSales - totalPaid;
    if (pendingAmounts < 0) pendingAmounts = 0; // منع الديون السالبة

    // إحصائيات ملخص المركبات
    var purchasedCarsCount = Context.Cars.Count(c => c.StatusId == 1);
    var usaWarehouseCount = Context.Cars.Count(c => c.StatusId == 2);
    var inTransitCarsCount = Context.Cars.Count(c => c.StatusId == 3);
    var arrivedCarsCount = Context.Cars.Count(c => c.StatusId >= 4);

    // إحصائيات ملخص الشحنات
    var loadingShipments = Context.Shipments.Count(s => s.Status == "Pending" || s.Status == "Loading");
    var sailedShipments = Context.Shipments.Count(s => s.Status == "Sailed");

    // إحصائيات الرسوم البيانية
    var sumSeaFreight = Context.Invoices.Sum(i => (decimal?)i.SeaFreight) ?? 0;
    var sumLandFreight = Context.Invoices.Sum(i => (decimal?)i.LandFreight) ?? 0;
    var sumCustoms = Context.Invoices.Sum(i => (decimal?)i.CustomsFees) ?? 0;
    var sumAdmin = Context.Invoices.Sum(i => (decimal?)i.AdminFees) ?? 0;

    // جلب أحدث 5 سيارات
    var recentCars = Context.Cars
        .Include(c => c.Customer)
        .Include(c => c.Auction)
        .OrderByDescending(c => c.Id)
        .Take(5)
        .ToList();
}

<style>
    .dashboard-wrapper {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* --- الإحصائيات العلوية --- */
    .top-stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.5rem;
    }

    .stat-card {
        background: white;
        border-radius: 1.5rem;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(26, 42, 58, 0.02);
        position: relative;
        overflow: hidden;
    }

        .stat-card::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--primary-gold);
        }

    .stat-info h4 {
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 800;
        margin: 0 0 0.5rem 0;
    }

    .stat-info .stat-val {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--primary-navy);
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 14px;
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    /* --- القسم الأوسط (الملخصات) --- */
    .middle-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media (min-width: 1024px) {
        .middle-grid {
            grid-template-columns: 1fr 2fr;
        }
    }

    .panel-card {
        background: white;
        border-radius: 1.5rem;
        padding: 1.5rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(26, 42, 58, 0.02);
    }

    .panel-title {
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    /* قائمة أحدث التحميلات */
    .updates-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .update-item {
        display: flex;
        gap: 1rem;
        align-items: center;
        padding-bottom: 1rem;
        border-bottom: 1px solid #f1f5f9;
    }

        .update-item:last-child {
            border: none;
            padding-bottom: 0;
        }

    .update-icon {
        width: 45px;
        height: 45px;
        border-radius: 10px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-navy);
        font-size: 1.2rem;
    }

    .update-details h5 {
        font-size: 0.95rem;
        font-weight: 800;
        color: var(--primary-navy);
        margin: 0 0 0.2rem 0;
    }

    .update-details p {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin: 0;
    }

    /* الجداول المصغرة */
    .mini-table {
        width: 100%;
        border-collapse: collapse;
        text-align: center;
    }

        .mini-table th {
            color: var(--text-muted);
            font-size: 0.85rem;
            font-weight: 800;
            padding-bottom: 1rem;
            border-bottom: 2px solid #f1f5f9;
        }

        .mini-table td {
            padding: 1rem 0;
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--text-dark);
            border-bottom: 1px solid #f1f5f9;
        }

        .mini-table tr:last-child td {
            border: none;
        }

    /* --- القسم السفلي (الرسوم البيانية) --- */
    .charts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .chart-box {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(26, 42, 58, 0.02);
        text-align: center;
    }

    .chart-title {
        font-size: 1rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 0.5rem;
    }

    .chart-subtitle {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
    }

    .doughnut-container {
        position: relative;
        width: 220px;
        height: 220px;
        margin: 0 auto;
    }

    .doughnut-center-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--primary-navy);
    }
</style>

<div class="dashboard-wrapper">
    <!-- Row 1: Stats -->
    <div class="top-stats-grid">
        <div class="stat-card">
            <div class="stat-info">
                <h4>@Localizer["إجمالي السيارات"]</h4>
                <div class="stat-val">@totalCars</div>
            </div>
            <div class="stat-icon"><i class="fa-solid fa-car"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h4>@Localizer["الشحنات النشطة"]</h4>
                <div class="stat-val">@activeShipments</div>
            </div>
            <div class="stat-icon"><i class="fa-solid fa-ship"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h4>@Localizer["إجمالي الإيرادات"]</h4>
                <div class="stat-val" dir="ltr">@totalSales.ToString("N0") <span style="font-size:1rem;">$</span></div>
            </div>
            <div class="stat-icon" style="color: #10b981; background: rgba(16, 185, 129, 0.1);"><i class="fa-solid fa-money-bill-trend-up"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h4>@Localizer["الديون المعلقة"]</h4>
                <div class="stat-val" dir="ltr">@pendingAmounts.ToString("N0") <span style="font-size:1rem;">$</span></div>
            </div>
            <div class="stat-icon" style="color: #ef4444; background: rgba(239, 68, 68, 0.1);"><i class="fa-solid fa-clock-rotate-left"></i></div>
        </div>
    </div>

    <!-- Row 2: Summaries -->
    <div class="middle-grid">
        <div class="panel-card">
            <div class="panel-title">
                <span><i class="fa-solid fa-bolt" style="color: var(--primary-gold); margin-inline-end: 5px;"></i> @Localizer["أحدث التحميلات"]</span>
            </div>
            <div class="updates-list">
                @if (recentCars.Any())
                {
                    foreach (var car in recentCars)
                    {
                        <div class="update-item">
                            <div class="update-icon"><i class="fa-solid fa-car-side"></i></div>
                            <div class="update-details">
                                <h5>@car.Make @car.Model @car.Year</h5>
                                <p>@Localizer["العميل:"] @(car.Customer?.Name ?? "-") | @Localizer["المزاد:"] @(car.Auction?.Name ?? "-")</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p style="text-align:center; color:var(--text-muted); margin-top:2rem;">@Localizer["لا توجد سيارات مضافة حديثاً"]</p>
                }
            </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div class="panel-card">
                <div class="panel-title"><i class="fa-solid fa-car-rear" style="color: var(--primary-navy); margin-inline-end: 5px;"></i> @Localizer["ملخص المركبات"]</div>
                <table class="mini-table">
                    <thead>
                        <tr><th>@Localizer["الموقع"]</th><th>@Localizer["في الطريق"]</th><th>@Localizer["متوفر"]</th><th>@Localizer["المجموع"]</th></tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@Localizer["المستودع الأمريكي"]</td>
                            <td>@purchasedCarsCount</td>
                            <td>@usaWarehouseCount</td>
                            <td>@(purchasedCarsCount + usaWarehouseCount)</td>
                        </tr>
                        <tr>
                            <td>@Localizer["ميناء صحار / صلالة"]</td>
                            <td>@inTransitCarsCount</td>
                            <td>@arrivedCarsCount</td>
                            <td>@(inTransitCarsCount + arrivedCarsCount)</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="panel-card">
                <div class="panel-title"><i class="fa-solid fa-ship" style="color: var(--primary-navy); margin-inline-end: 5px;"></i> @Localizer["ملخص الشحنات"]</div>
                <table class="mini-table">
                    <thead>
                        <tr><th>@Localizer["الموقع"]</th><th>@Localizer["قيد التحميل"]</th><th>@Localizer["في الطريق"]</th><th>@Localizer["المجموع"]</th></tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@Localizer["الشحن البحري"]</td>
                            <td>@loadingShipments</td>
                            <td>@sailedShipments</td>
                            <td>@(loadingShipments + sailedShipments)</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Row 3: Doughnut Charts -->
    <div class="charts-grid">
        <div class="chart-box">
            <h3 class="chart-title">@Localizer["حالة الفواتير والإيرادات"]</h3>
            <p class="chart-subtitle">@Localizer["مبالغ الفواتير الصادرة للعملاء"]</p>
            <div class="doughnut-container">
                <canvas id="invoiceChart"></canvas>
                <div class="doughnut-center-text" id="invoiceTotalText"></div>
            </div>
        </div>
        <div class="chart-box">
            <h3 class="chart-title">@Localizer["توزيع التكاليف اللوجستية"]</h3>
            <p class="chart-subtitle">@Localizer["الشحن البحري مقابل النقل الداخلي"]</p>
            <div class="doughnut-container">
                <canvas id="shippingChart"></canvas>
                <div class="doughnut-center-text" id="shippingTotalText"></div>
            </div>
        </div>
        <div class="chart-box">
            <h3 class="chart-title">@Localizer["الجمارك والعمولات"]</h3>
            <p class="chart-subtitle">@Localizer["مبالغ الجمارك مقابل عمولات الشركة"]</p>
            <div class="doughnut-container">
                <canvas id="taxChart"></canvas>
                <div class="doughnut-center-text" id="taxTotalText"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // المتغيرات الديناميكية من السيرفر - تجنب مشكلة الفواصل العشرية
        const jsTotalSales = @Html.Raw(totalSales.ToString(System.Globalization.CultureInfo.InvariantCulture));
        const jsTotalPaid = @Html.Raw(totalPaid.ToString(System.Globalization.CultureInfo.InvariantCulture));
        const jsPending = @Html.Raw(pendingAmounts.ToString(System.Globalization.CultureInfo.InvariantCulture));

        const jsSeaFreight = @Html.Raw(sumSeaFreight.ToString(System.Globalization.CultureInfo.InvariantCulture));
        const jsLandFreight = @Html.Raw(sumLandFreight.ToString(System.Globalization.CultureInfo.InvariantCulture));
        const jsTotalFreight = jsSeaFreight + jsLandFreight;

        const jsCustoms = @Html.Raw(sumCustoms.ToString(System.Globalization.CultureInfo.InvariantCulture));
        const jsAdmin = @Html.Raw(sumAdmin.ToString(System.Globalization.CultureInfo.InvariantCulture));
        const jsTotalTaxAdmin = jsCustoms + jsAdmin;

        // تحديث النصوص المركزية للرسوم البيانية
        document.getElementById('invoiceTotalText').innerHTML = jsTotalSales.toLocaleString() + '<br><span style="font-size:0.7rem;color:var(--text-muted);">TOTAL</span>';
        document.getElementById('shippingTotalText').innerHTML = jsTotalFreight.toLocaleString() + '<br><span style="font-size:0.7rem;color:var(--text-muted);">TOTAL</span>';
        document.getElementById('taxTotalText').innerHTML = jsTotalTaxAdmin.toLocaleString() + '<br><span style="font-size:0.7rem;color:var(--text-muted);">TOTAL</span>';

        const rootStyles = getComputedStyle(document.documentElement);
        const goldColor = rootStyles.getPropertyValue('--primary-gold').trim();
        const navyColor = rootStyles.getPropertyValue('--primary-navy').trim();

        const commonOptions = {
            responsive: true, maintainAspectRatio: false, cutout: '75%',
            plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, font: { family: 'Cairo' } } } }
        };

        // الرسم 1 (الفواتير)
        new Chart(document.getElementById('invoiceChart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['@Html.Raw(Localizer["المدفوع"])', '@Html.Raw(Localizer["المتبقي"])'],
                datasets: [{ data: [jsTotalPaid, jsPending], backgroundColor: ['#16a34a', '#e2e8f0'], borderWidth: 0 }]
            },
            options: commonOptions
        });

        // الرسم 2 (الشحن البحري والداخلي)
        new Chart(document.getElementById('shippingChart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['@Html.Raw(Localizer["الشحن البحري"])', '@Html.Raw(Localizer["النقل الداخلي"])'],
                datasets: [{ data: [jsSeaFreight, jsLandFreight], backgroundColor: [goldColor, navyColor], borderWidth: 0 }]
            },
            options: commonOptions
        });

        // الرسم 3 (الجمارك والعمولات)
        new Chart(document.getElementById('taxChart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['@Html.Raw(Localizer["الجمارك"])', '@Html.Raw(Localizer["عمولة الشركة"])'],
                datasets: [{ data: [jsCustoms, jsAdmin], backgroundColor: ['#ef4444', goldColor], borderWidth: 0 }]
            },
            options: commonOptions
        });
    </script>
}