@using System.Text.Json
@using Microsoft.EntityFrameworkCore
@inject AlarganShipping.Models.ApplicationDbContext DbContext
@inject IWebHostEnvironment Env
@{
    ViewData["Title"] = Localizer["اتصل بنا"];

    // جلب رقم التواصل من ملف الإعدادات ديناميكياً لتفعيل أزرار الـ Promo
    string settingsPath = System.IO.Path.Combine(Env.WebRootPath, "settings.json");
    string phone = "96800000000"; // قيمة افتراضية في حال عدم وجود الملف
    if (System.IO.File.Exists(settingsPath))
    {
        var json = System.IO.File.ReadAllText(settingsPath);
        using var doc = JsonDocument.Parse(json);
        if (doc.RootElement.TryGetProperty("InquiryPhoneNumber", out var phoneProp))
        {
            phone = phoneProp.GetString() ?? phone;
        }
    }

    // جلب الموظفين الذين لديهم صلاحية الظهور في صفحة اتصل بنا ديناميكياً
    var contactStaff = DbContext.Users
        .Where(u => u.ShowOnContactPage && u.IsActive)
        .ToList();
}

<style>
    /* تطبيق الخلفية الداكنة المخصصة لهذه الصفحة لتتوافق مع الهوية البصرية */
    body {
        background-color: var(--secondary-navy) !important;
    }

    .main-content {
        background-color: var(--secondary-navy) !important;
    }

    .top-header .date-box, .top-header .notification-bell, .top-header .lang-btn, .mobile-toggle-btn {
        background: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.1);
        color: white;
    }

    .contact-page {
        max-width: 1200px;
        margin: 0 auto;
        color: white;
        padding-top: 2rem;
    }

    .contact-header {
        text-align: center;
        margin-bottom: 3rem;
    }

        .contact-header .badge {
            background: rgba(255,255,255,0.1);
            color: var(--primary-gold);
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 800;
            display: inline-block;
            margin-bottom: 1rem;
            border: 1px solid rgba(184, 147, 90, 0.3);
        }

        .contact-header h1 {
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 1rem;
        }

        .contact-header p {
            color: #94a3b8;
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.6;
        }

    /* البطاقة الذهبية الكبيرة */
    .promo-card {
        background: linear-gradient(135deg, var(--primary-gold) 0%, var(--secondary-gold) 100%);
        border-radius: 2rem;
        padding: 3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 3rem;
        box-shadow: 0 20px 40px rgba(184, 147, 90, 0.2);
        position: relative;
        overflow: hidden;
    }

    .promo-icon {
        width: 100px;
        height: 100px;
        background: rgba(255,255,255,0.2);
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        transform: rotate(-15deg);
        color: white;
        flex-shrink: 0;
    }

    .promo-content {
        flex: 1;
        margin-inline-start: 3rem;
        text-align: right;
    }

        .promo-content h2 {
            font-size: 2rem;
            font-weight: 900;
            margin-bottom: 1rem;
            color: white;
        }

        .promo-content p {
            font-size: 1.1rem;
            color: rgba(255,255,255,0.9);
            margin-bottom: 2rem;
            line-height: 1.6;
        }

    .promo-actions {
        display: flex;
        gap: 1rem;
    }

    .btn-promo-solid {
        background: white;
        color: var(--primary-navy);
        padding: 1rem 2.5rem;
        border-radius: 1rem;
        font-weight: 900;
        text-decoration: none;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .btn-promo-solid:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

    .btn-promo-outline {
        background: transparent;
        color: white;
        border: 2px solid rgba(255,255,255,0.5);
        padding: 1rem 2.5rem;
        border-radius: 1rem;
        font-weight: 900;
        text-decoration: none;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .btn-promo-outline:hover {
            background: rgba(255,255,255,0.1);
        }

    /* بطاقات الموظفين */
    .depts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
        margin-bottom: 4rem;
    }

    .dept-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        text-align: center;
        color: var(--primary-navy);
        border: 1px solid #f1f5f9;
        transition: 0.3s;
    }

        .dept-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

    .dept-icon {
        width: 60px;
        height: 60px;
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin: 0 auto 1.5rem;
    }

    .dept-card h3 {
        font-size: 1.4rem;
        font-weight: 900;
        margin-bottom: 0.5rem;
    }

    .dept-job {
        color: var(--primary-gold);
        font-weight: 800;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
        display: block;
    }

    .phone-box {
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        padding: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .phone-number {
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--primary-navy);
        font-family: monospace;
    }

    .phone-actions a {
        color: #94a3b8;
        font-size: 1.2rem;
        margin-inline-start: 10px;
        transition: 0.3s;
        text-decoration: none;
    }

        .phone-actions a:hover {
            color: var(--primary-gold);
        }

    /* ========================================================
           تعديلات الموبايل (الميديا كويري)
           ======================================================== */
    @@media (max-width: 768px) {
        .contact-page {
            padding: 1rem;
        }

        .contact-header h1 {
            font-size: 1.8rem;
        }

        .contact-header p {
            font-size: 1rem;
        }

        .promo-card {
            flex-direction: column;
            text-align: center;
            padding: 2rem 1.5rem;
            gap: 1.5rem;
        }

        .promo-content {
            margin: 0;
            text-align: center;
        }

            .promo-content h2 {
                font-size: 1.5rem;
            }

            .promo-content p {
                font-size: 1rem;
            }

        .promo-actions {
            flex-direction: column;
            width: 100%;
        }

        .btn-promo-solid, .btn-promo-outline {
            width: 100%;
            padding: 1rem;
            font-size: 0.95rem;
        }

        .depts-grid {
            grid-template-columns: 1fr;
        }

        .dept-card {
            padding: 2rem 1.5rem;
        }

        .phone-box {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
        }

        .phone-actions {
            margin: 0;
        }
    }
</style>

<div class="contact-page">
    <!-- هيدر الصفحة -->
    <div class="contact-header">
        <span class="badge">@Localizer["دعم فني متواصل"]</span>
        <h1>@Localizer["تواصل مع خبراء الأرجان"]</h1>
        <p>@Localizer["نحن هنا لخدمتك. تواصل مباشرة مع القسم المختص للحصول على استجابة سريعة."]</p>
    </div>

    <!-- بطاقة الترويج لحسابات المزادات -->
    <div class="promo-card">
        <div class="promo-icon"><i class="fa-solid fa-gavel"></i></div>
        <div class="promo-content">
            <h2>@Localizer["هل ترغب في فتح حساب مزاد؟"]</h2>
            <p>@Localizer["فريقنا مستعد لتزويدك بكافة الأدوات اللازمة لبدء استيراد سياراتك بأمان."]</p>
            <div class="promo-actions">
                <a href="https://wa.me/@(phone)?text=@Html.Raw(Uri.EscapeDataString("أهلاً شركة الأرجان، أرغب في طلب فتح حساب مزاد جديد لبدء المزايدة."))" target="_blank" class="btn-promo-solid">
                    <i class="fa-brands fa-whatsapp" style="margin-inline-end: 8px;"></i> @Localizer["اطلب حسابك الآن عبر واتساب"]
                </a>
                <a href="https://wa.me/@(phone)?text=@Html.Raw(Uri.EscapeDataString("أهلاً شركة الأرجان، أود التواصل مع قسم المزادات للاستفسار عن آلية العمل."))" target="_blank" class="btn-promo-outline">
                    @Localizer["تواصل مع قسم المزادات"]
                </a>
            </div>
        </div>
    </div>

    <!-- شبكة الموظفين المسجلين في صفحة اتصل بنا -->
    <div class="depts-grid">
        @if (contactStaff.Any())
        {
            foreach (var staff in contactStaff)
            {
                <div class="dept-card">
                    <div class="dept-icon">
                        <i class="fa-solid @(staff.DepartmentIcon ?? "fa-user-tie")"></i>
                    </div>
                    <h3>@staff.FullName</h3>
                    <span class="dept-job">@staff.JobTitle</span>

                    <div class="phone-box">
                        <div class="phone-number" dir="ltr">@staff.PhoneNumber</div>
                        <div class="phone-actions">
                            <a href="https://wa.me/@(staff.PhoneNumber?.Replace("+", ""))" target="_blank" title="WhatsApp">
                                <i class="fa-brands fa-whatsapp"></i>
                            </a>
                            <a href="tel:@staff.PhoneNumber" title="Call">
                                <i class="fa-solid fa-phone"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1/-1; text-align: center; padding: 4rem; opacity: 0.5;">
                <i class="fa-solid fa-users-slash" style="font-size: 3rem; margin-bottom: 1rem;"></i>
                <h3>@Localizer["لا توجد جهات اتصال مسجلة حالياً."]</h3>
            </div>
        }
    </div>
</div>