@{
    ViewData["Title"] = Localizer["اتصل بنا"];
}

<style>
    /* تطبيق الخلفية الداكنة المخصصة لهذه الصفحة لتتوافق مع الهوية البصرية */
    body {
        background-color: var(--secondary-navy) !important;
    }

    .main-content {
        background-color: var(--secondary-navy) !important;
    }

    .top-header .date-box, .top-header .notification-bell, .top-header .lang-btn, .mobile-toggle-btn {
        background: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.1);
        color: white;
    }

    .contact-page {
        max-width: 1200px;
        margin: 0 auto;
        color: white;
        padding-top: 2rem;
    }

    .contact-header {
        text-align: center;
        margin-bottom: 3rem;
    }

        .contact-header .badge {
            background: rgba(255,255,255,0.1);
            color: var(--primary-gold);
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 800;
            display: inline-block;
            margin-bottom: 1rem;
            border: 1px solid rgba(184, 147, 90, 0.3);
        }

        .contact-header h1 {
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 1rem;
        }

        .contact-header p {
            color: #94a3b8;
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.6;
        }

    /* البطاقة الذهبية الكبيرة */
    .promo-card {
        background: linear-gradient(135deg, var(--primary-gold) 0%, var(--secondary-gold) 100%);
        border-radius: 2rem;
        padding: 3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 3rem;
        box-shadow: 0 20px 40px rgba(184, 147, 90, 0.2);
    }

    .promo-icon {
        width: 120px;
        height: 120px;
        background: rgba(255,255,255,0.2);
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        transform: rotate(-15deg);
        color: white;
    }

    .promo-content {
        flex: 1;
        margin-inline-start: 3rem;
    }

        .promo-content h2 {
            font-size: 2rem;
            font-weight: 900;
            margin-bottom: 1rem;
            color: white;
        }

        .promo-content p {
            font-size: 1.1rem;
            color: rgba(255,255,255,0.9);
            margin-bottom: 2rem;
            line-height: 1.6;
        }

    .promo-actions {
        display: flex;
        gap: 1rem;
    }

    .btn-promo-solid {
        background: white;
        color: var(--primary-navy);
        padding: 1rem 2.5rem;
        border-radius: 1rem;
        font-weight: 900;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-promo-solid:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

    .btn-promo-outline {
        background: transparent;
        color: white;
        border: 2px solid rgba(255,255,255,0.5);
        padding: 1rem 2.5rem;
        border-radius: 1rem;
        font-weight: 900;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-promo-outline:hover {
            background: rgba(255,255,255,0.1);
        }

    /* بطاقات الأقسام (بيضاء) */
    .depts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
        margin-bottom: 4rem;
    }

    .dept-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        text-align: center;
        color: var(--primary-navy);
    }

    .dept-icon {
        width: 60px;
        height: 60px;
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin: 0 auto 1.5rem;
    }

    .dept-card h3 {
        font-size: 1.5rem;
        font-weight: 900;
        margin-bottom: 1rem;
    }

    .dept-card p {
        color: #64748b;
        font-size: 0.95rem;
        margin-bottom: 2rem;
        min-height: 40px;
    }

    .phone-box {
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        padding: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .phone-number {
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--primary-navy);
        font-family: monospace;
    }

    .phone-actions a {
        color: #94a3b8;
        font-size: 1.2rem;
        margin-inline-start: 10px;
        transition: 0.3s;
    }

        .phone-actions a:hover {
            color: var(--primary-gold);
        }

    /* الفروع */
    .branches-section {
        text-align: center;
        margin-bottom: 4rem;
    }

    .branches-title {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 1.3rem;
        font-weight: 900;
        margin-bottom: 2rem;
        color: white;
    }

    .branches-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
    }

    .branch-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 1rem;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: 0.3s;
    }

        .branch-card:hover {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.2);
            box-shadow: 0 5px 15px rgba(184, 147, 90, 0.1);
        }

    .branch-info {
        text-align: right;
    }

        .branch-info h4 {
            font-size: 1.1rem;
            font-weight: 900;
            margin-bottom: 0.3rem;
            color: white;
        }

        .branch-info p {
            font-size: 0.85rem;
            color: #94a3b8;
            margin: 0;
        }

    .branch-icon {
        color: var(--primary-gold);
        font-size: 1.5rem;
        background: rgba(184, 147, 90, 0.2);
        width: 45px;
        height: 45px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="contact-page">
    <div class="contact-header">
        <span class="badge">@Localizer["دعم فني متواصل"]</span>
        <h1>@Localizer["تواصل مع خبراء الأرجان"]</h1>
        <p>@Localizer["نحن هنا لخدمتك. يمكنك التواصل مباشرة مع القسم المختص للحصول على استجابة سريعة ودقيقة لاستفساراتك أو زيارة أحد فروعنا المنتشرة في السلطنة."]</p>
    </div>

    <div class="promo-card">
        <div class="promo-icon"><i class="fa-solid fa-gavel"></i></div>
        <div class="promo-content">
            <h2>@Localizer["هل ترغب في الحصول على حساب مزاد؟"]</h2>
            <p>@Localizer["فريقنا المتواجد في صلالة أو نزوى أو مسقط وأمريكا مستعد لتزويدك بكافة الأدوات اللازمة لبدء استيراد سياراتك بأقل التكاليف وبأعلى درجة من الأمان."]</p>
            <div class="promo-actions">
                <a href="#" class="btn-promo-solid">@Localizer["اطلب حسابك الآن"]</a>
                <a href="#" class="btn-promo-outline">@Localizer["تواصل مع قسم المزادات"]</a>
            </div>
        </div>
    </div>

    <div class="depts-grid">
        <div class="dept-card">
            <div class="dept-icon"><i class="fa-solid fa-gavel"></i></div>
            <h3>@Localizer["قسم المزادات"]</h3>
            <p>@Localizer["للدعم الفني في حسابات كوبارت و IAAI والمزايدة المباشرة."]</p>
            <div class="phone-box">
                <div class="phone-number" dir="ltr">96505777</div>
                <div class="phone-actions"><a href="#"><i class="fa-brands fa-whatsapp"></i></a><a href="#"><i class="fa-solid fa-phone"></i></a></div>
            </div>
            <div class="phone-box">
                <div class="phone-number" dir="ltr">96202777</div>
                <div class="phone-actions"><a href="#"><i class="fa-brands fa-whatsapp"></i></a><a href="#"><i class="fa-solid fa-phone"></i></a></div>
            </div>
        </div>

        <div class="dept-card">
            <div class="dept-icon"><i class="fa-solid fa-headset"></i></div>
            <h3>@Localizer["قسم خدمة العملاء"]</h3>
            <p>@Localizer["لمتابعة حالة الشحنات، الدعم الفني، وتقديم الاقتراحات."]</p>
            <div class="phone-box">
                <div class="phone-number" dir="ltr">77521020</div>
                <div class="phone-actions"><a href="#"><i class="fa-brands fa-whatsapp"></i></a><a href="#"><i class="fa-solid fa-phone"></i></a></div>
            </div>
        </div>

        <div class="dept-card">
            <div class="dept-icon"><i class="fa-solid fa-tags"></i></div>
            <h3>@Localizer["قسم المبيعات"]</h3>
            <p>@Localizer["للاستفسارات التجارية، عروض الأسعار، والتعاقدات الجديدة."]</p>
            <div class="phone-box">
                <div class="phone-number" dir="ltr">94203663</div>
                <div class="phone-actions"><a href="#"><i class="fa-brands fa-whatsapp"></i></a><a href="#"><i class="fa-solid fa-phone"></i></a></div>
            </div>
            <div class="phone-box">
                <div class="phone-number" dir="ltr">77263111</div>
                <div class="phone-actions"><a href="#"><i class="fa-brands fa-whatsapp"></i></a><a href="#"><i class="fa-solid fa-phone"></i></a></div>
            </div>
        </div>
    </div>

    <div class="branches-section">
        <div class="branches-title"><i class="fa-solid fa-map-location-dot"></i> @Localizer["فروعنا في سلطنة عمان"]</div>
        <div class="branches-grid">
            <div class="branch-card" style="border-color: var(--primary-gold); background: rgba(184,147,90,0.05);">
                <div class="branch-info">
                    <h4>@Localizer["المركز الرئيسي - صلالة"]</h4>
                    <p>@Localizer["خلف مركز شرطة عوقد"]</p>
                </div>
                <div class="branch-icon"><i class="fa-solid fa-star"></i></div>
            </div>
            <div class="branch-card">
                <div class="branch-info">
                    <h4>@Localizer["فرع نزوى - نزوى"]</h4>
                    <p>@Localizer["صناعية كرشا"]</p>
                </div>
                <div class="branch-icon"><i class="fa-solid fa-location-dot"></i></div>
            </div>
            <div class="branch-card">
                <div class="branch-info">
                    <h4>@Localizer["فرع مسقط - مسقط"]</h4>
                    <p>@Localizer["المعبيلة الصناعية"]</p>
                </div>
                <div class="branch-icon"><i class="fa-solid fa-location-dot"></i></div>
            </div>
        </div>
    </div>
</div>