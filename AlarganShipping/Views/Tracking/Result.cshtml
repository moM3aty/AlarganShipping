@model AlarganShipping.Models.Car
@{
    ViewData["Title"] = Localizer["نتائج التتبع"];
    Layout = null;
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var htmlDir = isRtl ? "rtl" : "ltr";

    // حساب مرحلة شريط التقدم (4 مراحل رئيسية حسب التعديلات)
    int step = 1;
    if (Model.StatusId >= 7) step = 4; // تم التوصيل
    else if (Model.StatusId >= 5) step = 3; // تم الشحن
    else if (Model.StatusId >= 3) step = 2; // جاري المعالجة
    else step = 1; // تم الطلب
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name" dir="@htmlDir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ALARGAN</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-navy: #1e293b;
            --primary-gold: #b45309;
            --bg-color: #f4f7f9;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--bg-color);
            margin: 0;
            padding: 2rem 1rem;
            color: var(--primary-navy);
        }

        .tracking-container {
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        /* --- 1. الترويسة العلوية --- */
        .top-logo-area {
            text-align: center;
            margin-bottom: 1rem;
        }

            .top-logo-area img {
                width: 70px;
                height: 70px;
                border-radius: 50%;
                margin-bottom: 0.5rem;
                border: 2px solid var(--primary-gold);
                box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            }

            .top-logo-area h2 {
                font-size: 1.4rem;
                font-weight: 900;
                margin: 0;
                color: var(--primary-navy);
            }

            .top-logo-area p {
                color: #64748b;
                font-size: 0.85rem;
                margin: 0;
            }

        /* --- 2. شريط البحث العلوي --- */
        .search-bar-top {
            background: white;
            border-radius: 12px;
            padding: 0.5rem 1rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 5px 15px rgba(0,0,0,0.03);
            border: 1px solid #e2e8f0;
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
        }

            .search-bar-top input {
                border: none;
                outline: none;
                font-family: monospace;
                font-size: 1rem;
                font-weight: 800;
                color: var(--primary-navy);
                flex: 1;
                text-align: center;
                background: transparent;
            }

        .search-action-btn {
            background: transparent;
            border: none;
            color: #94a3b8;
            font-size: 1.2rem;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none;
            display: flex;
            align-items: center;
        }

            .search-action-btn:hover {
                color: var(--primary-gold);
            }

        /* --- 3. شريط التقدم (Stepper) --- */
        .stepper-card {
            background: white;
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 5px 15px rgba(0,0,0,0.03);
            text-align: center;
            border: 1px solid #e2e8f0;
        }

            .stepper-card h3 {
                font-size: 1.2rem;
                font-weight: 900;
                margin-top: 0;
                margin-bottom: 2rem;
                color: var(--primary-navy);
            }

        .stepper-wrapper {
            display: flex;
            justify-content: space-between;
            position: relative;
            max-width: 900px;
            margin: 0 auto;
        }

            .stepper-wrapper::before {
                content: '';
                position: absolute;
                top: 25px;
                left: 10%;
                right: 10%;
                height: 4px;
                background: #e2e8f0;
                z-index: 1;
            }

            .stepper-wrapper::after {
                content: '';
                position: absolute;
                top: 25px;
                height: 4px;
                background: var(--primary-gold);
                z-index: 2;
                transition: 1s;
                left: @(isRtl ? "auto" : "10%");
                right: @(isRtl ? "10%" : "auto");
                width: @(step == 1 ? "0%" : step == 2 ? "33%" : step == 3 ? "66%" : "80%");
            }

        .step-item {
            position: relative;
            z-index: 3;
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 120px;
        }

        .step-icon {
            width: 50px;
            height: 50px;
            background: white;
            border: 3px solid #e2e8f0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: #94a3b8;
            transition: 0.3s;
        }

        .step-label {
            margin-top: 0.8rem;
            font-weight: 900;
            font-size: 0.95rem;
            color: var(--primary-navy);
        }

        .step-sublabel {
            font-size: 0.75rem;
            color: #94a3b8;
            font-weight: 700;
            margin-top: 0.2rem;
        }

        .step-item.active .step-icon {
            background: var(--primary-navy);
            border-color: var(--primary-navy);
            color: white;
            box-shadow: 0 0 0 4px white, 0 4px 10px rgba(30, 41, 59, 0.3);
        }

        /* --- 4. تفاصيل السيارة والبطاقة المزدوجة --- */
        .main-details-wrapper {
            display: flex;
            gap: 2rem;
            background: white;
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 5px 15px rgba(0,0,0,0.03);
            border: 1px solid #e2e8f0;
        }

        /* القسم الأيسر: الصور والتبويبات */
        .car-image-section {
            width: 45%;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .image-tabs {
            display: flex;
            background: #f1f5f9;
            border-radius: 10px;
            padding: 4px;
        }

        .img-tab {
            flex: 1;
            text-align: center;
            padding: 0.6rem;
            font-weight: 800;
            color: #64748b;
            cursor: pointer;
            border-radius: 8px;
            transition: 0.3s;
            font-size: 0.9rem;
        }

            .img-tab.active {
                background: white;
                color: var(--primary-navy);
                box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            }

        .slider-container {
            position: relative;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
            height: 350px;
            background: #f8fafc;
        }

        .slider-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .slider-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.8);
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--primary-navy);
            font-size: 1.2rem;
            transition: 0.3s;
        }

            .slider-btn:hover {
                background: white;
                color: var(--primary-gold);
            }

            .slider-btn.left {
                left: 10px;
            }

            .slider-btn.right {
                right: 10px;
            }

        /* القسم الأيمن: البيانات والتواريخ */
        .car-data-section {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .car-header-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1rem;
        }

        .car-title {
            font-size: 1.6rem;
            font-weight: 900;
            color: var(--primary-navy);
            text-transform: uppercase;
            margin: 0;
        }

        .shipping-link-btn {
            width: 45px;
            height: 45px;
            background: rgba(184, 147, 90, 0.1);
            color: var(--primary-gold);
            border: 1px solid rgba(184, 147, 90, 0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            text-decoration: none;
            transition: 0.3s;
            flex-shrink: 0;
        }

            .shipping-link-btn:hover {
                background: var(--primary-gold);
                color: white;
                transform: translateY(-2px);
            }

        .tags-row {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 2rem;
            color: #64748b;
            font-size: 0.85rem;
            font-weight: 800;
            border-bottom: 1px solid #f1f5f9;
            padding-bottom: 1rem;
        }

            .tags-row span {
                display: flex;
                align-items: center;
                gap: 5px;
            }

        /* شبكة المربعات الـ 7 */
        .info-boxes-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
        }

        .box-item {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: 8px;
            background: #fdfdfd;
        }

        .box-item-icon {
            width: 30px;
            height: 30px;
            background: rgba(184,147,90,0.1);
            color: var(--primary-gold);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
        }

        .box-item-label {
            margin: 0;
            font-size: 0.75rem;
            color: #64748b;
            font-weight: 800;
        }

        .box-item-value {
            margin: 0;
            font-size: 0.9rem;
            font-weight: 900;
            color: var(--primary-navy);
            font-family: monospace;
        }

        .box-auction {
            grid-column: 1 / 2;
        }

        /* --- 5. سجل التحركات والمرفقات --- */
        .logs-section {
            background: white;
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 5px 15px rgba(0,0,0,0.03);
            border: 1px solid #e2e8f0;
            margin-top: 1.5rem;
        }

            .logs-section h3 {
                font-size: 1.3rem;
                font-weight: 900;
                color: var(--primary-navy);
                margin-top: 0;
                margin-bottom: 1.5rem;
                border-bottom: 2px solid #f1f5f9;
                padding-bottom: 10px;
            }

        .log-table {
            width: 100%;
            border-collapse: collapse;
        }

            .log-table th {
                text-align: start;
                padding: 1rem;
                background: #f8fafc;
                color: var(--text-muted);
                font-weight: 800;
                font-size: 0.9rem;
                border-bottom: 2px solid #e2e8f0;
            }

            .log-table td {
                padding: 1rem;
                border-bottom: 1px solid #f1f5f9;
                font-weight: 700;
                color: var(--primary-navy);
            }

        @@media (max-width: 992px) {
            .main-details-wrapper

        {
            flex-direction: column;
        }

        .car-image-section {
            width: 100%;
        }

        .info-boxes-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        }

        @@media (max-width: 576px) {
            .info-boxes-grid

        {
            grid-template-columns: 1fr;
        }

        .stepper-wrapper::before, .stepper-wrapper::after {
            left: 5%;
            right: 5%;
        }

        .step-item {
            width: 70px;
        }

        .step-label {
            font-size: 0.75rem;
            text-align: center;
        }

        .step-sublabel {
            display: none;
        }

        }
    </style>
</head>
<body>
    <div class="tracking-container">

        <!-- 1. الشعار والعنوان -->
        <div class="top-logo-area">
            <img src="~/images/logo.jpg" alt="Logo" onerror="this.onerror=null; this.style.display='none'" />
            <h2>@Localizer["تتبع المركبة"]</h2>
            <p>@Localizer["راقب تقدم شحنتك من خلال التحديثات الفورية"]</p>
        </div>

        <!-- 2. شريط البحث المدمج -->
        <div class="search-bar-top">
            <a href="@Url.Action("Index", "Tracking")" class="search-action-btn" title="@Localizer["إغلاق"]"><i class="fa-regular fa-circle-xmark"></i></a>
            <input type="text" value="@Model.VIN" readonly dir="ltr" />
            <a href="@Url.Action("Index", "Tracking")" class="search-action-btn" title="@Localizer["بحث جديد"]"><i class="fa-solid fa-magnifying-glass"></i></a>
        </div>

        <!-- 3. شريط التقدم (Stepper) -->
        <div class="stepper-card">
            <h3>@Localizer["تقدم الشحنة"]</h3>
            <p style="color: #94a3b8; font-size: 0.85rem; margin-top: -1.5rem; margin-bottom: 2rem;">@Localizer["تتبع رحلة مركبتك من خلال التحديثات الفورية"]</p>

            <div class="stepper-wrapper">
                <div class="step-item @(step >= 1 ? "active" : "")">
                    <div class="step-icon"><i class="fa-solid fa-box"></i></div>
                    <div class="step-label">@Localizer["تم الطلب"]</div>
                    <div class="step-sublabel">@Localizer["تم إنشاء الطلب"]</div>
                </div>
                <div class="step-item @(step >= 2 ? "active" : "")">
                    <div class="step-icon"><i class="fa-regular fa-clock"></i></div>
                    <div class="step-label">@Localizer["جاري المعالجة"]</div>
                    <div class="step-sublabel">@Localizer["قيد التحضير"]</div>
                </div>
                <div class="step-item @(step >= 3 ? "active" : "")">
                    <div class="step-icon"><i class="fa-solid fa-truck-fast"></i></div>
                    <div class="step-label">@Localizer["تم الشحن"]</div>
                    <div class="step-sublabel">@Localizer["في الطريق"]</div>
                </div>
                <div class="step-item @(step >= 4 ? "active" : "")">
                    <div class="step-icon"><i class="fa-regular fa-circle-check"></i></div>
                    <div class="step-label">@Localizer["تم التوصيل"]</div>
                    <div class="step-sublabel">@Localizer["وصل"]</div>
                </div>
            </div>
        </div>

        <!-- 4. التفاصيل والصور -->
        <div class="main-details-wrapper">
            <!-- الجانب الأيسر: الصور -->
            <div class="car-image-section">
                <div class="image-tabs">
                    <div class="img-tab active" onclick="switchImageTab(this)">Destination</div>
                    <div class="img-tab" onclick="switchImageTab(this)">Warehouse</div>
                </div>
                <div class="slider-container">
                    <button class="slider-btn left" onclick="nextImage()"><i class="fa-solid fa-angle-left"></i></button>

                    @if (!string.IsNullOrEmpty(Model.MainImageUrl))
                    {
                        <img src="@Model.MainImageUrl" alt="Car Image" class="slider-img" id="mainCarDisplayImg" />
                    }
                    else
                    {
                        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 5rem; color: #cbd5e1;">
                            <i class="fa-solid fa-car-side"></i>
                        </div>
                    }

                    <button class="slider-btn right" onclick="nextImage()"><i class="fa-solid fa-angle-right"></i></button>
                </div>
            </div>

            <!-- الجانب الأيمن: البيانات والتواريخ -->
            <div class="car-data-section">
                <div class="car-header-row">
                    <h1 class="car-title">@Model.Year @Model.Make @Model.Model @Model.Color</h1>

                    @if (Model.Shipment != null && !string.IsNullOrEmpty(Model.Shipment.ContainerNumber))
                    {
                        string trackingUrl = $"https://www.searates.com/container/tracking/?number={Model.Shipment.ContainerNumber}";
                        <a href="@trackingUrl" target="_blank" class="shipping-link-btn" title="@Localizer["تتبع السفينة"]">
                            <i class="fa-solid fa-ship"></i>
                        </a>
                    }
                </div>

                <div class="tags-row" dir="ltr" style="justify-content: @(isRtl ? "flex-end" : "flex-start");">
                    <span><span style="color:#94a3b8;"># VIN:</span> <span style="color:var(--primary-navy);">@Model.VIN</span></span>
                    <span style="margin: 0 10px; color:#e2e8f0;">|</span>
                    <span><i class="fa-solid fa-cube" style="color:#94a3b8;"></i> <span style="color:#94a3b8;">Lot:</span> <span style="color:var(--primary-navy);">@(string.IsNullOrEmpty(Model.LotNumber) ? "-" : Model.LotNumber)</span></span>

                    @if (Model.Shipment != null && !string.IsNullOrEmpty(Model.Shipment.ContainerNumber))
                    {
                        <span style="margin: 0 10px; color:#e2e8f0;">|</span>
                        <span><i class="fa-solid fa-box-open" style="color:#94a3b8;"></i> <span style="color:#94a3b8;">CN:</span> <span style="color:var(--primary-navy);">@Model.Shipment.ContainerNumber</span></span>
                    }
                </div>

                <!-- شبكة التواريخ (مربعات) -->
                <div class="info-boxes-grid">

                    <!-- الصف الأول -->
                    <div class="box-item box-auction">
                        <div class="box-item-icon"><i class="fa-solid fa-building-columns"></i></div>
                        <p class="box-item-label">@Localizer["مدينة المزاد"]</p>
                        <h4 class="box-item-value">@(Model.Auction?.Location ?? "غير محدد")</h4>
                    </div>
                    <!-- مربعات فارغة وهمية للحفاظ على التصميم -->
                    <div style="grid-column: 2 / 4;"></div>

                    <!-- الصف الثاني -->
                    <div class="box-item">
                        <div class="box-item-icon"><i class="fa-regular fa-calendar"></i></div>
                        <p class="box-item-label">@Localizer["تم الشراء"]</p>
                        <h4 class="box-item-value">@(Model.AddDate?.ToString("dd/MM/yyyy") ?? "-")</h4>
                    </div>
                    <div class="box-item">
                        <div class="box-item-icon"><i class="fa-solid fa-truck-ramp-box"></i></div>
                        <p class="box-item-label">@Localizer["الاستلام"]</p>
                        @{
                            // الاستلام غالبا بعد الشراء بأيام
                            string receiveDate = Model.StatusId >= 2 && Model.AddDate.HasValue ? Model.AddDate.Value.AddDays(2).ToString("dd/MM/yyyy") : "-";
                        }
                        <h4 class="box-item-value">@receiveDate</h4>
                    </div>
                    <div class="box-item">
                        <div class="box-item-icon"><i class="fa-regular fa-circle-check"></i></div>
                        <p class="box-item-label">@Localizer["التوصيل"]</p>
                        @{
                            string deliveryDate = Model.StatusId >= 7 && Model.Shipment?.ExpectedTimeOfArrival != null ? Model.Shipment.ExpectedTimeOfArrival.Value.ToString("dd/MM/yyyy") : "-";
                        }
                        <h4 class="box-item-value">@deliveryDate</h4>
                    </div>

                    <!-- الصف الثالث -->
                    <div class="box-item">
                        <div class="box-item-icon"><i class="fa-regular fa-calendar-check"></i></div>
                        <p class="box-item-label">@Localizer["تاريخ الوصول"] (ETA)</p>
                        <h4 class="box-item-value">@(Model.Shipment?.ExpectedTimeOfArrival?.ToString("dd/MM/yyyy") ?? "-")</h4>
                    </div>
                    <div class="box-item">
                        <div class="box-item-icon"><i class="fa-solid fa-warehouse"></i></div>
                        <p class="box-item-label">@Localizer["تاريخ التحميل"]</p>
                        @{
                            string loadingDate = Model.Shipment?.ExpectedTimeOfDeparture != null ? Model.Shipment.ExpectedTimeOfDeparture.Value.AddDays(-4).ToString("dd/MM/yyyy") : "-";
                        }
                        <h4 class="box-item-value">@loadingDate</h4>
                    </div>
                    <div class="box-item">
                        <div class="box-item-icon"><i class="fa-solid fa-ship"></i></div>
                        <p class="box-item-label">@Localizer["تاريخ المغادرة"] (ETD)</p>
                        <h4 class="box-item-value">@(Model.Shipment?.ExpectedTimeOfDeparture?.ToString("dd/MM/yyyy") ?? "-")</h4>
                    </div>

                </div>
            </div>
        </div>

        <!-- 5. سجل التحركات المفصل -->
        @if (Model.TrackingLogs != null && Model.TrackingLogs.Any())
        {
            <div class="logs-section">
                <h3><i class="fa-solid fa-clock-rotate-left" style="color: var(--primary-gold);"></i> @Localizer["سجل التحركات"]</h3>
                <div style="overflow-x: auto;">
                    <table class="log-table">
                        <thead>
                            <tr>
                                <th>@Localizer["التاريخ"]</th>
                                <th>@Localizer["الموقع"]</th>
                                <th>@Localizer["الحالة والتفاصيل"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.TrackingLogs.OrderByDescending(l => l.UpdateDate))
                            {
                                <tr>
                                    <td style="white-space: nowrap;">@log.UpdateDate.ToString("dd MMM yyyy - hh:mm tt")</td>
                                    <td><i class="fa-solid fa-location-dot" style="color: var(--text-muted); margin-inline-end: 5px;"></i> @log.Location</td>
                                    <td>
                                        <strong style="display: block; color: var(--primary-gold);">@Localizer[log.Title]</strong>
                                        <span style="font-size: 0.9rem; color: var(--text-muted);">@log.Description</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <script>
        function switchImageTab(element) {
            document.querySelectorAll('.img-tab').forEach(el => el.classList.remove('active'));
            element.classList.add('active');
        }

        function nextImage() {
            console.log('Next/Prev Image clicked');
        }
    </script>
</body>
</html>