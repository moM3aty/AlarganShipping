@{
    ViewData["Title"] = Localizer["بوابة تتبع الشحنات"];
    Layout = null; // صفحة مستقلة عن الـ Layout العام
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var htmlDir = isRtl ? "rtl" : "ltr";
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name" dir="@htmlDir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ALARGAN</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link href="~/images/logo.jpg" rel="icon" type="image/jpeg" />

    <style>
        :root {
            --primary-navy: #1e293b;
            --primary-gold: #b45309;
            --bg-color: #f4f7f9;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--bg-color);
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            padding: 1rem;
        }

        .tracking-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .logo-img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            border: 3px solid white;
            margin-bottom: 1.5rem;
        }

        .tracking-header h1 {
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--primary-navy);
            margin: 0 0 0.5rem 0;
        }

        .tracking-header p {
            color: #64748b;
            font-size: 1rem;
            font-weight: 700;
            margin: 0;
        }

        .search-card {
            background: white;
            width: 100%;
            max-width: 800px;
            padding: 3rem;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
            text-align: center;
        }

        .search-input-wrapper {
            display: flex;
            align-items: center;
            border: 2px solid var(--primary-gold);
            border-radius: 12px;
            padding: 0.5rem;
            background: white;
            transition: 0.3s;
            margin-bottom: 1.5rem;
        }

            .search-input-wrapper:focus-within {
                box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.2);
            }

            .search-input-wrapper input {
                flex: 1;
                border: none;
                padding: 1rem;
                font-size: 1.1rem;
                font-family: inherit;
                outline: none;
                color: var(--primary-navy);
                font-weight: 700;
            }

                .search-input-wrapper input::placeholder {
                    color: #94a3b8;
                    font-weight: 600;
                }

        .search-icon-left {
            padding: 0 1rem;
            color: var(--primary-gold);
            font-size: 1.2rem;
        }

        .btn-track {
            background: var(--primary-navy);
            color: white;
            border: none;
            padding: 1rem 2.5rem;
            border-radius: 10px;
            font-weight: 800;
            font-size: 1.1rem;
            cursor: pointer;
            transition: 0.3s;
            font-family: inherit;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .btn-track:hover {
                background: var(--primary-gold);
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(184, 147, 90, 0.3);
            }

        .hint-text {
            color: #64748b;
            font-size: 0.9rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .error-msg {
            color: #ef4444;
            background: #fef2f2;
            padding: 1rem;
            border-radius: 10px;
            margin-bottom: 1.5rem;
            font-weight: 700;
        }

        /* زر العودة للصفحة الرئيسية */
        .btn-home {
            margin-top: 2rem;
            color: var(--primary-navy);
            text-decoration: none;
            font-weight: 800;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.3s;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            background: rgba(44, 62, 80, 0.05);
        }

            .btn-home:hover {
                background: var(--primary-navy);
                color: white;
            }

        @@media (max-width: 768px) {
            .search-card

        {
            padding: 1.5rem;
            width: 90%;
        }

        .search-input-wrapper {
            flex-direction: column;
            border: none;
            padding: 0;
            background: transparent;
        }

            .search-input-wrapper input {
                width: 100%;
                border: 2px solid var(--primary-gold);
                border-radius: 12px;
                margin-bottom: 1rem;
                text-align: center;
            }

        .search-icon-left {
            display: none;
        }

        .btn-track {
            width: 100%;
            justify-content: center;
        }

        }
    </style>
</head>
<body>
    <div class="tracking-header">
        <img src="~/images/logo.jpg" alt="Alargan Logo" class="logo-img" onerror="this.onerror=null; this.style.display='none'" />
        <h1>@Localizer["بوابة تتبع الشحنات"]</h1>
        <p>@Localizer["نظام الإدارة اللوجستية التقني"]</p>
    </div>

    <div class="search-card">
        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="error-msg"><i class="fa-solid fa-circle-exclamation"></i> @ViewBag.Error</div>
        }

        <form asp-controller="Tracking" asp-action="Search" method="post">
            <div class="search-input-wrapper">
                <button type="submit" class="btn-track">
                    <i class="fa-solid fa-magnifying-glass-location"></i> @Localizer["تتبع الآن"]
                </button>
                <input type="text" name="vin" placeholder="@Localizer["أدخل رقم الشاصي (VIN) أو رقم اللوت..."]" required dir="ltr" style="text-align: right;" />
                <div class="search-icon-left"><i class="fa-solid fa-magnifying-glass"></i></div>
            </div>
        </form>

        <div class="hint-text">
            <i class="fa-solid fa-shield-halved" style="color: var(--primary-gold);"></i>
            @Localizer["تتبع حالة سيارتك لحظة بلحظة من المزاد وحتى باب منزلك"]
        </div>
    </div>

    <a href="@Url.Action("Login", "Account")" class="btn-home">
        <i class="fa-solid fa-arrow-right-to-bracket"></i> @Localizer["تسجيل الدخول للنظام"]
    </a>
</body>
</html>