@{
    ViewData["Title"] = Localizer["بوابة تتبع الشحنات"];
    Layout = null;
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var htmlDir = isRtl ? "rtl" : "ltr";
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name" dir="@htmlDir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ALARGAN</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">

    <style>
        :root {
            /* الألوان المستخرجة من الشعار للاستخدام الخارجي */
            --primary-navy: #2C3E50;
            --secondary-navy: #1A252F;
            --primary-gold: #B8935A;
            --secondary-gold: #967443;
            --bg-body: #f4f7f9;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background: linear-gradient(135deg, var(--bg-body) 0%, #e2e8f0 100%);
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .track-portal-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 4rem 1rem;
            text-align: center;
            width: 100%;
            max-width: 800px;
        }

        .track-logo-box {
            width: 140px;
            height: 140px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 2rem;
            box-shadow: 0 15px 35px rgba(184, 147, 90, 0.2);
            border: 4px solid var(--primary-gold);
            padding: 15px;
            overflow: hidden;
        }

            .track-logo-box img {
                max-width: 100%;
                height: auto;
                border-radius: 50%;
                object-fit: cover;
            }

        .track-portal-header h2 {
            font-size: 2.5rem;
            font-weight: 900;
            color: var(--primary-navy);
            margin: 0 0 0.5rem 0;
        }

        .track-portal-header p {
            color: #64748b;
            font-weight: 800;
            letter-spacing: 2px;
            margin: 0 0 3rem 0;
        }

        .search-card {
            background: white;
            width: 100%;
            padding: 3rem;
            border-radius: 2rem;
            box-shadow: 0 20px 50px rgba(44, 62, 80, 0.08);
            border: 1px solid #f1f5f9;
        }

        .search-input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            background: #f8fafc;
            border-radius: 1.5rem;
            padding: 0.5rem;
            border: 2px solid transparent;
            transition: 0.3s;
        }

            .search-input-wrapper:focus-within {
                border-color: var(--primary-gold);
                background: white;
                box-shadow: 0 0 0 5px rgba(184, 147, 90, 0.1);
            }

            .search-input-wrapper input {
                flex: 1;
                border: none;
                background: transparent;
                padding: 1.25rem 1.5rem;
                font-size: 1.1rem;
                font-family: inherit;
                outline: none;
                text-align: center;
                color: var(--primary-navy);
                font-weight: 800;
                text-transform: uppercase;
            }

                .search-input-wrapper input::placeholder {
                    color: #94a3b8;
                    font-weight: 600;
                    text-transform: none;
                }

        .btn-track-now {
            background: linear-gradient(to right, var(--primary-gold), var(--secondary-gold));
            color: white;
            border: none;
            padding: 1rem 2.5rem;
            border-radius: 1.25rem;
            font-weight: 900;
            font-size: 1.1rem;
            cursor: pointer;
            transition: 0.3s;
            font-family: inherit;
            box-shadow: 0 5px 15px rgba(184, 147, 90, 0.4);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .btn-track-now:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(184, 147, 90, 0.5);
            }

        .track-hint {
            margin-top: 2rem;
            color: #64748b;
            font-size: 0.95rem;
            font-weight: 700;
        }

        .error-message {
            color: #ef4444;
            background: #fef2f2;
            padding: 1rem;
            border-radius: 1rem;
            margin-bottom: 2rem;
            font-weight: 800;
        }
    </style>
</head>
<body>
    <div class="track-portal-container">
        <div class="track-logo-box">
            <img src="~/images/logo.jpg" alt="Alargan Logo" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fa-solid fa-ship\' style=\'font-size: 4rem; color: var(--primary-navy);\'></i>'" />
        </div>

        <div class="track-portal-header">
            <h2>@Localizer["بوابة تتبع الشحنات"]</h2>
            <p>@Localizer["نظام الإدارة اللوجستية التقني"]</p>
        </div>

        <div class="search-card">
            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="error-message"><i class="fa-solid fa-circle-exclamation"></i> @ViewBag.Error</div>
            }

            <form asp-controller="Tracking" asp-action="Search" method="post">
                <div class="search-input-wrapper">
                    <input type="text" name="vin" placeholder="@Localizer["أدخل رقم الشاصي (VIN) المكون من 17 رمزاً..."]" required dir="ltr" />
                    <button type="submit" class="btn-track-now"><i class="fa-solid fa-magnifying-glass-location"></i> @Localizer["تتبع الآن"]</button>
                </div>
            </form>
            <p class="track-hint"><i class="fa-solid fa-shield-halved"></i> @Localizer["تتبع حالة سيارتك لحظة بلحظة من المزاد وحتى باب منزلك"]</p>
        </div>
    </div>
</body>
</html>