@model AlarganShipping.Models.Shipment
@{
    ViewData["Title"] = "إضافة شحنة جديدة";
}

<style>
    /* Premium Pure CSS Form (Reused logic from Cars/Create for consistency) */
    .form-page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
    .form-page-title { font-size: 1.75rem; font-weight: 800; color: #2b3f56; margin: 0; }
    .btn-back { background-color: #f1f5f9; color: #475569; padding: 0.75rem 1.5rem; border-radius: 0.75rem; font-weight: 700; text-decoration: none; transition: all 0.3s ease; }
    .btn-back:hover { background-color: #e2e8f0; color: #1e293b; }

    .premium-form-card { background-color: #ffffff; border-radius: 1.25rem; box-shadow: 0 10px 30px rgba(43, 63, 86, 0.05); border: 1px solid #f8fafc; padding: 2.5rem; position: relative; overflow: hidden; }
    .premium-form-card::before { content: ''; position: absolute; top: 0; right: 0; width: 100%; height: 6px; background: linear-gradient(to left, #be955b, #d4af7a); }

    .form-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
    @@media (min-width: 768px) { .form-grid { grid-template-columns: repeat(2, 1fr); } }

    .form-group { display: flex; flex-direction: column; }
    .form-label { font-weight: 700; color: #2b3f56; margin-bottom: 0.5rem; font-size: 0.95rem; }
    
    .form-control { padding: 0.85rem 1.25rem; border: 2px solid #e2e8f0; border-radius: 0.75rem; font-family: 'Cairo', sans-serif; font-size: 1rem; color: #1e293b; background-color: #f8fafc; transition: all 0.3s ease; outline: none; }
    .form-control:focus { border-color: #be955b; background-color: #ffffff; box-shadow: 0 0 0 4px rgba(190, 149, 91, 0.1); }
    
    .form-actions { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid #f1f5f9; display: flex; justify-content: flex-end; }
    .btn-submit { background: linear-gradient(to right, #be955b, #d4af7a); color: #ffffff; border: none; padding: 0.85rem 2.5rem; border-radius: 0.75rem; font-weight: 800; font-size: 1.1rem; cursor: pointer; font-family: 'Cairo', sans-serif; box-shadow: 0 4px 15px rgba(190, 149, 91, 0.3); transition: all 0.3s ease; }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(190, 149, 91, 0.4); }
    .text-danger { color: #dc2626; font-size: 0.85rem; font-weight: 600; margin-top: 0.25rem; }
</style>

<div>
    <div class="form-page-header">
        <h2 class="form-page-title">إضافة حاوية / شحنة جديدة</h2>
        <a href="@Url.Action("Index", "Shipments")" class="btn-back">عودة للقائمة</a>
    </div>

    <div class="premium-form-card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="ContainerNumber" class="form-label">رقم الحاوية (Container No)</label>
                    <input asp-for="ContainerNumber" class="form-control" placeholder="مثال: MSKU1234567" style="text-transform: uppercase;" />
                    <span asp-validation-for="ContainerNumber" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="BookingNumber" class="form-label">رقم الحجز (Booking No)</label>
                    <input asp-for="BookingNumber" class="form-control" placeholder="رقم الحجز من خط الملاحة" />
                    <span asp-validation-for="BookingNumber" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="BillOfLading" class="form-label">رقم بوليصة الشحن (B/L)</label>
                    <input asp-for="BillOfLading" class="form-control" placeholder="رقم البوليصة (اختياري)" />
                    <span asp-validation-for="BillOfLading" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ShippingLine" class="form-label">خط الملاحة</label>
                    <input asp-for="ShippingLine" class="form-control" placeholder="مثال: Maersk, MSC, Hapag-Lloyd" />
                    <span asp-validation-for="ShippingLine" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="LoadingPortId" class="form-label">ميناء التحميل (Origin)</label>
                    <select asp-for="LoadingPortId" class="form-control" asp-items="ViewBag.LoadingPortId">
                        <option value="">-- اختر ميناء التحميل --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="DischargePortId" class="form-label">ميناء الوصول (Destination)</label>
                    <select asp-for="DischargePortId" class="form-control" asp-items="ViewBag.DischargePortId">
                        <option value="">-- اختر ميناء الوصول --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="ExpectedTimeOfDeparture" class="form-label">تاريخ الإبحار المتوقع (ETD)</label>
                    <input asp-for="ExpectedTimeOfDeparture" type="date" class="form-control" />
                    <span asp-validation-for="ExpectedTimeOfDeparture" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ExpectedTimeOfArrival" class="form-label">تاريخ الوصول المتوقع (ETA)</label>
                    <input asp-for="ExpectedTimeOfArrival" type="date" class="form-control" />
                    <span asp-validation-for="ExpectedTimeOfArrival" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">حفظ بيانات الشحنة</button>
            </div>
        </form>
    </div>
</div>