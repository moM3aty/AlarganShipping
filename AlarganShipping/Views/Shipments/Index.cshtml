@model IEnumerable<AlarganShipping.Models.Shipment>
@{
    ViewData["Title"] = Localizer["إدارة الشحنات والحاويات"];
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #ffffff;
        padding: 1.5rem;
        border-radius: 1.5rem;
        box-shadow: 0 5px 20px rgba(44, 62, 80, 0.03);
        margin-bottom: 2rem;
        border: 1px solid #f1f5f9;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .page-title i {
            color: var(--primary-gold);
        }

    .btn-add {
        background: linear-gradient(to right, var(--primary-gold), var(--secondary-gold));
        color: #ffffff;
        font-weight: 800;
        padding: 0.85rem 1.75rem;
        border-radius: 1rem;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(184, 147, 90, 0.3);
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(184, 147, 90, 0.4);
            color: white;
        }

    .data-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        overflow-x: auto;
    }

    .table-enterprise {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }

        .table-enterprise th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            padding: 1.25rem 1rem;
            border-bottom: 2px solid #e2e8f0;
            text-align: start;
            white-space: nowrap;
        }

        .table-enterprise td {
            padding: 1.25rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-dark);
            font-weight: 700;
            vertical-align: middle;
        }

        .table-enterprise tbody tr:hover {
            background-color: #f8fafc;
            transition: 0.2s;
        }

    .container-number {
        font-family: monospace;
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--primary-navy);
        background: rgba(44,62,80,0.05);
        padding: 0.4rem 1rem;
        border-radius: 8px;
        border: 1px solid rgba(44,62,80,0.1);
    }

    .route-td {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 800;
    }

    .route-arrow {
        color: var(--primary-gold);
        font-size: 1.2rem;
    }

    .status-badge {
        background: #f1f5f9;
        color: var(--text-muted);
        padding: 0.4rem 1.2rem;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 800;
        display: inline-block;
        border: 1px solid #e2e8f0;
    }

    .status-active {
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
        border-color: rgba(184, 147, 90, 0.2);
    }

    .status-arrived {
        background: rgba(34, 197, 94, 0.1);
        color: #16a34a;
        border-color: rgba(34, 197, 94, 0.2);
    }

    /* ستايل أزرار الإجراءات الموحد */
    .action-btn {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 0.6rem 1rem;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        cursor: pointer;
        transition: 0.3s;
        text-decoration: none;
        font-weight: 800;
        color: var(--primary-navy);
        gap: 5px;
    }

    .btn-contents:hover {
        background: var(--primary-navy);
        color: white;
        border-color: var(--primary-navy);
    }

    .btn-edit {
        color: var(--primary-gold);
    }

        .btn-edit:hover {
            background: var(--primary-gold);
            color: white;
            border-color: var(--primary-gold);
        }

    .btn-delete {
        color: #ef4444;
    }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
            border-color: #ef4444;
        }

    /* ========================================================
           تعديلات الموبايل (الميديا كويري)
           ======================================================== */
    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: stretch;
            text-align: center;
            padding: 1.5rem;
        }

        .btn-add {
            width: 100%;
            justify-content: center;
        }

        .data-card {
            padding: 1rem;
            border-radius: 1.2rem;
        }

        .action-btn {
            padding: 0.5rem;
            font-size: 0.8rem;
        }
    }
</style>

<div>
    @Html.AntiForgeryToken()
    <div class="page-header">
        <h2 class="page-title"><i class="fa-solid fa-ship"></i> @Localizer["إدارة الشحنات والحاويات"]</h2>
        <a href="@Url.Action("Create", "Shipments")" class="btn-add"><i class="fa-solid fa-plus"></i> @Localizer["إضافة شحنة جديدة"]</a>
    </div>

    <div class="data-card">
        <table id="shipmentsDataTable" class="table-enterprise display" style="width:100%">
            <thead>
                <tr>
                    <th>@Localizer["رقم الحاوية"]</th>
                    <th>@Localizer["خط الملاحة / الحجز"]</th>
                    <th>@Localizer["مسار الشحنة"]</th>
                    <th>@Localizer["تاريخ الإبحار"] (ETD)</th>
                    <th>@Localizer["الحالة"]</th>
                    <th>@Localizer["إجراءات"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var ship in Model)
                    {
                        <tr>
                            <td><span class="container-number">@ship.ContainerNumber</span></td>
                            <td>
                                <div style="font-weight: 900; color: var(--primary-navy); font-size: 1.1rem;">@ship.ShippingLine</div>
                                <div style="color: var(--text-muted); font-size: 0.85rem; font-family: monospace;">BKG: @ship.BookingNumber</div>
                            </td>
                            <td>
                                <div class="route-td">
                                    <span>@(ship.LoadingPort?.Name ?? "-")</span>
                                    <i class="fa-solid fa-arrow-right-long route-arrow" style="transform: @(System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft ? "scaleX(-1)" : "none");"></i>
                                    <span>@(ship.DischargePort?.Name ?? "-")</span>
                                </div>
                            </td>
                            <td style="font-weight: 800; color: var(--text-muted);">@(ship.ExpectedTimeOfDeparture?.ToString("dd MMM yyyy") ?? "-")</td>
                            <td>
                                @{
                                    string badgeClass = ship.Status == "Arrived" || ship.Status == "Cleared" ? "status-arrived" : "status-active";
                                }
                                <span class="status-badge @badgeClass">@Localizer[ship.Status ?? "Pending"]</span>
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a href="@Url.Action("Details", "Shipments", new { id = ship.Id })" class="action-btn btn-contents" title="@Localizer["المحتويات"]">
                                        <i class="fa-solid fa-box-open"></i> @Localizer["المحتويات"]
                                    </a>
                                    <a href="@Url.Action("Edit", "Shipments", new { id = ship.Id })" class="action-btn btn-edit" title="@Localizer["تعديل"]">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <button type="button" onclick="confirmDelete(@ship.Id)" class="action-btn btn-delete" title="@Localizer["حذف"]">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: "@Html.Raw(Localizer["هل أنت متأكد؟"])",
                text: "@Html.Raw(Localizer["لن تتمكن من التراجع عن عملية الحذف!"])",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: 'var(--primary-navy)',
                confirmButtonText: "@Html.Raw(Localizer["نعم، احذفه!"])",
                cancelButtonText: "@Html.Raw(Localizer["إلغاء"])"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Shipments")',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    title: "@Html.Raw(Localizer["تم الحذف!"])",
                                    text: "@Html.Raw(Localizer["تم حذف الشحنة بنجاح."])",
                                    icon: 'success',
                                    confirmButtonColor: 'var(--primary-gold)'
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire("@Html.Raw(Localizer["خطأ!"])", response.message || "@Html.Raw(Localizer["حدث خطأ أثناء الحذف."])", 'error');
                            }
                        },
                        error: function () {
                            Swal.fire("@Html.Raw(Localizer["خطأ!"])", "@Html.Raw(Localizer["لا يمكن الاتصال بالخادم."])", 'error');
                        }
                    });
                }
            });
        }

        $(document).ready(function () {
            var dir = $('html').attr('dir') === 'rtl';
            $('#shipmentsDataTable').DataTable({
                "language": { "url": dir ? "//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json" : "" },
                "pageLength": 10,
                "ordering": true,
                "responsive": true,
                "order": [[ 3, "desc" ]],
                "dom": '<"top"f>rt<"bottom"lp><"clear">'
            });
        });
    </script>
}