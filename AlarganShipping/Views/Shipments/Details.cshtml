<!-- مسار الملف في المشروع: Views/Shipments/Details.cshtml -->
@model AlarganShipping.Models.Shipment
@{
    ViewData["Title"] = Localizer["تفاصيل الشحنة والحاوية"];
}

<style>
    .details-header {
        background: linear-gradient(135deg, var(--primary-navy) 0%, var(--secondary-navy) 100%);
        color: white;
        padding: 2.5rem;
        border-radius: 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 15px 30px rgba(26, 42, 58, 0.15);
        position: relative;
        overflow: hidden;
    }

        .details-header::after {
            content: '\26F4'; /* Ship icon */
            position: absolute;
            top: -20%;
            inset-inline-start: -5%;
            font-size: 15rem;
            color: rgba(255,255,255,0.03);
            z-index: 1;
        }

    .shipment-title-large {
        font-size: 2rem;
        font-weight: 900;
        margin: 0 0 0.5rem 0;
        color: var(--primary-gold);
        position: relative;
        z-index: 2;
        letter-spacing: 2px;
    }

    .info-badge {
        background-color: rgba(255,255,255,0.1);
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        font-size: 0.95rem;
        position: relative;
        z-index: 2;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-inline-end: 1rem;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .btn-outline-light {
        background: rgba(255,255,255,0.1);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,0.2);
        transition: 0.3s;
        position: relative;
        z-index: 2;
    }

        .btn-outline-light:hover {
            background: white;
            color: var(--primary-navy);
        }

    .route-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        margin-bottom: 2.5rem;
        border: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .port-section {
        text-align: center;
        flex: 1;
    }

    .port-label {
        color: var(--text-muted);
        font-weight: 800;
        margin-bottom: 0.5rem;
        display: block;
    }

    .port-value {
        color: var(--primary-navy);
        font-size: 1.5rem;
        font-weight: 900;
    }

    .port-date {
        color: var(--primary-gold);
        font-weight: 800;
        font-size: 0.9rem;
        margin-top: 0.25rem;
        display: block;
    }

    .route-divider {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

        .route-divider::before {
            content: '';
            position: absolute;
            width: 100%;
            height: 2px;
            background: dashed 2px #cbd5e1;
            z-index: 1;
        }

    .route-icon {
        background: white;
        color: var(--primary-gold);
        font-size: 2rem;
        position: relative;
        z-index: 2;
        padding: 0 1rem;
        transform: @(System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft ? "scaleX(-1)" : "none");
    }

    .section-container {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        border: 1px solid #e2e8f0;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

        .section-title i {
            color: var(--primary-gold);
        }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        text-align: start;
    }

        .data-table th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            padding: 1rem;
            border-bottom: 2px solid #e2e8f0;
        }

        .data-table td {
            padding: 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-dark);
            font-weight: 700;
        }

        .data-table tr:hover {
            background-color: #f8fafc;
        }

    .btn-sm-gold {
        color: var(--primary-gold);
        font-weight: 800;
        text-decoration: none;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        background: rgba(195,154,92,0.1);
        transition: 0.3s;
    }

        .btn-sm-gold:hover {
            background: var(--primary-gold);
            color: white;
        }
</style>

<div>
    <div class="details-header">
        <div style="z-index: 2;">
            <h1 class="shipment-title-large">@Localizer["حاوية:"] @Model.ContainerNumber</h1>
            <span class="info-badge"><i class="fa-solid fa-ship"></i> @Localizer["خط الملاحة:"] @Model.ShippingLine</span>
            <span class="info-badge"><i class="fa-solid fa-file-contract"></i> @Localizer["بوليصة الشحن (B/L):"] @(string.IsNullOrEmpty(Model.BillOfLading) ? Localizer["قيد الانتظار"] : Model.BillOfLading)</span>
        </div>
        <div style="z-index: 2;">
            <a href="@Url.Action("Index", "Shipments")" class="btn-outline-light">@Localizer["العودة للشحنات"]</a>
        </div>
    </div>

    <div class="route-card">
        <div class="port-section">
            <span class="port-label">@Localizer["ميناء التحميل"]</span>
            <span class="port-value">@(Model.LoadingPort?.Name ?? Localizer["غير محدد"].Value)</span>
            <span class="port-date">ETD: @(Model.ExpectedTimeOfDeparture?.ToString("dd/MM/yyyy") ?? "-")</span>
        </div>
        <div class="route-divider">
            <span class="route-icon">✈</span>
        </div>
        <div class="port-section">
            <span class="port-label">@Localizer["ميناء الوصول"]</span>
            <span class="port-value">@(Model.DischargePort?.Name ?? Localizer["غير محدد"].Value)</span>
            <span class="port-date">ETA: @(Model.ExpectedTimeOfArrival?.ToString("dd/MM/yyyy") ?? "-")</span>
        </div>
    </div>

    <div class="section-container">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <h2 class="section-title" style="margin: 0;"><i class="fa-solid fa-cars"></i> @Localizer["السيارات داخل الحاوية"]</h2>
            <span style="background: #f8fafc; color: var(--primary-navy); padding: 0.5rem 1.5rem; border-radius: 0.75rem; font-weight: 800; border: 1px solid #e2e8f0;">@Localizer["العدد:"] @(Model.Cars?.Count ?? 0) @Localizer["سيارة"]</span>
        </div>

        <div style="overflow-x: auto;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>@Localizer["السيارة"]</th>
                        <th>@Localizer["رقم الشاصي (VIN)"]</th>
                        <th>@Localizer["العميل المالك"]</th>
                        <th>@Localizer["إجراءات"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Cars != null && Model.Cars.Any())
                    {
                        foreach (var car in Model.Cars)
                        {
                            <tr>
                                <td>@car.Make @car.Model @car.Year</td>
                                <td style="font-family: monospace; color: var(--text-muted);">@car.VIN</td>
                                <td>@(car.Customer?.Name ?? "-")</td>
                                <td><a href="@Url.Action("Details", "Cars", new { id = car.Id })" class="btn-sm-gold">@Localizer["عرض السيارة"]</a></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" style="text-align: center; color: var(--text-muted); padding: 2rem; font-weight: 700;">@Localizer["لم يتم تحميل أي سيارات في هذه الحاوية بعد."]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>