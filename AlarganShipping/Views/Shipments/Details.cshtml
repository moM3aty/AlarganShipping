@model AlarganShipping.Models.Shipment
@{
    ViewData["Title"] = Localizer["تفاصيل الشحنة والحاوية"];
}

<!-- استدعاء مكتبات التنسيق الضرورية -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<style>
    /* هيدر الصفحة الفاخر */
    .details-header {
        background: linear-gradient(135deg, var(--primary-navy) 0%, var(--secondary-navy) 100%);
        color: white;
        padding: 3rem;
        border-radius: 1.5rem;
        margin-bottom: 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 15px 35px rgba(44, 62, 80, 0.15);
        position: relative;
        overflow: hidden;
    }

        .details-header::before {
            content: '\f21a';
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            position: absolute;
            top: -20px;
            inset-inline-end: -20px;
            font-size: 15rem;
            color: rgba(184,147,90,0.08);
            z-index: 1;
        }

    .header-content {
        position: relative;
        z-index: 2;
    }

    .container-title {
        font-size: 2.5rem;
        font-weight: 900;
        margin: 0 0 0.5rem 0;
        color: var(--primary-gold);
        font-family: monospace;
        letter-spacing: 2px;
    }

    .status-badge-lg {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0.5rem 1.5rem;
        border-radius: 50px;
        font-weight: 800;
        border: 1px solid rgba(255,255,255,0.2);
        background: rgba(255,255,255,0.1);
        margin-bottom: 1rem;
    }

    .btn-outline-light {
        background: rgba(255,255,255,0.1);
        color: white;
        padding: 0.8rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,0.2);
        transition: 0.3s;
        z-index: 2;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-outline-light:hover {
            background: white;
            color: var(--primary-navy);
        }

    /* مسار الشحنة البصري (المتطور) */
    .route-visualizer {
        background: white;
        border-radius: 1.5rem;
        padding: 3rem;
        border: 1px solid #e2e8f0;
        margin-bottom: 2.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
    }

    .port-node {
        text-align: center;
        flex: 1;
        z-index: 5;
    }

    .port-icon {
        width: 65px;
        height: 65px;
        background: white;
        border: 3px solid var(--primary-gold);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: var(--primary-navy);
        margin: 0 auto 1.2rem;
        box-shadow: 0 5px 15px rgba(184, 147, 90, 0.2);
    }

    .port-name {
        font-weight: 900;
        color: var(--primary-navy);
        font-size: 1.2rem;
        margin-bottom: 0.3rem;
    }

    .port-date {
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 800;
        font-family: monospace;
    }

    .route-line {
        flex: 2;
        height: 6px;
        background: #f1f5f9;
        position: relative;
        margin: 0 1rem;
        border-radius: 10px;
    }

    .route-line-fill {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        background: var(--primary-gold);
        border-radius: 10px;
        width: 50%;
        transition: 1.5s ease;
    }

    .ship-icon {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 1.8rem;
        color: var(--primary-navy);
        background: white;
        padding: 0 15px;
    }

    /* كروت المعلومات */
    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }

    .info-card {
        background: white;
        padding: 1.5rem;
        border-radius: 1.25rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 5px 15px rgba(0,0,0,0.02);
    }

    .info-label {
        display: block;
        font-size: 0.8rem;
        color: var(--text-muted);
        font-weight: 800;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
    }

    .info-value {
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--primary-navy);
    }

    /* جدول السيارات */
    .section-container {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 0;
    }

    .btn-add-car {
        background: var(--primary-gold);
        color: white;
        border: none;
        padding: 0.8rem 1.5rem;
        border-radius: 0.8rem;
        font-weight: 800;
        cursor: pointer;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
    }

        .btn-add-car:hover {
            background: var(--secondary-gold);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(184, 147, 90, 0.3);
        }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table th {
            background: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            padding: 1.2rem 1rem;
            border-bottom: 2px solid #e2e8f0;
            text-align: start;
        }

        .data-table td {
            padding: 1.2rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-dark);
            font-weight: 700;
            vertical-align: middle;
        }

    .car-td-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .car-td-icon {
        width: 42px;
        height: 42px;
        background: rgba(184,147,90,0.1);
        color: var(--primary-gold);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    /* إصلاحات الـ Modal (الحل الجذري للمشكلة) */
    .custom-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(26, 37, 47, 0.85);
        z-index: 10000;
        display: none;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px);
        padding: 1.5rem;
    }

    .custom-modal {
        background: white;
        border-radius: 2rem;
        width: 100%;
        max-width: 550px;
        padding: 2.5rem;
        box-shadow: 0 25px 60px rgba(0,0,0,0.3);
        transform: scale(0.9);
        opacity: 0;
        transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .custom-modal.show {
            transform: scale(1);
            opacity: 1;
        }

    .modal-title {
        font-size: 1.6rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    /* تخصيص Select2 داخل المودال ليكون بريميوم */
    .select2-container--default .select2-selection--single {
        height: 55px !important;
        border: 2px solid #e2e8f0 !important;
        border-radius: 1rem !important;
        display: flex !important;
        align-items: center !important;
        font-weight: 700 !important;
        background: #f8fafc !important;
    }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            padding-inline-start: 1.2rem !important;
            color: var(--primary-navy) !important;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 53px !important;
            top: 0 !important;
        }

    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        margin-top: 2.5rem;
    }

    .btn-modal {
        padding: 0.9rem 2rem;
        border-radius: 1rem;
        font-weight: 800;
        cursor: pointer;
        border: none;
        transition: 0.3s;
        font-family: inherit;
        font-size: 1rem;
    }

    .btn-modal-cancel {
        background: #f1f5f9;
        color: var(--text-muted);
    }

    .btn-modal-confirm {
        background: var(--primary-navy);
        color: white;
        box-shadow: 0 5px 15px rgba(44, 62, 80, 0.2);
    }

        .btn-modal-confirm:hover {
            background: var(--primary-gold);
        }

    /* ميديا كويري للموبايل */
    @@media (max-width: 768px) {
        .details-header {
            flex-direction: column;
            text-align: center;
            padding: 2rem;
            gap: 2rem;
        }

        .container-title {
            font-size: 1.8rem;
        }

        .btn-outline-light {
            width: 100%;
            justify-content: center;
        }

        .route-visualizer {
            flex-direction: column;
            gap: 2.5rem;
            padding: 2.5rem 1.5rem;
        }

        .route-line {
            width: 6px;
            height: 100px;
            margin: 0;
        }

        .route-line-fill {
            width: 100%;
            height: 50%;
            top: 0;
        }

        .ship-icon {
            transform: translate(-50%, -50%) rotate(90deg);
            top: 50%;
        }

        .section-header {
            flex-direction: column;
            align-items: stretch;
            gap: 1rem;
            text-align: center;
        }

        .btn-add-car {
            justify-content: center;
        }

        .section-title {
            justify-content: center;
        }
    }
</style>

<div class="shipment-details-page">
    @Html.AntiForgeryToken()
    <input type="hidden" id="currentShipmentId" value="@Model.Id" />

    <!-- 1. الهيدر -->
    <div class="details-header">
        <div class="header-content">
            <div class="status-badge-lg">
                <i class="fa-solid fa-circle-dot" style="color: #4ade80;"></i>
                @Localizer[Model.Status ?? "Pending"]
            </div>
            <h1 class="container-title">@Model.ContainerNumber</h1>
            <p>@Localizer["خط الملاحة:"] @Model.ShippingLine | @Localizer["رقم الحجز:"] @Model.BookingNumber</p>
        </div>
        <a href="@Url.Action("Index", "Shipments")" class="btn-outline-light"><i class="fa-solid fa-arrow-right-long"></i> @Localizer["العودة للشحنات"]</a>
    </div>

    <!-- 2. متتبع المسار -->
    <div class="route-visualizer">
        <div class="port-node">
            <div class="port-icon"><i class="fa-solid fa-ship"></i></div>
            <div class="port-name">@(Model.LoadingPort?.Name ?? Localizer["غير محدد"].Value)</div>
            <div class="port-date">ETD: @(Model.ExpectedTimeOfDeparture?.ToString("dd MMM yyyy") ?? "-")</div>
        </div>
        <div class="route-line">
            <div class="route-line-fill" style="width: @(Model.Status == "Arrived" || Model.Status == "Cleared" ? "100%" : "50%")"></div>
            <div class="ship-icon"><i class="fa-solid fa-ferry"></i></div>
        </div>
        <div class="port-node">
            <div class="port-icon"><i class="fa-solid fa-anchor"></i></div>
            <div class="port-name">@(Model.DischargePort?.Name ?? Localizer["غير محدد"].Value)</div>
            <div class="port-date">ETA: @(Model.ExpectedTimeOfArrival?.ToString("dd MMM yyyy") ?? "-")</div>
        </div>
    </div>

    <!-- 3. كروت المعلومات -->
    <div class="info-grid">
        <div class="info-card">
            <span class="info-label">@Localizer["بوليصة الشحن (B/L)"]</span>
            <div class="info-value" style="font-family: monospace;">@(string.IsNullOrEmpty(Model.BillOfLading) ? "-" : Model.BillOfLading)</div>
        </div>
        <div class="info-card">
            <span class="info-label">@Localizer["عدد السيارات"]</span>
            <div class="info-value"><i class="fa-solid fa-car-side"></i> @(Model.Cars?.Count ?? 0) / 4</div>
        </div>
        <div class="info-card">
            <span class="info-label">@Localizer["ميناء التحميل"]</span>
            <div class="info-value">@(Model.LoadingPort?.Name ?? "-")</div>
        </div>
        <div class="info-card">
            <span class="info-label">@Localizer["ميناء الوصول"]</span>
            <div class="info-value">@(Model.DischargePort?.Name ?? "-")</div>
        </div>
    </div>

    <!-- 4. جدول السيارات -->
    <div class="section-container">
        <div class="section-header">
            <h2 class="section-title"><i class="fa-solid fa-cubes"></i> @Localizer["السيارات المحملة في هذه الحاوية"]</h2>
            @if ((Model.Cars?.Count ?? 0) < 4)
            {
                <button type="button" class="btn-add-car" onclick="openLinkModal()">
                    <i class="fa-solid fa-link"></i> @Localizer["ربط سيارة بالحاوية"]
                </button>
            }
        </div>

        <div style="overflow-x: auto; margin-top: 1rem;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>@Localizer["السيارة"]</th>
                        <th>@Localizer["رقم الشاصي"] (VIN)</th>
                        <th>@Localizer["المالك"]</th>
                        <th style="text-align: center;">@Localizer["إجراءات"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Cars != null && Model.Cars.Any())
                    {
                        foreach (var car in Model.Cars)
                        {
                            <tr>
                                <td>
                                    <div class="car-td-info">
                                        <div class="car-td-icon"><i class="fa-solid fa-car"></i></div>
                                        <div>
                                            <div style="color: var(--primary-navy); font-weight: 900; white-space: nowrap;">@car.Make @car.Model</div>
                                            <div style="color: var(--text-muted); font-size: 0.85rem;">@car.Year</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="font-family: monospace; color: var(--text-muted); font-weight: 800;">@car.VIN</td>
                                <td style="white-space: nowrap;"><i class="fa-solid fa-user-tie" style="color: #cbd5e1; margin-inline-end: 8px;"></i> @(car.Customer?.Name ?? "-")</td>
                                <td style="text-align: center;">
                                    <div style="display: flex; gap: 10px; justify-content: center;">
                                        <a href="@Url.Action("Details", "Cars", new { id = car.Id })" class="btn-sm-navy" style="text-decoration:none;">@Localizer["التفاصيل"]</a>
                                        <button type="button" class="btn-sm-danger" style="background:transparent; border:none; color:#ef4444; cursor:pointer;" onclick="confirmUnlink(@car.Id)"><i class="fa-solid fa-unlink"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" style="text-align: center; color: var(--text-muted); padding: 4rem;">
                                <i class="fa-solid fa-box-open" style="font-size: 3.5rem; color: #f1f5f9; margin-bottom: 1.5rem; display: block;"></i>
                                @Localizer["الحاوية فارغة حالياً. قم بربط السيارات من المستودع."]
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- المودال المصلح والمحسن لربط السيارة -->
<div class="custom-modal-overlay" id="linkCarModal">
    <div class="custom-modal">
        <div class="modal-title">
            <i class="fa-solid fa-car-on" style="color: var(--primary-gold);"></i>
            @Localizer["اختر سيارة لربطها"]
        </div>

        <div style="margin-bottom: 1rem;">
            <select id="carSelect" class="select2-modal-pro">
                <option value="">-- @Localizer["جاري التحميل..."] --</option>
            </select>
        </div>

        <div class="modal-actions">
            <button type="button" class="btn-modal btn-modal-cancel" onclick="closeLinkModal()">@Localizer["إلغاء"]</button>
            <button type="button" class="btn-modal btn-modal-confirm" id="btnSubmitLink" onclick="submitLinkCar()">
                <i class="fa-solid fa-check-circle"></i> @Localizer["تأكيد الربط"]
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script>
        $(document).ready(function() {
            // تهيئة أولية لـ Select2 مع تحديد الوالد (Modal) لحل مشكلة الظهور
            initializeSelect2();
        });

        function initializeSelect2() {
            var dir = $('html').attr('dir');
            $('.select2-modal-pro').select2({
                dir: dir,
                width: '100%',
                dropdownParent: $('#linkCarModal'), // هذا السطر يحل مشكلة ظهور القائمة خلف المودال
                placeholder: "@Localizer["اختر السيارة..."]"
            });
        }

        function openLinkModal() {
            $('#carSelect').empty().append('<option value="">-- @Html.Raw(Localizer["جاري التحميل..."]) --</option>');
            $('#linkCarModal').css('display', 'flex').hide().fadeIn(200);
            setTimeout(() => $('.custom-modal').addClass('show'), 10);

            // جلب السيارات المتاحة
            $.get('@Url.Action("GetAvailableCars", "Shipments")', function(data) {
                $('#carSelect').empty().append('<option value="">-- @Html.Raw(Localizer["اختر السيارة..."]) --</option>');
                if(data && data.length > 0) {
                    data.forEach(c => {
                        var text = c.make + ' ' + c.model + ' (' + c.vin + ')';
                        $('#carSelect').append(new Option(text, c.id));
                    });
                } else {
                    $('#carSelect').empty().append('<option value="">-- @Html.Raw(Localizer["لا توجد سيارات متاحة في المستودع"]) --</option>');
                }
                // تحديث Select2 بعد إضافة الخيارات
                $('.select2-modal-pro').trigger('change');
            });
        }

        function closeLinkModal() {
            $('.custom-modal').removeClass('show');
            $('#linkCarModal').fadeOut(200);
        }

        function submitLinkCar() {
            var carId = $('#carSelect').val();
            var shipmentId = $('#currentShipmentId').val();

            if(!carId) {
                Swal.fire({ title: "@Html.Raw(Localizer["تنبيه!"])", text: "@Html.Raw(Localizer["يرجى اختيار سيارة أولاً"])", icon: 'warning', confirmButtonColor: 'var(--primary-gold)' });
                return;
            }

            var btn = $('#btnSubmitLink');
            btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');

            $.post('@Url.Action("LinkCar", "Shipments")', {
                shipmentId: shipmentId,
                carId: carId,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            }, function(res) {
                if(res.success) {
                    location.reload();
                } else {
                    Swal.fire({ title: "@Html.Raw(Localizer["خطأ!"])", text: res.message, icon: 'error', confirmButtonColor: 'var(--primary-navy)' });
                    btn.prop('disabled', false).html('<i class="fa-solid fa-check-circle"></i> @Html.Raw(Localizer["تأكيد الربط"])');
                }
            }).fail(function() {
                Swal.fire({ title: "@Html.Raw(Localizer["خطأ!"])", text: "@Html.Raw(Localizer["حدث خطأ أثناء الاتصال بالخادم."])", icon: 'error' });
                btn.prop('disabled', false).html('<i class="fa-solid fa-check-circle"></i> @Html.Raw(Localizer["تأكيد الربط"])');
            });
        }

        function confirmUnlink(carId) {
            Swal.fire({
                title: "@Html.Raw(Localizer["هل أنت متأكد؟"])",
                text: "@Html.Raw(Localizer["سيتم فك ارتباط هذه السيارة من الحاوية وإعادتها لحالة المستودع."])",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: 'var(--primary-navy)',
                confirmButtonText: "@Html.Raw(Localizer["نعم، إزالة"])",
                cancelButtonText: "@Html.Raw(Localizer["إلغاء"])"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("UnlinkCar", "Shipments")', {
                        carId: carId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    }, function(res) {
                        if(res.success) {
                            location.reload();
                        } else {
                            Swal.fire({ title: "@Html.Raw(Localizer["خطأ!"])", text: res.message, icon: 'error' });
                        }
                    });
                }
            });
        }
    </script>
}