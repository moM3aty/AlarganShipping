@model AlarganShipping.Models.Car
@{
    ViewData["Title"] = Localizer["تعديل بيانات المركبة"];
}

<style>
    /* --- الهيدر الفاخر --- */
    .details-header {
        background: linear-gradient(135deg, var(--secondary-navy) 0%, var(--primary-navy) 100%);
        color: white;
        padding: 3rem;
        border-radius: 1.5rem;
        margin-bottom: 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 15px 35px rgba(26, 37, 47, 0.15);
        position: relative;
        overflow: hidden;
    }

        .details-header::before {
            content: '';
            position: absolute;
            top: -50px;
            inset-inline-end: -50px;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(184, 147, 90, 0.2) 0%, transparent 70%);
        }

    .header-content {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .car-main-img-preview {
        width: 90px;
        height: 90px;
        border-radius: 1.2rem;
        object-fit: cover;
        border: 3px solid var(--primary-gold);
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        color: var(--primary-navy);
    }

    .header-title-large {
        font-size: 2.2rem;
        font-weight: 900;
        margin: 0 0 0.5rem 0;
        color: white;
    }

    .header-subtitle {
        background-color: rgba(255,255,255,0.1);
        padding: 0.3rem 1rem;
        border-radius: 0.5rem;
        font-family: monospace;
        font-size: 1rem;
        letter-spacing: 1px;
        border: 1px solid rgba(255,255,255,0.2);
        display: inline-block;
        color: var(--primary-gold);
    }

    .btn-action-light {
        background: rgba(255,255,255,0.1);
        color: white;
        padding: 0.8rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        text-decoration: none;
        transition: 0.3s;
        border: 1px solid rgba(255,255,255,0.3);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        position: relative;
        z-index: 2;
    }

        .btn-action-light:hover {
            background: white;
            color: var(--primary-navy);
        }

    /* --- بطاقة النموذج (Form Card) --- */
    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(44, 62, 80, 0.03);
        border: 1px solid #f1f5f9;
        padding: 2.5rem;
    }

    .section-divider {
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 2rem 0 1.5rem 0;
        padding-bottom: 0.8rem;
        border-bottom: 2px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-divider:first-of-type {
            margin-top: 0;
        }

    .form-grid-4 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media (min-width: 768px) {
        .form-grid-4 {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (min-width: 1200px) {
        .form-grid-4 {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-label {
        font-weight: 800;
        color: var(--text-muted);
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
    }

    .form-control {
        padding: 0.9rem 1.2rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--primary-navy);
        transition: 0.3s;
        outline: none;
        background: #f8fafc;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            background: white;
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

    .input-group-dynamic {
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .input-group-dynamic .select2-container {
            flex: 1;
        }

    .btn-quick-add {
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
        border: 1px solid rgba(184, 147, 90, 0.2);
        width: 46px;
        height: 46px;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.3s;
        flex-shrink: 0;
    }

        .btn-quick-add:hover {
            background: var(--primary-gold);
            color: white;
        }

    /* تعديل الصورة المتقدم */
    .image-edit-box {
        background: #f8fafc;
        border: 2px dashed #cbd5e1;
        padding: 1.5rem;
        border-radius: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        grid-column: 1 / -1;
        gap: 2rem;
        transition: 0.3s;
        cursor: pointer;
    }

        .image-edit-box:hover {
            border-color: var(--primary-gold);
            background: rgba(184, 147, 90, 0.05);
        }

        .image-edit-box input[type="file"] {
            display: none;
        }

    .img-upload-info {
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .img-upload-info i {
            font-size: 2.5rem;
            color: var(--primary-gold);
        }

    .img-upload-text h4 {
        margin: 0 0 5px 0;
        color: var(--primary-navy);
        font-weight: 900;
    }

    .img-upload-text p {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.85rem;
        font-weight: 700;
    }

    .form-actions {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-submit {
        background: var(--primary-navy);
        color: white;
        border: none;
        padding: 1.2rem 3rem;
        border-radius: 1rem;
        font-weight: 900;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 10px 20px rgba(26, 37, 47, 0.2);
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-submit:hover {
            background: var(--primary-gold);
            transform: translateY(-3px);
            box-shadow: 0 15px 25px rgba(184, 147, 90, 0.3);
        }

    .btn-delete {
        background: transparent;
        color: #ef4444;
        border: 1px solid #ef4444;
        padding: 1rem 2rem;
        border-radius: 1rem;
        font-weight: 900;
        cursor: pointer;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
            box-shadow: 0 5px 15px rgba(239, 68, 68, 0.2);
        }

    /* Select2 Customization */
    .select2-container--default .select2-selection--single {
        background-color: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        height: 46px;
        display: flex;
        align-items: center;
        transition: 0.3s;
    }

        .select2-container--default .select2-selection--single:focus, .select2-container--focus .select2-selection--single {
            border-color: var(--primary-gold);
            background-color: white;
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            color: var(--primary-navy);
            font-weight: 700;
            padding: 0 1rem;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 44px;
            right: 10px;
        }

    html[dir="rtl"] .select2-container--default .select2-selection--single .select2-selection__arrow {
        left: 10px;
        right: auto;
    }

    @@media (max-width: 768px) {
        .details-header {
            flex-direction: column;
            text-align: center;
            padding: 2rem 1.5rem;
            gap: 1.5rem;
        }

        .header-content {
            flex-direction: column;
        }

        .btn-action-light {
            width: 100%;
            justify-content: center;
        }

        .premium-form-card {
            padding: 1.5rem;
        }

        .image-edit-box {
            flex-direction: column;
            text-align: center;
        }

        .form-actions {
            flex-direction: column-reverse;
            gap: 1rem;
        }

        .btn-submit, .btn-delete {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<div class="cars-edit-page">
    <!-- الهيدر الفاخر -->
    <div class="details-header">
        <div class="header-content">
            @if (!string.IsNullOrEmpty(Model.MainImageUrl))
            {
                <img src="@Model.MainImageUrl" class="car-main-img-preview" alt="Car Image" />
            }
            else
            {
                <div class="car-main-img-preview"><i class="fa-solid fa-car"></i></div>
            }
            <div>
                <h1 class="header-title-large">@Localizer["تعديل:"] @Model.Make @Model.Model</h1>
                <div class="header-subtitle">VIN: @Model.VIN</div>
            </div>
        </div>
        <a href="@Url.Action("Index", "Cars")" class="btn-action-light">
            <i class="fa-solid fa-list-ul"></i> @Localizer["قائمة السيارات"]
        </a>
    </div>

    <!-- بطاقة النموذج -->
    <div class="premium-form-card">
        <form asp-action="Edit" method="post" id="carEditForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="MainImageUrl" />
            <input type="hidden" asp-for="AddDate" />

            <!-- صندوق تغيير الصورة -->
            <div class="image-edit-box" onclick="document.getElementById('mainImageUpload').click()">
                <div class="img-upload-info">
                    <i class="fa-solid fa-image"></i>
                    <div class="img-upload-text">
                        <h4>@Localizer["تغيير صورة السيارة الرئيسية"]</h4>
                        <p id="mainImgNameText">@Localizer["اضغط هنا لاختيار صورة جديدة (سيتم استبدال الصورة الحالية)"]</p>
                    </div>
                </div>
                <div style="background: white; padding: 0.5rem 1rem; border-radius: 0.8rem; border: 1px solid #e2e8f0; font-weight: 800; color: var(--primary-navy);">@Localizer["استعراض..."]</div>
                <input type="file" id="mainImageUpload" name="mainImage" accept="image/*" onchange="showEditFileName(this)" />
            </div>

            <!-- 1. البيانات الأساسية -->
            <div class="section-divider"><i class="fa-solid fa-car" style="color:var(--primary-gold);"></i> @Localizer["البيانات الأساسية"]</div>
            <div class="form-grid-4">
                <div class="form-group">
                    <label asp-for="VIN" class="form-label">@Localizer["رقم الشاصي (VIN)"] *</label>
                    <input asp-for="VIN" class="form-control" dir="ltr" style="font-family: monospace; font-size: 1.1rem; color: var(--primary-gold);" required />
                </div>
                <div class="form-group">
                    <label asp-for="Year" class="form-label">@Localizer["سنة الصنع"] *</label>
                    <input asp-for="Year" class="form-control" type="number" required />
                </div>
                <div class="form-group">
                    <label asp-for="Make" class="form-label">@Localizer["الماركة"] *</label>
                    <div class="input-group-dynamic">
                        <select asp-for="Make" class="form-control select2-search" required>
                            <option value="">@Localizer["اختر الماركة..."]</option>
                            <option value="Toyota">Toyota</option>
                            <option value="Lexus">Lexus</option>
                            <option value="Chevrolet">Chevrolet</option>
                            <option value="Mercedes">Mercedes</option>
                            <option value="BMW">BMW</option>
                            <option value="Ford">Ford</option>
                            @if (!string.IsNullOrEmpty(Model.Make) && Model.Make != "Toyota" && Model.Make != "BMW" && Model.Make != "Lexus" && Model.Make != "Mercedes" && Model.Make != "Ford")
                            {
                                <option value="@Model.Make" selected>@Model.Make</option>
                            }
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('Make', '@Html.Raw(Localizer["إضافة ماركة سيارة جديدة"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="VehicleType" class="form-label">@Localizer["نوع المركبة"]</label>
                    <div class="input-group-dynamic">
                        <select asp-for="VehicleType" class="form-control select2-search" asp-items="ViewBag.VehicleShapes">
                            <option value="">@Localizer["اختر النوع..."]</option>
                            @if (!string.IsNullOrEmpty(Model.VehicleType) && !(ViewBag.VehicleShapes as SelectList).Any(t => t.Text == Model.VehicleType))
                            {
                                <option value="@Model.VehicleType" selected>@Model.VehicleType</option>
                            }
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('VehicleType', '@Html.Raw(Localizer["إضافة نوع مركبة جديد"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Model" class="form-label">@Localizer["الموديل"] *</label>
                    <input asp-for="Model" class="form-control" required />
                </div>
                <div class="form-group">
                    <label asp-for="Color" class="form-label">@Localizer["اللون"] *</label>
                    <input asp-for="Color" class="form-control" required />
                </div>
                <div class="form-group">
                    <label asp-for="LotNumber" class="form-label">@Localizer["رقم اللوت (Lot)"]</label>
                    <input asp-for="LotNumber" class="form-control" dir="ltr" />
                </div>
            </div>

            <!-- 2. الشراء والتسعير -->
            <div class="section-divider"><i class="fa-solid fa-money-bill-wave" style="color:var(--primary-gold);"></i> @Localizer["بيانات الشراء والتسعير"]</div>
            <div class="form-grid-4">
                <div class="form-group">
                    <label asp-for="CustomerId" class="form-label">@Localizer["العميل (مطلوب)"] *</label>
                    <div class="input-group-dynamic">
                        <select asp-for="CustomerId" class="form-control select2-search" asp-items="ViewBag.CustomerId" required></select>
                        <button type="button" class="btn-quick-add" onclick="quickAddCustomer()"><i class="fa-solid fa-user-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="AuctionId" class="form-label">@Localizer["المعرض / المزاد"] *</label>
                    <div class="input-group-dynamic">
                        <select asp-for="AuctionId" class="form-control select2-search" asp-items="ViewBag.AuctionId" required></select>
                        <button type="button" class="btn-quick-add" onclick="quickAddAuction()"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="PurchasePrice" class="form-label" style="color: #ef4444;">@Localizer["سعر الشراء (التكلفة الفعلية) $"] *</label>
                    <input asp-for="PurchasePrice" class="form-control" type="number" step="0.01" style="font-family:monospace; font-size: 1.1rem; border-color: #fca5a5;" required />
                </div>
                <div class="form-group">
                    <label asp-for="SellingPrice" class="form-label" style="color: #16a34a;">@Localizer["سعر البيع (شامل الربح) $"]</label>
                    <input asp-for="SellingPrice" class="form-control" type="number" step="0.01" style="font-family:monospace; font-size: 1.1rem; border-color: #86efac;" />
                </div>
            </div>

            <!-- 3. التتبع والضرائب -->
            <div class="section-divider"><i class="fa-solid fa-map-location-dot" style="color:var(--primary-gold);"></i> @Localizer["التتبع والضرائب"]</div>
            <div class="form-grid-4">
                <div class="form-group">
                    <label asp-for="StatusId" class="form-label">@Localizer["حالة المركبة (7 مراحل)"] *</label>
                    <select asp-for="StatusId" class="form-control select2-search" required>
                        <option value="1">@Localizer["الشراء"]</option>
                        <option value="2">@Localizer["الدفع"]</option>
                        <option value="3">@Localizer["النقل الداخلي"]</option>
                        <option value="4">@Localizer["وصول المستودع"]</option>
                        <option value="5">@Localizer["التحميل"]</option>
                        <option value="6">@Localizer["الإقلاع"]</option>
                        <option value="7">@Localizer["الوصول"]</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="CurrentLocation" class="form-label">@Localizer["توجد في (الموقع الحالي)"]</label>
                    <input asp-for="CurrentLocation" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="TaxType" class="form-label">@Localizer["نوع الضريبة"]</label>
                    <div class="input-group-dynamic">
                        <select asp-for="TaxType" class="form-control select2-search" id="TaxTypeSelect" asp-items="ViewBag.TaxTypes">
                            <option value="">@Localizer["اختر النوع..."]</option>
                            <option value="شامل الضريبة">@Localizer["شامل الضريبة"]</option>
                            @if (!string.IsNullOrEmpty(Model.TaxType) && !(ViewBag.TaxTypes as SelectList).Any(t => t.Text == Model.TaxType) && Model.TaxType != "شامل الضريبة")
                            {
                                <option value="@Model.TaxType" selected>@Model.TaxType</option>
                            }
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('TaxTypeSelect', '@Html.Raw(Localizer["إضافة نوع ضريبة جديد"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="TaxAmount" class="form-label">@Localizer["مبلغ الضريبة / النسبة"]</label>
                    <input asp-for="TaxAmount" type="number" step="0.01" class="form-control" id="TaxAmountInput" />
                </div>
                <div class="form-group">
                    <label asp-for="TaxMethod" class="form-label">@Localizer["طريقة الضريبة"]</label>
                    <div class="input-group-dynamic">
                        <select asp-for="TaxMethod" class="form-control select2-search" asp-items="ViewBag.TaxMethods">
                            <option value="">@Localizer["اختر الطريقة..."]</option>
                            @if (!string.IsNullOrEmpty(Model.TaxMethod) && !(ViewBag.TaxMethods as SelectList).Any(t => t.Text == Model.TaxMethod))
                            {
                                <option value="@Model.TaxMethod" selected>@Model.TaxMethod</option>
                            }
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('TaxMethod', '@Html.Raw(Localizer["إضافة طريقة ضريبة جديدة"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
            </div>

            <!-- 4. قسم التفاصيل الفنية -->
            <div class="section-divider"><i class="fa-solid fa-gears" style="color:var(--primary-gold);"></i> @Localizer["تفاصيل إضافية"]</div>
            <div class="form-grid-4">
                <div class="form-group">
                    <label asp-for="InternalCode" class="form-label">@Localizer["الكود الداخلي"]</label>
                    <input asp-for="InternalCode" class="form-control" dir="ltr" />
                </div>
                <div class="form-group">
                    <label asp-for="PlateNo" class="form-label">@Localizer["رقم اللوحة"]</label>
                    <input asp-for="PlateNo" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="CardNo" class="form-label">@Localizer["رقم الكرت"]</label>
                    <input asp-for="CardNo" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="EngineNo" class="form-label">@Localizer["رقم الماكينة"]</label>
                    <input asp-for="EngineNo" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="CustomsDeclaration" class="form-label">@Localizer["البيان الجمركي"]</label>
                    <input asp-for="CustomsDeclaration" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="InsuranceNo" class="form-label">@Localizer["الرقم التأميني"]</label>
                    <input asp-for="InsuranceNo" class="form-control" />
                </div>
            </div>

            <div class="form-actions">
                <button type="button" class="btn-delete" onclick="confirmDelete(@Model.Id)">
                    <i class="fa-solid fa-trash-can"></i> @Localizer["حذف السيارة"]
                </button>
                <button type="submit" class="btn-submit" id="btnSubmit">
                    <i class="fa-solid fa-save"></i> @Localizer["تحديث البيانات"]
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>

    <script>
        function showEditFileName(input) {
            var fileName = input.value.split('\\').pop();
            if(fileName) {
                $('#mainImgNameText').text("✔ " + fileName).css('color', '#16a34a');
            }
        }

        // إضافة سريعة للخيار
        function quickAddOption(selectId, titleText) {
            Swal.fire({
                title: titleText,
                input: 'text',
                inputPlaceholder: '@Html.Raw(Localizer["أدخل الاسم هنا..."])',
                showCancelButton: true,
                confirmButtonText: '@Html.Raw(Localizer["إضافة"])',
                cancelButtonText: '@Html.Raw(Localizer["إلغاء"])',
                confirmButtonColor: 'var(--primary-gold)',
                cancelButtonColor: 'var(--primary-navy)',
                inputValidator: (value) => {
                    if (!value) { return '@Html.Raw(Localizer["لا يمكن ترك الحقل فارغاً!"])'; }
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    var newOption = new Option(result.value, result.value, true, true);
                    $('#' + selectId).append(newOption).trigger('change');
                }
            });
        }

        // إضافة عميل سريع
        function quickAddCustomer() {
            Swal.fire({
                title: '@Html.Raw(Localizer["إضافة عميل سريع"])',
                input: 'text',
                inputPlaceholder: '@Html.Raw(Localizer["اسم العميل أو الشركة..."])',
                showCancelButton: true,
                confirmButtonText: '@Html.Raw(Localizer["إضافة"])',
                cancelButtonText: '@Html.Raw(Localizer["إلغاء"])',
                confirmButtonColor: 'var(--primary-gold)',
                cancelButtonColor: 'var(--primary-navy)'
            }).then((result) => {
                if (result.isConfirmed && result.value) {
                    $.post('@Url.Action("CreateQuick", "Customers")', { name: result.value, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() }, function(res) {
                        if (res.success) {
                            $('#CustomerId').append(new Option(res.name, res.id, true, true)).trigger('change');
                            Swal.fire({ title: '@Html.Raw(Localizer["تمت الإضافة!"])', icon: 'success', timer: 1500, showConfirmButton: false });
                        }
                    });
                }
            });
        }

