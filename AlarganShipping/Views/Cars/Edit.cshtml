@model AlarganShipping.Models.Car
@{
    ViewData["Title"] = Localizer["تعديل بيانات المركبة"];
}

<style>
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-back {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        padding: 0.6rem 1.2rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: var(--primary-navy);
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(44, 62, 80, 0.03);
        border: 1px solid #f1f5f9;
        padding: 3rem;
        position: relative;
        overflow: hidden;
    }

    .form-grid-4 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media (min-width: 768px) {
        .form-grid-4 {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (min-width: 1200px) {
        .form-grid-4 {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-label {
        font-weight: 800;
        color: var(--text-muted);
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
    }

    .form-control {
        padding: 0.85rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 0.95rem;
        color: var(--primary-navy);
        font-weight: 700;
        background-color: white;
        transition: 0.3s;
        outline: none;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

    .input-vin {
        border-color: #fca5a5;
        background-color: #fef2f2;
    }

        .input-vin:focus {
            border-color: #ef4444;
            box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.1);
        }

    .select2-container--default .select2-selection--single {
        background-color: white;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        height: 45px;
        display: flex;
        align-items: center;
        transition: 0.3s;
    }

        .select2-container--default .select2-selection--single:focus, .select2-container--focus .select2-selection--single {
            border-color: var(--primary-gold);
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            color: var(--primary-navy);
            font-weight: 700;
            padding-left: 1rem;
            padding-right: 1rem;
            font-size: 0.95rem;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 43px;
            right: 10px;
        }

    html[dir="rtl"] .select2-container--default .select2-selection--single .select2-selection__arrow {
        left: 10px;
        right: auto;
    }

    .input-group-dynamic {
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .input-group-dynamic .select2-container {
            flex: 1;
        }

    .btn-quick-add {
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
        border: 1px solid rgba(184, 147, 90, 0.2);
        width: 45px;
        height: 45px;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.3s;
        flex-shrink: 0;
    }

        .btn-quick-add:hover {
            background: var(--primary-gold);
            color: white;
            box-shadow: 0 4px 10px rgba(184, 147, 90, 0.2);
        }

    .form-actions {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-start;
        gap: 1rem;
        align-items: center;
    }

    .btn-submit {
        background: var(--primary-navy);
        color: white;
        border: none;
        padding: 0.85rem 2.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        font-size: 1rem;
        cursor: pointer;
        transition: 0.3s;
        font-family: inherit;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 4px 15px rgba(26, 37, 47, 0.2);
    }

        .btn-submit:hover {
            background: var(--secondary-navy);
            transform: translateY(-2px);
        }

    .btn-cancel {
        background: transparent;
        color: var(--text-dark);
        border: none;
        font-weight: 800;
        cursor: pointer;
        text-decoration: none;
        padding: 0.85rem 1rem;
    }

    .form-hint {
        font-size: 0.8rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 5px;
        margin-inline-start: auto;
    }

    /* ستايل زر الحذف */
    .btn-delete {
        background: transparent;
        color: #ef4444;
        border: 1px solid #ef4444;
        padding: 0.85rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        cursor: pointer;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-inline-end: auto;
        text-decoration: none;
    }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
            box-shadow: 0 4px 15px rgba(239, 68, 68, 0.2);
        }
</style>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<div>
    <div class="form-page-header">
        <h2 class="form-page-title">@Localizer["تعديل بيانات المركبة"] <i class="fa-solid fa-pen-to-square" style="color: var(--primary-gold); background: rgba(184, 147, 90, 0.1); padding: 8px; border-radius: 8px; font-size:1.2rem;"></i></h2>
        <a href="@Url.Action("Index", "Cars")" class="btn-back"><i class="fa-solid fa-arrow-right-long"></i> @Localizer["العودة للقائمة"]</a>
    </div>

    <div class="premium-form-card">
        <form asp-action="Edit" method="post" id="carEditForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- حقول مخفية مهمة جداً للحفاظ على البيانات الأساسية أثناء التعديل -->
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="MainImageUrl" />
            <input type="hidden" asp-for="AddDate" />
            <input type="hidden" asp-for="PurchasePrice" />

            <div class="form-grid-4">
                <!-- صورة السيارة -->
                <div class="form-group" style="grid-column: 1 / -1; display: flex; align-items: center; gap: 1.5rem; background: #f8fafc; padding: 1.5rem; border-radius: 1rem; border: 1px dashed #cbd5e1;">
                    @if (!string.IsNullOrEmpty(Model.MainImageUrl))
                    {
                        <img src="@Model.MainImageUrl" alt="Car" style="width: 100px; height: 100px; border-radius: 1rem; object-fit: cover; border: 2px solid var(--primary-gold);" />
                    }
                    else
                    {
                        <div style="width: 100px; height: 100px; border-radius: 1rem; background: #e2e8f0; display:flex; align-items:center; justify-content:center; font-size: 2rem; color: #94a3b8;"><i class="fa-solid fa-car"></i></div>
                    }
                    <div style="flex: 1;">
                        <label class="form-label" style="color: var(--primary-navy);">@Localizer["تغيير صورة السيارة الرئيسية (اختياري)"]</label>
                        <input type="file" name="mainImage" class="form-control" accept="image/*" style="padding: 0.5rem; background: white;" />
                    </div>
                </div>

                <!-- الصف الأول -->
                <div class="form-group">
                    <label asp-for="InternalCode" class="form-label">@Localizer["الكود الداخلي"]</label>
                    <input asp-for="InternalCode" class="form-control" dir="ltr" placeholder="AUTO-2024-..." />
                </div>
                <div class="form-group">
                    <label asp-for="VIN" class="form-label">@Localizer["رقم الشاصي"] *</label>
                    <input asp-for="VIN" class="form-control input-vin" dir="ltr" required />
                </div>
                <div class="form-group">
                    <label asp-for="Year" class="form-label">@Localizer["سنة الصنع"] *</label>
                    <input asp-for="Year" class="form-control" type="number" required />
                </div>
                <div class="form-group">
                    <label asp-for="Make" class="form-label">@Localizer["الماركة"] *</label>
                    <div class="input-group-dynamic">
                        <select asp-for="Make" class="form-control select2-search" required>
                            <option value="">@Localizer["اختر الماركة..."]</option>
                            <option value="Toyota">Toyota</option>
                            <option value="BMW">BMW</option>
                            <option value="Lexus">Lexus</option>
                            @if (Model.Make != "Toyota" && Model.Make != "BMW" && Model.Make != "Lexus")
                            {
                                <option value="@Model.Make" selected>@Model.Make</option>
                            }
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('Make', '@Html.Raw(Localizer["إضافة ماركة سيارة جديدة"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>

                <!-- الصف الثاني -->
                <div class="form-group">
                    <label asp-for="Model" class="form-label">@Localizer["الموديل والنوع"] *</label>
                    <input asp-for="Model" class="form-control" required />
                </div>
                <div class="form-group">
                    <label asp-for="CustomerId" class="form-label">@Localizer["العميل (مطلوب)"] *</label>
                    <div class="input-group-dynamic">
                        <select asp-for="CustomerId" class="form-control select2-search input-customer" asp-items="ViewBag.CustomerId" required></select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('CustomerId', '@Html.Raw(Localizer["إضافة عميل سريع"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="AuctionId" class="form-label">@Localizer["المعرض"] *</label>
                    <div class="input-group-dynamic">
                        <select asp-for="AuctionId" class="form-control select2-search" asp-items="ViewBag.AuctionId" required></select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('AuctionId', '@Html.Raw(Localizer["إضافة معرض جديد"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="StatusId" class="form-label">@Localizer["حالة المركبة"] *</label>
                    <select asp-for="StatusId" class="form-control select2-search" required>
                        <option value="1">@Localizer["تم الشراء"]</option>
                        <option value="2">@Localizer["في المستودع"]</option>
                        <option value="3">@Localizer["الشحن البحري"]</option>
                        <option value="4">@Localizer["واصلة الميناء"]</option>
                    </select>
                </div>

                <!-- الصف الثالث -->
                <div class="form-group">
                    <label asp-for="CurrentLocation" class="form-label">@Localizer["توجد في (الموقع الحالي)"]</label>
                    <input asp-for="CurrentLocation" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="PlateNo" class="form-label">@Localizer["رقم اللوحة"]</label>
                    <input asp-for="PlateNo" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="CardNo" class="form-label">@Localizer["رقم الكرت"]</label>
                    <input asp-for="CardNo" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="EngineNo" class="form-label">@Localizer["رقم الماكينة"]</label>
                    <input asp-for="EngineNo" class="form-control" />
                </div>

                <!-- الصف الرابع -->
                <div class="form-group">
                    <label asp-for="Color" class="form-label">@Localizer["اللون"] *</label>
                    <input asp-for="Color" class="form-control" required />
                </div>
                <div class="form-group">
                    <label asp-for="TaxType" class="form-label">@Localizer["نوع الضريبة"]</label>
                    <div class="input-group-dynamic">
                        <select asp-for="TaxType" class="form-control select2-search" asp-items="ViewBag.TaxTypes">
                            <option value="">@Localizer["اختر النوع..."]</option>
                            @if (!string.IsNullOrEmpty(Model.TaxType) && !(ViewBag.TaxTypes as SelectList).Any(t => t.Text == Model.TaxType))
                            {
                                <option value="@Model.TaxType" selected>@Model.TaxType</option>
                            }
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('TaxType', '@Html.Raw(Localizer["إضافة نوع ضريبة جديد"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="TaxAmount" class="form-label">@Localizer["مبلغ الضريبة / النسبة"]</label>
                    <input asp-for="TaxAmount" type="number" step="0.01" class="form-control" placeholder="0" />
                </div>
                <div class="form-group">
                    <label asp-for="CustomsDeclaration" class="form-label">@Localizer["البيان الجمركي"]</label>
                    <input asp-for="CustomsDeclaration" class="form-control" />
                </div>

                <!-- الصف الخامس -->
                <div class="form-group">
                    <label asp-for="InsuranceNo" class="form-label">@Localizer["الرقم التأميني"]</label>
                    <input asp-for="InsuranceNo" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="VehicleType" class="form-label">@Localizer["نوع المركبة"]</label>
                    <div class="input-group-dynamic">
                        <select asp-for="VehicleType" class="form-control select2-search">
                            <option value="">@Localizer["اختر النوع..."]</option>
                            <option value="Sedan">@Localizer["صالون (Sedan)"]</option>
                            <option value="SUV">@Localizer["دفع رباعي (SUV)"]</option>
                            <option value="Pickup">@Localizer["بيك أب (Pickup)"]</option>
                            @if (!string.IsNullOrEmpty(Model.VehicleType) && Model.VehicleType != "Sedan" && Model.VehicleType != "SUV" && Model.VehicleType != "Pickup")
                            {
                                <option value="@Model.VehicleType" selected>@Model.VehicleType</option>
                            }
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('VehicleType', '@Html.Raw(Localizer["إضافة نوع مركبة جديد"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="TaxMethod" class="form-label">@Localizer["طريقة الضريبة"]</label>
                    <div class="input-group-dynamic">
                        <select asp-for="TaxMethod" class="form-control select2-search" asp-items="ViewBag.TaxMethods">
                            <option value="">@Localizer["اختر الطريقة..."]</option>
                            @if (!string.IsNullOrEmpty(Model.TaxMethod) && !(ViewBag.TaxMethods as SelectList).Any(t => t.Text == Model.TaxMethod))
                            {
                                <option value="@Model.TaxMethod" selected>@Model.TaxMethod</option>
                            }
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('TaxMethod', '@Html.Raw(Localizer["إضافة طريقة ضريبة جديدة"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="VehicleShape" class="form-label">@Localizer["الشكل"]</label>
                    <div class="input-group-dynamic">
                        <select asp-for="VehicleShape" class="form-control select2-search" asp-items="ViewBag.VehicleShapes">
                            <option value="">@Localizer["اختر الشكل..."]</option>
                            @if (!string.IsNullOrEmpty(Model.VehicleShape) && !(ViewBag.VehicleShapes as SelectList).Any(t => t.Text == Model.VehicleShape))
                            {
                                <option value="@Model.VehicleShape" selected>@Model.VehicleShape</option>
                            }
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('VehicleShape', '@Html.Raw(Localizer["إضافة شكل سيارة جديد"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="button" class="btn-delete" onclick="confirmDelete(@Model.Id)">
                    <i class="fa-solid fa-trash-can"></i> @Localizer["حذف السيارة"]
                </button>
                <button type="submit" class="btn-submit" id="btnSubmit">
                    <i class="fa-solid fa-save"></i> @Localizer["تحديث البيانات"]
                </button>
                <a href="@Url.Action("Index", "Cars")" class="btn-cancel">@Localizer["إلغاء"]</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>

    <script>
        function quickAddOption(selectId, titleText) {
            Swal.fire({
                title: titleText,
                input: 'text',
                inputPlaceholder: '@Html.Raw(Localizer["أدخل الاسم هنا..."])',
                showCancelButton: true,
                confirmButtonText: '@Html.Raw(Localizer["إضافة"])',
                cancelButtonText: '@Html.Raw(Localizer["إلغاء"])',
                confirmButtonColor: 'var(--primary-gold)',
                cancelButtonColor: 'var(--primary-navy)',
                inputValidator: (value) => {
                    if (!value) { return '@Html.Raw(Localizer["لا يمكن ترك الحقل فارغاً!"])'; }
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    var newOption = new Option(result.value, result.value, true, true);
                    $('#' + selectId).append(newOption).trigger('change');
                    Swal.fire({ title: '@Html.Raw(Localizer["تمت الإضافة!"])', icon: 'success', timer: 1500, showConfirmButton: false });
                }
            });
        }

        // دالة تأكيد وحذف السيارة
        function confirmDelete(id) {
            Swal.fire({
                title: '@Html.Raw(Localizer["هل أنت متأكد؟"])',
                text: '@Html.Raw(Localizer["لن تتمكن من التراجع عن عملية الحذف!"])',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: 'var(--primary-navy)',
                confirmButtonText: '@Html.Raw(Localizer["نعم، احذفها!"])',
                cancelButtonText: '@Html.Raw(Localizer["إلغاء"])'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Cars")/' + id,
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    title: '@Html.Raw(Localizer["تم الحذف!"])',
                                    text: '@Html.Raw(Localizer["تم حذف بيانات السيارة بنجاح."])',
                                    icon: 'success',
                                    confirmButtonColor: 'var(--primary-gold)'
                                }).then(() => {
                                    window.location.href = '@Url.Action("Index", "Cars")';
                                });
                            } else {
                                Swal.fire('@Html.Raw(Localizer["خطأ!"])', response.message || '@Html.Raw(Localizer["حدث خطأ أثناء الحذف."])', 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('@Html.Raw(Localizer["خطأ!"])', '@Html.Raw(Localizer["لا يمكن الاتصال بالخادم."])', 'error');
                        }
                    });
                }
            });
        }

        $(document).ready(function() {
            var dir = $('html').attr('dir');
            $('.select2-search').select2({ dir: dir, width: '100%' });

            $('#carEditForm').on('submit', function(e) {
                e.preventDefault();
                var form = $(this);
                if (!form[0].checkValidity()) { form[0].reportValidity(); return; }

                var btn = $('#btnSubmit');
                var originalText = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin"></i> @Html.Raw(Localizer["جاري التحديث..."])').prop('disabled', true);

                var formData = new FormData(form[0]);

                $.ajax({
                    url: form.attr('action'), type: form.attr('method'), data: formData,
                    processData: false, contentType: false,
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                title: '@Html.Raw(Localizer["تم التحديث بنجاح!"])', icon: 'success', confirmButtonColor: 'var(--primary-gold)',
                                confirmButtonText: '@Html.Raw(Localizer["العودة للقائمة"])'
                            }).then(() => { window.location.href = '@Url.Action("Index", "Cars")'; });
                        } else {
                            var errorMsg = response.errors ? response.errors.join('\n') : '@Html.Raw(Localizer["تأكد من البيانات المدخلة"])';
                            Swal.fire({ title: '@Html.Raw(Localizer["خطأ!"])', text: errorMsg, icon: 'error', confirmButtonColor: 'var(--primary-navy)' });
                            btn.html(originalText).prop('disabled', false);
                        }
                    },
                    error: function () {
                        Swal.fire({ title: '@Html.Raw(Localizer["خطأ!"])', text: '@Html.Raw(Localizer["حدث خطأ أثناء الحفظ."])', icon: 'error', confirmButtonColor: 'var(--primary-navy)' });
                        btn.html(originalText).prop('disabled', false);
                    }
                });
            });
        });
    </script>
}