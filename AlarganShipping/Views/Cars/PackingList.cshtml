@model AlarganShipping.Models.Car
@{
    ViewData["Title"] = Localizer["قائمة التعبئة والتغليف"];
    Layout = null; // صفحة مخصصة للطباعة النظيفة بدون هيدر
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>Packing List - @Model.VIN</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Cairo', sans-serif;
            background: #e2e8f0;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
        }

        .packing-container {
            background: white;
            width: 100%;
            max-width: 800px;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 3px solid #1e293b;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

            .header img {
                height: 70px;
            }

            .header h1 {
                margin: 0;
                font-size: 2.2rem;
                color: #1e293b;
                font-weight: 900;
            }

            .header h2 {
                margin: 5px 0 0 0;
                color: #64748b;
                font-size: 1.2rem;
                letter-spacing: 2px;
            }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .info-box {
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            padding: 15px;
            background: #f8fafc;
        }

        .info-title {
            font-size: 1rem;
            font-weight: 900;
            color: white;
            background: #1e293b;
            padding: 5px 12px;
            border-radius: 5px;
            display: inline-block;
            margin-top: -28px;
            margin-bottom: 15px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-weight: 700;
            border-bottom: 1px dashed #cbd5e1;
            padding-bottom: 4px;
        }

            .info-row:last-child {
                border-bottom: none;
            }

        .val {
            color: #b45309;
            font-weight: 900;
            font-family: monospace;
            font-size: 1.1rem;
        }

        /* قائمة التعبئة (Checklist) */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
            border: 2px solid #1e293b;
        }

        th {
            background: #1e293b;
            color: white;
            padding: 12px;
            text-align: right;
            border: 1px solid #1e293b;
        }

        td {
            padding: 12px;
            border: 1px solid #e2e8f0;
            font-weight: 800;
            font-size: 1rem;
        }

        .checkbox-cell {
            text-align: center;
            width: 60px;
        }

        .checkbox-box {
            width: 25px;
            height: 25px;
            border: 2px solid #94a3b8;
            border-radius: 4px;
            display: inline-block;
        }

        .notes-area {
            border: 2px dashed #94a3b8;
            padding: 15px;
            height: 100px;
            border-radius: 8px;
            margin-bottom: 30px;
            color: #94a3b8;
            font-weight: bold;
        }

        .footer {
            display: flex;
            justify-content: space-between;
            margin-top: 50px;
            padding-top: 20px;
        }

        .sig-box {
            text-align: center;
            width: 200px;
        }

        .sig-line {
            border-bottom: 2px solid #1e293b;
            margin-bottom: 10px;
            height: 40px;
        }

        .controls {
            text-align: center;
            margin-bottom: 20px;
        }

        .btn-print {
            background: #b45309;
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 8px;
            font-weight: 800;
            font-family: inherit;
            font-size: 1.1rem;
            cursor: pointer;
            transition: 0.3s;
        }

            .btn-print:hover {
                background: #1e293b;
            }

        @@media print {
            body

        {
            background: white;
            padding: 0;
            margin: 0;
        }

        .packing-container {
            box-shadow: none;
            padding: 0;
            max-width: 100%;
            border: none;
        }

        .controls {
            display: none;
        }

        .info-title, th {
            background-color: #1e293b !important;
            color: white !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        }
    </style>
</head>
<body>
    <div style="width: 100%; max-width: 800px;">
        <div class="controls">
            <button class="btn-print" onclick="window.print()">🖨️ طباعة قائمة التعبئة</button>
            <button class="btn-print" style="background:#1e293b; margin-inline-start:10px;" onclick="history.back()">العودة</button>
        </div>

        <div class="packing-container">
            <div class="header">
                <div>
                    <h1>ALARGAN SHIPPING</h1>
                    <h2>قائمة التعبئة والتغليف (PACKING LIST)</h2>
                </div>
                <img src="/images/logo.png" alt="Logo" onerror="this.style.display='none'" />
            </div>

            <div class="info-grid">
                <div class="info-box">
                    <div class="info-title">بيانات المركبة (Vehicle)</div>
                    <div class="info-row"><span>المركبة:</span> <span class="val" style="color:#1e293b;">@Model.Make @Model.Model @Model.Year</span></div>
                    <div class="info-row"><span>رقم الشاصي:</span> <span class="val" dir="ltr">@Model.VIN</span></div>
                    <div class="info-row"><span>رقم اللوت:</span> <span class="val" dir="ltr">@(Model.LotNumber ?? "-")</span></div>
                    <div class="info-row"><span>اللون:</span> <span class="val" style="color:#1e293b;">@Model.Color</span></div>
                </div>
                <div class="info-box">
                    <div class="info-title">بيانات الشحن (Shipping)</div>
                    <div class="info-row"><span>العميل:</span> <span class="val" style="color:#1e293b;">@(Model.Customer?.Name ?? "-")</span></div>
                    <div class="info-row"><span>الكود:</span> <span class="val">@(Model.Customer?.CustomerCode ?? "-")</span></div>
                    <div class="info-row"><span>رقم الحاوية:</span> <span class="val">@(Model.Shipment?.ContainerNumber ?? "Pending")</span></div>
                    <div class="info-row"><span>الوجهة:</span> <span class="val" style="color:#1e293b;">@(Model.Shipment?.DischargePort?.Name ?? "-")</span></div>
                </div>
            </div>

            <table>
                <thead>
                    <tr>
                        <th class="checkbox-cell">تأكيد</th>
                        <th>البند (Item)</th>
                        <th>ملاحظات الحالة (Condition Notes)</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td class="checkbox-cell"><div class="checkbox-box"></div></td><td>مفاتيح السيارة (Car Keys)</td><td></td></tr>
                    <tr><td class="checkbox-cell"><div class="checkbox-box"></div></td><td>ملكية السيارة / التايتل (Title / Certificate)</td><td></td></tr>
                    <tr><td class="checkbox-cell"><div class="checkbox-box"></div></td><td>إطار احتياطي (Spare Tire)</td><td></td></tr>
                    <tr><td class="checkbox-cell"><div class="checkbox-box"></div></td><td>كتيب المالك (Owner's Manual)</td><td></td></tr>
                    <tr><td class="checkbox-cell"><div class="checkbox-box"></div></td><td>أجزاء مفككة داخل السيارة (Loose Parts)</td><td></td></tr>
                    <tr><td class="checkbox-cell"><div class="checkbox-box"></div></td><td>الحالة العامة للزجاج (Glass Condition)</td><td></td></tr>
                </tbody>
            </table>

            <div class="notes-area">
                ملاحظات إضافية أثناء التعبئة (Additional Notes):
            </div>

            <div class="footer">
                <div class="sig-box">
                    <div class="sig-line"></div>
                    <div style="font-weight: bold;">توقيع مسؤول التحميل<br />Loader Signature</div>
                </div>
                <div class="sig-box">
                    <div class="sig-line"></div>
                    <div style="font-weight: bold;">توقيع مسؤول المستودع<br />Warehouse Manager</div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>