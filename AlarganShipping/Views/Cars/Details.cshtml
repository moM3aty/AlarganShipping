@model AlarganShipping.Models.Car
@using System.Text.Json
@inject IWebHostEnvironment Env
@{
    ViewData["Title"] = Localizer["تفاصيل السيارة والتتبع"];

    // --- جلب إعدادات الشركة ديناميكياً ---
    string settingsPath = System.IO.Path.Combine(Env.WebRootPath, "settings.json");
    string companyPhone = "96894203663"; // رقم افتراضي
    if (System.IO.File.Exists(settingsPath))
    {
        var json = System.IO.File.ReadAllText(settingsPath);
        using var doc = JsonDocument.Parse(json);
        if (doc.RootElement.TryGetProperty("InquiryPhoneNumber", out var phoneProp))
        {
            companyPhone = phoneProp.GetString() ?? companyPhone;
        }
    }

    // متغيرات لسهولة التعديل مستقبلاً
    string vatNumber = "00016800820";
    string crNumber = "0001425763";
    string companyAddressAr = "صلاله شارع المعارض";
    string companyAddressEn = "Salalah, Exhibition St.";

    // --- التعديل الجذري هنا: سحب سعر البيع للعميل بدلاً من سعر التكلفة ---
    decimal customerCarPrice = (Model.SellingPrice.HasValue && Model.SellingPrice.Value > 0) ? Model.SellingPrice.Value : Model.PurchasePrice;

    // المتغيرات المالية
    var invoice = Model.Invoices?.FirstOrDefault();
    decimal auctionFee = invoice?.AuctionFees ?? 0;
    decimal towingFee = invoice?.InlandTowing ?? 0;
    decimal seaFreight = invoice?.SeaFreight ?? 0;
    decimal customs = invoice?.CustomsAndTaxes ?? 0;
    decimal adminFee = invoice?.CompanyCommission ?? 0;

    decimal transferFee = invoice?.TransferFees ?? 0;
    decimal omanTowing = invoice?.OmanTowingFees ?? 0;
    decimal sizeFee = invoice?.CarSizeFees ?? 0;

    // المجاميع بناءً على الفاتورة أو القيمة المبدئية للعميل
    decimal totalAmount = invoice?.TotalAmount ?? customerCarPrice;
    decimal paidAmount = invoice?.AmountPaid ?? 0;
    decimal remainingAmount = invoice != null ? (invoice.TotalAmount - invoice.AmountPaid) : customerCarPrice;

    string displayInvoiceNo = invoice != null && !string.IsNullOrEmpty(invoice.InvoiceNumber) ? invoice.InvoiceNumber : "PRO-" + (Model.InternalCode ?? (Model.VIN?.Substring(Math.Max(0, Model.VIN.Length - 6))));
    string invoiceDateStr = invoice?.IssueDate.ToString("dd/MM/yyyy HH:mm") ?? DateTime.Now.ToString("dd/MM/yyyy HH:mm");
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name" dir="@(System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <title>@Localizer["فاتورة رقم"] @displayInvoiceNo</title>
    <style>
        /* --- إعدادات عامة للشاشة --- */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f0f0;
            margin: 0;
            padding: 20px;
            font-size: 14px;
        }

        /* --- حاوية الفاتورة (ورقة A4) --- */
        .invoice-container {
            background: white;
            width: 210mm; /* عرض A4 */
            min-height: 297mm; /* طول A4 */
            max-height: 297mm; /* تثبيت الطول لمنع التمدد */
            margin: 0 auto;
            padding: 10mm 15mm; /* هوامش داخلية */
            box-shadow: 0 0 15px rgba(0,0,0,0.1);
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            overflow: hidden; /* منع خروج المحتوى */
        }

        /* --- تنسيق الجدول --- */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
            font-size: 11pt; /* حجم خط مناسب للقراءة والطباعة */
        }

            .items-table th, .items-table td {
                border: 1px solid #000;
                padding: 4px 6px; /* تقليل الـ padding لضغط المحتوى */
                text-align: center;
                vertical-align: middle;
            }

            .items-table th {
                background-color: #f2f2f2;
                font-weight: bold;
                font-size: 10pt;
            }

            .items-table tbody tr:nth-child(even) {
                background-color: #fafafa;
            }

        /* --- قسم التذييل (Totals) --- */
        .totals-section {
            margin-top: auto; /* دفع القسم للأسفل */
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .totals-table {
            width: 45%;
            border-collapse: collapse;
            font-size: 11pt;
        }

            .totals-table td {
                padding: 3px 5px;
                border: none;
            }

        .grand-total-row {
            font-weight: bold;
            font-size: 13pt;
            border-top: 2px solid #000;
        }

        /* --- الطباعة --- */
        @@media print {
            body

        {
            background: none;
            margin: 0;
            padding: 0;
        }

        .invoice-container {
            box-shadow: none;
            margin: 0;
            width: 100%;
            height: 100%; /* ملء الصفحة */
            min-height: auto;
            max-height: none;
            border: none;
            padding: 10mm; /* هوامش الطباعة */
        }

        /* إخفاء عناصر غير ضرورية للطباعة إن وجدت */
        .no-print {
            display: none;
        }

        }

        /* تنسيقات إضافية للعناوين */
        .header-logo {
            width: 120px;
        }

        .header-title {
            font-size: 22px;
            font-weight: bold;
            color: #1a5f7a;
        }

        .company-info {
            font-size: 10pt;
            color: #555;
            text-align: center;
        }

        .invoice-meta {
            font-size: 10pt;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

    <div class="invoice-container">
        <!-- رأس الفاتورة (Header) -->
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #1a5f7a; padding-bottom: 10px; margin-bottom: 15px;">
            <div style="text-align: right;">
                <div class="header-title">@Localizer["فاتورة بيع / شحن"]</div>
                <div style="font-size: 10pt; color:#666;">@Localizer["رقم الفاتورة:"] @displayInvoiceNo</div>
            </div>
            <div style="text-align: center;">
                <!-- استبدل بمسار اللوجو الخاص بك -->
                <img src="~/images/logo.png" class="header-logo" alt="Logo" onerror="this.style.display='none'" />
                <div class="company-info">@companyAddressAr - @companyAddressEn</div>
            </div>
            <div style="text-align: left; font-size: 10pt;">
                <div>@Localizer["التاريخ:"] @invoiceDateStr</div>
                <div>@Localizer["الرقم الضريبي:"] @vatNumber</div>
            </div>
        </div>

        <!-- معلومات العميل والسيارة -->
        <div class="invoice-meta" style="display: flex; justify-content: space-between;">
            <div style="width: 48%;">
                <strong>@Localizer["بيانات العميل:"]</strong><br />
                @Localizer["الاسم:"] @Model.Customer?.Name <br />
                @Localizer["الجوال:"] @Model.Customer?.Phone
            </div>
            <div style="width: 48%; text-align: left;">
                <strong>@Localizer["بيانات السيارة:"]</strong><br />
                @Localizer["السيارة:"] @Model.Make @Model.Model @Model.Year <br />
                @Localizer["اللون:"] @Localizer[Model.Color ?? "-"]
            </div>
        </div>

        <!-- جدول الأصناف (تم تطبيقه هنا) -->
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width: 5%;">@Localizer["مسلسل"]<br />Sr. No</th>
                    <th style="width: 20%;">@Localizer["رقم الشاصي"]<br />Chesis.No</th>
                    <th style="width: 40%;">@Localizer["وصف الصنف"]<br />Description</th>
                    <th style="width: 8%;">@Localizer["الوحدة"]<br />Unit</th>
                    <th style="width: 5%;">@Localizer["الكمية"]<br />QTY</th>
                    <th style="width: 12%;">@Localizer["السعر"]<br />Price</th>
                    <th style="width: 5%;">@Localizer["الإجمالي"]<br />Total</th>
                </tr>
            </thead>
            <tbody>
                <!-- الصنف الرئيسي (السيارة) -->
                <tr>
                    <td>1</td>
                    <td dir="ltr" style="font-size: 9pt;">@Model.VIN</td>
                    <td dir="ltr">@Model.Make - @Model.Model - @Model.Year - @Localizer[Model.Color ?? "-"]</td>
                    <td>@Localizer["واحد"]</td>
                    <td>1.00</td>
                    <!-- ✅ تم وضع سعر البيع للعميل بدلاً من سعر الشراء -->
                    <td>@customerCarPrice.ToString("N2")</td>
                    <td>@customerCarPrice.ToString("N2")</td>
                </tr>

                <!-- المصاريف الإضافية -->
                @if (invoice != null && !invoice.IsShippingOnly && auctionFee > 0)
                {
                    <tr>
                        <td>-</td>
                        <td dir="ltr">-</td>
                        <td>Auction Fees - @Localizer["رسوم المزاد"]</td>
                        <td>-</td>
                        <td>-</td>
                        <td>@auctionFee.ToString("N2")</td>
                        <td>@auctionFee.ToString("N2")</td>
                    </tr>
                }
                @if (transferFee > 0)
                {
                    <tr>
                        <td>-</td>
                        <td dir="ltr">-</td>
                        <td>Transfer Fees - @Localizer["رسوم التحويل"]</td>
                        <td>-</td>
                        <td>-</td>
                        <td>@transferFee.ToString("N2")</td>
                        <td>@transferFee.ToString("N2")</td>
                    </tr>
                }
                @if (sizeFee > 0)
                {
                    <tr>
                        <td>-</td>
                        <td dir="ltr">-</td>
                        <td>Car Size Fees - @Localizer["رسوم حجم السيارة"]</td>
                        <td>-</td>
                        <td>-</td>
                        <td>@sizeFee.ToString("N2")</td>
                        <td>@sizeFee.ToString("N2")</td>
                    </tr>
                }
                @if (towingFee > 0)
                {
                    <tr>
                        <td>-</td>
                        <td dir="ltr">-</td>
                        <td>Inland Towing (US) - @Localizer["النقل الداخلي (أمريكا)"]</td>
                        <td>-</td>
                        <td>-</td>
                        <td>@towingFee.ToString("N2")</td>
                        <td>@towingFee.ToString("N2")</td>
                    </tr>
                }
                @if (seaFreight > 0)
                {
                    <tr>
                        <td>-</td>
                        <td dir="ltr">-</td>
                        <td>Ocean Freight - @Localizer["الشحن البحري"]</td>
                        <td>-</td>
                        <td>-</td>
                        <td>@seaFreight.ToString("N2")</td>
                        <td>@seaFreight.ToString("N2")</td>
                    </tr>
                }
                @if (omanTowing > 0)
                {
                    <tr>
                        <td>-</td>
                        <td dir="ltr">-</td>
                        <td>Oman Towing - @Localizer["النقل الداخلي عمان"]</td>
                        <td>-</td>
                        <td>-</td>
                        <td>@omanTowing.ToString("N2")</td>
                        <td>@omanTowing.ToString("N2")</td>
                    </tr>
                }
                @if (adminFee > 0)
                {
                    <tr>
                        <td>-</td>
                        <td dir="ltr">-</td>
                        <td>Admin Commission - @Localizer["عمولة الشركة"]</td>
                        <td>-</td>
                        <td>-</td>
                        <td>@adminFee.ToString("N2")</td>
                        <td>@adminFee.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- المجاميع -->
        <div class="totals-section">
            <div style="width: 50%; font-size: 9pt;">
                <strong>@Localizer["ملاحظات:"]</strong><br />
                @Localizer["شكراً لتعاملكم معنا."]<br />
                @Localizer["تذكير: يرجى التحقق من صحة البيانات قبل السداد."]
            </div>

            <table class="totals-table" dir="@(System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft ? "rtl" : "ltr")">
                <tr>
                    <td>@Localizer["المبلغ الإجمالي:"]</td>
                    <td style="text-align: left;" dir="ltr">@totalAmount.ToString("N2") OMR</td>
                </tr>
                <tr>
                    <td>@Localizer["المبلغ المدفوع:"]</td>
                    <td style="text-align: left;" dir="ltr">@paidAmount.ToString("N2") OMR</td>
                </tr>
                <tr class="grand-total-row">
                    <td>@Localizer["المتبقي:"]</td>
                    <td style="text-align: left;" dir="ltr">@remainingAmount.ToString("N2") OMR</td>
                </tr>
            </table>
        </div>

        <!-- تذييل الصفحة -->
        <div style="margin-top: auto; text-align: center; font-size: 9pt; border-top: 1px solid #ccc; padding-top: 5px;">
            @Localizer["الرقم الضريبي:"] @vatNumber | @Localizer["الرقم التجاري:"] @crNumber | @Localizer["هاتف:"] @companyPhone
        </div>
    </div>

</body>
</html>