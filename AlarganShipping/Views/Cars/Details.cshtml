@model AlarganShipping.Models.Car
@{
    ViewData["Title"] = Localizer["تفاصيل السيارة والتتبع"];
}

<style>
    .details-header {
        background: var(--primary-navy);
        color: white;
        padding: 3rem;
        border-radius: 1.5rem;
        margin-bottom: 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 15px 35px rgba(26, 42, 58, 0.15);
        position: relative;
        overflow: hidden;
    }

        .details-header::before {
            content: '';
            position: absolute;
            top: -50px;
            inset-inline-end: -50px;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(195,154,92,0.2) 0%, transparent 70%);
        }

    .car-title-large {
        font-size: 2.5rem;
        font-weight: 900;
        margin: 0 0 1rem 0;
        color: var(--primary-gold);
    }

    .vin-badge {
        background-color: rgba(255,255,255,0.1);
        padding: 0.5rem 1.5rem;
        border-radius: 0.75rem;
        font-family: monospace;
        font-size: 1.1rem;
        letter-spacing: 2px;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .btn-action-light {
        background: rgba(255,255,255,0.1);
        color: white;
        padding: 0.8rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        text-decoration: none;
        transition: 0.3s;
        border: 1px solid rgba(255,255,255,0.3);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-action-light:hover {
            background: white;
            color: var(--primary-navy);
        }

    /* Stepper Styling */
    .tracking-card {
        background: white;
        border-radius: 1.5rem;
        padding: 3rem;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        margin-bottom: 2.5rem;
        border: 1px solid #e2e8f0;
    }

    .tracking-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 3rem;
        text-align: center;
    }

    .stepper-wrapper {
        display: flex;
        justify-content: space-between;
        position: relative;
        max-width: 800px;
        margin: 0 auto;
    }

        .stepper-wrapper::before {
            content: '';
            position: absolute;
            top: 25px;
            left: 0;
            right: 0;
            height: 4px;
            background-color: #f1f5f9;
            z-index: 1;
        }

    .step-item {
        position: relative;
        z-index: 3;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100px;
    }

    .step-circle {
        width: 54px;
        height: 54px;
        background-color: #ffffff;
        border: 4px solid #e2e8f0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        color: #94a3b8;
        margin-bottom: 1rem;
        transition: 0.3s;
        box-shadow: 0 0 0 5px white;
    }

    .step-item.active .step-circle {
        border-color: var(--primary-gold);
        background-color: var(--primary-gold);
        color: white;
        box-shadow: 0 0 0 5px white, 0 4px 15px rgba(195, 154, 92, 0.4);
    }

    .step-label {
        font-weight: 800;
        font-size: 0.9rem;
        color: var(--text-muted);
        text-align: center;
    }

    .step-item.active .step-label {
        color: var(--primary-navy);
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media (min-width: 768px) {
        .info-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    .info-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 5px 20px rgba(0,0,0,0.02);
    }

    .info-card-title {
        color: var(--primary-navy);
        font-size: 1.25rem;
        font-weight: 900;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .info-card-title i {
            color: var(--primary-gold);
        }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 1rem 0;
        border-bottom: 1px dashed #e2e8f0;
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-label {
        color: var(--text-muted);
        font-weight: 800;
    }

    .info-value {
        color: var(--text-dark);
        font-weight: 900;
    }
</style>

<div>
    <div class="details-header">
        <div style="z-index: 2;">
            <h1 class="car-title-large">@Model.Make @Model.Model @Model.Year</h1>
            <span class="vin-badge">VIN: @Model.VIN</span>
        </div>
        <div style="z-index: 2; display: flex; flex-direction: column; gap: 10px;">
            <a href="@Url.Action("Index", "Cars")" class="btn-action-light"><i class="fa-solid fa-list"></i> @Localizer["قائمة السيارات"]</a>
            <a href="@Url.Action("Create", "CarInspections", new { carId = Model.Id })" class="btn-action-light" style="background: var(--primary-gold); border-color: var(--primary-gold);"><i class="fa-solid fa-clipboard-check"></i> @Localizer["إضافة تقرير فحص"]</a>
        </div>
    </div>

    <!-- Tracking Stepper -->
    <div class="tracking-card">
        <h2 class="tracking-title">@Localizer["مراحل الشحن والتتبع"]</h2>

        @{
            int status = Model.StatusId;
            // شريط التقدم يعتمد على الاتجاه، لذلك نستخدم CSS Logical properties
            string lineWidth = status == 1 ? "0%" : status == 2 ? "33%" : status == 3 ? "66%" : status >= 4 ? "100%" : "0%";
        }

        <div class="stepper-wrapper">
            <style>
                .stepper-wrapper::after {
                    content: '';
                    position: absolute;
                    top: 25px;
                    inset-inline-start: 0;
                    height: 4px;
                    background-color: var(--primary-gold);
                    z-index: 2;
                    transition: width 0.5s ease;
                    width: @lineWidth;
                }
            </style>

            <div class="step-item @(status >= 1 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-gavel"></i></div>
                <div class="step-label">@Localizer["تم الشراء"]</div>
            </div>
            <div class="step-item @(status >= 2 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-warehouse"></i></div>
                <div class="step-label">@Localizer["في المستودع"]</div>
            </div>
            <div class="step-item @(status >= 3 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-ship"></i></div>
                <div class="step-label">@Localizer["أبحرت"]</div>
            </div>
            <div class="step-item @(status >= 4 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-anchor"></i></div>
                <div class="step-label">@Localizer["وصلت الميناء"]</div>
            </div>
        </div>
    </div>

    <!-- Details Grid -->
    <div class="info-grid">
        <div class="info-card">
            <h3 class="info-card-title"><i class="fa-solid fa-car"></i> @Localizer["معلومات السيارة"]</h3>
            <div class="info-row"><span class="info-label">@Localizer["الشركة المصنعة"]</span><span class="info-value">@Model.Make</span></div>
            <div class="info-row"><span class="info-label">@Localizer["الموديل"]</span><span class="info-value">@Model.Model</span></div>
            <div class="info-row"><span class="info-label">@Localizer["سنة الصنع"]</span><span class="info-value">@Model.Year</span></div>
            <div class="info-row"><span class="info-label">@Localizer["اللون"]</span><span class="info-value">@Model.Color</span></div>
        </div>

        <div class="info-card">
            <h3 class="info-card-title"><i class="fa-solid fa-user-tie"></i> @Localizer["معلومات المالك"]</h3>
            <div class="info-row"><span class="info-label">@Localizer["اسم العميل"]</span><span class="info-value">@(Model.Customer?.Name ?? Localizer["غير محدد"].Value)</span></div>
            <div class="info-row"><span class="info-label">@Localizer["رقم الهاتف"]</span><span class="info-value" dir="ltr">@(Model.Customer?.Phone ?? "-")</span></div>
            <div class="info-row"><span class="info-label">@Localizer["سعر الشراء"]</span><span class="info-value" style="color: #16a34a;">$@Model.PurchasePrice</span></div>
            <div class="info-row"><span class="info-label">@Localizer["المزاد"]</span><span class="info-value">@(Model.Auction?.Name ?? Localizer["خارجي"].Value)</span></div>
        </div>
    </div>
</div>