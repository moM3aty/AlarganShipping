@model AlarganShipping.Models.Car
@{
    ViewData["Title"] = Localizer["تفاصيل السيارة والتتبع"];
}

<style>
    /* ========================================================
       1. التنسيقات الأساسية والهيدر
       ======================================================== */
    .details-header {
        background: linear-gradient(135deg, var(--secondary-navy) 0%, var(--primary-navy) 100%);
        color: white;
        padding: 3rem;
        border-radius: 1.5rem;
        margin-bottom: 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 15px 35px rgba(26, 37, 47, 0.15);
        position: relative;
        overflow: hidden;
        flex-wrap: wrap;
        gap: 2rem;
    }

    .details-header::before {
        content: '';
        position: absolute;
        top: -50px;
        inset-inline-end: -50px;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(184, 147, 90, 0.2) 0%, transparent 70%);
    }

    .car-header-info {
        display: flex;
        align-items: center;
        gap: 2rem;
        z-index: 2;
        position: relative;
    }

    .car-main-img {
        width: 150px;
        height: 150px;
        border-radius: 1rem;
        object-fit: cover;
        border: 4px solid var(--primary-gold);
        box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: #cbd5e1;
    }

    .car-title-large {
        font-size: 2.5rem;
        font-weight: 900;
        margin: 0 0 1rem 0;
        color: var(--primary-gold);
    }

    .vin-badge {
        background-color: rgba(255,255,255,0.1);
        padding: 0.5rem 1.5rem;
        border-radius: 0.75rem;
        font-family: monospace;
        font-size: 1.1rem;
        letter-spacing: 2px;
        border: 1px solid rgba(255,255,255,0.2);
        display: inline-block;
    }

    /* شبكة أزرار الإجراءات في الهيدر */
    .header-actions-grid {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        min-width: 350px;
    }

    .btn-action-light {
        background: rgba(255,255,255,0.1);
        color: white;
        padding: 0.8rem 1.2rem;
        border-radius: 0.75rem;
        font-weight: 800;
        font-size: 0.9rem;
        text-decoration: none;
        transition: 0.3s;
        border: 1px solid rgba(255,255,255,0.3);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        cursor: pointer;
        font-family: inherit;
    }

    .btn-action-light:hover {
        background: white;
        color: var(--primary-navy);
        border-color: white;
    }

    .btn-full-width {
        grid-column: 1 / -1;
    }

    /* ========================================================
       2. شريط التتبع (Stepper)
       ======================================================== */
    .tracking-card {
        background: white;
        border-radius: 1.5rem;
        padding: 3rem;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        margin-bottom: 2.5rem;
        border: 1px solid #e2e8f0;
    }

    .tracking-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 3rem;
        text-align: center;
    }

    .stepper-wrapper {
        display: flex;
        justify-content: space-between;
        position: relative;
        max-width: 800px;
        margin: 0 auto;
    }

    .stepper-wrapper::before {
        content: ''; position: absolute; top: 25px; left: 0; right: 0;
        height: 4px; background-color: #f1f5f9; z-index: 1;
    }

    .stepper-wrapper::after {
        content: ''; position: absolute; top: 25px; inset-inline-start: 0;
        height: 4px; background-color: var(--primary-gold); z-index: 2;
        transition: width 0.5s ease; width: var(--progress-width, 0%);
    }

    .step-item { position: relative; z-index: 3; display: flex; flex-direction: column; align-items: center; width: 100px; }

    .step-circle {
        width: 54px; height: 54px; background-color: #ffffff;
        border: 4px solid #e2e8f0; border-radius: 50%; display: flex;
        align-items: center; justify-content: center; font-weight: 900;
        color: #94a3b8; margin-bottom: 1rem; transition: 0.3s;
        box-shadow: 0 0 0 5px white;
    }

    .step-item.active .step-circle {
        border-color: var(--primary-gold); background-color: var(--primary-gold);
        color: white; box-shadow: 0 0 0 5px white, 0 4px 15px rgba(184, 147, 90, 0.4);
    }

    .step-label { font-weight: 800; font-size: 0.9rem; color: var(--text-muted); text-align: center; }
    .step-item.active .step-label { color: var(--primary-navy); }

    /* ========================================================
       3. كروت المعلومات
       ======================================================== */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media (min-width: 768px) {
        .info-grid { grid-template-columns: 1fr 1fr; }
    }

    .info-card {
        background: white; border-radius: 1.5rem; padding: 2rem;
        border: 1px solid #e2e8f0; box-shadow: 0 5px 20px rgba(0,0,0,0.02);
    }

    .info-card-title {
        color: var(--primary-navy); font-size: 1.25rem; font-weight: 900;
        margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px;
    }
    .info-card-title i { color: var(--primary-gold); }

    .info-row {
        display: flex; justify-content: space-between; padding: 1rem 0;
        border-bottom: 1px dashed #e2e8f0;
    }
    .info-row:last-child { border-bottom: none; }

    .info-label { color: var(--text-muted); font-weight: 800; }
    .info-value { color: var(--text-dark); font-weight: 900; }

    /* ========================================================
       4. التبويبات والمستندات (التصميم الجديد)
       ======================================================== */
    .tabs-container {
        margin-top: 2.5rem; background: white; border-radius: 1.5rem;
        padding: 2rem; box-shadow: 0 5px 20px rgba(0,0,0,0.02); border: 1px solid #e2e8f0;
    }

    .tabs-header {
        display: flex; gap: 1rem; border-bottom: 2px solid #f1f5f9;
        margin-bottom: 2rem; overflow-x: auto; scrollbar-width: none;
    }
    .tabs-header::-webkit-scrollbar { display: none; }

    .tab-btn {
        background: transparent; border: none; padding: 1rem 1.5rem; font-size: 1rem;
        font-weight: 900; color: var(--text-muted); cursor: pointer;
        position: relative; transition: 0.3s; white-space: nowrap;
    }
    .tab-btn:hover { color: var(--primary-navy); }
    .tab-btn.active { color: var(--primary-gold); }
    .tab-btn.active::after {
        content: ''; position: absolute; bottom: -2px; left: 0; right: 0;
        height: 4px; background: var(--primary-gold); border-radius: 4px 4px 0 0;
    }

    .tab-content { display: none; }
    .tab-content.active { display: block; }

    .doc-table { width: 100%; border-collapse: collapse; text-align: start; }
    .doc-table th { background: #f8fafc; color: var(--text-muted); font-weight: 800; padding: 1rem; border-bottom: 2px solid #e2e8f0; white-space: nowrap; }
    .doc-table td { padding: 1rem; border-bottom: 1px solid #f1f5f9; color: var(--text-dark); font-weight: 700; }

    /* بطاقات المستندات (Premium Document Cards) */
    .docs-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }
    
    .doc-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 1.2rem;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        transition: 0.3s;
    }
    .doc-card:hover {
        background: white;
        border-color: var(--primary-gold);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        transform: translateY(-3px);
    }
    
    .doc-icon-wrapper {
        width: 60px;
        height: 60px;
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-bottom: 1rem;
    }
    
    .doc-title { font-weight: 900; color: var(--primary-navy); font-size: 1.1rem; margin-bottom: 0.5rem; }
    .doc-meta { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 1.5rem; font-family: monospace; }
    
    .btn-download {
        background: var(--primary-navy);
        color: white;
        padding: 0.6rem 1.5rem;
        border-radius: 0.75rem;
        text-decoration: none;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
        width: 100%;
        justify-content: center;
    }
    .btn-download:hover { background: var(--primary-gold); color: white; }

    /* ========================================================
       5. إعدادات طباعة التقرير (Print Report Styles)
       ======================================================== */
    .print-only { display: none; } 

    @@media print {
        @@page { margin: 1cm; size: A4 portrait; }
        body { background: white; padding: 0; font-family: 'Cairo', sans-serif; color: black; }
        
        /* إخفاء عناصر واجهة المستخدم (الأزرار والتبويبات) */
        .no-print, .header-actions-grid, .tabs-header, .btn-download { display: none !important; }
        
        /* إظهار العناصر المخصصة للطباعة */
        .print-only { display: block; }
        
        /* ترويسة الطباعة الرسمية */
        .print-header {
            text-align: center;
            border-bottom: 3px solid var(--primary-gold);
            padding-bottom: 15px;
            margin-bottom: 30px;
        }
        .print-header img { height: 70px; margin-bottom: 10px; }
        .print-header h1 { font-size: 2rem; color: var(--primary-navy); margin: 0; font-weight: 900; }
        .print-header p { font-size: 1.1rem; color: var(--text-muted); margin: 5px 0 0 0; }

        /* تعديل الهيدر الأساسي للطباعة */
        .details-header { 
            background: transparent !important; color: black !important; padding: 0 !important; 
            box-shadow: none !important; border-radius: 0 !important; margin-bottom: 2rem !important; 
        }
        .details-header::before { display: none; }
        .car-title-large { color: var(--primary-navy) !important; font-size: 2rem; }
        .vin-badge { border: 1px solid black; color: black; background: transparent; }
        .car-main-img { border: 2px solid black; }

        /* إظهار كل محتويات التبويبات للطباعة */
        .tab-content { display: block !important; margin-bottom: 2rem; page-break-inside: avoid; }
        .tracking-card, .info-card, .tabs-container { border: 1px solid #000; box-shadow: none; padding: 1rem; border-radius: 0; background: white; }
        .info-card-title { border-bottom: 1px solid #ccc; padding-bottom: 10px; }
        
        /* تذييل الطباعة (التوقيعات) */
        .print-footer {
            display: flex;
            justify-content: space-between;
            margin-top: 50px;
            padding-top: 20px;
            page-break-inside: avoid;
        }
        .signature-box { text-align: center; width: 200px; }
        .signature-line { border-bottom: 2px solid black; margin-bottom: 10px; height: 50px; }
        .signature-title { font-weight: bold; }
    }

    /* ========================================================
       6. تعديلات الموبايل (الميديا كويري)
       ======================================================== */
    @@media (max-width: 768px) {
        .details-header { flex-direction: column; text-align: center; padding: 1.5rem; gap: 1.5rem; }
        .car-header-info { flex-direction: column; }
        .car-title-large { font-size: 1.6rem; }
        .details-header > div:last-child { width: 100%; }
        
        .header-actions-grid { grid-template-columns: 1fr; width: 100%; min-width: 100%; }
        
        .tracking-card, .info-card, .tabs-container { padding: 1.5rem; }
        .tracking-title { font-size: 1.2rem; margin-bottom: 2rem; }
        .step-circle { width: 40px; height: 40px; border-width: 3px; font-size: 1rem; margin-bottom: 0.5rem; }
        .step-item.active .step-circle { box-shadow: 0 0 0 3px white, 0 4px 10px rgba(184, 147, 90, 0.4); }
        .stepper-wrapper::before, .stepper-wrapper::after { top: 18px; height: 3px; }
        .step-label { font-size: 0.7rem; }
        .step-item { width: 70px; }
        
        .tabs-header { flex-direction: column; gap: 0.5rem; border-bottom: none; }
        .tab-btn { width: 100%; border-radius: 0.5rem; background: #f8fafc; border: 1px solid #e2e8f0; }
        .tab-btn.active { background: rgba(184, 147, 90, 0.1); border-color: var(--primary-gold); }
        .tab-btn.active::after { display: none; }
        .table-responsive-wrapper { overflow-x: auto; width: 100%; }
    }
</style>

<div>
    <!-- ترويسة مخصصة للطباعة فقط -->
    <div class="print-only print-header">
        <img src="~/images/logo.png" alt="Alargan Logo" onerror="this.style.display='none'" />
        <h1>ALARGAN AUTO SHIPPING</h1>
        <p>@Localizer["تقرير حالة مركبة شامل"] | @DateTime.Now.ToString("yyyy-MM-dd")</p>
    </div>

    <div class="details-header">
        <div class="car-header-info">
            @if (!string.IsNullOrEmpty(Model.MainImageUrl))
            {
                <img src="@Model.MainImageUrl" alt="@Model.Make @Model.Model" class="car-main-img" />
            }
            else
            {
                <div class="car-main-img"><i class="fa-solid fa-car"></i></div>
            }

            <div>
                <h1 class="car-title-large">@Model.Make @Model.Model @Model.Year</h1>
                <div class="vin-badge">VIN: @Model.VIN</div>
                @if (!string.IsNullOrEmpty(Model.InternalCode))
                {
                    <div style="margin-top: 10px; font-weight: 800; color: #cbd5e1;" class="no-print">@Localizer["الكود:"] @Model.InternalCode</div>
                }
            </div>
        </div>

        <!-- شبكة الأزرار الشاملة (4 أزرار للإجراءات + زر الطباعة) -->
        <div class="no-print header-actions-grid">
            <a href="@Url.Action("Index", "Cars")" class="btn-action-light">
                <i class="fa-solid fa-list-ul"></i> @Localizer["قائمة السيارات"]
            </a>
            
            <a href="@Url.Action("Create", "TrackingLogs", new { carId = Model.Id })" class="btn-action-light" style="background: var(--primary-gold); border-color: var(--primary-gold);">
                <i class="fa-solid fa-location-crosshairs"></i> @Localizer["إضافة تحديث تتبع"]
            </a>
            
            <a href="@Url.Action("Create", "DocumentAttachments", new { carId = Model.Id })" class="btn-action-light" style="background: rgba(255,255,255,0.15);">
                <i class="fa-solid fa-paperclip"></i> @Localizer["رفع مستند للسيارة"]
            </a>
            
            <a href="@Url.Action("Create", "CarInspections", new { carId = Model.Id })" class="btn-action-light" style="background: rgba(255,255,255,0.15);">
                <i class="fa-solid fa-clipboard-check"></i> @Localizer["إضافة تقرير فحص"]
            </a>

            <button onclick="window.print()" class="btn-action-light btn-full-width" style="background: var(--primary-navy); border-color: var(--primary-gold);">
                <i class="fa-solid fa-print"></i> @Localizer["طباعة التقرير الشامل"]
            </button>
        </div>
    </div>

    <!-- Tracking Stepper -->
    <div class="tracking-card">
        <h2 class="tracking-title">@Localizer["مراحل الشحن والتتبع"]</h2>

        @{
            int status = Model.StatusId;
            string lineWidth = status == 1 ? "0%" :
            status == 2 ? "16.6%" :
            status == 3 ? "33.3%" :
            status == 4 ? "50%" :
            status == 5 ? "66.6%" :
            status == 6 ? "83.3%" :
            status >= 7 ? "100%" : "0%";
        }

        <div class="stepper-wrapper" style="--progress-width: @lineWidth;">
            <div class="step-item @(status >= 1 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-gavel"></i></div>
                <div class="step-label">@Localizer["الشراء"]</div>
            </div>
            <div class="step-item @(status >= 2 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-money-bill-wave"></i></div>
                <div class="step-label">@Localizer["الدفع"]</div>
            </div>
            <div class="step-item @(status >= 3 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-truck-pickup"></i></div>
                <div class="step-label">@Localizer["النقل"]</div>
            </div>
            <div class="step-item @(status >= 4 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-warehouse"></i></div>
                <div class="step-label">@Localizer["المستودع"]</div>
            </div>
            <div class="step-item @(status >= 5 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-box-open"></i></div>
                <div class="step-label">@Localizer["التحميل"]</div>
            </div>
            <div class="step-item @(status >= 6 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-ship"></i></div>
                <div class="step-label">@Localizer["الإقلاع"]</div>
            </div>
            <div class="step-item @(status >= 7 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-anchor"></i></div>
                <div class="step-label">@Localizer["الوصول"]</div>
            </div>
        </div>
    </div>

    <!-- Details Grid -->
    <div class="info-grid">
        <div class="info-card">
            <h3 class="info-card-title"><i class="fa-solid fa-car"></i> @Localizer["معلومات السيارة"]</h3>
            <div class="info-row"><span class="info-label">@Localizer["الشركة المصنعة"]</span><span class="info-value">@Model.Make</span></div>
            <div class="info-row"><span class="info-label">@Localizer["الموديل"]</span><span class="info-value">@Model.Model</span></div>
            <div class="info-row"><span class="info-label">@Localizer["سنة الصنع"]</span><span class="info-value">@Model.Year</span></div>
            <div class="info-row"><span class="info-label">@Localizer["اللون"]</span><span class="info-value">@Model.Color</span></div>
            <div class="info-row"><span class="info-label">@Localizer["نوع المركبة والشكل"]</span><span class="info-value">@(Model.VehicleType ?? "-") - @(Model.VehicleShape ?? "-")</span></div>
        </div>

        <div class="info-card">
            <h3 class="info-card-title"><i class="fa-solid fa-user-tie"></i> @Localizer["معلومات المالك والشراء"]</h3>
            <div class="info-row"><span class="info-label">@Localizer["اسم العميل"]</span><span class="info-value">@(Model.Customer?.Name ?? Localizer["غير محدد"].Value)</span></div>
            <div class="info-row"><span class="info-label">@Localizer["رقم الهاتف"]</span><span class="info-value" dir="ltr">@(Model.Customer?.Phone ?? "-")</span></div>
            <div class="info-row"><span class="info-label">@Localizer["سعر الشراء"]</span><span class="info-value" style="color: #ef4444; font-family: monospace;">$@Model.PurchasePrice.ToString("N2")</span></div>

            @if (Model.SellingPrice.HasValue)
            {
                <div class="info-row"><span class="info-label">@Localizer["سعر البيع"]</span><span class="info-value" style="color: #16a34a; font-family: monospace;">$@Model.SellingPrice.Value.ToString("N2")</span></div>
            }

            <div class="info-row"><span class="info-label">@Localizer["المزاد"]</span><span class="info-value">@(Model.Auction?.Name ?? Localizer["خارجي"].Value)</span></div>
            <div class="info-row"><span class="info-label">@Localizer["الموقع الحالي"]</span><span class="info-value">@(Model.CurrentLocation ?? "-")</span></div>
        </div>
    </div>

    <!-- قسم التقارير والمستندات (Tabs) -->
    <div class="tabs-container">
        <div class="tabs-header">
            <button class="tab-btn active" onclick="openTab('tracking-logs')"><i class="fa-solid fa-history"></i> @Localizer["سجل التتبع"] (@(Model.TrackingLogs?.Count ?? 0))</button>
            <button class="tab-btn" onclick="openTab('inspections')"><i class="fa-solid fa-clipboard-list"></i> @Localizer["تقارير الفحص"] (@(Model.CarInspections?.Count ?? 0))</button>
            <button class="tab-btn" onclick="openTab('documents')"><i class="fa-solid fa-folder-open"></i> @Localizer["المستندات والملفات"] (@(Model.DocumentAttachments?.Count ?? 0))</button>
        </div>

        <!-- تبويب سجل التتبع -->
        <div id="tracking-logs" class="tab-content active">
            <h3 class="print-only info-card-title"><i class="fa-solid fa-history"></i> @Localizer["سجل التتبع"]</h3>
            @if (Model.TrackingLogs != null && Model.TrackingLogs.Any())
            {
                <div class="table-responsive-wrapper">
                    <table class="doc-table">
                        <thead>
                            <tr>
                                <th>@Localizer["عنوان التحديث"]</th>
                                <th>@Localizer["التاريخ"]</th>
                                <th>@Localizer["الموقع"]</th>
                                <th>@Localizer["الوصف"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.TrackingLogs.OrderByDescending(l => l.UpdateDate))
                            {
                                <tr>
                                    <td style="color: var(--primary-navy); font-weight: 900;">@Localizer[log.Title]</td>
                                    <td>@log.UpdateDate.ToString("dd MMM yyyy - HH:mm")</td>
                                    <td><i class="fa-solid fa-location-dot" style="color: var(--primary-gold);"></i> @log.Location</td>
                                    <td style="font-size: 0.9rem; color: var(--text-muted);">@log.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
                    <i class="fa-solid fa-satellite-dish" style="font-size: 2rem; margin-bottom: 1rem;"></i>
                    <p>@Localizer["لا توجد تحديثات تتبع مسجلة لهذه السيارة."]</p>
                </div>
            }
        </div>

        <!-- تبويب تقارير الفحص -->
        <div id="inspections" class="tab-content">
            <h3 class="print-only info-card-title"><i class="fa-solid fa-clipboard-list"></i> @Localizer["تقارير الفحص"]</h3>
            @if (Model.CarInspections != null && Model.CarInspections.Any())
            {
                <div class="table-responsive-wrapper">
                    <table class="doc-table">
                        <thead>
                            <tr>
                                <th>@Localizer["مرحلة الفحص"]</th>
                                <th>@Localizer["تاريخ الفحص"]</th>
                                <th>@Localizer["الفاحص"]</th>
                                <th>@Localizer["مفاتيح"]</th>
                                <th>@Localizer["الملكية"]</th>
                                <th>@Localizer["تشغيل"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var insp in Model.CarInspections.OrderByDescending(i => i.InspectionDate))
                            {
                                <tr>
                                    <td style="color: var(--primary-navy); font-weight: 900;">@Localizer[insp.InspectionStage]</td>
                                    <td>@insp.InspectionDate.ToString("dd MMM yyyy")</td>
                                    <td>@insp.InspectorName</td>
                                    <td>@(insp.HasKeys ? "✅" : "❌")</td>
                                    <td>@(insp.HasTitle ? "✅" : "❌")</td>
                                    <td>@(insp.IsRunAndDrive ? "✅" : "❌")</td>
                                </tr>
                                @if (!string.IsNullOrEmpty(insp.DamageNotes))
                                {
                                    <tr>
                                        <td colspan="6" style="background: #fef2f2; color: #ef4444; font-size: 0.9rem; padding: 0.5rem 1rem;">
                                            <strong>@Localizer["ملاحظات الأضرار:"]</strong> @insp.DamageNotes
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
                    <i class="fa-regular fa-folder-open" style="font-size: 2rem; margin-bottom: 1rem;"></i>
                    <p>@Localizer["لا توجد تقارير فحص لهذه السيارة بعد."]</p>
                </div>
            }
        </div>

        <!-- تبويب المستندات المرفقة (تصميم البطاقات الجديد) -->
        <div id="documents" class="tab-content">
            <h3 class="print-only info-card-title"><i class="fa-solid fa-folder-open"></i> @Localizer["المستندات والملفات"]</h3>
            @if (Model.DocumentAttachments != null && Model.DocumentAttachments.Any())
            {
                <div class="docs-grid">
                    @foreach (var doc in Model.DocumentAttachments.OrderByDescending(d => d.UploadDate))
                    {
                        // تحديد الأيقونة واللون بناءً على نوع المستند
                        string iconClass = "fa-file";
                        if (doc.DocumentType == "AuctionInvoice") iconClass = "fa-file-invoice-dollar";
                        else if (doc.DocumentType == "BankTransfer") iconClass = "fa-money-bill-transfer";
                        else if (doc.DocumentType == "Title") iconClass = "fa-certificate";
                        else if (doc.DocumentType == "CarImage") iconClass = "fa-image";

                        <div class="doc-card">
                            <div class="doc-icon-wrapper">
                                <i class="fa-solid @iconClass"></i>
                            </div>
                            <div class="doc-title">@Localizer[doc.DocumentType]</div>
                            <div class="doc-meta">@doc.UploadDate.ToString("yyyy-MM-dd")</div>
                            <a href="@doc.FilePath" target="_blank" class="btn-download">
                                <i class="fa-solid fa-download"></i> @Localizer["عرض / تحميل"]
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
                    <i class="fa-solid fa-file-circle-xmark" style="font-size: 2rem; margin-bottom: 1rem;"></i>
                    <p>@Localizer["لا توجد مستندات مرفقة لهذه السيارة بعد."]</p>
                </div>
            }
        </div>
    </div>

    <!-- تذييل مخصص للطباعة فقط -->
    <div class="print-only print-footer">
        <div class="signature-box">
            <div class="signature-line"></div>
            <div class="signature-title">@Localizer["توقيع الموظف المسؤول"]</div>
        </div>
        <div class="signature-box">
            <div class="signature-line"></div>
            <div class="signature-title">@Localizer["توقيع العميل / المستلم"]</div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        function openTab(tabId) {
            // تجاهل أمر فتح التبويبات أثناء الطباعة (كلها تظهر معاً)
            if (window.matchMedia('print').matches) return;

            $('.tab-content').removeClass('active');
            $('.tab-btn').removeClass('active');
            $('#' + tabId).addClass('active');
            event.currentTarget.classList.add('active');
        }
    </script>
}