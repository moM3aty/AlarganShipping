            }

        .signatures-section {
            display: flex;
            justify-content: space-between;
            text-align: center;
            font-weight: bold;
            margin-top: 50px;
            font-size: 14px;
            page-break-inside: avoid;
        }

        .sig-block {
            width: 200px;
            border-top: 1px solid #000;
            padding-top: 5px;
        }
    }

    /* ========================================================
           6. تعديلات الموبايل (الميديا كويري)
           ======================================================== */
    @@media (max-width: 768px) {
        .details-header {
            flex-direction: column;
            text-align: center;
            padding: 1.5rem;
            gap: 1.5rem;
        }

        .car-header-info {
            flex-direction: column;
        }

        .car-title-large {
            font-size: 1.6rem;
        }

        .details-header > div:last-child {
            width: 100%;
        }

        .header-actions-column {
            width: 100%;
            min-width: 100%;
        }

        .tracking-card, .info-card, .tabs-container {
            padding: 1.5rem;
        }

        .tracking-title {
            font-size: 1.2rem;
            margin-bottom: 2rem;
        }

        .step-circle {
            width: 40px;
            height: 40px;
            border-width: 3px;
            font-size: 1rem;
            margin-bottom: 0.5rem;
        }

        .step-item.active .step-circle {
            box-shadow: 0 0 0 3px white, 0 4px 10px rgba(184, 147, 90, 0.4);
        }

        .stepper-wrapper::before, .stepper-wrapper::after {
            top: 18px;
            height: 3px;
        }

        .step-label {
            font-size: 0.7rem;
        }

        .step-item {
            width: 70px;
        }

        .tabs-header {
            flex-direction: column;
            gap: 0.5rem;
            border-bottom: none;
        }

        .tab-btn {
            width: 100%;
            border-radius: 0.5rem;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
        }

            .tab-btn.active {
                background: rgba(184, 147, 90, 0.1);
                border-color: var(--primary-gold);
            }

                .tab-btn.active::after {
                    display: none;
                }
    }
</style>

<div>
    <!-- توكن الحماية لطلبات AJAX -->
    @Html.AntiForgeryToken()

    <!-- =======================================================
         قالب الطباعة المخفي (الفاتورة التفصيلية المطابقة للصورة وديناميكية)
         ======================================================= -->
    <div class="print-only invoice-container-print" dir="rtl">

        <!-- الترويسة العلوية للتواريخ والأرقام -->
        <div class="header-top">
            <div class="right-header">
                <div class="red-text bold">@Localizer["رقم الفاتورة"] <span dir="ltr">Invoice No @displayInvoiceNo</span></div>
                <div class="red-text bold">@Localizer["الرقم المرجعي"] <span dir="ltr">Reference @(Model.InternalCode ?? "N/A")</span></div>
            </div>
            <div class="left-header">
                <span class="red-text bold">@Localizer["تاريخ الفاتورة"] <span dir="ltr">Invoice Date @invoiceDateStr</span></span>
            </div>
        </div>

        <!-- تفاصيل الشركة والشعار (ديناميكية) -->
        <div class="company-details">
            <div class="company-ar">
                <div class="bold">@Localizer["معرض الارجان"]</div>
                <div dir="ltr">@Localizer["تلفون :"] @companyPhone</div>
                <div>@companyAddressAr</div>
                <div dir="ltr">@Localizer["الرقم الضريبي :"] @vatNumber</div>
                <div dir="ltr">@Localizer["السجل التجاري :"] @crNumber</div>
            </div>
            <div class="logo-center">
                <img src="/images/logo.jpg" alt="Alargan Logo" onerror="this.style.display='none'" />
                <div>@Localizer["بيع شراء مزاد شحن"]</div>
            </div>
            <div class="company-en" dir="ltr">
                <div class="bold">Alargan Gallery</div>
                <div>Tel : @companyPhone</div>
                <div>@companyAddressEn</div>
                <div>VAT No : @vatNumber</div>
                <div>CR No : @crNumber</div>
            </div>
        </div>

        <!-- تفاصيل العميل والباركود -->
        <div class="customer-section">
            <div class="customer-box">
                <div class="cust-box-header">
                    <span>@Localizer["تفاصيل العميل"]</span>
                    <span dir="ltr">Customer Details</span>
                </div>
                <!-- ✅ تم حل مشكلة التكرار هنا: يظهر التصنيف بالعربي/الإنجليزي والقيمة مرة واحدة -->
                <div class="cust-box-body">
                    <div class="cust-row">
                        <span>@Localizer["الاسم"] / Name:</span>
                        <span style="color: var(--primary-navy);" dir="ltr">@(Model.Customer?.Name ?? "-")</span>
                    </div>
                    <div class="cust-row">
                        <span>@Localizer["تلفون"] / Phone:</span>
                        <span style="color: var(--primary-navy);" dir="ltr">@(Model.Customer?.Phone ?? "-")</span>
                    </div>
                    <div class="cust-row">
                        <span>@Localizer["الكود"] / Code:</span>
                        <span style="color: var(--primary-navy);" dir="ltr">@(Model.Customer?.CustomerCode ?? "-")</span>
                    </div>
                </div>
            </div>
            <div class="qr-code">
                <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=@Model.VIN" alt="QR Code" />
            </div>
        </div>

        <!-- جدول تفاصيل الصنف (السيارة) -->
        <table class="items-table">
            <thead>
                <tr>
                    <th>مسلسل<br />Sr. No</th>
                    <th>رقم الشاصي<br />Chesis.No</th>
                    <th>وصف الصنف<br />Description</th>
                    <th>الوحدة<br />Unit</th>
                    <th>الكمية<br />QTY</th>
                    <th>السعر<br />Price</th>
                    <th>خصم<br />Discount</th>
                    <th>السعر الإجمالي<br />Total Price</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td dir="ltr">@Model.VIN</td>
                    <td dir="ltr">@Model.Make - @Model.Model - @Model.Year - @Model.Color</td>
                    <td>واحد</td>
                    <td>1.00</td>
                    <!-- ✅ تم وضع سعر البيع للعميل بدلاً من سعر الشراء -->
                    <td>@baseCarPrice.ToString("N3")</td>
                    <td>0.000</td>
                    <td>@baseCarPrice.ToString("N3")</td>
                </tr>
                @if (invoice != null && !invoice.IsShippingOnly)
                {
                    @if (auctionFee > 0)
                    {
                        <tr>
                            <td>2</td>
                            <td dir="ltr">-</td>
                            <td dir="ltr">Auction & Gate Fees - رسوم المزاد والبوابة</td>
                            <td>-</td>
                            <td>-</td>
                            <td>@auctionFee.ToString("N3")</td>
                            <td>0.000</td>
                            <td>@auctionFee.ToString("N3")</td>
                        </tr>
                    }
                    @if (transferFee > 0)
                    {
                        <tr>
                            <td>-</td>
                            <td dir="ltr">-</td>
                            <td dir="ltr">Transfer Fees - رسوم التحويل</td>
                            <td>-</td>
                            <td>-</td>
                            <td>@transferFee.ToString("N3")</td>
                            <td>0.000</td>
                            <td>@transferFee.ToString("N3")</td>
                        </tr>
                    }
                    @if (carSizeFee > 0)
                    {
                        <tr>
                            <td>-</td>
                            <td dir="ltr">-</td>
                            <td dir="ltr">Car Size Surcharge - رسوم حجم السيارة</td>
                            <td>-</td>
                            <td>-</td>
                            <td>@carSizeFee.ToString("N3")</td>
                            <td>0.000</td>
                            <td>@carSizeFee.ToString("N3")</td>
                        </tr>
                    }
                }
                @if (towingFee > 0)
                {
                    <tr>
                        <td>-</td>
                        <td dir="ltr">-</td>
                        <td dir="ltr">Inland Towing - أجور النقل الداخلي</td>
                        <td>-</td>
                        <td>-</td>
                        <td>@towingFee.ToString("N3")</td>
                        <td>0.000</td>
                        <td>@towingFee.ToString("N3")</td>
                    </tr>
                }
                @if (seaFreight > 0)
                {
                    <tr>
                        <td>-</td>
                        <td dir="ltr">-</td>
                        <td dir="ltr">Ocean Freight - أجور الشحن البحري</td>
                        <td>-</td>
                        <td>-</td>
                        <td>@seaFreight.ToString("N3")</td>
                        <td>0.000</td>
                        <td>@seaFreight.ToString("N3")</td>
                    </tr>
                }
                @if (adminFee > 0)
                {
                    <tr>
                        <td>-</td>
                        <td dir="ltr">-</td>
                        <td dir="ltr">Admin & Storage Fees - رسوم إدارية وغرامات</td>
                        <td>-</td>
                        <td>-</td>
                        <td>@adminFee.ToString("N3")</td>
                        <td>0.000</td>
                        <td>@adminFee.ToString("N3")</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- المجاميع -->
        <div class="totals-section">
            <div class="summary-table-container">
                <table class="summary-table">
                    <tr>
                        <td class="lbl ar-text">عدد الأصناف المباعة</td>
                        <td class="val">1</td>
                        <td class="lbl" dir="ltr">Item Sold Total</td>
                    </tr>
                    <tr>
                        <td class="lbl ar-text">اجمالي المبلغ</td>
                        @{
                            decimal subTotal = totalAmount - totalTaxes;
                        }
                        <td class="val">OMR @subTotal.ToString("N3")</td>
                        <td class="lbl" dir="ltr">Sub Total</td>
                    </tr>
                    <tr>
                        <td class="lbl ar-text">اجمالي الخصم</td>
                        <td class="val">0.000</td>
                        <td class="lbl" dir="ltr">Total Discounts</td>
                    </tr>
                    <tr>
                        <!-- ✅ تم تعديلها لتشمل مجموع (تخليص + جمارك + ضريبة) -->
                        <td class="lbl ar-text">اجمالي الضريبة والجمارك</td>
                        <td class="val">@totalTaxes.ToString("N3")</td>
                        <td class="lbl" dir="ltr">Total VAT & Customs</td>
                    </tr>
                    <tr>
                        <td class="lbl ar-text">اجمالي الفاتورة</td>
                        <td class="val red-text">OMR @totalAmount.ToString("N3")</td>
                        <td class="lbl" dir="ltr">Total Invoice</td>
                    </tr>
                </table>
            </div>
            <div class="amount-in-words"></div>
        </div>

        <!-- الدفعات والرصيد -->
        <div class="payments-section">
            <div class="payment-row">
                <span class="lbl-ar">مدفوع</span>
                <span class="val">OMR @paidAmount.ToString("N3")</span>
                <span class="lbl-en" dir="ltr">Paid</span>
            </div>
            @if (paidAmount > 0)
            {
                <div class="payment-row">
                    <span class="lbl-ar">مدفوع بواسطة</span>
                    <span class="val">OMR @paidAmount.ToString("N3") @invoiceDateStr : دفعة مسجلة</span>
                    <span class="lbl-en" dir="ltr">Paid by</span>
                </div>
            }
            <div class="payment-row" style="border-top: 1px solid #ccc;">
                <span class="lbl-ar">الرصيد</span>
                <span class="val">OMR @remainingAmount.ToString("N3")</span>
                <span class="lbl-en" dir="ltr">Balance</span>
            </div>
        </div>

        <!-- التوقيعات -->
        <div class="signatures-section">
            <div class="sig-block">
                <div>التوقيع</div>
                <div dir="ltr">Signature</div>
            </div>
            <div class="sig-block">
                <div>استلمت من قبل</div>
                <div dir="ltr">Received By</div>
            </div>
            <div class="sig-block">
                <div>اعدت بواسطة</div>
                <div dir="ltr">Prepared By</div>
            </div>
        </div>
    </div>

    <!-- =======================================================
         شاشة عرض الويب الفاخرة (لا تظهر في الطباعة نهائياً)
         ======================================================= -->
    <div class="no-print details-header">
        <div class="car-header-info">
            @if (!string.IsNullOrEmpty(Model.MainImageUrl))
            {
                <img src="@Model.MainImageUrl" alt="@Model.Make @Model.Model" class="car-main-img" />
            }
            else
            {
                <div class="car-main-img"><i class="fa-solid fa-car"></i></div>
            }

            <div>
                <h1 class="car-title-large">@Model.Make @Model.Model @Model.Year</h1>
                <div class="vin-badge">VIN: @Model.VIN</div>
                @if (!string.IsNullOrEmpty(Model.InternalCode))
                {
                    <div style="margin-top: 10px; font-weight: 800; color: #cbd5e1;">@Localizer["الكود:"] @Model.InternalCode</div>
                }
            </div>
        </div>

        <!-- تصميم الأزرار العمودية الجديد المطابق للصورة -->
        <div class="header-actions-column">
            <a href="@Url.Action("Index", "Cars")" class="btn-action-custom btn-dark-slate">
                @Localizer["قائمة السيارات"] <i class="fa-solid fa-list-ul"></i>
            </a>

            <a href="@Url.Action("Create", "TrackingLogs", new { carId = Model.Id })" class="btn-action-custom btn-bright-blue">
                @Localizer["إضافة تحديث تتبع"] <i class="fa-solid fa-location-crosshairs"></i>
            </a>

            <a href="@Url.Action("Create", "DocumentAttachments", new { carId = Model.Id })" class="btn-action-custom btn-dark-slate">
                @Localizer["رفع مستند للسيارة"] <i class="fa-solid fa-paperclip"></i>
            </a>

            <a href="@Url.Action("Create", "CarInspections", new { carId = Model.Id })" class="btn-action-custom btn-gold-brown">
                @Localizer["إضافة تقرير فحص"] <i class="fa-solid fa-clipboard-check"></i>
            </a>

            <button onclick="window.print()" class="btn-action-custom btn-print-white" style="margin-top: 10px;">
                @Localizer["طباعة الفاتورة"] <i class="fa-solid fa-print"></i>
            </button>
        </div>
    </div>

    <!-- Tracking Stepper -->
    <div class="no-print tracking-card">
        <h2 class="tracking-title">@Localizer["مراحل الشحن والتتبع"]</h2>

        @{
            int status = Model.StatusId;
            string lineWidth = status == 1 ? "0%" :
            status == 2 ? "16.6%" :
            status == 3 ? "33.3%" :
            status == 4 ? "50%" :
            status == 5 ? "66.6%" :
            status == 6 ? "83.3%" :
            status >= 7 ? "100%" : "0%";
        }

        <div class="stepper-wrapper" style="--progress-width: @lineWidth;">
            <div class="step-item @(status >= 1 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-gavel"></i></div>
                <div class="step-label">@Localizer["الشراء"]</div>
            </div>
            <div class="step-item @(status >= 2 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-money-bill-wave"></i></div>
                <div class="step-label">@Localizer["الدفع"]</div>
            </div>
            <div class="step-item @(status >= 3 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-truck-pickup"></i></div>
                <div class="step-label">@Localizer["النقل"]</div>
            </div>
            <div class="step-item @(status >= 4 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-warehouse"></i></div>
                <div class="step-label">@Localizer["المستودع"]</div>
            </div>
            <div class="step-item @(status >= 5 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-box-open"></i></div>
                <div class="step-label">@Localizer["التحميل"]</div>
            </div>
            <div class="step-item @(status >= 6 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-ship"></i></div>
                <div class="step-label">@Localizer["الإقلاع"]</div>
            </div>
            <div class="step-item @(status >= 7 ? "active" : "")">
                <div class="step-circle"><i class="fa-solid fa-anchor"></i></div>
                <div class="step-label">@Localizer["الوصول"]</div>
            </div>
        </div>
    </div>

    <!-- Details Grid -->
    <div class="no-print info-grid">
        <div class="info-card">
            <h3 class="info-card-title"><i class="fa-solid fa-car"></i> @Localizer["معلومات السيارة"]</h3>
            <div class="info-row"><span class="info-label">@Localizer["الشركة المصنعة"]</span><span class="info-value">@Model.Make</span></div>
            <div class="info-row"><span class="info-label">@Localizer["الموديل"]</span><span class="info-value">@Model.Model</span></div>
            <div class="info-row"><span class="info-label">@Localizer["سنة الصنع"]</span><span class="info-value">@Model.Year</span></div>
            <div class="info-row"><span class="info-label">@Localizer["اللون"]</span><span class="info-value">@Model.Color</span></div>
            <div class="info-row"><span class="info-label">@Localizer["نوع المركبة والشكل"]</span><span class="info-value">@(Model.VehicleType ?? "-") - @(Model.VehicleShape ?? "-")</span></div>
        </div>

        <div class="info-card">
            <h3 class="info-card-title"><i class="fa-solid fa-user-tie"></i> @Localizer["معلومات المالك والشراء"]</h3>
            <div class="info-row"><span class="info-label">@Localizer["اسم العميل"]</span><span class="info-value">@(Model.Customer?.Name ?? Localizer["غير محدد"].Value)</span></div>
            <div class="info-row"><span class="info-label">@Localizer["رقم الهاتف"]</span><span class="info-value" dir="ltr">@(Model.Customer?.Phone ?? "-")</span></div>
            <div class="info-row"><span class="info-label">@Localizer["سعر الشراء"]</span><span class="info-value" style="color: #ef4444; font-family: monospace;">$@Model.PurchasePrice.ToString("N2")</span></div>

            @if (Model.SellingPrice.HasValue)
            {
                <div class="info-row"><span class="info-label">@Localizer["سعر البيع"]</span><span class="info-value" style="color: #16a34a; font-family: monospace;">$@Model.SellingPrice.Value.ToString("N2")</span></div>
            }

            <div class="info-row"><span class="info-label">@Localizer["المزاد"]</span><span class="info-value">@(Model.Auction?.Name ?? Localizer["خارجي"].Value)</span></div>
            <div class="info-row"><span class="info-label">@Localizer["الموقع الحالي"]</span><span class="info-value">@(Model.CurrentLocation ?? "-")</span></div>
        </div>
    </div>

    <!-- قسم التقارير والمستندات (Tabs) -->
    <div class="no-print tabs-container">
        <div class="tabs-header">
            <button class="tab-btn active" onclick="openTab('tracking-logs', this)"><i class="fa-solid fa-history"></i> @Localizer["سجل التتبع"] (@(Model.TrackingLogs?.Count ?? 0))</button>
            <button class="tab-btn" onclick="openTab('inspections', this)"><i class="fa-solid fa-clipboard-list"></i> @Localizer["تقارير الفحص"] (@(Model.CarInspections?.Count ?? 0))</button>
            <button class="tab-btn" onclick="openTab('documents', this)"><i class="fa-solid fa-folder-open"></i> @Localizer["المستندات والملفات"] (@(Model.DocumentAttachments?.Count ?? 0))</button>
        </div>

        <!-- تبويب سجل التتبع -->
        <div id="tracking-logs" class="tab-content active">
            @if (Model.TrackingLogs != null && Model.TrackingLogs.Any())
            {
                <div class="table-responsive-wrapper">
                    <table class="doc-table">
                        <thead>
                            <tr>
                                <th>@Localizer["عنوان التحديث"]</th>
                                <th>@Localizer["التاريخ"]</th>
                                <th>@Localizer["الموقع"]</th>
                                <th>@Localizer["الوصف"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.TrackingLogs.OrderByDescending(l => l.UpdateDate))
                            {
                                <tr>
                                    <td style="color: var(--primary-navy); font-weight: 900;">@Localizer[log.Title]</td>
                                    <td>@log.UpdateDate.ToString("dd MMM yyyy - HH:mm")</td>
                                    <td><i class="fa-solid fa-location-dot" style="color: var(--primary-gold);"></i> @log.Location</td>
                                    <td style="font-size: 0.9rem; color: var(--text-muted);">@log.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
                    <i class="fa-solid fa-satellite-dish" style="font-size: 2rem; margin-bottom: 1rem;"></i>
                    <p>@Localizer["لا توجد تحديثات تتبع مسجلة لهذه السيارة."]</p>
                </div>
            }
        </div>

        <!-- تبويب تقارير الفحص -->
        <div id="inspections" class="tab-content">
            @if (Model.CarInspections != null && Model.CarInspections.Any())
            {
                <div class="table-responsive-wrapper">
                    <table class="doc-table">
                        <thead>
                            <tr>
                                <th>@Localizer["مرحلة الفحص"]</th>
                                <th>@Localizer["تاريخ الفحص"]</th>
                                <th>@Localizer["الفاحص"]</th>
                                <th>@Localizer["مفاتيح"]</th>
                                <th>@Localizer["الملكية"]</th>
                                <th>@Localizer["تشغيل"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var insp in Model.CarInspections.OrderByDescending(i => i.InspectionDate))
                            {
                                <tr>
                                    <td style="color: var(--primary-navy); font-weight: 900;">@Localizer[insp.InspectionStage]</td>
                                    <td>@insp.InspectionDate.ToString("dd MMM yyyy")</td>
                                    <td>@insp.InspectorName</td>
                                    <td>@(insp.HasKeys ? "✅" : "❌")</td>
                                    <td>@(insp.HasTitle ? "✅" : "❌")</td>
                                    <td>@(insp.IsRunAndDrive ? "✅" : "❌")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
                    <i class="fa-regular fa-folder-open" style="font-size: 2rem; margin-bottom: 1rem;"></i>
                    <p>@Localizer["لا توجد تقارير فحص لهذه السيارة بعد."]</p>
                </div>
            }
        </div>

        <!-- تبويب المستندات المرفقة -->
        <div id="documents" class="tab-content">
            @if (Model.DocumentAttachments != null && Model.DocumentAttachments.Any())
            {
                <div class="docs-grid">
                    @foreach (var doc in Model.DocumentAttachments.OrderByDescending(d => d.UploadDate))
                    {
                        string iconClass = "fa-file";
                        if (doc.DocumentType == "AuctionInvoice") iconClass = "fa-file-invoice-dollar";
                        else if (doc.DocumentType == "BankTransfer") iconClass = "fa-money-bill-transfer";
                        else if (doc.DocumentType == "Title") iconClass = "fa-certificate";
                        else if (doc.DocumentType == "CarImage") iconClass = "fa-image";

                        <div class="doc-card">
                            <div class="doc-icon-wrapper"><i class="fa-solid @iconClass"></i></div>
                            <div class="doc-title">@Localizer[doc.DocumentType]</div>
                            <div class="doc-meta">@doc.UploadDate.ToString("yyyy-MM-dd")</div>
                            <div class="doc-actions">
                                <a href="@doc.FilePath" target="_blank" class="btn-download">
                                    <i class="fa-solid fa-eye"></i> @Localizer["عرض"]
                                </a>
                                <button type="button" class="btn-delete-doc" onclick="deleteDocument(@doc.Id)" title="@Localizer["حذف الملف"]">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
                    <i class="fa-solid fa-file-circle-xmark" style="font-size: 2rem; margin-bottom: 1rem;"></i>
                    <p>@Localizer["لا توجد مستندات مرفقة لهذه السيارة بعد."]</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>

    <script>
        function openTab(tabId, element) {
            // تجاهل أمر فتح التبويبات أثناء الطباعة
            if (window.matchMedia('print').matches) return;

            $('.tab-content').removeClass('active');
            $('.tab-btn').removeClass('active');
            $('#' + tabId).addClass('active');
            $(element).addClass('active');
        }

        function deleteDocument(docId) {
            Swal.fire({
                title: '@Html.Raw(Localizer["هل أنت متأكد؟"])',
                text: '@Html.Raw(Localizer["سيتم حذف هذا الملف نهائياً ولن تتمكن من استرجاعه!"])',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: 'var(--primary-navy)',
                confirmButtonText: '@Html.Raw(Localizer["نعم، احذف!"])',
                cancelButtonText: '@Html.Raw(Localizer["إلغاء"])'
            }).then((result) => {
                if (result.isConfirmed) {
                    // إرسال طلب الحذف للكنترولر
                    $.post('@Url.Action("Delete", "DocumentAttachments")/' + docId, {
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    }, function(res) {
                        if(res.success) {
                            Swal.fire({
                                title: '@Html.Raw(Localizer["تم الحذف!"])',
                                text: '@Html.Raw(Localizer["تم حذف المستند بنجاح."])',
                                icon: 'success',
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => location.reload());
                        } else {
                            Swal.fire('@Html.Raw(Localizer["خطأ!"])', res.message || '@Html.Raw(Localizer["حدث خطأ أثناء الحذف."])', 'error');
                        }
                    }).fail(function() {
                        Swal.fire('@Html.Raw(Localizer["خطأ!"])', '@Html.Raw(Localizer["تعذر الاتصال بالخادم."])', 'error');
                    });
                }
            });
        }
    </script>
}