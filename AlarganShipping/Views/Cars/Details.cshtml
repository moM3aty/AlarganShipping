@model AlarganShipping.Models.Car
@using System.Text.Json
@inject IWebHostEnvironment Env
@{
    ViewData["Title"] = Localizer["تفاصيل السيارة والتتبع"];

    // --- جلب إعدادات الشركة ديناميكياً ---
    string settingsPath = System.IO.Path.Combine(Env.WebRootPath, "settings.json");
    string companyPhone = "96894203663"; // رقم افتراضي
    if (System.IO.File.Exists(settingsPath))
    {
        var json = System.IO.File.ReadAllText(settingsPath);
        using var doc = JsonDocument.Parse(json);
        if (doc.RootElement.TryGetProperty("InquiryPhoneNumber", out var phoneProp))
        {
            companyPhone = phoneProp.GetString() ?? companyPhone;
        }
    }

    // متغيرات لسهولة التعديل مستقبلاً
    string vatNumber = "00016800820";
    string crNumber = "0001425763";
    string companyAddressAr = "صلاله شارع المعارض";
    string companyAddressEn = "Salalah, Exhibition St.";

    // --- جلب البيانات المالية من الفاتورة بدقة ---
    var invoice = Model.Invoices?.FirstOrDefault();

    // 1. استخدام سعر البيع للعميل بدلاً من سعر التكلفة
    decimal baseCarPrice = invoice != null ? invoice.CarPrice : (Model.SellingPrice ?? Model.PurchasePrice);

    // 2. تجميع باقي الرسوم لطباعتها
    decimal auctionFee = invoice?.AuctionFees ?? 0;
    decimal transferFee = invoice?.TransferFees ?? 0;
    decimal carSizeFee = invoice?.CarSizeFees ?? 0;

    // دمج الشحن الداخلي (أمريكا + عمان)
    decimal towingFee = (invoice?.InlandTowing ?? 0) + (invoice?.OmanTowingFees ?? 0);

    decimal seaFreight = invoice?.SeaFreight ?? 0;

    // دمج كل أنواع الضرائب والجمارك والتخليص
    decimal totalTaxes = (invoice?.ClearanceFees ?? 0) + (invoice?.TaxAmount ?? 0) + (invoice?.CustomsAmount ?? 0);

    // دمج العمولة الإدارية مع الغرامات (الأرضيات)
    decimal adminFee = (invoice?.CompanyCommission ?? 0) + (invoice?.StorageFees ?? 0);

    decimal totalAmount = invoice?.TotalAmount ?? (Model.SellingPrice ?? Model.PurchasePrice);
    decimal paidAmount = invoice?.AmountPaid ?? 0;
    decimal remainingAmount = invoice != null ? invoice.RemainingAmount : totalAmount;

    // توليد رقم فاتورة للطباعة
    string displayInvoiceNo = invoice != null && !string.IsNullOrEmpty(invoice.InvoiceNumber)
                                ? invoice.InvoiceNumber
                                : "PRO-" + (Model.InternalCode ?? (Model.VIN?.Substring(Math.Max(0, Model.VIN.Length - 6))));

    string invoiceDateStr = invoice?.IssueDate.ToString("dd/MM/yyyy HH:mm") ?? DateTime.Now.ToString("dd/MM/yyyy HH:mm");
}

<style>
    /* ========================================================
           1. التنسيقات الأساسية والهيدر (لشاشة الويب فقط)
           ======================================================== */
    .details-header {
        background: linear-gradient(135deg, var(--secondary-navy) 0%, var(--primary-navy) 100%);
