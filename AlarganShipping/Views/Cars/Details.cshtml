        }

    .car-header-info {
        display: flex;
        align-items: center;
        gap: 2rem;
        z-index: 2;
        position: relative;
    }

    .car-main-img {
        width: 150px;
        height: 150px;
        border-radius: 1rem;
        object-fit: cover;
        border: 4px solid var(--primary-gold);
        box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: #cbd5e1;
    }

    .car-title-large {
        font-size: 2.5rem;
        font-weight: 900;
        margin: 0 0 1rem 0;
        color: var(--primary-gold);
    }

    .vin-badge {
        background-color: rgba(255,255,255,0.1);
        padding: 0.5rem 1.5rem;
        border-radius: 0.75rem;
        font-family: monospace;
        font-size: 1.1rem;
        letter-spacing: 2px;
        border: 1px solid rgba(255,255,255,0.2);
        display: inline-block;
    }

    /* شبكة أزرار الإجراءات في الهيدر */
    .header-actions-column {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-width: 260px;
    }

    .btn-action-custom {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 0.9rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 900;
        font-size: 0.9rem;
        text-decoration: none;
        transition: 0.3s;
        border: 1px solid rgba(255,255,255,0.15);
        font-family: inherit;
        color: white;
        cursor: pointer;
    }

    /* ألوان الأزرار */
    .btn-dark-slate {
        background-color: #3f4b5b;
    }

        .btn-dark-slate:hover {
            background-color: #2c3644;
            border-color: rgba(255,255,255,0.3);
        }

    .btn-bright-blue {
        background-color: #3b82f6;
        border-color: #60a5fa;
    }

        .btn-bright-blue:hover {
            background-color: #2563eb;
        }

    .btn-gold-brown {
        background-color: #b4844c;
        border-color: #d4a373;
    }

        .btn-gold-brown:hover {
            background-color: #9c703d;
        }

    .btn-print-white {
        background-color: white;
        color: var(--primary-navy);
        border-color: white;
    }

        .btn-print-white:hover {
            background-color: #f1f5f9;
        }

    /* ========================================================
           2. شريط التتبع (Stepper)
           ======================================================== */
    .tracking-card {
        background: white;
        border-radius: 1.5rem;
        padding: 3rem;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        margin-bottom: 2.5rem;
        border: 1px solid #e2e8f0;
    }

    .tracking-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 3rem;
        text-align: center;
    }

    .stepper-wrapper {
        display: flex;
        justify-content: space-between;
        position: relative;
        max-width: 800px;
        margin: 0 auto;
    }

        .stepper-wrapper::before {
            content: '';
            position: absolute;
            top: 25px;
            left: 0;
            right: 0;
            height: 4px;
            background-color: #f1f5f9;
            z-index: 1;
        }

        .stepper-wrapper::after {
            content: '';
            position: absolute;
            top: 25px;
            inset-inline-start: 0;
            height: 4px;
            background-color: var(--primary-gold);
            z-index: 2;
            transition: width 0.5s ease;
            width: var(--progress-width, 0%);
        }

    .step-item {
        position: relative;
        z-index: 3;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100px;
    }

    .step-circle {
        width: 54px;
        height: 54px;
        background-color: #ffffff;
        border: 4px solid #e2e8f0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        color: #94a3b8;
        margin-bottom: 1rem;
        transition: 0.3s;
        box-shadow: 0 0 0 5px white;
    }

    .step-item.active .step-circle {
        border-color: var(--primary-gold);
        background-color: var(--primary-gold);
        color: white;
        box-shadow: 0 0 0 5px white, 0 4px 15px rgba(184, 147, 90, 0.4);
    }

    .step-label {
        font-weight: 800;
        font-size: 0.9rem;
        color: var(--text-muted);
        text-align: center;
    }

    .step-item.active .step-label {
        color: var(--primary-navy);
    }

