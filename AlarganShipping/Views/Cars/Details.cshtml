            color: white;
        }

    .btn-delete-doc {
        background: #fef2f2;
        color: #ef4444;
        border: 1px solid #fecaca;
        width: 42px;
        padding: 0;
        border-radius: 0.75rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-delete-doc:hover {
            background: #ef4444;
            color: white;
            border-color: #ef4444;
        }

    /* ========================================================
           5. إعدادات طباعة الفاتورة (Invoice Print Layout - الصارمة لمنع السكرول)
           ======================================================== */
    .print-only {
        display: none;
    }

    @@media print {
        @@page {
            margin: 10mm;
            size: A4 portrait;
        }
        /* تدمير أي سكرول او ابعاد تسبب مشكلة */
        html, body {
            background: white !important;
            padding: 0 !important;
            margin: 0 !important;
            width: 100% !important;
            height: auto !important;
            overflow: visible !important;
            font-family: 'Cairo', Arial, sans-serif;
            color: black;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        /* إخفاء الهيدر الجانبي والعلوي الخاص بالموقع بالكامل */
        .sidebar, .topbar, .public-navbar, footer, nav, header {
            display: none !important;
        }
        /* تحرير حاويات التخطيط الأساسية من قيود الارتفاع والفليكس */
        .app-container, .main-content, .content-body {
            display: block !important;
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            height: auto !important;
            min-height: auto !important;
            background: white !important;
            box-shadow: none !important;
            overflow: visible !important;
        }
        /* إخفاء عناصر واجهة الويب داخل صفحة التفاصيل */
        .no-print, .header-actions-column, .tabs-header, .tabs-container, .details-header, .tracking-card, .info-grid {
            display: none !important;
        }
        /* إظهار حاوية الفاتورة للطباعة */
        .print-only {
            display: block !important;
            width: 100% !important;
            padding: 0 !important;
            margin: 0 !important;
            box-sizing: border-box;
        }

        .invoice-container-print {
            width: 100%;
            max-width: 100% !important;
            font-size: 13px;
            line-height: 1.5;
            margin: 0 !important;
            padding: 0 !important;
            border: none !important;
        }

        .red-text {
            color: #dc2626 !important;
