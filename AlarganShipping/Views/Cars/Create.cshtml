@model AlarganShipping.Models.Car
@{
    ViewData["Title"] = Localizer["إدارة بيانات المركبة - جديدة"];
}

<style>
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        gap: 10px;
    }

    .form-page-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-back {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        padding: 0.6rem 1.2rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
        flex-shrink: 0;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: var(--primary-navy);
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(44, 62, 80, 0.03);
        border: 1px solid #f1f5f9;
        padding: 3rem;
        position: relative;
        overflow: hidden;
    }

    /* الأقسام الداخلية */
    .section-divider {
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 2rem 0 1.5rem 0;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-divider:first-of-type {
            margin-top: 0;
        }

    .form-grid-4 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media (min-width: 768px) {
        .form-grid-4 {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (min-width: 1200px) {
        .form-grid-4 {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-label {
        font-weight: 800;
        color: var(--text-muted);
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
    }

    .form-control {
        padding: 0.85rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 0.95rem;
        color: var(--primary-navy);
        font-weight: 700;
        background-color: white;
        transition: 0.3s;
        outline: none;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

    .input-vin {
        border-color: #fca5a5;
        background-color: #fef2f2;
    }

        .input-vin:focus {
            border-color: #ef4444;
            box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.1);
        }

    .select2-container--default .select2-selection--single {
        background-color: white;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        height: 45px;
        display: flex;
        align-items: center;
        transition: 0.3s;
    }

        .select2-container--default .select2-selection--single:focus, .select2-container--focus .select2-selection--single {
            border-color: var(--primary-gold);
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            color: var(--primary-navy);
            font-weight: 700;
            padding-left: 1rem;
            padding-right: 1rem;
            font-size: 0.95rem;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 43px;
            right: 10px;
        }

    html[dir="rtl"] .select2-container--default .select2-selection--single .select2-selection__arrow {
        left: 10px;
        right: auto;
    }

    .input-group-dynamic {
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .input-group-dynamic .select2-container {
            flex: 1;
            width: auto !important;
        }

    .btn-quick-add {
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
        border: 1px solid rgba(184, 147, 90, 0.2);
        width: 45px;
        height: 45px;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.3s;
        flex-shrink: 0;
    }

        .btn-quick-add:hover {
            background: var(--primary-gold);
            color: white;
            box-shadow: 0 4px 10px rgba(184, 147, 90, 0.2);
        }

    .form-actions {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-start;
        gap: 1rem;
        align-items: center;
    }

    .btn-submit {
        background: #e2e8f0;
        color: #94a3b8;
        border: none;
        padding: 0.85rem 2.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        font-size: 1rem;
        cursor: pointer;
        transition: 0.3s;
        font-family: inherit;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .btn-submit.ready {
            background: var(--primary-navy);
            color: white;
            box-shadow: 0 4px 15px rgba(26, 37, 47, 0.2);
        }

            .btn-submit.ready:hover {
                background: var(--secondary-navy);
                transform: translateY(-2px);
            }

    .btn-cancel {
        background: transparent;
        color: var(--text-dark);
        border: none;
        font-weight: 800;
        cursor: pointer;
        text-decoration: none;
        padding: 0.85rem 1rem;
        display: inline-flex;
        justify-content: center;
    }

    @@media (max-width: 768px) {
        .premium-form-card {
            padding: 1.5rem;
            border-radius: 1.2rem;
        }

        .form-page-header {
            flex-direction: column;
            align-items: stretch;
            gap: 1rem;
            margin-bottom: 1.5rem;
            text-align: center;
        }

        .form-page-title {
            font-size: 1.2rem;
            justify-content: center;
        }

        .btn-back {
            width: 100%;
            text-align: center;
            justify-content: center;
            display: flex;
        }

        .form-actions {
            flex-direction: column-reverse;
            align-items: stretch;
            gap: 0.5rem;
            margin-top: 2rem;
            justify-content: center;
        }

        .btn-submit, .btn-cancel {
            width: 100%;
            margin: 0;
        }

        .btn-cancel {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 0.75rem;
        }
    }
</style>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<div>
    <div class="form-page-header">
        <h2 class="form-page-title">@Localizer["إدارة بيانات المركبة - جديدة"] <i class="fa-solid fa-car-side" style="color: var(--primary-gold); background: rgba(184, 147, 90, 0.1); padding: 8px; border-radius: 8px; font-size:1.1rem;"></i></h2>
        <a href="javascript:history.back()" class="btn-back"><i class="fa-solid fa-xmark"></i></a>
    </div>

    <div class="premium-form-card">
        <form asp-action="Create" method="post" id="carForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="form-grid-4">
                <div class="form-group" style="grid-column: 1 / -1;">
                    <label class="form-label">@Localizer["صورة السيارة الرئيسية"]</label>
                    <input type="file" name="mainImage" class="form-control" accept="image/*" style="padding: 0.6rem; background: #f8fafc;" />
                </div>
            </div>

            <!-- القسم الأساسي -->
            <div class="section-divider"><i class="fa-solid fa-circle-info" style="color:var(--primary-gold);"></i> البيانات الأساسية</div>
            <div class="form-grid-4">
                <div class="form-group">
                    <label asp-for="VIN" class="form-label">@Localizer["رقم الشاصي"] *</label>
                    <input asp-for="VIN" class="form-control input-vin" dir="ltr" placeholder="@Localizer["أدخل رقم الشاصي..."]" required />
                </div>
                <div class="form-group">
                    <label asp-for="Year" class="form-label">@Localizer["سنة الصنع"] *</label>
                    <input asp-for="Year" class="form-control" type="number" placeholder="2026" required />
                </div>
                <div class="form-group">
                    <label asp-for="Make" class="form-label">@Localizer["الماركة"] *</label>
                    <div class="input-group-dynamic">
                        <select asp-for="Make" class="form-control select2-search" required>
                            <option value="">@Localizer["اختر الماركة..."]</option>
                            <option value="Toyota">Toyota</option>
                            <option value="BMW">BMW</option>
                            <option value="Lexus">Lexus</option>
                            <option value="Mercedes">Mercedes</option>
                            <option value="Ford">Ford</option>
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('Make', '@Html.Raw(Localizer["إضافة ماركة سيارة جديدة"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="VehicleType" class="form-label">@Localizer["نوع المركبة"]</label>
                    <div class="input-group-dynamic">
                        <select asp-for="VehicleType" class="form-control select2-search" asp-items="ViewBag.VehicleShapes">
                            <option value="">@Localizer["اختر النوع..."]</option>
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('VehicleType', '@Html.Raw(Localizer["إضافة نوع مركبة جديد"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Model" class="form-label">@Localizer["الموديل"] *</label>
                    <input asp-for="Model" class="form-control" placeholder="@Localizer["أدخل الموديل..."]" required />
                </div>
                <div class="form-group">
                    <label asp-for="Color" class="form-label">@Localizer["اللون"] *</label>
                    <input asp-for="Color" class="form-control" placeholder="@Localizer["اختر اللون..."]" required />
                </div>
            </div>

            <!-- قسم الأسعار والمشتريات -->
            <div class="section-divider"><i class="fa-solid fa-money-bill-wave" style="color:var(--primary-gold);"></i> بيانات الشراء والتسعير</div>
            <div class="form-grid-4">
                <div class="form-group">
                    <label asp-for="CustomerId" class="form-label">@Localizer["العميل (مطلوب)"] *</label>
                    <div class="input-group-dynamic">
                        <select asp-for="CustomerId" class="form-control select2-search input-customer" asp-items="ViewBag.CustomerId" required>
                            <option value="">@Localizer["اختر العميل..."]</option>
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddCustomer()" title="إضافة عميل سريع"><i class="fa-solid fa-user-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="AuctionId" class="form-label">@Localizer["المعرض / المزاد"] *</label>
                    <div class="input-group-dynamic">
                        <select asp-for="AuctionId" class="form-control select2-search" asp-items="ViewBag.AuctionId" required>
                            <option value="">@Localizer["اختر المعرض..."]</option>
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddAuction()"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="PurchasePrice" class="form-label" style="color: #ef4444;">@Localizer["سعر الشراء (التكلفة الفعلية) $"] *</label>
                    <input asp-for="PurchasePrice" class="form-control" type="number" step="0.01" placeholder="0.00" style="font-family:monospace; font-size: 1.1rem;" required />
                </div>
                <div class="form-group">
                    <label asp-for="SellingPrice" class="form-label" style="color: #16a34a;">@Localizer["سعر البيع (شامل الربح) $"]</label>
                    <input asp-for="SellingPrice" class="form-control" type="number" step="0.01" placeholder="0.00" style="font-family:monospace; font-size: 1.1rem;" />
                </div>
            </div>

            <!-- قسم التتبع والضرائب -->
            <div class="section-divider"><i class="fa-solid fa-map-location-dot" style="color:var(--primary-gold);"></i> التتبع والضرائب</div>
            <div class="form-grid-4">
                <div class="form-group">
                    <label asp-for="StatusId" class="form-label">@Localizer["حالة المركبة (7 مراحل)"] *</label>
                    <select asp-for="StatusId" class="form-control select2-search" required>
                        <option value="1">@Localizer["الشراء"]</option>
                        <option value="2">@Localizer["الدفع"]</option>
                        <option value="3">@Localizer["النقل الداخلي"]</option>
                        <option value="4">@Localizer["وصول المستودع"]</option>
                        <option value="5">@Localizer["التحميل"]</option>
                        <option value="6">@Localizer["الإقلاع"]</option>
                        <option value="7">@Localizer["الوصول"]</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="CurrentLocation" class="form-label">@Localizer["توجد في"]</label>
                    <input asp-for="CurrentLocation" class="form-control" placeholder="@Localizer["موقع السيارة الحالي..."]" />
                </div>
                <div class="form-group">
                    <label asp-for="TaxType" class="form-label">@Localizer["نوع الضريبة"]</label>
                    <div class="input-group-dynamic">
                        <select asp-for="TaxType" class="form-control select2-search" asp-items="ViewBag.TaxTypes">
                            <option value="">@Localizer["اختر النوع..."]</option>
                            <option value="شامل الضريبة">@Localizer["شامل الضريبة"]</option>
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('TaxType', '@Html.Raw(Localizer["إضافة نوع ضريبة جديد"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="TaxAmount" class="form-label">@Localizer["مبلغ الضريبة / النسبة"]</label>
                    <input asp-for="TaxAmount" type="number" step="0.01" class="form-control" id="TaxAmountInput" placeholder="0" />
                </div>
                <div class="form-group">
                    <label asp-for="TaxMethod" class="form-label">@Localizer["طريقة الضريبة"]</label>
                    <div class="input-group-dynamic">
                        <select asp-for="TaxMethod" class="form-control select2-search" asp-items="ViewBag.TaxMethods">
                            <option value="">@Localizer["اختر الطريقة..."]</option>
                        </select>
                        <button type="button" class="btn-quick-add" onclick="quickAddOption('TaxMethod', '@Html.Raw(Localizer["إضافة طريقة ضريبة جديدة"])')"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
            </div>

            <!-- قسم التفاصيل الفنية -->
            <div class="section-divider"><i class="fa-solid fa-gears" style="color:var(--primary-gold);"></i> تفاصيل إضافية</div>
            <div class="form-grid-4">
                <div class="form-group">
                    <label asp-for="AddDate" class="form-label">@Localizer["تاريخ الإضافة"]</label>
                    <input asp-for="AddDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-group">
                    <label asp-for="PlateNo" class="form-label">@Localizer["رقم اللوحة"]</label>
                    <input asp-for="PlateNo" class="form-control" placeholder="@Localizer["أدخل رقم اللوحة..."]" />
                </div>
                <div class="form-group">
                    <label asp-for="CardNo" class="form-label">@Localizer["رقم الكرت"]</label>
                    <input asp-for="CardNo" class="form-control" placeholder="@Localizer["أدخل رقم الكرت..."]" />
                </div>
                <div class="form-group">
                    <label asp-for="EngineNo" class="form-label">@Localizer["رقم الماكينة"]</label>
                    <input asp-for="EngineNo" class="form-control" placeholder="@Localizer["أدخل رقم الماكينة..."]" />
                </div>
                <div class="form-group">
                    <label asp-for="CustomsDeclaration" class="form-label">@Localizer["البيان الجمركي"]</label>
                    <input asp-for="CustomsDeclaration" class="form-control" placeholder="@Localizer["رقم البيان الجمركي..."]" />
                </div>
                <div class="form-group">
                    <label asp-for="InsuranceNo" class="form-label">@Localizer["الرقم التأميني"]</label>
                    <input asp-for="InsuranceNo" class="form-control" placeholder="@Localizer["رقم التأمين..."]" />
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit" id="btnSubmit">
                    <i class="fa-solid fa-save"></i> @Localizer["حفظ بيانات المركبة"]
                </button>
                <a href="javascript:history.back()" class="btn-cancel">@Localizer["إلغاء"]</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>

    <script>
        // دوال الإضافة السريعة للقوائم المنسدلة
        function quickAddOption(selectId, titleText) {
            Swal.fire({
                title: titleText,
                input: 'text',
                inputPlaceholder: '@Html.Raw(Localizer["أدخل الاسم هنا..."])',
                showCancelButton: true,
                confirmButtonText: '@Html.Raw(Localizer["إضافة"])',
                cancelButtonText: '@Html.Raw(Localizer["إلغاء"])',
                confirmButtonColor: 'var(--primary-gold)',
                cancelButtonColor: 'var(--primary-navy)',
                inputValidator: (value) => {
                    if (!value) { return '@Html.Raw(Localizer["لا يمكن ترك الحقل فارغاً!"])'; }
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    var newOption = new Option(result.value, result.value, true, true);
                    $('#' + selectId).append(newOption).trigger('change');
                    Swal.fire({ title: '@Html.Raw(Localizer["تمت الإضافة!"])', icon: 'success', timer: 1500, showConfirmButton: false });
                }
            });
        }

        function quickAddCustomer() {
            Swal.fire({
                title: '@Html.Raw(Localizer["إضافة عميل سريع"])',
                input: 'text',
                inputPlaceholder: '@Html.Raw(Localizer["أدخل اسم العميل..."])',
                showCancelButton: true,
                confirmButtonText: '@Html.Raw(Localizer["إضافة"])',
                cancelButtonText: '@Html.Raw(Localizer["إلغاء"])',
                confirmButtonColor: 'var(--primary-gold)',
                cancelButtonColor: 'var(--primary-navy)',
                inputValidator: (value) => {
                    if (!value) return '@Html.Raw(Localizer["لا يمكن ترك الحقل فارغاً!"])';
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("CreateQuick", "Customers")', {
                        name: result.value,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    }, function(res) {
                        if (res.success) {
                            var newOption = new Option(res.name, res.id, true, true);
                            $('#CustomerId').append(newOption).trigger('change');
                            Swal.fire({ title: '@Html.Raw(Localizer["تمت الإضافة!"])', icon: 'success', timer: 1500, showConfirmButton: false });
                        }
                    });
                }
            });
        }

        function quickAddAuction() {
            Swal.fire({
                title: '@Html.Raw(Localizer["إضافة معرض سريع"])',
                input: 'text',
                inputPlaceholder: '@Html.Raw(Localizer["أدخل اسم المعرض..."])',
                showCancelButton: true,
                confirmButtonText: '@Html.Raw(Localizer["إضافة"])',
                cancelButtonText: '@Html.Raw(Localizer["إلغاء"])',
                confirmButtonColor: 'var(--primary-gold)',
                cancelButtonColor: 'var(--primary-navy)',
                inputValidator: (value) => {
                    if (!value) return '@Html.Raw(Localizer["لا يمكن ترك الحقل فارغاً!"])';
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("CreateQuick", "Auctions")', {
                        name: result.value,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    }, function(res) {
                        if (res.success) {
                            var newOption = new Option(res.name, res.id, true, true);
                            $('#AuctionId').append(newOption).trigger('change');
                            Swal.fire({ title: '@Html.Raw(Localizer["تمت الإضافة!"])', icon: 'success', timer: 1500, showConfirmButton: false });
                        }
                    });
                }
            });
        }

        $(document).ready(function() {
            var dir = $('html').attr('dir');
            $('.select2-search').select2({ dir: dir, width: '100%' });

            // كود تصفير الضريبة وإلغاء التعديل عند اختيار "شامل الضريبة"
            function handleTaxType() {
                if ($('#TaxType').val() === 'شامل الضريبة') {
                    $('#TaxAmountInput').val('0').prop('readonly', true).css({ 'background-color': '#e2e8f0', 'cursor': 'not-allowed' });
                } else {
                    $('#TaxAmountInput').prop('readonly', false).css({ 'background-color': '#ffffff', 'cursor': 'text' });
                }
            }
            $('#TaxType').on('change', handleTaxType);
            handleTaxType();

            $('#VIN').on('input', function() {
                if($(this).val().length > 0) {
                    $('#btnSubmit').addClass('ready');
                } else {
                    $('#btnSubmit').removeClass('ready');
                }
            });

            $('#carForm').on('submit', function(e) {
                e.preventDefault();
                var form = $(this);
                if (!form[0].checkValidity()) { form[0].reportValidity(); return; }

                var btn = $('#btnSubmit');
                var originalText = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin"></i> @Html.Raw(Localizer["جاري الحفظ..."])').prop('disabled', true);

                var formData = new FormData(form[0]);

                $.ajax({
                    url: form.attr('action'), type: form.attr('method'), data: formData,
                    processData: false, contentType: false,
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                title: '@Html.Raw(Localizer["تم الحفظ بنجاح!"])', icon: 'success', confirmButtonColor: 'var(--primary-gold)',
                                confirmButtonText: '@Html.Raw(Localizer["العودة للقائمة"])'
                            }).then(() => { window.location.href = '@Url.Action("Index", "Cars")'; });
                        } else {
                            var errorMsg = response.errors ? response.errors.join('\n') : '@Html.Raw(Localizer["تأكد من البيانات المدخلة"])';
                            Swal.fire({ title: '@Html.Raw(Localizer["خطأ!"])', text: errorMsg, icon: 'error', confirmButtonColor: 'var(--primary-navy)' });
                            btn.html(originalText).prop('disabled', false);
                        }
                    },
                    error: function () {
                        Swal.fire({ title: '@Html.Raw(Localizer["خطأ!"])', text: '@Html.Raw(Localizer["حدث خطأ أثناء الحفظ."])', icon: 'error', confirmButtonColor: 'var(--primary-navy)' });
                        btn.html(originalText).prop('disabled', false);
                    }
                });
            });
        });
    </script>
}