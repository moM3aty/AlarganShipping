@model AlarganShipping.Models.Auction
@{
    ViewData["Title"] = Localizer["تعديل بيانات المزاد"];
}

<style>
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.6rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-back {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        padding: 0.6rem 1.2rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: var(--primary-navy);
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(44, 62, 80, 0.03);
        border: 1px solid #f1f5f9;
        padding: 3rem;
        position: relative;
        overflow: hidden;
        max-width: 800px;
        margin: 0 auto;
    }

        .premium-form-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            left: 0;
            height: 6px;
            background: linear-gradient(to right, var(--primary-navy), var(--primary-gold));
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media (min-width: 768px) {
        .form-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-group-full {
        grid-column: 1 / -1;
    }

    .form-label {
        font-weight: 800;
        color: var(--primary-navy);
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-control {
        padding: 1rem 1.25rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 1rem;
        color: var(--text-dark);
        background-color: #f8fafc;
        transition: 0.3s;
        outline: none;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

    .form-actions {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
    }

    .btn-submit {
        background: var(--primary-gold);
        color: #ffffff;
        border: none;
        padding: 1rem 3rem;
        border-radius: 1rem;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 4px 15px rgba(184, 147, 90, 0.2);
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-submit:hover {
            background: var(--secondary-gold);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(184, 147, 90, 0.3);
        }

    @@media (max-width: 768px) {
        .form-page-header {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
        }

        .premium-form-card {
            padding: 1.5rem;
        }

        .btn-submit {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div>
    <div class="form-page-header">
        <h2 class="form-page-title"><i class="fa-solid fa-pen-to-square" style="color: var(--primary-gold);"></i> @Localizer["تعديل بيانات المزاد"]</h2>
        <a href="@Url.Action("Index", "Auctions")" class="btn-back"><i class="fa-solid fa-arrow-right-long"></i> @Localizer["إلغاء والعودة"]</a>
    </div>

    <div class="premium-form-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 1rem; color: #ef4444; font-weight: bold;"></div>

            <div class="form-grid">
                <div class="form-group form-group-full">
                    <label asp-for="Name" class="form-label">@Localizer["اسم المزاد / المعرض"] *</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" style="color: #ef4444; font-size: 0.85rem; margin-top: 5px;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="BuyerNumber" class="form-label">@Localizer["رقم المشتري (Buyer Number)"]</label>
                    <input asp-for="BuyerNumber" class="form-control" dir="ltr" />
                    <span asp-validation-for="BuyerNumber" style="color: #ef4444; font-size: 0.85rem; margin-top: 5px;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Location" class="form-label">@Localizer["المدينة / الموقع"]</label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" style="color: #ef4444; font-size: 0.85rem; margin-top: 5px;"></span>
                </div>

                <div class="form-group form-group-full">
                    <label asp-for="DefaultAuctionFee" class="form-label">@Localizer["رسوم المزاد الافتراضية ($)"]</label>
                    <!-- 💡 تم تصحيح مشكلة تحويل الفواصل في الأرقام العشرية (Invariant) -->
                    <input asp-for="DefaultAuctionFee" type="number" step="0.01" value="@Model.DefaultAuctionFee.ToString(System.Globalization.CultureInfo.InvariantCulture)" class="form-control" style="font-family: monospace; color: #16a34a;" />
                    <span asp-validation-for="DefaultAuctionFee" style="color: #ef4444; font-size: 0.85rem; margin-top: 5px;"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit" onclick="this.innerHTML='<i class=\'fa-solid fa-spinner fa-spin\'></i> @Localizer["جاري التحديث..."]';">
                    <i class="fa-solid fa-save"></i> @Localizer["حفظ التعديلات"]
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}