@model IEnumerable<AlarganShipping.Models.Auction>
@{
    ViewData["Title"] = Localizer["إدارة المزادات"];
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<style>
    .page-header-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: white;
        padding: 1.5rem;
        border-radius: 1.5rem;
        box-shadow: 0 5px 20px rgba(44, 62, 80, 0.03);
        border: 1px solid #f1f5f9;
        margin-bottom: 2rem;
    }

    .page-header-text h2 {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .page-header-text h2 i {
            color: var(--primary-gold);
        }

    .btn-add {
        background: linear-gradient(to right, var(--primary-navy), var(--secondary-navy));
        color: #ffffff;
        font-weight: 800;
        padding: 0.85rem 1.75rem;
        border-radius: 1rem;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(44, 62, 80, 0.3);
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(44, 62, 80, 0.4);
            background: linear-gradient(to right, var(--primary-gold), var(--secondary-gold));
            color: white;
        }

    .data-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        overflow-x: auto;
    }

    .table-enterprise {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }

        .table-enterprise th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            padding: 1.25rem 1rem;
            border-bottom: 2px solid #e2e8f0;
            text-align: start;
            white-space: nowrap;
        }

        .table-enterprise td {
            padding: 1.25rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-dark);
            font-weight: 700;
            vertical-align: middle;
        }

        .table-enterprise tbody tr:hover {
            background-color: #f8fafc;
            transition: 0.2s;
        }

    .auction-logo {
        width: 45px;
        height: 45px;
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-inline-end: 15px;
        vertical-align: middle;
    }

    /* ستايل أزرار الإجراءات (تعديل وحذف) بشكل عصري ومربع */
    .action-btn {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        cursor: pointer;
        transition: 0.3s;
        text-decoration: none;
    }

    .btn-edit {
        color: var(--primary-gold);
    }

        .btn-edit:hover {
            background: var(--primary-gold);
            color: white;
            border-color: var(--primary-gold);
            box-shadow: 0 4px 10px rgba(184, 147, 90, 0.2);
        }

    .btn-delete {
        color: #ef4444;
    }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
            border-color: #ef4444;
            box-shadow: 0 4px 10px rgba(239, 68, 68, 0.2);
        }

    /* ========================================================
           تعديلات الموبايل (الميديا كويري)
           ======================================================== */
    @@media (max-width: 768px) {
        .page-header-container {
            flex-direction: column;
            align-items: stretch;
            gap: 1.5rem;
            padding: 1.5rem;
        }

        .header-actions {
            width: 100%;
        }

        .btn-add {
            width: 100%;
            justify-content: center; /* توسيط محتوى الزر */
        }

        .data-card {
            padding: 1.5rem; /* تقليل حواف الجدول الجانبية لتوفير مساحة */
            border-radius: 1.2rem;
        }
    }
</style>

<div>
    @Html.AntiForgeryToken()
    <div class="page-header-container">
        <div class="page-header-text">
            <h2><i class="fa-solid fa-gavel"></i> @Localizer["إدارة المزادات"]</h2>
            <p style="color: var(--text-muted); font-weight: 600; margin-top: 5px;">• @Localizer["قائمة المزادات المعتمدة وحسابات الشراء"]</p>
        </div>
        <div class="header-actions">
            <a href="@Url.Action("Create", "Auctions")" class="btn-add"><i class="fa-solid fa-plus"></i> @Localizer["إضافة مزاد جديد"]</a>
        </div>
    </div>

    <div class="data-card">
        <table id="auctionsTable" class="table-enterprise display" style="width:100%">
            <thead>
                <tr>
                    <th>@Localizer["اسم المزاد"]</th>
                    <th>@Localizer["الموقع الأساسي"]</th>
                    <th>@Localizer["رقم المشتري (Buyer No)"]</th>
                    <!-- تمت إزالة عمود رسوم المزاد -->
                    <th>@Localizer["إجراءات"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var auc in Model)
                    {
                        <tr>
                            <td>
                                <div class="auction-logo"><i class="fa-solid fa-building-columns"></i></div>
                                <span style="font-weight: 900; color: var(--primary-navy); font-size: 1.1rem;">@auc.Name</span>
                            </td>
                            <td style="color: var(--text-muted);"><i class="fa-solid fa-location-dot" style="margin-inline-end: 5px;"></i> @auc.Location</td>
                            <td style="font-family: monospace; font-weight: 900; color: var(--primary-navy);">@(string.IsNullOrEmpty(auc.BuyerNumber) ? "-" : auc.BuyerNumber)</td>
                            <td>
                                <div style="display:flex; gap: 8px;">
                                    <a href="@Url.Action("Edit", "Auctions", new { id = auc.Id })" class="action-btn btn-edit" title="@Localizer["تعديل"]">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <button type="button" onclick="confirmDelete(@auc.Id)" class="action-btn btn-delete" title="@Localizer["حذف"]">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script>
        // دالة الحذف
        function confirmDelete(id) {
            Swal.fire({
                title: "@Html.Raw(Localizer["هل أنت متأكد؟"])",
                text: "@Html.Raw(Localizer["لن تتمكن من التراجع عن عملية الحذف!"])",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: 'var(--primary-navy)',
                confirmButtonText: "@Html.Raw(Localizer["نعم، احذفه!"])",
                cancelButtonText: "@Html.Raw(Localizer["إلغاء"])"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Auctions")', // إصلاح الرابط
                        type: 'POST',
                        data: {
                            id: id, // تمرير الـ ID ضمن البيانات
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    title: "@Html.Raw(Localizer["تم الحذف!"])",
                                    text: "@Html.Raw(Localizer["تم حذف المزاد بنجاح."])",
                                    icon: 'success',
                                    confirmButtonColor: 'var(--primary-gold)'
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire("@Html.Raw(Localizer["خطأ!"])", response.message || "@Html.Raw(Localizer["حدث خطأ أثناء الحذف."])", 'error');
                            }
                        },
                        error: function () {
                            Swal.fire("@Html.Raw(Localizer["خطأ!"])", "@Html.Raw(Localizer["لا يمكن الاتصال بالخادم."])", 'error');
                        }
                    });
                }
            });
        }

        $(document).ready(function () {
            var dir = $('html').attr('dir') === 'rtl';
            $('#auctionsTable').DataTable({
                "language": { "url": dir ? "//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json" : "" },
                "pageLength": 10,
                "responsive": true
            });
        });
    </script>
}