@model IEnumerable<AlarganShipping.Models.Auction>
@{
    ViewData["Title"] = Localizer["إدارة المزادات والمعارض"];
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<style>
    .page-header-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: white;
        padding: 1.5rem;
        border-radius: 1.5rem;
        box-shadow: 0 5px 20px rgba(44, 62, 80, 0.03);
        margin-bottom: 2rem;
        border: 1px solid #f1f5f9;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-header-text h2 {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .page-header-text p {
        color: var(--text-muted);
        font-size: 0.9rem;
        font-weight: 600;
        margin: 0;
        margin-top: 5px;
    }

    .btn-add {
        background: var(--primary-navy);
        color: white;
        font-weight: 800;
        padding: 0.85rem 1.75rem;
        border-radius: 1rem;
        text-decoration: none;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add:hover {
            background: var(--primary-gold);
            color: white;
            box-shadow: 0 5px 15px rgba(184, 147, 90, 0.3);
            transform: translateY(-2px);
        }

    .data-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
    }

    .table-enterprise {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }

        .table-enterprise th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            padding: 1.25rem 1rem;
            border-bottom: 2px solid #e2e8f0;
            text-align: start;
        }

        .table-enterprise td {
            padding: 1.25rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: var(--primary-navy);
            font-weight: 700;
            vertical-align: middle;
        }

    .action-btn-pro {
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: 0.3s;
        text-decoration: none;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        cursor: pointer;
        font-size: 1.1rem;
    }

    .btn-edit-pro {
        color: var(--primary-gold);
    }

        .btn-edit-pro:hover {
            background: var(--primary-gold);
            color: white;
            border-color: var(--primary-gold);
        }

    .btn-delete-pro {
        color: #ef4444;
    }

        .btn-delete-pro:hover {
            background: #ef4444;
            color: white;
            border-color: #ef4444;
        }

    .auction-badge {
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
        padding: 5px 12px;
        border-radius: 8px;
        font-weight: 800;
        font-size: 0.85rem;
        border: 1px solid rgba(184, 147, 90, 0.2);
    }

    @@media (max-width: 768px) {
        .page-header-container {
            flex-direction: column;
            text-align: center;
        }

        .btn-add {
            width: 100%;
            justify-content: center;
        }

        .data-card {
            padding: 1rem;
        }
    }
</style>

<!-- 💡 إضافة التوكن لكي تنجح عملية الحذف بالـ AJAX -->
@Html.AntiForgeryToken()

<div class="page-header-container">
    <div class="page-header-text">
        <h2><i class="fa-solid fa-gavel" style="color: var(--primary-gold);"></i> @Localizer["المزادات والمعارض"]</h2>
        <p>• @Localizer["إدارة جهات الشراء والمزادات العالمية والمحلية"]</p>
    </div>
    <div class="header-actions">
        <a href="@Url.Action("Create", "Auctions")" class="btn-add"><i class="fa-solid fa-plus"></i> @Localizer["إضافة مزاد جديد"]</a>
    </div>
</div>

<div class="data-card">
    <div style="overflow-x: auto; width: 100%;">
        <table id="auctionsTable" class="table-enterprise display" style="width:100%">
            <thead>
                <tr>
                    <th>@Localizer["المزاد / المعرض"]</th>
                    <th>@Localizer["رقم المشتري"] (Buyer No)</th>
                    <th>@Localizer["المدينة / الموقع"]</th>
                    <th>@Localizer["الرسوم الافتراضية"] ($)</th>
                    <th style="text-align: center;">@Localizer["إجراءات"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div style="font-weight: 900; font-size: 1.1rem; color: var(--primary-navy);">
                                    <i class="fa-solid fa-building-columns" style="color: #cbd5e1; margin-inline-end: 5px;"></i> @item.Name
                                </div>
                            </td>
                            <td><span class="auction-badge" dir="ltr">@(item.BuyerNumber ?? "-")</span></td>
                            <td><i class="fa-solid fa-location-dot" style="color: var(--text-muted);"></i> @(item.Location ?? "-")</td>
                            <td style="font-family: monospace; font-weight: 900; color: #16a34a;">
                                $@item.DefaultAuctionFee.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)
                            </td>
                            <td style="text-align: center;">
                                <div style="display: flex; gap: 8px; justify-content: center;">
                                    <a href="@Url.Action("Edit", "Auctions", new { id = item.Id })" class="action-btn-pro btn-edit-pro" title="@Localizer["تعديل"]">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <button type="button" class="action-btn-pro btn-delete-pro" onclick="confirmDelete(@item.Id)" title="@Localizer["حذف"]">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script>
        $(document).ready(function () {
            var dir = $('html').attr('dir') === 'rtl';

            // 💡 إصلاح تحميل لغة الجداول
            var tableOptions = {
                pageLength: 10,
                responsive: true
            };
            if (dir) {
                tableOptions.language = { url: "//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json" };
            }
            $('#auctionsTable').DataTable(tableOptions);
        });

        function confirmDelete(id) {
            Swal.fire({
                title: `@Html.Raw(Localizer["هل أنت متأكد؟"])`,
                text: `@Html.Raw(Localizer["لن تتمكن من استرجاع بيانات هذا المزاد!"])`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: 'var(--primary-navy)',
                confirmButtonText: `@Html.Raw(Localizer["نعم، احذفه!"])`,
                cancelButtonText: `@Html.Raw(Localizer["إلغاء"])`
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Auctions")/' + id,
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({
                                    title: `@Html.Raw(Localizer["تم الحذف!"])`,
                                    icon: 'success',
                                    timer: 1500,
                                    showConfirmButton: false
                                }).then(() => location.reload());
                            } else {
                                Swal.fire(`@Html.Raw(Localizer["خطأ!"])`, res.message, 'error');
                            }
                        }
                    });
                }
            });
        }
    </script>
}