@model AlarganShipping.Models.CarInspection
@{
    ViewData["Title"] = "إضافة تقرير فحص سيارة";
}

<style>
    /* Premium Pure CSS specific to Car Inspections */
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: #2b3f56;
        margin: 0;
    }

    .btn-back {
        background-color: #f1f5f9;
        color: #475569;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .btn-back:hover {
            background-color: #e2e8f0;
            color: #1e293b;
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.25rem;
        box-shadow: 0 10px 30px rgba(43, 63, 86, 0.05);
        border: 1px solid #f8fafc;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
    }

        .premium-form-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(to left, #eab308, #facc15);
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @@media (min-width: 768px) {
        .form-grid

    {
        grid-template-columns: repeat(2, 1fr);
    }

    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-group-full {
        grid-column: 1 / -1;
    }

    .form-label {
        font-weight: 700;
        color: #2b3f56;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-control {
        padding: 0.85rem 1.25rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: 'Cairo', sans-serif;
        font-size: 1rem;
        color: #1e293b;
        background-color: #f8fafc;
        transition: all 0.3s ease;
        outline: none;
    }

        .form-control:focus {
            border-color: #eab308;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(234, 179, 8, 0.1);
        }

    /* Checkbox Styling */
    .checkbox-container {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .checkbox-container:hover {
            border-color: #eab308;
        }

    .checkbox-input {
        width: 1.25rem;
        height: 1.25rem;
        accent-color: #eab308;
        cursor: pointer;
    }

    .checkbox-label {
        font-weight: 700;
        color: #1e293b;
        cursor: pointer;
        margin: 0;
    }

    .form-actions {
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
    }

    .btn-submit {
        background: linear-gradient(to right, #eab308, #facc15);
        color: #ffffff;
        border: none;
        padding: 0.85rem 2.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        font-family: 'Cairo', sans-serif;
        box-shadow: 0 4px 15px rgba(234, 179, 8, 0.3);
        transition: all 0.3s ease;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(234, 179, 8, 0.4);
        }

    .text-danger {
        color: #dc2626;
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 0.25rem;
    }
</style>

<div>
    <div class="form-page-header">
        <h2 class="form-page-title">إضافة تقرير فحص وحالة سيارة</h2>
        <a href="@Url.Action("Index", "Cars")" class="btn-back">العودة للسيارات</a>
    </div>

    <div class="premium-form-card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">
                <div class="form-group form-group-full">
                    <label asp-for="CarId" class="form-label">السيارة المراد فحصها</label>
                    <select asp-for="CarId" class="form-control" asp-items="ViewBag.CarId"></select>
                </div>

                <div class="form-group">
                    <label asp-for="InspectionStage" class="form-label">مرحلة الفحص</label>
                    <select asp-for="InspectionStage" class="form-control">
                        <option value="عند المزاد">عند الشراء من المزاد</option>
                        <option value="في المستودع">عند الوصول للمستودع (أمريكا)</option>
                        <option value="عند الوصول">عند الوصول للميناء (الوجهة)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="InspectorName" class="form-label">اسم الفاحص / السائق</label>
                    <input asp-for="InspectorName" class="form-control" placeholder="اسم الموظف الذي قام بالفحص" />
                </div>

                <div class="form-group">
                    <label class="checkbox-container">
                        <input asp-for="HasKeys" type="checkbox" class="checkbox-input" />
                        <span class="checkbox-label">هل يوجد مفتاح للسيارة؟</span>
                    </label>
                </div>

                <div class="form-group">
                    <label class="checkbox-container">
                        <input asp-for="HasTitle" type="checkbox" class="checkbox-input" />
                        <span class="checkbox-label">هل الملكية (Title) موجودة؟</span>
                    </label>
                </div>

                <div class="form-group">
                    <label class="checkbox-container">
                        <input asp-for="IsRunAndDrive" type="checkbox" class="checkbox-input" />
                        <span class="checkbox-label">حالة التشغيل (Run & Drive) سليمة؟</span>
                    </label>
                </div>

                <div class="form-group form-group-full">
                    <label asp-for="DamageNotes" class="form-label">تفاصيل الأضرار والملاحظات (إن وجدت)</label>
                    <textarea asp-for="DamageNotes" class="form-control" rows="3" placeholder="سجل أي خدوش، أجزاء مفقودة، أو زجاج مكسور لحفظ حقوق الشركة..."></textarea>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">حفظ التقرير</button>
            </div>
        </form>
    </div>
</div>