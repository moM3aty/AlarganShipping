@using System.Text.Json
@inject IWebHostEnvironment Env
@{
    ViewData["Title"] = Localizer["دليل الخدمات والأسعار"];

    // جلب رقم التواصل من ملف الإعدادات ديناميكياً
    string settingsPath = System.IO.Path.Combine(Env.WebRootPath, "settings.json");
    string phone = "96800000000";
    if (System.IO.File.Exists(settingsPath))
    {
        var json = System.IO.File.ReadAllText(settingsPath);
        using var doc = JsonDocument.Parse(json);
        if (doc.RootElement.TryGetProperty("InquiryPhoneNumber", out var phoneProp))
        {
            phone = phoneProp.GetString() ?? phone;
        }
    }
}

<style>
    .page-header-container {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 3rem;
    }

    .page-header-text h2 {
        font-size: 2.2rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
    }

    .page-header-text p {
        color: var(--text-muted);
        font-size: 1rem;
        font-weight: 600;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .intro-text {
        text-align: center;
        max-width: 800px;
        margin: 0 auto 4rem auto;
    }

        .intro-text h1 {
            font-size: 2.5rem;
            font-weight: 900;
            color: var(--primary-navy);
            margin-bottom: 1rem;
        }

        .intro-text p {
            font-size: 1.1rem;
            color: var(--text-muted);
            line-height: 1.8;
            font-weight: 600;
        }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 5rem;
    }

    .service-card {
        background: white;
        border-radius: 2rem;
        padding: 3rem 2rem;
        text-align: center;
        box-shadow: 0 15px 40px rgba(44, 62, 80, 0.02);
        border: 1px solid #f1f5f9;
        transition: 0.3s;
        display: flex;
        flex-direction: column;
    }

        .service-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 50px rgba(44, 62, 80, 0.08);
            border-color: var(--primary-gold);
        }

    .srv-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 1.5rem auto;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
    }

    .service-card h3 {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 1rem;
    }

    .service-card p {
        color: var(--text-muted);
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 2rem;
        line-height: 1.7;
        flex: 1;
    }

    .btn-srv-link {
        color: var(--primary-navy);
        font-weight: 800;
        text-decoration: none;
        font-size: 0.95rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        justify-content: center;
        transition: 0.3s;
        background: #f8fafc;
        padding: 0.8rem;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
    }

        .btn-srv-link:hover {
            color: white;
            background: var(--primary-gold);
            border-color: var(--primary-gold);
        }

    .cta-banner-dark {
        background: var(--primary-navy);
        border-radius: 2.5rem;
        padding: 4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: white;
        position: relative;
        overflow: hidden;
    }

        .cta-banner-dark::before {
            content: '\f0e3';
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            position: absolute;
            left: -20px;
            top: 50%;
            transform: translateY(-50%) rotate(-15deg);
            font-size: 15rem;
            color: rgba(184, 147, 90, 0.05);
            z-index: 1;
        }

    .cta-content {
        max-width: 600px;
        position: relative;
        z-index: 2;
        text-align: right;
    }

        .cta-content h2 {
            font-size: 2.5rem;
            font-weight: 900;
            margin: 0 0 1rem 0;
            color: var(--primary-gold);
        }

        .cta-content p {
            font-size: 1.1rem;
            line-height: 1.8;
            font-weight: 600;
            opacity: 0.8;
            margin: 0;
        }

    .btn-cta-outline {
        background: var(--primary-gold);
        color: white;
        padding: 1rem 2.5rem;
        border-radius: 1rem;
        border: none;
        font-weight: 800;
        text-decoration: none;
        transition: 0.3s;
        position: relative;
        z-index: 2;
        box-shadow: 0 4px 15px rgba(184, 147, 90, 0.3);
    }

        .btn-cta-outline:hover {
            background: var(--secondary-gold);
            transform: translateY(-2px);
        }

    @@media (max-width: 768px) {
        .page-header-container

    {
        flex-direction: column;
        text-align: center;
        gap: 1rem;
    }

    .page-header-text h2 {
        font-size: 1.8rem;
    }

    .page-header-text p {
        justify-content: center;
    }

    .intro-text {
        margin-bottom: 2.5rem;
        padding: 0 1rem;
    }

        .intro-text h1 {
            font-size: 2rem;
        }

    .service-card {
        padding: 2rem 1.5rem;
    }

    .cta-banner-dark {
        flex-direction: column;
        padding: 2.5rem 1.5rem;
        text-align: center;
        gap: 2rem;
        border-radius: 1.5rem;
    }

    .cta-content {
        text-align: center;
    }

        .cta-content h2 {
            font-size: 1.8rem;
        }

    .btn-cta-outline {
        width: 100%;
        text-align: center;
        padding: 1rem;
    }

    }
</style>

<div>
    <div class="page-header-container">
        <div class="page-header-text">
            <h2>@Localizer["دليل الخدمات والأسعار"]</h2>
            <p><span style="width: 6px; height: 6px; background: var(--primary-gold); border-radius: 50%;"></span> @Localizer["نظام الإدارة اللوجستية التقني"]</p>
        </div>
    </div>

    <div class="intro-text">
        <h1>@Localizer["حلولنا اللوجستية المتكاملة"]</h1>
        <p>@Localizer["نقدم في شركة الارجان للشحن تجربة استيراد فريدة، تبدأ من الاستشارة الفنية قبل المزاد وتنتهي عند وصول سيارتك إلى منزلك."]</p>
    </div>

    <div class="services-grid">
        <div class="service-card">
            <div class="srv-icon"><i class="fa-solid fa-ship"></i></div>
            <h3>@Localizer["الشحن البحري الدولي"]</h3>
            <p>@Localizer["حلول شحن متكاملة عبر الحاويات أو نظام RORO من كافة موانئ العالم."]</p>
            <a href="https://wa.me/@(phone)?text=@Html.Raw(Uri.EscapeDataString("أهلاً شركة الأرجان، أود الاستفسار عن خدمات الشحن البحري الدولي."))" target="_blank" class="btn-srv-link">
                <i class="fa-brands fa-whatsapp"></i> @Localizer["استفسر الآن"]
            </a>
        </div>

        <div class="service-card">
            <div class="srv-icon"><i class="fa-solid fa-file-shield"></i></div>
            <h3>@Localizer["فحص وتأمين المركبات"]</h3>
            <p>@Localizer["توفير تقارير فحص مفصلة قبل الشراء، وتأمين شامل على الشحنات البحرية."]</p>
            <a href="https://wa.me/@(phone)?text=@Html.Raw(Uri.EscapeDataString("أهلاً شركة الأرجان، أود الاستفسار عن فحص وتأمين سيارتي قبل الشراء."))" target="_blank" class="btn-srv-link">
                <i class="fa-brands fa-whatsapp"></i> @Localizer["استفسر الآن"]
            </a>
        </div>

        <div class="service-card">
            <div class="srv-icon"><i class="fa-solid fa-truck-fast"></i></div>
            <h3>@Localizer["النقل الداخلي (أمريكا)"]</h3>
            <p>@Localizer["خدمة سحب ونقل احترافية (Towing) من كافة مواقع المزاد في الولايات المتحدة."]</p>
            <a href="https://wa.me/@(phone)?text=@Html.Raw(Uri.EscapeDataString("أهلاً شركة الأرجان، أود الاستفسار عن تكاليف النقل الداخلي (Towing) في أمريكا."))" target="_blank" class="btn-srv-link">
                <i class="fa-brands fa-whatsapp"></i> @Localizer["استفسر الآن"]
            </a>
        </div>

        <div class="service-card">
            <div class="srv-icon"><i class="fa-solid fa-building-shield"></i></div>
            <h3>@Localizer["التخليص الجمركي في عمان"]</h3>
            <p>@Localizer["إنهاء كافة الإجراءات الجمركية والضريبية بسرعة وكفاءة في موانئ السلطنة."]</p>
            <a href="https://wa.me/@(phone)?text=@Html.Raw(Uri.EscapeDataString("أهلاً شركة الأرجان، أود الاستفسار عن إجراءات التخليص الجمركي والضرائب في عمان."))" target="_blank" class="btn-srv-link">
                <i class="fa-brands fa-whatsapp"></i> @Localizer["استفسر الآن"]
            </a>
        </div>

        <div class="service-card">
            <div class="srv-icon"><i class="fa-solid fa-gavel"></i></div>
            <h3>@Localizer["استشارات وحسابات المزادات"]</h3>
            <p>@Localizer["نوفر لعملائنا حسابات خاصة للمشاركة المباشرة في كبرى المزادات العالمية."]</p>
            <a href="https://wa.me/@(phone)?text=@Html.Raw(Uri.EscapeDataString("أهلاً شركة الأرجان، أرغب في الحصول على حساب مزاد للمزايدة بنفسي."))" target="_blank" class="btn-srv-link">
                <i class="fa-brands fa-whatsapp"></i> @Localizer["استفسر الآن"]
            </a>
        </div>
    </div>

    <div class="cta-banner-dark" dir="rtl">
        <div class="cta-content">
            <h2>@Localizer["هل ترغب في الحصول على حساب مزاد؟"]</h2>
            <p>@Localizer["فريقنا مستعد لتزويدك بكافة الأدوات لبدء استيراد سيارتك بأمان وبأقل التكاليف."]</p>
        </div>
        <a href="@Url.Action("Index", "Contact")" class="btn-cta-outline">@Localizer["تواصل معنا"]</a>
    </div>
</div>