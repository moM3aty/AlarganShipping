@model AlarganShipping.Models.DispatchOrder
@{
    ViewData["Title"] = Localizer["إنشاء أمر تسليم (Gate Pass)"];
}

<style>
    .premium-form-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        font-weight: 800;
        color: var(--primary-navy);
        margin-bottom: 0.5rem;
        display: block;
    }

    .form-control {
        padding: 0.9rem 1.2rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        width: 100%;
        font-weight: 700;
        color: var(--text-dark);
        background: #f8fafc;
        transition: 0.3s;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            outline: none;
            background: white;
        }

    .car-mini-details {
        background: linear-gradient(135deg, var(--secondary-navy) 0%, var(--primary-navy) 100%);
        color: white;
        padding: 1.5rem;
        border-radius: 1rem;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-submit {
        background: var(--primary-gold);
        color: white;
        border: none;
        padding: 1rem 3rem;
        border-radius: 1rem;
        font-weight: 900;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-submit:hover {
            background: var(--primary-navy);
        }
</style>

<div class="page-header-container" style="background: white; padding: 1.5rem; border-radius: 1.5rem; margin-bottom: 2rem; border: 1px solid #f1f5f9;">
    <h2 style="margin:0; font-weight:900; color:var(--primary-navy);"><i class="fa-solid fa-truck" style="color:var(--primary-gold);"></i> @Localizer["إنشاء أمر تسليم سيارة"]</h2>
</div>

<div class="premium-form-card">
    <div class="car-mini-details">
        <div>
            <div style="font-size: 0.9rem; color: #cbd5e1; font-weight: bold;">المركبة المراد تسليمها</div>
            <div style="font-size: 1.5rem; font-weight: 900;">@ViewBag.CarName</div>
            <div style="font-family: monospace; font-size: 1.1rem; color: var(--primary-gold);">VIN: @ViewBag.CarVIN</div>
        </div>
        <i class="fa-solid fa-warehouse" style="font-size: 3rem; opacity: 0.5;"></i>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CarId" value="@ViewBag.CarId" />

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <div class="form-group">
                <label asp-for="DriverName" class="form-label">@Localizer["اسم السائق / المستلم"] *</label>
                <input asp-for="DriverName" class="form-control" required placeholder="أدخل اسم الشخص الذي سيستلم السيارة..." />
            </div>
            <div class="form-group">
                <label asp-for="DriverPhone" class="form-label">@Localizer["رقم هاتف السائق"] *</label>
                <input asp-for="DriverPhone" class="form-control" required dir="ltr" />
            </div>
            <div class="form-group">
                <label asp-for="TowingCompany" class="form-label">@Localizer["شركة النقل (إن وجدت)"]</label>
                <input asp-for="TowingCompany" class="form-control" placeholder="اسم الريكفري..." />
            </div>
            <div class="form-group">
                <label asp-for="DispatchDate" class="form-label">@Localizer["تاريخ التسليم"]</label>
                <input asp-for="DispatchDate" type="datetime-local" class="form-control" required />
            </div>
            <div class="form-group" style="grid-column: 1 / -1;">
                <label asp-for="Notes" class="form-label">@Localizer["ملاحظات التسليم"]</label>
                <textarea asp-for="Notes" class="form-control" rows="3" placeholder="أي ملاحظات حول حالة السيارة وقت التسليم..."></textarea>
            </div>
        </div>

        <div style="margin-top: 2rem; border-top: 1px solid #e2e8f0; padding-top: 1.5rem; text-align: end;">
            <button type="submit" class="btn-submit">
                <i class="fa-solid fa-check"></i> @Localizer["تأكيد خروج السيارة"]
            </button>
        </div>
    </form>
</div>