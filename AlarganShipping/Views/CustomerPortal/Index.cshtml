@model AlarganShipping.Models.Customer
@{
    ViewData["Title"] = Localizer["لوحة التحكم الخاصة بي"];

    decimal totalPaid = Model.TotalPaid;
    decimal totalBalance = Model.TotalBalance;
    decimal totalRequired = totalPaid + totalBalance;
    decimal payPercentage = totalRequired > 0 ? (totalPaid / totalRequired) * 100 : 0;
}

<style>
    .welcome-banner {
        background: linear-gradient(135deg, var(--secondary-navy) 0%, var(--primary-navy) 100%);
        color: white;
        padding: 3rem;
        border-radius: 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 15px 30px rgba(44, 62, 80, 0.15);
        position: relative;
        overflow: hidden;
    }

        .welcome-banner::before {
            content: '\f406'; /* أيقونة مستخدم */
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            position: absolute;
            left: -20px;
            top: 50%;
            transform: translateY(-50%) rotate(-15deg);
            font-size: 15rem;
            color: rgba(184, 147, 90, 0.05);
            z-index: 1;
        }

    .welcome-content {
        position: relative;
        z-index: 2;
    }

        .welcome-content h1 {
            font-size: 2rem;
            font-weight: 900;
            margin: 0 0 0.5rem 0;
            color: var(--primary-gold);
        }

        .welcome-content p {
            color: #cbd5e1;
            font-size: 1.1rem;
            font-weight: 600;
            margin: 0;
        }

    /* كروت الخلاصة المالية */
    .finance-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }

    @@media (min-width: 768px) {
        .finance-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .finance-card {
        background: white;
        padding: 2rem;
        border-radius: 1.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        border: 1px solid #e2e8f0;
        text-align: center;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
    }

    .finance-title {
        color: var(--text-muted);
        font-size: 1rem;
        font-weight: 800;
        margin-bottom: 0.75rem;
    }

    .finance-value {
        font-size: 2.2rem;
        font-weight: 900;
        font-family: monospace;
    }

    /* التقدم */
    .progress-bar-bg {
        width: 100%;
        height: 10px;
        background: #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
        margin-top: 1rem;
    }

    .progress-bar-fill {
        height: 100%;
        background: #16a34a;
        border-radius: 10px;
        transition: 1s ease;
    }

    /* قسم السيارات */
    .section-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .cars-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    .car-card {
        background: white;
        border-radius: 1.5rem;
        border: 1px solid #f1f5f9;
        box-shadow: 0 10px 20px rgba(0,0,0,0.03);
        padding: 1.5rem;
        transition: 0.3s;
        display: flex;
        flex-direction: column;
    }

        .car-card:hover {
            border-color: var(--primary-gold);
            transform: translateY(-3px);
        }

    .car-header {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 1.5rem;
        border-bottom: 1px dashed #e2e8f0;
        padding-bottom: 1rem;
    }

    .car-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        background: rgba(184, 147, 90, 0.1);
        color: var(--primary-gold);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .car-name {
        font-weight: 900;
        color: var(--primary-navy);
        font-size: 1.2rem;
        margin-bottom: 4px;
    }

    .car-vin {
        color: var(--text-muted);
        font-family: monospace;
        font-weight: 800;
        font-size: 0.85rem;
    }

    .car-status-text {
        font-weight: 800;
        font-size: 0.9rem;
        color: var(--primary-gold);
        background: rgba(184, 147, 90, 0.1);
        padding: 5px 12px;
        border-radius: 8px;
        display: inline-block;
        margin-bottom: 1.5rem;
        align-self: flex-start;
    }

    .btn-track-car {
        background: var(--primary-navy);
        color: white;
        padding: 0.8rem;
        border-radius: 10px;
        text-align: center;
        font-weight: 800;
        text-decoration: none;
        transition: 0.3s;
        margin-top: auto;
    }

        .btn-track-car:hover {
            background: var(--primary-gold);
            color: white;
        }
</style>

<div class="welcome-banner">
    <div class="welcome-content">
        <h1>@Localizer["مرحباً بك،"] @Model.Name</h1>
        <p>@Localizer["بوابتك الذكية لمتابعة سياراتك ومدفوعاتك مع شركة الأرجان"]</p>
    </div>
    <a href="@Url.Action("PrintStatement", "Customers", new { id = Model.Id })" target="_blank" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.3); color: white; padding: 1rem 2rem; border-radius: 1rem; font-weight: 900; text-decoration: none; transition: 0.3s; z-index: 2;">
        <i class="fa-solid fa-print"></i> @Localizer["طباعة كشف الحساب"]
    </a>
</div>

<div class="finance-grid">
    <div class="finance-card" style="border-bottom: 5px solid var(--primary-navy);">
        <h3 class="finance-title">@Localizer["إجمالي المشتريات والخدمات"]</h3>
        <div class="finance-value" style="color: var(--primary-navy);">
            <small style="font-size: 1rem; margin-inline-end: 4px;">$</small>@totalRequired.ToString("N0")
        </div>
    </div>
    <div class="finance-card" style="border-bottom: 5px solid #16a34a;">
        <h3 class="finance-title">@Localizer["ما تم سداده"]</h3>
        <div class="finance-value" style="color: #16a34a;">
            <small style="font-size: 1rem; margin-inline-end: 4px;">$</small>@totalPaid.ToString("N0")
        </div>
        <div class="progress-bar-bg">
            <div class="progress-bar-fill" style="width: @((int)payPercentage)%;"></div>
        </div>
    </div>
    <div class="finance-card" style="border-bottom: 5px solid #ef4444;">
        <h3 class="finance-title">@Localizer["الرصيد المتبقي (المطلوب)"]</h3>
        <div class="finance-value" style="color: #ef4444;">
            <small style="font-size: 1rem; margin-inline-end: 4px;">$</small>@totalBalance.ToString("N0")
        </div>
    </div>
</div>

<h2 class="section-title"><i class="fa-solid fa-car-side"></i> @Localizer["سياراتي"]</h2>

<div class="cars-grid">
    @if (Model.Cars != null && Model.Cars.Any())
    {
        foreach (var car in Model.Cars.OrderByDescending(c => c.Id))
        {
            string statusLabel = car.StatusId == 1 ? "تم الشراء من المزاد" : car.StatusId == 2 ? "تم الدفع وتنتظر النقل" : car.StatusId == 3 ? "جاري النقل الداخلي" : car.StatusId == 4 ? "وصلت المستودع (تجميع)" : car.StatusId == 5 ? "قيد التحميل في الحاوية" : car.StatusId == 6 ? "أبحرت السفينة" : "وصلت الميناء";

            <div class="car-card">
                <div class="car-header">
                    <div class="car-icon"><i class="fa-solid fa-car"></i></div>
                    <div>
                        <div class="car-name">@car.Make @car.Model @car.Year</div>
                        <div class="car-vin">VIN: @car.VIN</div>
                    </div>
                </div>
                <div class="car-status-text">
                    <!-- 💡 تم تعديل هذا السطر ليتم ترجمة الحالة بشكل صحيح -->
                    <i class="fa-solid fa-location-dot"></i> @Localizer[statusLabel]
                </div>
                <a href="@Url.Action("TrackCar", "CustomerPortal", new { id = car.Id })" class="btn-track-car">
                    <i class="fa-solid fa-location-crosshairs"></i> @Localizer["تتبع حالة السيارة"]
                </a>
            </div>
        }
    }
    else
    {
        <div style="grid-column: 1 / -1; text-align: center; padding: 4rem; background: white; border-radius: 1.5rem; border: 2px dashed #e2e8f0; color: #94a3b8;">
            <i class="fa-solid fa-car-on" style="font-size: 3rem; margin-bottom: 1rem;"></i>
            <h3>@Localizer["لا توجد سيارات مسجلة في حسابك حالياً."]</h3>
        </div>
    }
</div>