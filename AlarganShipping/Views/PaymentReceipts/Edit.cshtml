@model AlarganShipping.Models.PaymentReceipt
@{
    ViewData["Title"] = Localizer["تعديل السداد / الدفع"];
}

<style>
    /* التنسيقات العصرية (نفس الـ Create) */
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-back {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        padding: 0.6rem 1.2rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: var(--primary-navy);
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(44, 62, 80, 0.03);
        border: 1px solid #f1f5f9;
        padding: 2.5rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 1.5rem;
    }

    .form-label {
        font-weight: 800;
        color: var(--primary-navy);
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .form-control {
        padding: 0.85rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 1rem;
        font-weight: 700;
        transition: 0.3s;
        outline: none;
        background: #f8fafc;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            background: white;
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

    .input-money {
        font-family: monospace;
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
    }

    /* محول العملات */
    .currency-switcher {
        display: flex;
        gap: 10px;
        background: #f1f5f9;
        padding: 6px;
        border-radius: 1rem;
        border: 1px solid #e2e8f0;
    }

    .currency-btn {
        flex: 1;
        text-align: center;
    }

        .currency-btn input {
            display: none;
        }

        .currency-btn label {
            display: block;
            padding: 10px;
            cursor: pointer;
            font-weight: 900;
            font-size: 1rem;
            border-radius: 0.75rem;
            transition: 0.3s;
            color: #64748b;
        }

        .currency-btn input:checked + label {
            background: var(--primary-navy);
            color: white;
            box-shadow: 0 4px 10px rgba(30, 41, 59, 0.2);
        }

    .conversion-alert {
        margin-top: 10px;
        padding: 15px;
        border-radius: 10px;
        font-weight: 800;
        display: none;
    }

        .conversion-alert.show {
            display: block;
            animation: fadeIn 0.3s;
        }

    .alert-green {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #16a34a;
    }

    .alert-blue {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1d4ed8;
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(-5px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .form-actions {
        margin-top: 2.5rem;
        text-align: left;
        border-top: 1px solid #f1f5f9;
        padding-top: 1.5rem;
    }

    .btn-submit {
        background: var(--primary-gold);
        color: white;
        border: none;
        padding: 1rem 3rem;
        border-radius: 0.75rem;
        font-weight: 900;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 4px 15px rgba(184, 147, 90, 0.2);
    }

        .btn-submit:hover {
            background: var(--secondary-gold);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(184, 147, 90, 0.3);
        }

    .select2-container--default .select2-selection--single {
        background-color: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        height: 48px;
        display: flex;
        align-items: center;
        transition: 0.3s;
    }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            font-weight: 700;
            color: var(--primary-navy);
            padding: 0 1rem;
        }

    .file-input-wrapper {
        display: flex;
        align-items: center;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        overflow: hidden;
        background: #f8fafc;
    }

    .btn-browse {
        background: #e2e8f0;
        color: var(--primary-navy);
        padding: 0.85rem 1.5rem;
        font-weight: 800;
        border: none;
        border-inline-end: 2px solid #cbd5e1;
        cursor: pointer;
    }

    .file-path-display {
        flex: 1;
        padding: 0.85rem 1rem;
        color: var(--text-muted);
        font-size: 0.9rem;
        background: transparent;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    input[type="file"] {
        display: none;
    }
</style>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet" />

<div class="form-page-header">
    <h2 class="form-page-title"><i class="fa-solid fa-pen-to-square" style="color: var(--primary-gold);"></i> @Localizer["تعديل السداد / الدفع"]</h2>
    <a href="@Url.Action("Index", "PaymentReceipts")" class="btn-back"><i class="fa-solid fa-xmark"></i> @Localizer["إلغاء والعودة"]</a>
</div>

<div class="premium-form-card">
    <div style="text-align: center; margin-bottom: 20px; font-family: monospace; font-size: 1.2rem; font-weight: bold; color: var(--primary-navy);">
        رقم السند: @Model.ReceiptNumber
    </div>

    <form asp-action="Edit" method="post" id="receiptEditForm" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ReceiptNumber" />
        <input type="hidden" asp-for="AttachmentPath" />

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="CustomerId" class="form-label">@Localizer["العميل"] *</label>
                <select asp-for="CustomerId" class="form-control select2" asp-items="ViewBag.CustomerId" required>
                    <option value="">-- @Localizer["اختر العميل"] --</option>
                </select>
            </div>

            <!-- الحقل الجديد: ربط الدفعة بالسيارة -->
            <div class="form-group">
                <label asp-for="CarId" class="form-label" style="color: var(--primary-gold);">@Localizer["ربط الدفعة بسيارة معينة (اختياري)"]</label>
                <select asp-for="CarId" id="CarId" class="form-control select2" asp-items="ViewBag.CustomerCars">
                    <option value="">-- @Localizer["سداد عام (أو اختر سيارة)"] --</option>
                </select>
            </div>

            <div class="form-group" style="grid-column: 1 / -1;">
                <label asp-for="PaymentDate" class="form-label">@Localizer["تاريخ وتوقيت الاستلام"] *</label>
                <input asp-for="PaymentDate" type="datetime-local" class="form-control" value="@Model.PaymentDate.ToString("yyyy-MM-ddTHH:mm")" required />
            </div>
        </div>

        <div style="border: 2px dashed #cbd5e1; padding: 2rem; border-radius: 1.2rem; background: #f8fafc; margin-bottom: 2rem;">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">@Localizer["عملة الدفع لتسوية الحساب"] *</label>
                    <div class="currency-switcher">
                        <div class="currency-btn">
                            <input type="radio" name="currency" id="currUSD" value="USD" checked>
                            <label for="currUSD"><i class="fa-solid fa-dollar-sign"></i> دولار أمريكي ($)</label>
                        </div>
                        <div class="currency-btn">
                            <input type="radio" name="currency" id="currOMR" value="OMR">
                            <label for="currOMR"><i class="fa-solid fa-money-bill-wave"></i> ريال عماني (OMR)</label>
                        </div>
                    </div>
                </div>

                <div class="form-group" id="exchangeRateGroup" style="display:none;">
                    <label class="form-label">@Localizer["سعر الصرف (1$ = ? OMR)"]</label>
                    <input type="number" name="exchangeRate" id="exchangeRate" value="0.386" step="0.001" class="form-control" style="border-color: var(--primary-gold);" />
                </div>
            </div>

            <div class="form-grid" style="grid-template-columns: 1fr 1fr;">
                <div class="form-group">
                    <label asp-for="Amount" class="form-label" style="font-size: 1.1rem;">@Localizer["المبلغ"] *</label>
                    <input asp-for="Amount" id="inpAmount" class="form-control input-money" type="number" step="0.01" value="@Model.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)" required />
                </div>
                <div class="form-group">
                    <label asp-for="Discount" class="form-label" style="font-size: 1.1rem;">@Localizer["خصم مسموح به (بالدولار)"]</label>
                    <input asp-for="Discount" id="inpDiscount" class="form-control input-money" type="number" step="0.01" style="color: var(--primary-gold);" value="@Model.Discount.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                </div>
            </div>

            <div id="conversionMsg" class="conversion-alert"></div>
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="PaymentMethod" class="form-label">@Localizer["طريقة الدفع"] *</label>
                <select asp-for="PaymentMethod" class="form-control select2" required>
                    <option value="نقداً">نقداً (Cash)</option>
                    <option value="تحويل بنكي">تحويل بنكي (Bank Transfer)</option>
                    <option value="شيك">شيك (Cheque)</option>
                    <option value="POS">نقاط البيع بطاقة (POS)</option>
                </select>
            </div>

            <div class="form-group">
                <label asp-for="ReferenceNumber" class="form-label">@Localizer["الرقم المرجعي"]</label>
                <input asp-for="ReferenceNumber" class="form-control" dir="ltr" />
            </div>

            <!-- الحقل المضاف: مسحوب على بنك -->
            <div class="form-group">
                <label asp-for="BankName" class="form-label">@Localizer["مسحوب على بنك (اختياري)"]</label>
                <input asp-for="BankName" class="form-control" placeholder="@Localizer["مثال: بنك مسقط، بنك ظفار..."]" />
            </div>

            <div class="form-group" style="grid-column: 1 / -1;">
                <label class="form-label">@Localizer["ملحقات (استبدال الملف الحالي)"]</label>
                <div class="file-input-wrapper">
                    <button type="button" class="btn-browse" onclick="document.getElementById('AttachmentFile').click()">
                        <i class="fa-solid fa-folder-open"></i> @Localizer["تصفح"]
                    </button>
                    <div class="file-path-display">
                        <span id="fileNameDisplay">@(string.IsNullOrEmpty(Model.AttachmentPath) ? "لم يتم اختيار ملف" : "يوجد ملف مرفق حالياً")</span>
                        @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                        {
                            <a href="@Model.AttachmentPath" target="_blank" style="color: var(--primary-gold);"><i class="fa-solid fa-download"></i> عرض الملف</a>
                        }
                    </div>
                    <input type="file" id="AttachmentFile" name="AttachmentFile" onchange="document.getElementById('fileNameDisplay').innerText = this.files[0].name" />
                </div>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Notes" class="form-label">@Localizer["مذكرة / ملاحظات"]</label>
            <textarea asp-for="Notes" class="form-control summernote" rows="3"></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit" id="btnSubmit">
                <i class="fa-solid fa-save"></i> @Localizer["حفظ التعديلات وتسوية الحساب"]
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>

    <script>
        $(document).ready(function() {
            $('.select2').select2({ dir: $('html').attr('dir') });
            $('.summernote').summernote({ height: 120, toolbar: [['style', ['bold', 'italic', 'clear']]] });

            // --- جلب سيارات العميل ديناميكياً (AJAX) إذا تم تغيير العميل ---
            $('#CustomerId').on('change', function() {
                var custId = $(this).val();
                var carSelect = $('#CarId');

                carSelect.empty();

                if(custId) {
                    carSelect.append('<option value="">-- @Html.Raw(Localizer["جاري جلب السيارات..."]) --</option>');

                    $.get('@Url.Action("GetCustomerCars", "PaymentReceipts")', { customerId: custId }, function(data) {
                        carSelect.empty();
                        carSelect.append('<option value="">-- @Html.Raw(Localizer["سداد عام (أو اختر سيارة)"]) --</option>');

                        data.forEach(function(car) {
                            carSelect.append(new Option(car.text, car.id, false, false));
                        });

                        carSelect.trigger('change');
                    });
                } else {
                    carSelect.append('<option value="">-- @Html.Raw(Localizer["يرجى اختيار العميل أولاً"]) --</option>');
                }
            });

            // دالة حساب التحويل الديناميكي للتعديل
            function calculateEquivalent() {
                var amount = parseFloat($('#inpAmount').val()) || 0;
                var currency = $('input[name="currency"]:checked').val();
                var exRate = parseFloat($('#exchangeRate').val()) || 0.386;
                var msgBox = $('#conversionMsg');

                if (amount <= 0) {
                    msgBox.removeClass('show');
                    return;
                }

                if (currency === 'OMR') {
                    $('#exchangeRateGroup').slideDown();
                    var usdValue = amount / exRate;
                    msgBox.removeClass('alert-blue').addClass('alert-green show');
                    msgBox.html('<i class="fa-solid fa-arrow-right-arrow-left"></i> @Html.Raw(Localizer["المبلغ المُدخل بالريال، سيتم خصم"]) <strong style="font-size:1.2rem; font-family:monospace;">$' + usdValue.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + '</strong> @Html.Raw(Localizer["كقيمة دولارية."])');
                } else {
                    $('#exchangeRateGroup').slideUp();
                    msgBox.removeClass('alert-green').addClass('alert-blue show');
                    msgBox.html('<i class="fa-solid fa-check-circle"></i> @Html.Raw(Localizer["الدفعة بالدولار، سيتم تعديل الحساب بالقيمة المدخلة كما هي."])');
                }
            }

            $('#inpAmount, #exchangeRate').on('input', calculateEquivalent);
            $('input[name="currency"]').on('change', calculateEquivalent);

            $('#receiptEditForm').on('submit', function(e) {
                e.preventDefault();
                var form = this;
                if (!form.checkValidity()) { form.reportValidity(); return; }

                var btn = $('#btnSubmit');
                var origText = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin"></i> جاري التحديث...').prop('disabled', true);

                var formData = new FormData(form);

                $.ajax({
                    url: $(form).attr('action'), type: $(form).attr('method'), data: formData,
                    processData: false, contentType: false,
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                title: "تم التحديث بنجاح!", text: "تم تعديل بيانات الدفعة وتسوية رصيد العميل مالياً.", icon: 'success', confirmButtonColor: 'var(--primary-gold)'
                            }).then(() => { window.location.href = '@Url.Action("Index", "PaymentReceipts")'; });
                        } else {
                            var errorMsg = response.errors ? response.errors.join('\n') : "تأكد من البيانات";
                            Swal.fire("خطأ!", errorMsg, 'error');
                            btn.html(origText).prop('disabled', false);
                        }
                    },
                    error: function () {
                        Swal.fire("خطأ!", "حدث خطأ أثناء الاتصال بالسيرفر.", 'error');
                        btn.html(origText).prop('disabled', false);
                    }
                });
            });
        });
    </script>
}