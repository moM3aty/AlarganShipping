@model AlarganShipping.Models.PaymentReceipt
@{
    ViewData["Title"] = Localizer["تعديل السداد / الدفع"];
}

<style>
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-back {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        padding: 0.6rem 1.2rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: var(--primary-navy);
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1rem;
        box-shadow: 0 10px 30px rgba(44, 62, 80, 0.03);
        border: 1px solid #f1f5f9;
        padding: 2rem;
    }

    .form-hint-text {
        text-align: center;
        color: var(--text-muted);
        font-size: 0.9rem;
        font-weight: 700;
        margin-bottom: 2rem;
    }

    /* تخطيط مطابق للصورة المرفقة */
    .row-top {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .gray-panel {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 1.5rem;
        border-radius: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .row-amounts {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 1rem;
    }

    .form-label {
        font-weight: 800;
        color: var(--primary-navy);
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
        text-align: end;
    }

    .form-control {
        padding: 0.75rem 1rem;
        border: 1px solid #cbd5e1;
        border-radius: 0.5rem;
        font-family: inherit;
        font-size: 1rem;
        font-weight: 700;
        transition: 0.3s;
        outline: none;
        text-align: end;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            box-shadow: 0 0 0 3px rgba(184, 147, 90, 0.1);
        }

        .form-control[readonly] {
            background-color: #e2e8f0;
            cursor: not-allowed;
            color: #64748b;
        }

    .file-input-wrapper {
        display: flex;
        align-items: center;
        border: 1px solid #cbd5e1;
        border-radius: 0.5rem;
        overflow: hidden;
    }

    .btn-browse {
        background: #e2e8f0;
        color: var(--primary-navy);
        padding: 0.75rem 1.5rem;
        font-weight: 800;
        border: none;
        border-inline-end: 1px solid #cbd5e1;
        cursor: pointer;
    }

    .file-path-display {
        flex: 1;
        padding: 0.75rem 1rem;
        color: var(--text-muted);
        font-size: 0.9rem;
        background: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    input[type="file"] {
        display: none;
    }

    /* أزرار الإجراءات */
    .form-actions {
        display: flex;
        justify-content: flex-start;
        margin-top: 2rem;
        border-top: 1px solid #f1f5f9;
        padding-top: 1.5rem;
    }

    .btn-submit {
        background: var(--primary-gold);
        color: white;
        border: none;
        padding: 0.85rem 2.5rem;
        border-radius: 0.5rem;
        font-weight: 900;
        font-size: 1rem;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-submit:hover {
            background: var(--secondary-gold);
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(184, 147, 90, 0.3);
        }

    /* Select2 Fix */
    .select2-container .select2-selection--single {
        height: 42px;
        border: 1px solid #cbd5e1;
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        font-weight: 700;
        color: var(--primary-navy);
    }

    @@media (max-width: 768px) {
        .row-top, .row-amounts {
            grid-template-columns: 1fr;
        }
    }
</style>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet" />

<div class="form-page-header">
    <h2 class="form-page-title"><i class="fa-solid fa-pen-to-square" style="color: var(--primary-gold);"></i> @Localizer["تعديل الدفع"]</h2>
    <a href="@Url.Action("Index", "PaymentReceipts")" class="btn-back"><i class="fa-solid fa-xmark"></i></a>
</div>

<div class="premium-form-card">
    <p class="form-hint-text">@Localizer["يرجى ملء المعلومات أدناه. تسميات الحقول التي تحمل علامة * هي حقول الإدخال."]</p>

    <!-- حقل مخفي لحفظ رقم السند والعميل القديم لتسوية الحسابات أثناء التعديل -->
    <div style="text-align: center; margin-bottom: 20px; font-family: monospace; font-size: 1.2rem; font-weight: bold; color: var(--primary-navy);">
        رقم السند: @Model.ReceiptNumber
    </div>

    <form asp-action="Edit" method="post" id="receiptEditForm" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ReceiptNumber" />
        <input type="hidden" asp-for="AttachmentPath" /> <!-- الحفاظ على مسار الملف القديم -->

        <div class="form-group" style="margin-bottom: 2rem;">
            <label asp-for="CustomerId" class="form-label" style="text-align: right;">@Localizer["العميل"] *</label>
            <select asp-for="CustomerId" class="form-control select2" asp-items="ViewBag.CustomerId" required>
                <option value="">-- @Localizer["اختر العميل"] --</option>
            </select>
        </div>

        <div class="row-top">
            <div class="form-group">
                <label asp-for="ReferenceNumber" class="form-label">@Localizer["الرقم المرجعي"]</label>
                <input asp-for="ReferenceNumber" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="PaymentDate" class="form-label">@Localizer["تاريخ"] *</label>
                <input asp-for="PaymentDate" type="datetime-local" class="form-control" value="@Model.PaymentDate.ToString("yyyy-MM-ddTHH:mm")" required />
            </div>
        </div>

        <div class="gray-panel">
            <div class="row-amounts">
                <div class="form-group">
                    <label class="form-label">@Localizer["المبلغ بعد الخصم"]</label>
                    <input type="text" id="netAmount" class="form-control" readonly value="@((Model.Amount - Model.Discount).ToString("0.000"))" />
                </div>
                <div class="form-group">
                    <label asp-for="Discount" class="form-label">@Localizer["خصم مسموح به"]</label>
                    <input asp-for="Discount" type="number" step="0.001" class="form-control calc-input" id="discountInput" />
                </div>
                <div class="form-group">
                    <label asp-for="Amount" class="form-label">@Localizer["مبلغ"] * (OMR)</label>
                    <input asp-for="Amount" type="number" step="0.001" class="form-control calc-input" id="amountInput" required />
                </div>
            </div>

            <div class="form-group" style="width: 30%; margin-inline-start: auto;">
                <label asp-for="PaymentMethod" class="form-label">@Localizer["الدفع بواسطة"] *</label>
                <select asp-for="PaymentMethod" class="form-control" required style="text-align: end;">
                    <option value="نقداً">نقداً</option>
                    <option value="تحويل بنكي">تحويل بنكي</option>
                    <option value="شيك">شيك</option>
                    <option value="POS">نقاط البيع (POS)</option>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">@Localizer["ملحقات (استبدال الملف الحالي)"]</label>
            <div class="file-input-wrapper">
                <button type="button" class="btn-browse" onclick="document.getElementById('AttachmentFile').click()">
                    <i class="fa-solid fa-folder-open"></i> @Localizer["تصفح"]
                </button>
                <div class="file-path-display">
                    <span id="fileNameDisplay">@(string.IsNullOrEmpty(Model.AttachmentPath) ? "لم يتم اختيار ملف" : "يوجد ملف مرفق حالياً")</span>
                    @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                    {
                        <a href="@Model.AttachmentPath" target="_blank" style="color: var(--primary-gold);"><i class="fa-solid fa-download"></i> عرض</a>
                    }
                </div>
                <input type="file" id="AttachmentFile" name="AttachmentFile" onchange="document.getElementById('fileNameDisplay').innerText = this.files[0].name" />
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Notes" class="form-label">@Localizer["مذكرة"]</label>
            <textarea asp-for="Notes" class="form-control summernote" rows="4"></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit" id="btnSubmit"><i class="fa-solid fa-save"></i> @Localizer["حفظ التعديلات"]</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>

    <script>
        $(document).ready(function() {
            $('.select2').select2({ dir: $('html').attr('dir') });

            $('.summernote').summernote({
                height: 150,
                toolbar: [
                    ['style', ['bold', 'italic', 'underline', 'clear']],
                    ['font', ['strikethrough', 'superscript']],
                    ['para', ['ul', 'ol', 'paragraph']],
                    ['insert', ['link']],
                    ['view', ['codeview']]
                ]
            });

            function calculateNet() {
                var amount = parseFloat($('#amountInput').val()) || 0;
                var discount = parseFloat($('#discountInput').val()) || 0;
                var net = amount - discount;
                $('#netAmount').val(net.toFixed(3));
            }

            $('.calc-input').on('input', calculateNet);
            calculateNet(); // تشغيل عند التحميل لضبط القيمة الافتراضية

            $('#receiptEditForm').on('submit', function(e) {
                e.preventDefault();
                var form = this;
                if (!form.checkValidity()) { form.reportValidity(); return; }

                var btn = $('#btnSubmit');
                var originalText = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin"></i>').prop('disabled', true);

                var formData = new FormData(form);

                $.ajax({
                    url: $(form).attr('action'), type: $(form).attr('method'), data: formData,
                    processData: false, contentType: false,
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                title: "تم التحديث بنجاح!", text: "تم تعديل بيانات الدفعة وتسوية رصيد العميل.", icon: 'success', confirmButtonColor: 'var(--primary-gold)'
                            }).then(() => { window.location.href = '@Url.Action("Index", "PaymentReceipts")'; });
                        } else {
                            var errorMsg = response.errors ? response.errors.join('\n') : "تأكد من البيانات";
                            Swal.fire("خطأ!", errorMsg, 'error');
                            btn.html(originalText).prop('disabled', false);
                        }
                    },
                    error: function () {
                        Swal.fire("خطأ!", "حدث خطأ أثناء الاتصال بالسيرفر.", 'error');
                        btn.html(originalText).prop('disabled', false);
                    }
                });
            });
        });
    </script>
}