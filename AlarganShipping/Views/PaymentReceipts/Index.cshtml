@model IEnumerable<AlarganShipping.Models.PaymentReceipt>
@{
    ViewData["Title"] = Localizer["سجل المقبوضات (المدفوعات)"];
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<style>
    /* --- الهيدر الرئيسي --- */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #ffffff;
        padding: 1.5rem;
        border-radius: 1.5rem;
        box-shadow: 0 5px 20px rgba(44, 62, 80, 0.03);
        margin-bottom: 2rem;
        border: 1px solid #f1f5f9;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .page-title i {
            color: var(--primary-gold);
        }

    .btn-add {
        background: linear-gradient(135deg, var(--primary-navy), var(--secondary-navy));
        color: #ffffff;
        font-weight: 800;
        padding: 0.85rem 1.75rem;
        border-radius: 1rem;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(44, 62, 80, 0.3);
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(44, 62, 80, 0.4);
            color: white;
            background: linear-gradient(135deg, var(--primary-gold), var(--secondary-gold));
        }

    /* --- بطاقة البيانات والجدول --- */
    .data-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
    }

    .table-enterprise {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }

        .table-enterprise th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            padding: 1.25rem 1rem;
            border-bottom: 2px solid #e2e8f0;
            text-align: start;
            white-space: nowrap;
        }

        .table-enterprise td {
            padding: 1.25rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-dark);
            font-weight: 700;
            vertical-align: middle;
        }

        .table-enterprise tbody tr:hover {
            background-color: #f8fafc;
            transition: 0.2s;
        }

    .rec-number {
        font-family: monospace;
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--primary-navy);
        background: rgba(44, 62, 80, 0.05);
        padding: 0.3rem 0.8rem;
        border-radius: 6px;
        white-space: nowrap;
    }

    .rec-amount {
        font-family: monospace;
        font-size: 1.1rem;
        font-weight: 900;
        color: #16a34a;
        background: rgba(22, 163, 74, 0.05);
        padding: 0.4rem 1rem;
        border-radius: 8px;
        border: 1px solid rgba(22, 163, 74, 0.1);
        white-space: nowrap;
    }

    .rec-discount {
        font-family: monospace;
        font-size: 0.9rem;
        font-weight: 800;
        color: var(--primary-gold);
    }

    .method-badge {
        background: white;
        color: var(--primary-navy);
        padding: 0.4rem 1rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        white-space: nowrap;
    }

        .method-badge i {
            color: var(--primary-gold);
        }

    /* --- أزرار الإجراءات الاحترافية --- */
    .actions-wrapper {
        display: flex;
        gap: 8px;
        justify-content: center;
    }

    .action-btn-pro {
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: 0.3s;
        text-decoration: none;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        cursor: pointer;
        font-size: 1.1rem;
    }

    .btn-print-pro {
        color: var(--primary-navy);
    }

        .btn-print-pro:hover {
            background: var(--primary-navy);
            color: white;
            border-color: var(--primary-navy);
            transform: scale(1.1);
        }

    .btn-edit-pro {
        color: var(--primary-gold);
    }

        .btn-edit-pro:hover {
            background: var(--primary-gold);
            color: white;
            border-color: var(--primary-gold);
            transform: scale(1.1);
        }

    .btn-delete-pro {
        color: #ef4444;
    }

        .btn-delete-pro:hover {
            background: #ef4444;
            color: white;
            border-color: #ef4444;
            transform: scale(1.1);
        }

    /* ========================================================
               تعديلات الموبايل (الميديا كويري)
               ======================================================== */
    @@media (max-width: 768px) {
        .page-header

    {
        flex-direction: column;
        align-items: stretch;
        text-align: center;
        padding: 1.5rem;
    }

    .page-title {
        justify-content: center;
    }

    .btn-add {
        width: 100%;
        justify-content: center;
    }

    .data-card {
        padding: 1rem;
        border-radius: 1.2rem;
    }

    }
</style>

<div class="receipts-index-page">
    @Html.AntiForgeryToken()

    <!-- الترويسة -->
    <div class="page-header">
        <h2 class="page-title"><i class="fa-solid fa-hand-holding-dollar"></i> @Localizer["سجل المقبوضات (المدفوعات)"]</h2>
        <a href="@Url.Action("Create", "PaymentReceipts")" class="btn-add"><i class="fa-solid fa-plus"></i> @Localizer["إصدار سند قبض جديد"]</a>
    </div>

    <!-- بطاقة الجدول -->
    <div class="data-card">
        <div style="overflow-x: auto; width: 100%;">
            <table id="receiptsDataTable" class="table-enterprise display" style="width:100%">
                <thead>
                    <tr>
                        <th>@Localizer["رقم السند"]</th>
                        <th>@Localizer["تاريخ الدفع"]</th>
                        <th>@Localizer["العميل المُسدد"]</th>
                        <th>@Localizer["طريقة الدفع"]</th>
                        <th>@Localizer["المبلغ المخصوم (الإجمالي)"]</th>
                        <th style="text-align: center;">@Localizer["إجراءات"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var rec in Model)
                        {
                            <tr>
                                <td>
                                    <span class="rec-number">@rec.ReceiptNumber</span>
                                    @if (!string.IsNullOrEmpty(rec.AttachmentPath))
                                    {
                                        <a href="@rec.AttachmentPath" target="_blank" style="margin-inline-start: 8px; color: var(--primary-navy);" title="عرض المرفق"><i class="fa-solid fa-paperclip"></i></a>
                                    }
                                </td>
                                <td style="color: var(--text-muted); font-weight: 800; white-space: nowrap;">
                                    @rec.PaymentDate.ToString("dd MMM yyyy - hh:mm tt")
                                </td>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 8px; font-weight: 900; color: var(--primary-navy);">
                                        <i class="fa-solid fa-user-check" style="color: #cbd5e1;"></i>
                                        <span style="white-space: nowrap;">@(rec.Customer?.Name ?? "-")</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="method-badge">
                                        <i class="fa-solid fa-money-bill-transfer"></i> @Localizer[rec.PaymentMethod]
                                    </span>
                                </td>
                                <td>
                                    <div style="display: flex; flex-direction: column; gap: 4px;">
                                        <span class="rec-amount">@rec.TotalDeducted.ToString("N3") OMR</span>
                                        @if (rec.Discount > 0)
                                        {
                                            <span class="rec-discount"><i class="fa-solid fa-tag"></i> يشتمل خصم: @rec.Discount.ToString("N3")</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="actions-wrapper">
                                        <a href="@Url.Action("Print", "PaymentReceipts", new { id = rec.Id })" class="action-btn-pro btn-print-pro" title="@Localizer["طباعة السند"]">
                                            <i class="fa-solid fa-print"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", "PaymentReceipts", new { id = rec.Id })" class="action-btn-pro btn-edit-pro" title="@Localizer["تعديل السند"]">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <button type="button" class="action-btn-pro btn-delete-pro" onclick="confirmDelete(@rec.Id)" title="@Localizer["حذف السند"]">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: "@Html.Raw(Localizer["هل أنت متأكد؟"])",
                text: "@Html.Raw(Localizer["عند حذف السند، سيتم التراجع عن خصم المبلغ من مديونية العميل (بما فيها الخصم المسجل)."])",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#ef4444",
                cancelButtonColor: "var(--primary-navy)",
                confirmButtonText: "@Html.Raw(Localizer["نعم، احذفه!"])",
                cancelButtonText: "@Html.Raw(Localizer["إلغاء"])"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "PaymentReceipts")',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    title: "@Html.Raw(Localizer["تم الحذف!"])",
                                    text: "@Html.Raw(Localizer["تم حذف السند وتحديث حساب العميل."])",
                                    icon: "success",
                                    timer: 2000,
                                    showConfirmButton: false,
                                    confirmButtonColor: "var(--primary-gold)"
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire("@Html.Raw(Localizer["خطأ!"])", response.message || "@Html.Raw(Localizer["حدث خطأ أثناء الحذف."])", "error");
                            }
                        },
                        error: function () {
                            Swal.fire("@Html.Raw(Localizer["خطأ!"])", "@Html.Raw(Localizer["لا يمكن الاتصال بالخادم."])", "error");
                        }
                    });
                }
            });
        }

        $(document).ready(function () {
            var dir = $('html').attr('dir') === 'rtl';
            $('#receiptsDataTable').DataTable({
                "language": { "url": dir ? "//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json" : "" },
                "pageLength": 10,
                "ordering": true,
                "order": [[ 1, "desc" ]], // ترتيب افتراضي من الأحدث للأقدم
                "responsive": true,
                "dom": '<"top"f>rt<"bottom"lp><"clear">'
            });
        });
    </script>
}