@model IEnumerable<AlarganShipping.Models.PaymentReceipt>
@{
    ViewData["Title"] = Localizer["سندات القبض"];
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #ffffff;
        padding: 1.5rem;
        border-radius: 1.5rem;
        box-shadow: 0 5px 20px rgba(44, 62, 80, 0.03);
        margin-bottom: 2rem;
        border: 1px solid #f1f5f9;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .page-title i {
            color: var(--primary-gold);
        }

    .btn-add {
        background: linear-gradient(to right, var(--primary-navy), var(--secondary-navy));
        color: #ffffff;
        font-weight: 800;
        padding: 0.85rem 1.75rem;
        border-radius: 1rem;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(44, 62, 80, 0.3);
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(44, 62, 80, 0.4);
            background: linear-gradient(to right, var(--primary-gold), var(--secondary-gold));
            color: white;
        }

    .data-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        overflow-x: auto;
    }

    .table-enterprise {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }

        .table-enterprise th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 800;
            padding: 1.25rem 1rem;
            border-bottom: 2px solid #e2e8f0;
            text-align: start;
            white-space: nowrap;
        }

        .table-enterprise td {
            padding: 1.25rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-dark);
            font-weight: 700;
            vertical-align: middle;
        }

        .table-enterprise tbody tr:hover {
            background-color: #f8fafc;
            transition: 0.2s;
        }

    .rec-number {
        font-family: monospace;
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--primary-navy);
        background: rgba(44, 62, 80, 0.05);
        padding: 0.3rem 0.8rem;
        border-radius: 6px;
    }

    .rec-amount {
        font-family: monospace;
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--primary-gold);
        background: rgba(184, 147, 90, 0.1);
        padding: 0.4rem 1rem;
        border-radius: 8px;
        border: 1px solid rgba(184, 147, 90, 0.2);
    }

    .method-badge {
        background: white;
        color: var(--primary-navy);
        padding: 0.4rem 1rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    }

        .method-badge i {
            color: var(--primary-gold);
        }

    /* أزرار الإجراءات */
    .actions-wrapper {
        display: flex;
        gap: 8px;
    }

    .action-btn-outline {
        color: var(--primary-gold);
        background: rgba(184, 147, 90, 0.05);
        border: 1px solid rgba(184, 147, 90, 0.2);
        padding: 0.6rem 1rem;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 800;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
    }

        .action-btn-outline:hover {
            background: var(--primary-gold);
            color: white;
        }

    .action-btn-danger {
        color: #ef4444;
        background: rgba(239, 68, 68, 0.05);
        border: 1px solid rgba(239, 68, 68, 0.2);
        padding: 0.6rem 1rem;
        border-radius: 10px;
        cursor: pointer;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
    }

        .action-btn-danger:hover {
            background: #ef4444;
            color: white;
        }
</style>

<div>
    @Html.AntiForgeryToken()
    <div class="page-header">
        <h2 class="page-title"><i class="fa-solid fa-hand-holding-dollar"></i> @Localizer["سجل المقبوضات (المدفوعات)"]</h2>
        <a href="@Url.Action("Create", "PaymentReceipts")" class="btn-add"><i class="fa-solid fa-plus"></i> @Localizer["إصدار سند قبض جديد"]</a>
    </div>

    <div class="data-card">
        <table id="receiptsDataTable" class="table-enterprise display" style="width:100%">
            <thead>
                <tr>
                    <th>@Localizer["رقم السند"]</th>
                    <th>@Localizer["تاريخ الدفع"]</th>
                    <th>@Localizer["العميل المُسدد"]</th>
                    <th>@Localizer["طريقة الدفع"]</th>
                    <th>@Localizer["المبلغ"]</th>
                    <th>@Localizer["إجراءات"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var rec in Model)
                    {
                        <tr>
                            <td><span class="rec-number">@rec.ReceiptNumber</span></td>
                            <td style="color: var(--text-muted); font-weight: 800;">@rec.PaymentDate.ToString("dd MMM yyyy - hh:mm tt")</td>
                            <td><i class="fa-solid fa-user-check" style="color: #cbd5e1; margin-inline-end: 8px;"></i> @(rec.Customer?.Name ?? "-")</td>
                            <td>
                                <span class="method-badge">
                                    <i class="fa-solid fa-money-bill-transfer"></i> @Localizer[rec.PaymentMethod]
                                </span>
                            </td>
                            <td><span class="rec-amount">$@rec.Amount</span></td>
                            <td>
                                <div class="actions-wrapper">
                                    <a href="@Url.Action("Edit", "PaymentReceipts", new { id = rec.Id })" class="action-btn-outline" title="@Localizer["تعديل السند"]">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <button type="button" class="action-btn-danger" onclick="confirmDelete(@rec.Id)" title="@Localizer["حذف السند"]">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: '@Html.Raw(Localizer["هل أنت متأكد؟"])',
                text: '@Html.Raw(Localizer["عند حذف السند، سيتم التراجع عن خصم المبلغ من مديونية العميل."])',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: 'var(--primary-navy)',
                confirmButtonText: '@Html.Raw(Localizer["نعم، احذفه!"])',
                cancelButtonText: '@Html.Raw(Localizer["إلغاء"])'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "PaymentReceipts")/' + id,
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    title: '@Html.Raw(Localizer["تم الحذف!"])',
                                    text: '@Html.Raw(Localizer["تم حذف السند وتحديث حساب العميل."])',
                                    icon: 'success',
                                    confirmButtonColor: 'var(--primary-gold)'
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('@Html.Raw(Localizer["خطأ!"])', response.message || '@Html.Raw(Localizer["حدث خطأ أثناء الحذف."])', 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('@Html.Raw(Localizer["خطأ!"])', '@Html.Raw(Localizer["لا يمكن الاتصال بالخادم."])', 'error');
                        }
                    });
                }
            });
        }

        $(document).ready(function () {
            var dir = $('html').attr('dir') === 'rtl';
            $('#receiptsDataTable').DataTable({
                "language": { "url": dir ? "//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json" : "" },
                "pageLength": 10,
                "ordering": true,
                "order": [[ 1, "desc" ]], // ترتيب من الأحدث للأقدم
                "responsive": true,
                "dom": '<"top"f>rt<"bottom"lp><"clear">'
            });
        });
    </script>
}