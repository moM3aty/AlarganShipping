@model AlarganShipping.Models.PaymentReceipt
@{
    ViewData["Title"] = Localizer["تسجيل دفعة جديدة"];
}

<style>
    /* التنسيقات العصرية للشاشة */
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-back {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        padding: 0.6rem 1.2rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: var(--primary-navy);
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(44, 62, 80, 0.03);
        border: 1px solid #f1f5f9;
        padding: 2.5rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 1.5rem;
    }

    .form-label {
        font-weight: 800;
        color: var(--primary-navy);
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .form-control {
        padding: 0.85rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 1rem;
        font-weight: 700;
        transition: 0.3s;
        outline: none;
        background: #f8fafc;
    }

        .form-control:focus {
            border-color: var(--primary-gold);
            background: white;
            box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
        }

    .input-money {
        font-family: monospace;
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-navy);
    }

    /* محول العملات */
    .currency-switcher {
        display: flex;
        gap: 10px;
        background: #f1f5f9;
        padding: 6px;
        border-radius: 1rem;
        border: 1px solid #e2e8f0;
    }

    .currency-btn {
        flex: 1;
        text-align: center;
    }

        .currency-btn input {
            display: none;
        }

        .currency-btn label {
            display: block;
            padding: 10px;
            cursor: pointer;
            font-weight: 900;
            font-size: 1rem;
            border-radius: 0.75rem;
            transition: 0.3s;
            color: #64748b;
        }

        .currency-btn input:checked + label {
            background: var(--primary-navy);
            color: white;
            box-shadow: 0 4px 10px rgba(30, 41, 59, 0.2);
        }

    .conversion-alert {
        margin-top: 10px;
        padding: 15px;
        border-radius: 10px;
        font-weight: 800;
        display: none;
    }

        .conversion-alert.show {
            display: block;
            animation: fadeIn 0.3s;
        }

    .alert-green {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #16a34a;
    }

    .alert-blue {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1d4ed8;
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(-5px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .form-actions {
        margin-top: 2.5rem;
        text-align: left;
        border-top: 1px solid #f1f5f9;
        padding-top: 1.5rem;
    }

    .btn-submit {
        background: var(--primary-navy);
        color: white;
        border: none;
        padding: 1rem 3rem;
        border-radius: 0.75rem;
        font-weight: 900;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 5px 15px rgba(30, 41, 59, 0.2);
    }

        .btn-submit:hover {
            background: var(--primary-gold);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(184, 147, 90, 0.3);
        }

    .select2-container--default .select2-selection--single {
        background-color: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        height: 48px;
        display: flex;
        align-items: center;
        transition: 0.3s;
    }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            font-weight: 700;
            color: var(--primary-navy);
            padding: 0 1rem;
        }

    .file-input-wrapper {
        display: flex;
        align-items: center;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        overflow: hidden;
        background: #f8fafc;
    }

    .btn-browse {
        background: #e2e8f0;
        color: var(--primary-navy);
        padding: 0.85rem 1.5rem;
        font-weight: 800;
        border: none;
        border-inline-end: 2px solid #cbd5e1;
        cursor: pointer;
    }

    .file-path-display {
        flex: 1;
        padding: 0.85rem 1rem;
        color: var(--text-muted);
        font-size: 0.9rem;
        background: transparent;
    }

    input[type="file"] {
        display: none;
    }
</style>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">

<div class="form-page-header">
    <h2 class="form-page-title"><i class="fa-solid fa-hand-holding-dollar" style="color: var(--primary-gold);"></i> @Localizer["تسجيل دفعة استلام"]</h2>
    <a href="javascript:history.back()" class="btn-back"><i class="fa-solid fa-arrow-right-long"></i> @Localizer["العودة"]</a>
</div>

<div class="premium-form-card">
    <form asp-action="Create" method="post" id="receiptForm" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="CustomerId" class="form-label">@Localizer["العميل (المُسدد)"] *</label>
                <select asp-for="CustomerId" class="form-control select2" asp-items="ViewBag.CustomerId" required>
                    <option value="">-- @Localizer["اختر العميل"] --</option>
                </select>
            </div>

            <div class="form-group">
                <label asp-for="PaymentDate" class="form-label">@Localizer["تاريخ وتوقيت الاستلام"] *</label>
                <input asp-for="PaymentDate" type="datetime-local" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
            </div>
        </div>

        <div style="border: 2px dashed #cbd5e1; padding: 2rem; border-radius: 1.2rem; background: #f8fafc; margin-bottom: 2rem;">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">@Localizer["عملة الدفع المستلمة"] *</label>
                    <div class="currency-switcher">
                        <div class="currency-btn">
                            <input type="radio" name="currency" id="currUSD" value="USD" checked>
                            <label for="currUSD"><i class="fa-solid fa-dollar-sign"></i> دولار أمريكي ($)</label>
                        </div>
                        <div class="currency-btn">
                            <input type="radio" name="currency" id="currOMR" value="OMR">
                            <label for="currOMR"><i class="fa-solid fa-money-bill-wave"></i> ريال عماني (OMR)</label>
                        </div>
                    </div>
                </div>

                <div class="form-group" id="exchangeRateGroup" style="display:none;">
                    <label class="form-label">@Localizer["سعر الصرف (1$ = ? OMR)"]</label>
                    <input type="number" name="exchangeRate" id="exchangeRate" value="0.386" step="0.001" class="form-control" style="border-color: var(--primary-gold);" />
                </div>
            </div>

            <div class="form-grid" style="grid-template-columns: 1fr 1fr;">
                <div class="form-group">
                    <label asp-for="Amount" class="form-label" style="font-size: 1.1rem;">@Localizer["المبلغ المستلم"] *</label>
                    <input asp-for="Amount" id="inpAmount" class="form-control input-money" type="number" step="0.01" required />
                </div>
                <div class="form-group">
                    <label asp-for="Discount" class="form-label" style="font-size: 1.1rem;">@Localizer["خصم مسموح به (بالدولار)"]</label>
                    <input asp-for="Discount" id="inpDiscount" class="form-control input-money" type="number" step="0.01" style="color: var(--primary-gold);" />
                </div>
            </div>

            <div id="conversionMsg" class="conversion-alert"></div>
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="PaymentMethod" class="form-label">@Localizer["طريقة الدفع"] *</label>
                <select asp-for="PaymentMethod" class="form-control select2" required>
                    <option value="نقداً">نقداً (Cash)</option>
                    <option value="تحويل بنكي">تحويل بنكي (Bank Transfer)</option>
                    <option value="شيك">شيك (Cheque)</option>
                    <option value="POS">نقاط البيع بطاقة (POS)</option>
                </select>
            </div>

            <div class="form-group">
                <label asp-for="ReferenceNumber" class="form-label">@Localizer["رقم المرجع (رقم التحويل/الشيك)"]</label>
                <input asp-for="ReferenceNumber" class="form-control" dir="ltr" placeholder="اختياري..." />
            </div>

            <div class="form-group" style="grid-column: 1 / -1;">
                <label class="form-label">@Localizer["ملحقات (إيصال البنك أو الشيك)"]</label>
                <div class="file-input-wrapper">
                    <button type="button" class="btn-browse" onclick="document.getElementById('AttachmentFile').click()">
                        <i class="fa-solid fa-folder-open"></i> @Localizer["تصفح"]
                    </button>
                    <div class="file-path-display" id="fileNameDisplay">@Localizer["لم يتم اختيار ملف..."]</div>
                    <input type="file" id="AttachmentFile" name="AttachmentFile" onchange="document.getElementById('fileNameDisplay').innerText = this.files[0].name" />
                </div>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Notes" class="form-label">@Localizer["وذلك عن (البيان / ملاحظات)"]</label>
            <textarea asp-for="Notes" class="form-control summernote" rows="3" placeholder="مثال: دفعة مقدمة لشراء سيارة كامري..."></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit" id="btnSubmit">
                <i class="fa-solid fa-print"></i> @Localizer["حفظ وإصدار السند"]
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>

    <script>
        $(document).ready(function() {
            $('.select2').select2({ dir: $('html').attr('dir') });
            $('.summernote').summernote({ height: 120, toolbar: [['style', ['bold', 'italic', 'clear']]] });

            // دالة حساب التحويل الديناميكي
            function calculateEquivalent() {
                var amount = parseFloat($('#inpAmount').val()) || 0;
                var currency = $('input[name="currency"]:checked').val();
                var exRate = parseFloat($('#exchangeRate').val()) || 0.386;
                var msgBox = $('#conversionMsg');

                if (amount <= 0) {
                    msgBox.removeClass('show');
                    return;
                }

                if (currency === 'OMR') {
                    $('#exchangeRateGroup').slideDown();
                    var usdValue = amount / exRate;
                    msgBox.removeClass('alert-blue').addClass('alert-green show');
                    msgBox.html('<i class="fa-solid fa-arrow-right-arrow-left"></i> @Html.Raw(Localizer["سيتم التحويل في النظام وخصم"]) <strong style="font-size:1.2rem; font-family:monospace;">$' + usdValue.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + '</strong> @Html.Raw(Localizer["من ديون العميل."])');
                } else {
                    $('#exchangeRateGroup').slideUp();
                    msgBox.removeClass('alert-green').addClass('alert-blue show');
                    msgBox.html('<i class="fa-solid fa-check-circle"></i> @Html.Raw(Localizer["الدفعة بالدولار. سيتم خصم المبلغ المدخل كما هو من ديون العميل."])');
                }
            }

            $('#inpAmount, #exchangeRate').on('input', calculateEquivalent);
            $('input[name="currency"]').on('change', calculateEquivalent);

            $('#receiptForm').on('submit', function(e) {
                e.preventDefault();
                var form = this;
                if (!form.checkValidity()) { form.reportValidity(); return; }

                var btn = $('#btnSubmit');
                var origText = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin"></i> جاري الإصدار...').prop('disabled', true);

                var formData = new FormData(form);

                $.ajax({
                    url: $(form).attr('action'), type: $(form).attr('method'), data: formData,
                    processData: false, contentType: false,
                    success: function(res) {
                        if (res.success) {
                            Swal.fire({ title: 'تم الإصدار!', text: 'تم تسجيل الدفعة وخصمها من العميل بنجاح.', icon: 'success', confirmButtonColor: 'var(--primary-gold)' })
                            .then(() => window.location.href = '@Url.Action("Index", "PaymentReceipts")');
                        } else {
                            Swal.fire('خطأ!', res.errors ? res.errors.join('\n') : 'تأكد من البيانات', 'error');
                            btn.html(origText).prop('disabled', false);
                        }
                    }
                });
            });
        });
    </script>
}