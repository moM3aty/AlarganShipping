<!-- مسار الملف في المشروع: Views/PaymentReceipts/Create.cshtml -->
@model AlarganShipping.Models.PaymentReceipt
@{
    ViewData["Title"] = Localizer["إصدار سند قبض"];
}

<style>
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.75rem;
        font-weight: 900;
        color: var(--primary-navy);
        margin: 0;
    }

    .btn-back {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: var(--primary-navy);
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        padding: 3rem;
        position: relative;
        overflow: hidden;
    }

        .premium-form-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            left: 0;
            height: 6px;
            background: linear-gradient(to right, #16a34a, #22c55e);
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media (min-width: 768px) {
        .form-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-group-full {
        grid-column: 1 / -1;
    }

    .form-label {
        font-weight: 800;
        color: var(--primary-navy);
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-control {
        padding: 1rem 1.25rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: inherit;
        font-size: 1rem;
        color: var(--text-dark);
        background-color: #f8fafc;
        transition: 0.3s;
        outline: none;
    }

        .form-control:focus {
            border-color: #16a34a;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(22, 163, 74, 0.1);
        }

    /* Select2 Custom Premium Styling */
    .select2-container--default .select2-selection--single {
        background-color: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        height: 50px;
        display: flex;
        align-items: center;
        transition: 0.3s;
    }

        .select2-container--default .select2-selection--single:focus, .select2-container--focus .select2-selection--single {
            border-color: #16a34a;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(22, 163, 74, 0.1);
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            color: var(--text-dark);
            font-weight: 600;
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 48px;
            right: 10px;
        }

    html[dir="rtl"] .select2-container--default .select2-selection--single .select2-selection__arrow {
        left: 10px;
        right: auto;
    }


    .form-actions {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
    }

    .btn-submit {
        background: linear-gradient(to right, #16a34a, #22c55e);
        color: #ffffff;
        border: none;
        padding: 1rem 3rem;
        border-radius: 1rem;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 4px 15px rgba(22, 163, 74, 0.3);
        font-family: inherit;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(22, 163, 74, 0.4);
        }

    .text-danger {
        color: #ef4444;
        font-size: 0.85rem;
        font-weight: 700;
        margin-top: 0.4rem;
    }
</style>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css" rel="stylesheet">

<div>
    <div class="form-page-header">
        <h2 class="form-page-title"><i class="fa-solid fa-hand-holding-dollar" style="color: #16a34a; margin-inline-end: 10px;"></i> @Localizer["إصدار سند قبض (تسجيل دفعة)"]</h2>
        <a href="@Url.Action("Index", "PaymentReceipts")" class="btn-back">@Localizer["عودة للقائمة"]</a>
    </div>

    <div class="premium-form-card">
        <form asp-action="Create" method="post" id="receiptForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="CustomerId" class="form-label">@Localizer["العميل المُسدد"]</label>
                    <select asp-for="CustomerId" class="form-control select2-search" asp-items="ViewBag.CustomerId" required>
                        <option value="">-- @Localizer["ابحث عن العميل"] --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="Amount" class="form-label">@Localizer["المبلغ المدفوع"] ($)</label>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" style="color: #16a34a; font-weight: 900; font-size: 1.15rem;" placeholder="0.00" dir="ltr" required />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PaymentMethod" class="form-label">@Localizer["طريقة الدفع"]</label>
                    <select asp-for="PaymentMethod" class="form-control" required>
                        <option value="Cash">@Localizer["كاش (نقدي)"]</option>
                        <option value="Bank Transfer">@Localizer["تحويل بنكي"]</option>
                        <option value="Cheque">@Localizer["شيك مصدق"]</option>
                        <option value="Online Portal">@Localizer["بوابة إلكترونية"]</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="ReferenceNumber" class="form-label">@Localizer["الرقم المرجعي / رقم الشيك"]</label>
                    <input asp-for="ReferenceNumber" class="form-control" placeholder="@Localizer["رقم الحوالة البنكية أو الشيك إن وجد"]" />
                </div>

                <div class="form-group form-group-full">
                    <label asp-for="Notes" class="form-label">@Localizer["ملاحظات إضافية"]</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="@Localizer["أي تفاصيل تخص الدفعة..."]"></textarea>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit" id="btnSubmit">
                    <i class="fa-solid fa-receipt"></i> @Localizer["حفظ وإصدار السند"]
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>

    <script>
        $(document).ready(function() {
            var dir = $('html').attr('dir');
            $('.select2-search').select2({ dir: dir, width: '100%' });

            $('#receiptForm').on('submit', function(e) {
                e.preventDefault();
                var form = $(this);
                if (!form[0].checkValidity()) { form[0].reportValidity(); return; }

                var btn = $('#btnSubmit');
                var originalText = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin"></i> @Localizer["جاري الإصدار..."]').prop('disabled', true);

                $.ajax({
                    url: form.attr('action'), type: form.attr('method'), data: form.serialize(),
                    success: function () {
                        Swal.fire({
                            title: '@Localizer["تم إصدار السند بنجاح!"]',
                            icon: 'success',
                            confirmButtonColor: 'var(--primary-gold)',
                            confirmButtonText: '@Localizer["العودة لقائمة السندات"]',
                            showCancelButton: true,
                            cancelButtonText: '@Localizer["إصدار سند آخر"]',
                            cancelButtonColor: 'var(--primary-navy)'
                        }).then((result) => {
                            if (result.isConfirmed) { window.location.href = '@Url.Action("Index", "PaymentReceipts")'; }
                            else { form[0].reset(); $('.select2-search').val(null).trigger('change'); btn.html(originalText).prop('disabled', false); }
                        });
                    },
                    error: function () {
                        Swal.fire({ title: '@Localizer["خطأ!"]', text: '@Localizer["حدث خطأ أثناء الحفظ."]', icon: 'error', confirmButtonColor: 'var(--primary-navy)' });
                        btn.html(originalText).prop('disabled', false);
                    }
                });
            });
        });
    </script>
}