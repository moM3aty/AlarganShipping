@model AlarganShipping.Models.PaymentReceipt
@{
    ViewData["Title"] = "إصدار سند قبض";
}

<style>
    /* Premium Form CSS specific to Payments */
    .form-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .form-page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: #2b3f56;
        margin: 0;
    }

    .btn-back {
        background-color: #f1f5f9;
        color: #475569;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .btn-back:hover {
            background-color: #e2e8f0;
            color: #1e293b;
        }

    .premium-form-card {
        background-color: #ffffff;
        border-radius: 1.25rem;
        box-shadow: 0 10px 30px rgba(43, 63, 86, 0.05);
        border: 1px solid #f8fafc;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
    }

        .premium-form-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(to left, #16a34a, #22c55e);
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @@media (min-width: 768px) {
        .form-grid

    {
        grid-template-columns: repeat(2, 1fr);
    }

    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-group-full {
        grid-column: 1 / -1;
    }

    .form-label {
        font-weight: 700;
        color: #2b3f56;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-control {
        padding: 0.85rem 1.25rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-family: 'Cairo', sans-serif;
        font-size: 1rem;
        color: #1e293b;
        background-color: #f8fafc;
        transition: all 0.3s ease;
        outline: none;
    }

        .form-control:focus {
            border-color: #16a34a;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(22, 163, 74, 0.1);
        }

    .form-actions {
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
    }

    .btn-submit {
        background: linear-gradient(to right, #16a34a, #22c55e);
        color: #ffffff;
        border: none;
        padding: 0.85rem 2.5rem;
        border-radius: 0.75rem;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        font-family: 'Cairo', sans-serif;
        box-shadow: 0 4px 15px rgba(22, 163, 74, 0.3);
        transition: all 0.3s ease;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(22, 163, 74, 0.4);
        }

    .text-danger {
        color: #dc2626;
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 0.25rem;
    }
</style>

<div>
    <div class="form-page-header">
        <h2 class="form-page-title">إصدار سند قبض (تسجيل دفعة)</h2>
        <a href="@Url.Action("Index", "PaymentReceipts")" class="btn-back">عودة للقائمة</a>
    </div>

    <div class="premium-form-card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="CustomerId" class="form-label">العميل المُسدد</label>
                    <select asp-for="CustomerId" class="form-control" asp-items="ViewBag.CustomerId">
                        <option value="">-- اختر العميل --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="Amount" class="form-label">المبلغ المدفوع ($)</label>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" style="color: #16a34a; font-weight: bold; font-size: 1.1rem;" placeholder="0.00" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PaymentMethod" class="form-label">طريقة الدفع</label>
                    <select asp-for="PaymentMethod" class="form-control">
                        <option value="كاش">كاش (نقدي)</option>
                        <option value="تحويل بنكي">تحويل بنكي</option>
                        <option value="شيك">شيك مصدق</option>
                        <option value="بوابة إلكترونية">بوابة إلكترونية</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="ReferenceNumber" class="form-label">الرقم المرجعي / رقم الشيك</label>
                    <input asp-for="ReferenceNumber" class="form-control" placeholder="رقم الحوالة البنكية أو الشيك إن وجد" />
                </div>

                <div class="form-group form-group-full">
                    <label asp-for="Notes" class="form-label">ملاحظات إضافية</label>
                    <textarea asp-for="Notes" class="form-control" rows="2" placeholder="أي تفاصيل تخص الدفعة..."></textarea>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">حفظ وإصدار السند</button>
            </div>
        </form>
    </div>
</div>