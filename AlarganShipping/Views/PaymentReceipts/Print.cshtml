@model AlarganShipping.Models.PaymentReceipt
@{
    ViewData["Title"] = "طباعة سند قبض";
    Layout = null; 
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>سند قبض - @Model.ReceiptNumber</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <style>
        :root { --brand-red: #a81c2f; --text-dark: #1e293b; }
        body { font-family: 'Cairo', sans-serif; background-color: #e2e8f0; margin: 0; padding: 20px; display: flex; flex-direction: column; align-items: center; }
        
        .controls { display: flex; gap: 10px; margin-bottom: 20px; width: 100%; max-width: 800px; justify-content: flex-end; direction: ltr; }
        .btn-action { background: white; color: var(--text-dark); border: 1px solid #cbd5e1; padding: 8px 15px; border-radius: 5px; cursor: pointer; font-weight: 700; display: flex; align-items: center; gap: 5px; text-decoration: none; }

        .receipt-card { background: white; width: 100%; max-width: 800px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); position: relative; box-sizing: border-box; display: flex; flex-direction: column; }
        .top-bar { height: 25px; background-color: var(--brand-red); width: 100%; }
        
        .header-section { display: flex; justify-content: space-between; align-items: center; padding: 20px 40px; }
        .company-name-en { font-size: 1.2rem; font-weight: 700; color: var(--text-dark); flex: 1; text-align: left; }
        .logo-area { flex: 1; text-align: center; }
        .logo-area img { height: 90px; object-fit: contain; }
        .company-name-ar { font-size: 1.4rem; font-weight: 900; color: var(--text-dark); flex: 1; text-align: right; }

        .title-section { display: flex; justify-content: space-between; align-items: center; padding: 0 40px; margin-bottom: 40px; }
        .receipt-no { color: var(--brand-red); font-weight: 900; font-size: 1.1rem; flex: 1; text-align: left; }
        .receipt-title { flex: 1; text-align: center; }
        .receipt-title h2 { margin: 0; color: var(--brand-red); font-size: 1.6rem; font-weight: 900; }
        .receipt-title p { margin: 0; font-weight: 700; color: var(--text-dark); font-size: 1.1rem; }
        .receipt-date { flex: 1; text-align: right; font-weight: 700; font-size: 1.1rem; color: var(--text-dark); }

        .body-section { padding: 0 40px; flex-grow: 1; }
        .form-row { display: flex; align-items: flex-end; margin-bottom: 25px; }
        .label-ar { font-weight: 800; color: var(--text-dark); font-size: 1.1rem; white-space: nowrap; }
        .label-en { font-weight: 700; color: var(--text-dark); font-size: 1.05rem; white-space: nowrap; }
        .dotted-value { flex-grow: 1; border-bottom: 2px dotted #64748b; margin: 0 15px; text-align: center; font-weight: 800; font-size: 1.1rem; color: var(--text-dark); padding-bottom: 2px; }

        .signatures-section { display: flex; justify-content: space-between; padding: 20px 40px 40px; margin-top: 20px; }
        .sig-block { display: flex; align-items: flex-end; width: 45%; }
        .bottom-bar { background-color: var(--brand-red); padding: 12px 40px; display: flex; justify-content: flex-start; align-items: center; gap: 15px; direction: ltr; }
        .contact-icon { width: 28px; height: 28px; border: 1.5px solid white; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 0.9rem; }

        /* ========================================================
           كود الطباعة الموحد (One Page Magic)
           ======================================================== */
        @@media print {
            @@page { size: A4 landscape; margin: 5mm; }
            body, html { background: white !important; padding: 0 !important; margin: 0 !important; width: 100% !important; height: 100vh !important; overflow: hidden !important; }
            .controls { display: none !important; }
            .receipt-card { 
                box-shadow: none !important; margin: 0 !important; padding: 0 !important; 
                width: 100% !important; max-width: 100% !important; border: none !important;
                transform: scale(0.95); transform-origin: top center;
            }
            * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important; }
            .top-bar, .bottom-bar { background-color: var(--brand-red) !important; color: white !important; }
            .receipt-no, .receipt-title h2 { color: var(--brand-red) !important; }
            img { display: inline-block !important; visibility: visible !important; }
        }
    </style>
</head>
<body>

    <div class="controls">
        <button class="btn-action" onclick="window.print()"><i class="fa-solid fa-print"></i> طباعة</button>
        <a href="@Url.Action("Index", "PaymentReceipts")" class="btn-action" style="margin-right: auto; color: #ef4444;"><i class="fa-solid fa-xmark"></i> إغلاق</a>
    </div>

    <div class="receipt-card" id="receiptContent">
        <div class="top-bar"></div>
        <div class="header-section">
            <div class="company-name-en" dir="ltr">Arjan Projects Company</div>
            <div class="logo-area">
                <img src="/images/logo.jpg" alt="Alargan Logo" onerror="this.src='/images/logo.png'; this.onerror=null;" />
            </div>
            <div class="company-name-ar">شركة مشاريع الارجان</div>
        </div>

        <div class="title-section">
            <div class="receipt-no" dir="ltr">No: @Model.ReceiptNumber</div>
            <div class="receipt-title"><h2>سند قبض</h2><p>Cash Receipt</p></div>
            <div class="receipt-date" dir="ltr">@Model.PaymentDate.ToString("HH:mm dd/MM/yyyy") التاريخ</div>
        </div>

        <div class="body-section">
            <div class="form-row">
                <div class="label-ar">أستلمت من السيد</div>
                <div class="dotted-value">@Model.Customer?.Name</div>
                <div class="label-en" dir="ltr">Received from Mr</div>
            </div>
            <div class="form-row">
                <div class="label-ar">مبلغ قدره</div>
                <div class="dotted-value" dir="ltr">
                    ( $@Model.Amount.ToString("N2") ) <span style="font-size: 0.95rem; margin-right: 10px;">فقط لا غير</span>
                </div>
                <div class="label-en" dir="ltr">Amount</div>
            </div>
            <div class="form-row">
                <div class="label-ar">وذلك مقابل</div>
                <div class="dotted-value">@Html.Raw(Model.Notes)</div>
                <div class="label-en" dir="ltr">Being</div>
            </div>
            <div class="form-row">
                <div class="label-ar">نقدا / شيك رقم</div>
                <div class="dotted-value">@Model.PaymentMethod - @(Model.ReferenceNumber ?? "...................")</div>
                <div class="label-en" dir="ltr">Cash / Check number</div>
            </div>
            <div class="form-row">
                <div class="label-ar">على بنك</div>
                <div class="dotted-value">....................................................................</div>
                <div class="label-en" dir="ltr">On a Bank</div>
            </div>
        </div>

        <div class="signatures-section">
            <div class="sig-block"><div class="label-ar">المستلم</div><div class="dotted-value" style="margin: 0 10px;"></div><div class="label-en" dir="ltr">Received by</div></div>
            <div class="sig-block"><div class="label-ar">المحاسب</div><div class="dotted-value" style="margin: 0 10px;"></div><div class="label-en" dir="ltr">Accountant</div></div>
        </div>

        <div class="bottom-bar">
            <div class="contact-icon"><i class="fa-solid fa-location-dot"></i></div>
            <div class="contact-icon"><i class="fa-solid fa-phone"></i></div>
            <div class="contact-icon"><i class="fa-regular fa-envelope"></i></div>
        </div>
    </div>

    <script>
        function downloadPDF() {
            var element = document.getElementById('receiptContent');
            html2pdf().set({
                margin: 5, filename: 'Receipt_@Model.ReceiptNumber .pdf',
                image: { type: 'jpeg', quality: 1 },
                html2canvas: { scale: 2, useCORS: true, windowWidth: 900 },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' }
            }).from(element).save();
        }
    </script>
</body>
</html>