<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - الأرجان للشحن</title>

    <!-- رابط FontAwesome الموثوق -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <!-- خط القاهرة -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-dark: #1a2634;
            --navy-med: #2b3f56;
            --gold: #be955b;
            --bg-body: #f9f8f4;
            --sidebar-width: 280px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--bg-body);
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* --- القائمة الجانبية --- */
        .sidebar {
            width: var(--sidebar-width);
            background: #fff;
            border-left: 1px solid #eee;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0,0,0,0.02);
        }

        .sidebar-header {
            padding: 2rem;
            text-align: center;
            border-bottom: 1px solid #f5f5f5;
        }

        .logo-placeholder {
            width: 60px;
            height: 60px;
            background: var(--navy-dark);
            border-radius: 15px;
            margin: 0 auto 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 20px rgba(26,38,52,0.2);
        }

            .logo-placeholder i {
                color: #fff;
                font-size: 1.5rem;
            }

        .nav-menu {
            flex: 1;
            padding: 1.5rem;
            overflow-y: auto;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            color: #444;
            font-weight: 700;
            text-decoration: none;
            margin-bottom: 8px;
            transition: 0.3s;
        }

            .nav-item:hover {
                background: #f0f7ff;
                color: var(--navy-dark);
            }

            .nav-item i {
                width: 25px;
                text-align: center;
                font-size: 1.1rem;
                color: #999;
            }

            .nav-item:hover i {
                color: var(--gold);
            }

            /* الحالة النشطة للرابط */
            .nav-item.active {
                background: var(--navy-dark);
                color: #fff;
            }

                .nav-item.active i {
                    color: var(--gold);
                }

        /* --- المنطقة الرئيسية --- */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0; /* لمنع تمدد المحتوى */
        }

        .top-header {
            height: 70px;
            background: #fff;
            border-bottom: 1px solid #eee;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
        }

        .page-body {
            flex: 1;
            padding: 2rem;
            overflow-y: auto;
        }

        .btn-logout {
            color: #e11d48;
            font-weight: 800;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* تحسينات العرض الصغير */
        @@media (max-width: 768px) {
            .sidebar

        {
            display: none;
        }
        /* يمكن إضافة Toggle Menu لاحقاً */
        }
    </style>
</head>
<body>

    @if (User.Identity.IsAuthenticated)
    {
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo-placeholder">
                    <i class="fa-solid fa-anchor"></i>
                </div>
                <h2 style="font-size: 1.1rem; font-weight: 900; color: var(--navy-dark);">الأرجان للشحن</h2>
                <span style="font-size: 0.7rem; color: var(--gold); font-weight: 800; letter-spacing: 1px;">AUTO SHIPPING</span>
            </div>

            <nav class="nav-menu">
                <a href="@Url.Action("Index", "Home")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="fa-solid fa-chart-line"></i> لوحة التحكم
                </a>
                <a href="@Url.Action("Index", "Cars")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Cars" ? "active" : "")">
                    <i class="fa-solid fa-car"></i> إدارة السيارات
                </a>
                <a href="@Url.Action("Index", "Customers")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Customers" ? "active" : "")">
                    <i class="fa-solid fa-users"></i> العملاء
                </a>
                <a href="@Url.Action("Index", "Invoices")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Invoices" ? "active" : "")">
                    <i class="fa-solid fa-file-invoice-dollar"></i> الحسابات
                </a>
                <a href="@Url.Action("Index", "Tracking")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Tracking" ? "active" : "")">
                    <i class="fa-solid fa-location-dot"></i> التتبع
                </a>
                <a href="@Url.Action("Index", "Contact")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Contact" ? "active" : "")">
                    <i class="fa-solid fa-headset"></i> اتصل بنا
                </a>
            </nav>

            <div style="padding: 1.5rem; border-top: 1px solid #f5f5f5;">
                <a href="@Url.Action("Logout", "Account")" class="btn-logout">
                    <i class="fa-solid fa-right-from-bracket"></i> تسجيل الخروج
                </a>
            </div>
        </aside>

        <main class="main-content">
            <header class="top-header">
                <div style="font-weight: 800; color: #666;">
                    <i class="fa-regular fa-calendar-days" style="margin-left: 5px;"></i>
                    @DateTime.Now.ToString("dd MMMM yyyy")
                </div>
                <div style="display: flex; align-items: center; gap: 15px;">
                    <span style="font-weight: 800; color: var(--navy-dark);">@User.Identity.Name</span>
                    <div style="width: 35px; height: 35px; border-radius: 8px; background: var(--gold); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 900;">A</div>
                </div>
            </header>

            <div class="page-body">
                @RenderBody()
            </div>
        </main>
    }
    else
    {
        @RenderBody()
    }

    <!-- إصلاح بسيط: التأكد من ظهور المحتوى في حالة وجود خطأ JavaScript -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            console.log("النظام جاهز والواجهة محملة.");
        });
    </script>
</body>
</html>