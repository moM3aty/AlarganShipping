@using AlarganShipping.Models
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject ApplicationDbContext DbContext
@{
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var htmlDir = isRtl ? "rtl" : "ltr";

    var userEmail = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Email)?.Value;
    var userRole = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;
    var userIdString = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.NameIdentifier)?.Value;

    User currentUser = null;
    Customer currentCustomer = null;

    if (userRole == "Customer" && int.TryParse(userIdString, out int cid))
    {
        currentCustomer = DbContext.Customers.FirstOrDefault(c => c.Id == cid);
    }
    else if (!string.IsNullOrEmpty(userEmail))
    {
        currentUser = DbContext.Users.FirstOrDefault(u => u.Email == userEmail);
    }
    bool isAdmin = currentUser?.Role == "Admin";
    bool isCustomer = userRole == "Customer";
}
<!DOCTYPE html>
<html lang="@currentCulture" dir="@htmlDir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Localizer["الأرجان للشحن"]</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css" />
    <link href="~/images/logo.jpg" rel="icon" type="image/jpeg" />

    <style>
        :root {
            --primary-navy: #1e293b;
            --secondary-navy: #0f172a;
            --primary-gold: #b45309;
            --secondary-gold: #92400e;
            --bg-body: #f8fafc;
            --text-dark: #334155;
            --text-muted: #64748b;
            --sidebar-width: 280px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-dark);
        }

            /* --- إصلاح تخطيط العرض (Layout Fix) --- */
            body.admin-layout {
                display: flex;
                height: 100vh;
                overflow: hidden;
            }

            body.public-layout {
                display: flex;
                flex-direction: column;
                min-height: 100vh;
                overflow-y: auto;
                overflow-x: hidden;
            }

        /* --- Sidebar & Overlay --- */
        .sidebar-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.7);
            z-index: 999;
            opacity: 0;
            visibility: hidden;
            transition: 0.3s ease;
            backdrop-filter: blur(4px);
        }

            .sidebar-overlay.show {
                opacity: 1;
                visibility: visible;
            }

        .sidebar {
            width: var(--sidebar-width);
            background: #ffffff;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            border-inline-end: 1px solid #e2e8f0;
            transition: transform 0.3s ease;
            position: relative;
            flex-shrink: 0;
        }

        .sidebar-header {
            padding: 2rem 1.5rem 1rem;
            text-align: center;
        }

        .logo-placeholder {
            width: 90px;
            height: 90px;
            background: white;
            border-radius: 50%;
            margin: 0 auto 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 20px rgba(180, 83, 9, 0.15);
            border: 3px solid var(--primary-gold);
            overflow: hidden;
        }

            .logo-placeholder img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .brand-name {
            font-size: 1.4rem;
            font-weight: 900;
            color: var(--primary-navy);
            margin: 0 0 0.2rem 0;
        }

        .brand-sub {
            font-size: 0.75rem;
            color: var(--primary-gold);
            font-weight: 800;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .nav-menu {
            flex: 1;
            padding: 1rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

            .nav-menu::-webkit-scrollbar {
                width: 5px;
            }

            .nav-menu::-webkit-scrollbar-thumb {
                background-color: #cbd5e1;
                border-radius: 10px;
            }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0.8rem 1rem;
            border-radius: 10px;
            color: var(--text-muted);
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
            font-size: 0.95rem;
        }

            .nav-item:hover {
                background: #f1f5f9;
                color: var(--primary-navy);
            }

            .nav-item i {
                width: 20px;
                text-align: center;
                font-size: 1.1rem;
                color: #94a3b8;
                transition: 0.3s;
            }

            .nav-item:hover i {
                color: var(--primary-gold);
            }

            .nav-item.active {
                background: var(--primary-navy);
                color: white;
                box-shadow: 0 4px 10px rgba(30, 41, 59, 0.2);
            }

                .nav-item.active i {
                    color: var(--primary-gold);
                }

        .user-profile-bottom {
            margin: 1rem;
            padding: 1rem;
            background: #f8fafc;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border: 1px solid #e2e8f0;
        }

        .user-info {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 900;
            color: var(--primary-navy);
            font-size: 0.9rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 130px;
        }

        .user-role {
            font-weight: 800;
            color: var(--primary-gold);
            font-size: 0.7rem;
            text-transform: uppercase;
        }

        .user-avatar {
            width: 35px;
            height: 35px;
            border-radius: 8px;
            background: var(--primary-navy);
            color: var(--primary-gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            font-size: 1rem;
        }

        /* --- Main Content Area --- */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
            background: var(--bg-body);
            height: 100vh;
        }

        .top-header {
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            background: transparent;
            margin-top: 0.5rem;
            flex-shrink: 0;
        }

        .mobile-toggle-btn {
            display: none;
            background: white;
            border: 1px solid #e2e8f0;
            color: var(--primary-navy);
            font-size: 1.2rem;
            padding: 8px 12px;
            border-radius: 10px;
            cursor: pointer;
            transition: 0.3s;
        }

        .header-left, .header-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .lang-btn {
            background: white;
            border: 1px solid #e2e8f0;
            color: var(--primary-navy);
            font-weight: 800;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            cursor: pointer;
            font-family: inherit;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            transition: 0.3s;
        }

            .lang-btn:hover {
                border-color: var(--primary-gold);
                color: var(--primary-gold);
            }

        .date-box {
            background: white;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            font-weight: 800;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
            border: 1px solid #e2e8f0;
            font-size: 0.85rem;
        }

        .notification-bell {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            border: 1px solid #e2e8f0;
            position: relative;
            cursor: pointer;
            transition: 0.3s;
            font-size: 1.1rem;
            text-decoration: none;
        }

            .notification-bell:hover {
                color: var(--primary-gold);
                border-color: var(--primary-gold);
                background: rgba(180, 83, 9, 0.05);
            }

        .notification-badge {
            position: absolute;
            top: -2px;
            inset-inline-end: -2px;
            min-width: 20px;
            height: 20px;
            background: #ef4444;
            color: white;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 900;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
            padding: 0 4px;
        }

        .btn-logout {
            background: white;
            color: #ef4444;
            font-weight: 800;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            font-size: 0.85rem;
            border: 1px solid #fee2e2;
            transition: 0.3s;
        }

            .btn-logout:hover {
                background: #fef2f2;
            }

        .page-body {
            flex: 1;
            padding: 1rem 2rem 2rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .content-area {
            flex: 1;
        }

        .system-footer {
            margin-top: 3rem;
            padding: 1.5rem 0 0 0;
            border-top: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--text-muted);
            font-size: 0.85rem;
            font-weight: 700;
        }

        .footer-attribution a {
            color: var(--primary-gold);
            text-decoration: none;
            font-weight: 900;
        }

        /* --- للزوار (غير المسجلين) --- */
        .public-navbar {
            background: white;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        }

        .public-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.5rem;
            font-weight: 900;
            color: var(--primary-navy);
            text-decoration: none;
        }

            .public-logo img {
                width: 50px;
                border-radius: 50%;
                border: 2px solid var(--primary-gold);
            }

        .public-nav-links {
            display: flex;
            gap: 1.5rem;
            align-items: center;
        }

            .public-nav-links a {
                color: var(--text-muted);
                text-decoration: none;
                font-weight: 700;
                transition: 0.3s;
            }

                .public-nav-links a:hover {
                    color: var(--primary-gold);
                }

        .btn-portal-login {
            background: var(--primary-navy);
            color: white !important;
            padding: 0.5rem 1.5rem;
            border-radius: 10px;
        }

            .btn-portal-login:hover {
                background: var(--primary-gold);
            }

        .public-footer {
            background: white;
            text-align: center;
            padding: 3rem 1rem;
            border-top: 1px solid #e2e8f0;
            margin-top: auto;
        }

        /* --- الموبايل --- */
        @@media (max-width: 1024px) {
            .sidebar

        {
            position: fixed;
            top: 0;
            bottom: 0;
            height: 100vh;
            z-index: 1000;
            box-shadow: 0 0 50px rgba(0,0,0,0.1);
        }

        html[dir="rtl"] .sidebar {
            right: 0;
            transform: translateX(100%);
        }

        html[dir="ltr"] .sidebar {
            left: 0;
            transform: translateX(-100%);
        }

            html[dir="rtl"] .sidebar.open, html[dir="ltr"] .sidebar.open {
                transform: translateX(0);
            }

        .mobile-toggle-btn {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .top-header {
            padding: 0 1rem;
        }

        .date-box, .btn-logout span, .lang-btn span {
            display: none;
        }

        .btn-logout, .lang-btn {
            width: 40px;
            height: 40px;
            padding: 0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .page-body {
            padding: 1rem;
        }

        .system-footer {
            flex-direction: column;
            gap: 0.8rem;
            text-align: center;
        }

        .public-navbar {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
        }

        .public-nav-links {
            flex-wrap: wrap;
            justify-content: center;
        }

        }
    </style>
</head>
<body class="@(User.Identity.IsAuthenticated ? "admin-layout" : "public-layout")">

    @if (User.Identity.IsAuthenticated)
    {
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="mainSidebar">
            <div class="sidebar-header">
                <div class="logo-placeholder">
                    <img src="~/images/logo.jpg" alt="Logo" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fa-solid fa-ship\'></i>'" />
                </div>
                <h2 class="brand-name">@Localizer["الأرجان للشحن"]</h2>
                <span class="brand-sub">ALARGAN AUTO SHIPPING</span>
            </div>
            <nav class="nav-menu">
                @if (isCustomer)
                {
                    <!-- القائمة الجانبية الخاصة بالعملاء -->
                    <a href="@Url.Action("Index", "CustomerPortal")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "CustomerPortal" ? "active" : "")"><i class="fa-solid fa-house-user"></i> @Localizer["لوحة التحكم الخاصة بي"]</a>

                    <a href="@Url.Action("PrintStatement", "Customers", new { id = currentCustomer?.Id })" target="_blank" class="nav-item"><i class="fa-solid fa-file-invoice"></i> @Localizer["طباعة كشف حسابي"]</a>

                    <a href="@Url.Action("Index", "Calculator")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Calculator" ? "active" : "")"><i class="fa-solid fa-calculator"></i> @Localizer["حاسبة تكاليف الشحن"]</a>
                    <a href="@Url.Action("Index", "Contact")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Contact" ? "active" : "")"><i class="fa-solid fa-headset"></i> @Localizer["اتصل بنا للدعم"]</a>
                }
                else
                {
                    <!-- القائمة الجانبية الخاصة بالموظفين والإدارة -->
                    <a href="@Url.Action("Index", "Home")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"><i class="fa-solid fa-chart-pie"></i> @Localizer["لوحة التحكم الشاملة"]</a>

                    @if (isAdmin || currentUser?.CanManageCars == true)
                    {
                        <a href="@Url.Action("Index", "Cars")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Cars" ? "active" : "")"><i class="fa-solid fa-car-side"></i> @Localizer["إدارة السيارات والمخزون"]</a>

                        <!-- الزر الجديد لمعرض الشركة -->
                        <a href="@Url.Action("Index", "Showroom")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Showroom" ? "active" : "")" style="color: var(--primary-gold); font-weight: 900;">
                            <i class="fa-solid fa-store" style="color: var(--primary-gold);"></i> @Localizer["معرض سيارات الشركة"]
                        </a>

                        <a href="@Url.Action("Index", "Auctions")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Auctions" ? "active" : "")"><i class="fa-solid fa-gavel"></i> @Localizer["إدارة المزادات"]</a>
                        <a href="@Url.Action("Index", "Locations")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Locations" ? "active" : "")"><i class="fa-solid fa-map-location-dot"></i> @Localizer["المواقع والمستودعات"]</a>
                        <a href="@Url.Action("Index", "Transporters")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Transporters" ? "active" : "")"><i class="fa-solid fa-truck-fast"></i> @Localizer["شركات النقل"]</a>
                        <a href="@Url.Action("Index", "DispatchOrders")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DispatchOrders" ? "active" : "")"><i class="fa-solid fa-route"></i> @Localizer["أوامر النقل الداخلي"]</a>
                        <a href="@Url.Action("Index", "Shipments")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Shipments" ? "active" : "")"><i class="fa-solid fa-ship"></i> @Localizer["الشحنات والحاويات"]</a>
                    }

                    @if (isAdmin || currentUser?.CanManageCustomers == true)
                    {
                        <a href="@Url.Action("Index", "Customers")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Customers" ? "active" : "")"><i class="fa-solid fa-users"></i> @Localizer["إدارة العملاء"]</a>
                    }

                    @if (isAdmin || currentUser?.CanManageFinance == true)
                    {
                        <a href="@Url.Action("Index", "Accounting")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Accounting" ? "active" : "")"><i class="fa-solid fa-calculator"></i> @Localizer["المحاسبة والتقارير المالية"]</a>
                        <a href="@Url.Action("Index", "Invoices")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Invoices" ? "active" : "")"><i class="fa-solid fa-file-invoice-dollar"></i> @Localizer["الفواتير الضريبية"]</a>
                        <a href="@Url.Action("Index", "Reports")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reports" ? "active" : "")"><i class="fa-solid fa-chart-line"></i> @Localizer["التقارير"] </a>
                        <a href="@Url.Action("Index", "PaymentReceipts")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PaymentReceipts" ? "active" : "")"><i class="fa-solid fa-hand-holding-dollar"></i> @Localizer["سندات القبض"]</a>
                        <a href="@Url.Action("Index", "PaymentVouchers")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PaymentVouchers" ? "active" : "")"><i class="fa-solid fa-money-bill-transfer"></i> @Localizer["سندات الصرف"]</a>
                    }

                    <a href="@Url.Action("Index", "Services")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Services" ? "active" : "")"><i class="fa-solid fa-tags"></i> @Localizer["دليل الخدمات والأسعار"]</a>
                    <a href="@Url.Action("Index", "Tracking")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Tracking" ? "active" : "")"><i class="fa-solid fa-location-dot"></i> @Localizer["بوابة تتبع الشحنات"]</a>
                    <a href="@Url.Action("Index", "Calculator")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Calculator" ? "active" : "")"><i class="fa-solid fa-mobile-screen"></i> @Localizer["حاسبة تكاليف الشحن"]</a>
                    <a href="@Url.Action("Index", "Contact")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Contact" ? "active" : "")"><i class="fa-solid fa-headset"></i> @Localizer["اتصل بنا"]</a>

                    @if (isAdmin || currentUser?.CanManageSettings == true)
                    {
                        <div style="margin-top: 0.5rem; border-top: 1px solid #e2e8f0; padding-top: 0.5rem;"></div>
                        <a asp-controller="Users" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")">
                            <i class="fa-solid fa-users-gear"></i> @Localizer["إدارة الموظفين والصلاحيات"]
                        </a>
                        <a href="@Url.Action("Index", "Settings")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Settings" ? "active" : "")"><i class="fa-solid fa-gear"></i> @Localizer["إعدادات النظام"]</a>
                    }
                }
            </nav>

            <div class="user-profile-bottom">
                <div class="user-info">
                    <span class="user-name">@(currentUser?.FullName ?? Localizer["المسؤول الرئيسي"].Value)</span>
                    <span class="user-role">@(isAdmin ? "ADMIN" : "STAFF")</span>
                </div>
                <div class="user-avatar">
                    @(string.IsNullOrEmpty(currentUser?.FullName) ? "A" : currentUser.FullName.Substring(0, 1).ToUpper())
                </div>
            </div>
        </aside>

        <main class="main-content">
            <header class="top-header">
                <div class="header-right">
                    <button class="mobile-toggle-btn" id="sidebarToggle"><i class="fa-solid fa-bars"></i></button>
                    <div class="lang-switch">
                        <form asp-controller="Home" asp-action="SetLanguage" method="post" asp-route-returnUrl="@Context.Request.Path">
                            @if (currentCulture.StartsWith("ar"))
                            {
                                <button type="submit" name="culture" value="en-US" class="lang-btn"><i class="fa-solid fa-globe"></i> <span>English</span></button>
                            }
                            else
                            {
                                <button type="submit" name="culture" value="ar" class="lang-btn"><i class="fa-solid fa-globe"></i> <span>العربية</span></button>
                            }
                        </form>
                    </div>
                </div>
                <div class="header-left">
                    <div class="date-box"><i class="fa-regular fa-calendar"></i> @DateTime.Now.ToString("D", new System.Globalization.CultureInfo(currentCulture))</div>
                    <a href="@Url.Action("Index", "Notifications")" class="notification-bell"><i class="fa-regular fa-bell"></i><span class="notification-badge" id="unreadNotifBadge" style="display:none;"></span></a>
                    <a href="@Url.Action("Logout", "Account")" class="btn-logout"><i class="fa-solid fa-power-off"></i> <span>@Localizer["تسجيل الخروج"]</span></a>
                </div>
            </header>

            <div class="page-body">
                <div class="content-area">
                    @RenderBody()
                </div>

                <footer class="system-footer">
                    <div>&copy; @DateTime.Now.Year - @Localizer["شركة الأرجان للشحن"]. @Localizer["جميع الحقوق محفوظة"].</div>
                    <div class="footer-attribution">
                        <span>@Localizer["تم التصميم والتطوير بواسطة"]</span>
                        <a href="#" target="_blank">GMTWEB</a>
                    </div>
                </footer>
            </div>
        </main>
    }
    else
    {
        <header class="public-navbar">
            <a href="@Url.Action("Index", "Tracking")" class="public-logo">
                <img src="~/images/logo.jpg" alt="Logo" onerror="this.style.display='none'" />
                ALARGAN
            </a>
            <nav class="public-nav-links">
                <a href="@Url.Action("Index", "Tracking")"><i class="fa-solid fa-location-dot"></i> @Localizer["تتبع شحنتك"]</a>
                <a href="@Url.Action("Index", "Services")"><i class="fa-solid fa-briefcase"></i> @Localizer["خدماتنا"]</a>
                <a href="@Url.Action("Index", "Contact")"><i class="fa-solid fa-headset"></i> @Localizer["اتصل بنا"]</a>
                <a href="@Url.Action("Login", "Account")" class="btn-portal-login"><i class="fa-solid fa-user-lock"></i> @Localizer["الدخول"]</a>
            </nav>
        </header>

        <main style="flex: 1; background: white;">
            @RenderBody()
        </main>

        <footer class="public-footer">
            <div style="font-size: 1.5rem; font-weight: 900; margin-bottom: 1rem; color: var(--primary-gold);">ALARGAN AUTO SHIPPING</div>
            <p style="color: var(--text-muted); font-weight: 600;">@Localizer["شريكك الموثوق في الخدمات اللوجستية واستيراد السيارات"]</p>
            <div style="margin-top: 2rem; font-size: 0.9rem; color: #94a3b8;">&copy; @DateTime.Now.Year Alargan Shipping. @Localizer["جميع الحقوق محفوظة"]</div>
        </footer>
    }

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggleBtn = document.getElementById('sidebarToggle'),
                  sidebar = document.getElementById('mainSidebar'),
                  overlay = document.getElementById('sidebarOverlay');

            if(toggleBtn && sidebar && overlay) {
                toggleBtn.addEventListener('click', () => {
                    sidebar.classList.add('open');
                    overlay.classList.add('show');
                });
                overlay.addEventListener('click', () => {
                    sidebar.classList.remove('open');
                    overlay.classList.remove('show');
                });
            }

            // Fetch unread notifications count
            $.get('/Notifications/GetUnreadCount', function(data) {
                if(data && data > 0) {
                    $('#unreadNotifBadge').text(data).show();
                }
            });
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>