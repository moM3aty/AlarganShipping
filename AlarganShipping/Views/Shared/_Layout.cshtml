@using AlarganShipping.Models
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject ApplicationDbContext DbContext
@{
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var htmlDir = isRtl ? "rtl" : "ltr";

    // --- الحل الجذري لمشكلة صلاحيات الأدمن ---
    var userEmail = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Email)?.Value;

    var currentUser = !string.IsNullOrEmpty(userEmail)
        ? DbContext.Users.FirstOrDefault(u => u.Email == userEmail)
        : null;

    // إعطاء الإدارة كامل الصلاحيات
    bool isAdmin = currentUser?.Role == "Admin";
}
<!DOCTYPE html>
<html lang="@currentCulture" dir="@htmlDir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Localizer["الأرجان للشحن"]</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css" />
    <link href="~/images/logo.jpg" rel="icon" type="image/x-icon" />

    <style>
        :root {
            --primary-navy: #2C3E50;
            --secondary-navy: #1A252F;
            --primary-gold: #B8935A;
            --secondary-gold: #967443;
            --bg-body: #f4f7f9;
            --text-dark: #1e293b;
            --text-muted: #64748b;
            --sidebar-width: 300px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--bg-body);
            display: flex;
            height: 100vh;
            overflow: hidden;
            color: var(--text-dark);
        }

        /* --- Sidebar & Overlay --- */
        .sidebar-overlay {
            position: fixed;
            inset: 0;
            background: rgba(26, 37, 47, 0.6);
            z-index: 999;
            opacity: 0;
            visibility: hidden;
            transition: 0.3s ease;
            backdrop-filter: blur(4px);
        }

            .sidebar-overlay.show {
                opacity: 1;
                visibility: visible;
            }

        .sidebar {
            width: var(--sidebar-width);
            background: #ffffff;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            border-inline-end: 1px solid #e2e8f0;
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            flex-shrink: 0;
        }

        .sidebar-header {
            padding: 2.5rem 2rem 1.5rem;
            text-align: center;
        }

        .logo-placeholder {
            width: 100px;
            height: 100px;
            background: white;
            border-radius: 50%;
            margin: 0 auto 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 20px rgba(184, 147, 90, 0.15);
            color: var(--primary-navy);
            font-size: 2.5rem;
            border: 3px solid var(--primary-gold);
            overflow: hidden;
        }

            .logo-placeholder img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        /* اصلاح وتنسيق الهيدر العلوي بشكل دقيق */
        .header-left, .header-right {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .brand-name {
            font-size: 1.3rem;
            font-weight: 900;
            color: var(--primary-navy);
            margin: 0 0 0.25rem 0;
        }

        .brand-sub {
            font-size: 0.7rem;
            color: var(--primary-gold);
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .nav-menu {
            flex: 1;
            padding: 1rem 1.5rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 0.85rem 1.25rem;
            border-radius: 14px;
            color: var(--text-muted);
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
            font-size: 0.9rem;
        }

            .nav-item:hover {
                background: #f8fafc;
                color: var(--primary-navy);
            }

            .nav-item i {
                width: 25px;
                text-align: center;
                font-size: 1.1rem;
                color: #cbd5e1;
                transition: 0.3s;
            }

            .nav-item:hover i {
                color: var(--primary-gold);
            }

            .nav-item.active {
                background: var(--primary-navy);
                color: white;
                box-shadow: 0 4px 15px rgba(44, 62, 80, 0.2);
            }

                .nav-item.active i {
                    color: var(--primary-gold);
                }

        .user-profile-bottom {
            margin: 1.5rem;
            padding: 1rem;
            background: #f8fafc;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border: 1px solid #e2e8f0;
        }

        .user-info {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 900;
            color: var(--primary-navy);
            font-size: 0.85rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 140px;
        }

        .user-role {
            font-weight: 800;
            color: var(--primary-gold);
            font-size: 0.65rem;
            text-transform: uppercase;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--primary-navy);
            color: var(--primary-gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            font-size: 1.1rem;
            border: 1px solid rgba(184, 147, 90, 0.3);
        }

        /* --- Main Content Area --- */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
            background: var(--bg-body);
            height: 100vh;
        }

        .top-header {
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2.5rem;
            background: transparent;
            margin-top: 0.5rem;
            flex-shrink: 0;
        }

        .mobile-toggle-btn {
            display: none;
            background: white;
            border: 1px solid #e2e8f0;
            color: var(--primary-navy);
            font-size: 1.4rem;
            padding: 8px 14px;
            border-radius: 12px;
            cursor: pointer;
            transition: 0.3s;
        }

        .lang-btn {
            background: white;
            border: 1px solid #e2e8f0;
            color: var(--primary-navy);
            font-weight: 800;
            padding: 0.6rem 1.25rem;
            border-radius: 50px;
            cursor: pointer;
            font-family: inherit;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
            transition: 0.3s;
        }

            .lang-btn:hover {
                border-color: var(--primary-gold);
                color: var(--primary-gold);
            }

        .date-box {
            background: white;
            padding: 0.6rem 1.25rem;
            border-radius: 50px;
            font-weight: 800;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #e2e8f0;
            font-size: 0.85rem;
        }

        .notification-bell {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            border: 1px solid #e2e8f0;
            position: relative;
            cursor: pointer;
            transition: 0.3s;
            font-size: 1.2rem;
            text-decoration: none;
        }

            .notification-bell:hover {
                color: var(--primary-gold);
                border-color: var(--primary-gold);
                background: rgba(184, 147, 90, 0.05);
            }

        .notification-badge {
            position: absolute;
            top: -4px;
            inset-inline-end: -4px;
            min-width: 22px;
            height: 22px;
            background: #ef4444;
            color: white;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 900;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
            padding: 0 5px;
            line-height: 1;
            box-shadow: 0 2px 5px rgba(239,68,68,0.3);
        }

        .btn-logout {
            background: var(--primary-navy);
            color: white;
            font-weight: 800;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 0.75rem 1.5rem;
            border-radius: 50px;
            font-size: 0.9rem;
            border: 1px solid var(--primary-navy);
            transition: 0.3s;
        }

            .btn-logout:hover {
                background: var(--primary-gold);
                border-color: var(--primary-gold);
            }

        .page-body {
            flex: 1;
            padding: 1rem 2.5rem 2rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .content-area {
            flex: 1;
        }

        /* --- System Footer --- */
        .system-footer {
            margin-top: 3rem;
            padding: 1.5rem 0 0 0;
            border-top: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--text-muted);
            font-size: 0.85rem;
            font-weight: 700;
        }

        .footer-attribution {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .footer-attribution a {
                color: var(--primary-gold);
                text-decoration: none;
                font-weight: 900;
                transition: 0.3s;
            }

                .footer-attribution a:hover {
                    color: var(--primary-navy);
                    text-decoration: underline;
                }

        /* ========================================================
                   Global Premium Table Styles (DataTables)
                   ======================================================== */
        .data-card {
            background: transparent !important;
            border-radius: 0 !important;
            padding: 0 !important;
            box-shadow: none !important;
            border: none !important;
        }

        .table-enterprise {
            width: 100% !important;
            border-collapse: separate !important;
            border-spacing: 0 12px !important;
            margin-top: 1rem !important;
        }

            .table-enterprise th {
                background-color: transparent !important;
                color: #94a3b8 !important;
                font-weight: 900 !important;
                padding: 1rem 1.5rem !important;
                border-bottom: 2px solid #e2e8f0 !important;
                text-align: start !important;
                white-space: nowrap !important;
                font-size: 0.85rem !important;
                text-transform: uppercase !important;
                letter-spacing: 1px !important;
            }

            .table-enterprise tbody tr {
                background-color: #ffffff !important;
                box-shadow: 0 5px 15px rgba(44, 62, 80, 0.04) !important;
                transition: all 0.3s ease !important;
            }

                .table-enterprise tbody tr:hover {
                    transform: translateY(-3px) !important;
                    box-shadow: 0 12px 25px rgba(184, 147, 90, 0.15) !important;
                    background-color: #ffffff !important;
                }

            .table-enterprise td {
                padding: 1.25rem 1.5rem !important;
                border: none !important;
                border-top: 1px solid #f8fafc !important;
                border-bottom: 1px solid #f8fafc !important;
                color: var(--text-dark) !important;
                font-weight: 700 !important;
                vertical-align: middle !important;
            }

                .table-enterprise td:first-child {
                    border-inline-start: 1px solid #f8fafc !important;
                    border-start-start-radius: 1.25rem !important;
                    border-end-start-radius: 1.25rem !important;
                }

                .table-enterprise td:last-child {
                    border-inline-end: 1px solid #f8fafc !important;
                    border-start-end-radius: 1.25rem !important;
                    border-end-end-radius: 1.25rem !important;
                }

            .table-enterprise tbody tr:hover td {
                border-top-color: rgba(184, 147, 90, 0.3) !important;
                border-bottom-color: rgba(184, 147, 90, 0.3) !important;
            }

                .table-enterprise tbody tr:hover td:first-child {
                    border-inline-start-color: rgba(184, 147, 90, 0.3) !important;
                }

                .table-enterprise tbody tr:hover td:last-child {
                    border-inline-end-color: rgba(184, 147, 90, 0.3) !important;
                }

        /* --- Fix Select2 Dropdown Styling Globally (حل مشكلة النقاط والتداخل) --- */
        .select2-container--open {
            z-index: 9999999 !important;
        }

        .select2-results__options {
            list-style: none !important; /* إخفاء النقاط السوداء (Bullets) */
            margin: 0 !important;
            padding: 0 !important;
        }

        .select2-results__option {
            list-style-type: none !important;
            padding: 10px 15px !important;
            font-weight: 700 !important;
            color: var(--primary-navy) !important;
            font-family: 'Cairo', sans-serif !important;
        }

        .select2-results__option--highlighted {
            background-color: var(--primary-gold) !important;
            color: white !important;
        }

        .select2-search__field {
            border: 1px solid #e2e8f0 !important;
            border-radius: 8px !important;
            padding: 8px 12px !important;
            outline: none !important;
            font-family: 'Cairo', sans-serif !important;
        }

            .select2-search__field:focus {
                border-color: var(--primary-gold) !important;
            }

        .select2-dropdown {
            border: 2px solid #e2e8f0 !important;
            border-radius: 0.75rem !important;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
            overflow: hidden !important;
        }

        /* Modern DataTables Controls */
        .dataTables_wrapper .dataTables_filter {
            margin-bottom: 1.5rem;
        }

            .dataTables_wrapper .dataTables_filter input {
                border: 2px solid #e2e8f0;
                border-radius: 12px;
                padding: 10px 20px;
                outline: none;
                font-family: inherit;
                font-weight: 700;
                color: var(--primary-navy);
                background: #ffffff;
                transition: 0.3s;
                width: 250px;
                box-shadow: 0 4px 10px rgba(0,0,0,0.02);
            }

                .dataTables_wrapper .dataTables_filter input:focus {
                    border-color: var(--primary-gold);
                    box-shadow: 0 0 0 4px rgba(184, 147, 90, 0.1);
                    width: 320px;
                }

        .dataTables_wrapper .dataTables_length select {
            border-radius: 10px;
            padding: 8px 15px;
            font-family: inherit;
            font-weight: 700;
            border: 2px solid #e2e8f0;
            outline: none;
            background: #ffffff;
            color: var(--primary-navy);
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
        }

        .dataTables_wrapper .dataTables_paginate {
            margin-top: 1.5rem !important;
            padding-top: 1.5rem !important;
            display: flex !important;
            justify-content: flex-end !important;
            gap: 5px !important;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button {
                border-radius: 10px !important;
                border: 1px solid #e2e8f0 !important;
                background: white !important;
                color: var(--text-muted) !important;
                font-weight: 800 !important;
                padding: 8px 16px !important;
                margin: 0 2px !important;
                transition: 0.3s !important;
            }

                .dataTables_wrapper .dataTables_paginate .paginate_button.current,
                .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
                    background: var(--primary-gold) !important;
                    color: white !important;
                    border-color: var(--primary-gold) !important;
                    box-shadow: 0 4px 10px rgba(184, 147, 90, 0.3) !important;
                }

                .dataTables_wrapper .dataTables_paginate .paginate_button:hover:not(.current) {
                    background: var(--primary-navy) !important;
                    color: white !important;
                    border-color: var(--primary-navy) !important;
                }

        /* ========================================================
                   تعديلات الموبايل (الميديا كويري) لضمان تجاوب الشاشة بالكامل
                   ======================================================== */
        @@media (max-width: 1024px) {
            .sidebar {
                position: fixed;
                top: 0;
                bottom: 0;
                height: 100vh;
                z-index: 1000;
                transition: transform 0.4s ease;
                box-shadow: 0 0 50px rgba(0,0,0,0.1);
            }

            html[dir="rtl"] .sidebar {
                right: 0;
                transform: translateX(100%);
            }

            html[dir="ltr"] .sidebar {
                left: 0;
                transform: translateX(-100%);
            }

                html[dir="rtl"] .sidebar.open, html[dir="ltr"] .sidebar.open {
                    transform: translateX(0);
                }

            .mobile-toggle-btn {
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .top-header {
                padding: 0 1rem;
                height: 70px;
            }

            .header-left, .header-right {
                gap: 8px;
            }
            /* إخفاء النصوص من الأزرار العلوية لتوفير المساحة */
            .date-box, .btn-logout span, .lang-btn span {
                display: none;
            }
            /* تحويل أزرار اللغة والخروج إلى أيقونات دائرية متناسقة مع الجرس */
            .btn-logout, .lang-btn, .mobile-toggle-btn {
                width: 42px;
                height: 42px;
                padding: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 50%;
            }

                .btn-logout i, .lang-btn i {
                    margin: 0;
                }

            .page-body {
                padding: 1rem 1rem 2rem 1rem;
            }

            .system-footer {
                flex-direction: column;
                gap: 0.8rem;
                text-align: center;
            }
        }
    </style>
</head>
<body>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="mainSidebar">
            <div class="sidebar-header">
                <div class="logo-placeholder">
                    <img src="~/images/logo.jpg" alt="Alargan Logo" onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=\'fa-solid fa-anchor\'></i>'" />
                </div>
                <h2 class="brand-name">@Localizer["شركة الارجان للشحن"]</h2>
                <span class="brand-sub">ALARGAN AUTO SHIPPING</span>
            </div>

            <nav class="nav-menu">
                <a href="@Url.Action("Index", "Home")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"><i class="fa-solid fa-chart-pie"></i> @Localizer["لوحة التحكم الشاملة"]</a>

                @if (isAdmin || currentUser?.CanManageCars == true)
                {
                    <a href="@Url.Action("Index", "Cars")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Cars" ? "active" : "")"><i class="fa-solid fa-car-side"></i> @Localizer["إدارة السيارات والمخزون"]</a>
                    <a href="@Url.Action("Index", "Auctions")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Auctions" ? "active" : "")"><i class="fa-solid fa-gavel"></i> @Localizer["إدارة المزادات"]</a>
                    <a href="@Url.Action("Index", "Locations")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Locations" ? "active" : "")"><i class="fa-solid fa-map-location-dot"></i> @Localizer["المواقع والمستودعات"]</a>
                    <a href="@Url.Action("Index", "Transporters")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Transporters" ? "active" : "")"><i class="fa-solid fa-truck-fast"></i> @Localizer["شركات النقل الداخلي"]</a>
                    <a href="@Url.Action("Index", "DispatchOrders")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DispatchOrders" ? "active" : "")"><i class="fa-solid fa-route"></i> @Localizer["أوامر النقل (Dispatch)"]</a>
                    <a href="@Url.Action("Index", "Shipments")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Shipments" ? "active" : "")"><i class="fa-solid fa-ship"></i> @Localizer["الشحنات والحاويات"]</a>
                }

                @if (isAdmin || currentUser?.CanManageCustomers == true)
                {
                    <a href="@Url.Action("Index", "Customers")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Customers" ? "active" : "")"><i class="fa-solid fa-users"></i> @Localizer["إدارة شؤون العملاء"]</a>
                }

                @if (isAdmin || currentUser?.CanManageFinance == true)
                {
                    <a href="@Url.Action("Index", "Accounting")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Accounting" ? "active" : "")"><i class="fa-solid fa-calculator"></i> @Localizer["المحاسبة والتقارير المالية"]</a>
                    <a href="@Url.Action("Index", "Invoices")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Invoices" ? "active" : "")"><i class="fa-solid fa-file-invoice-dollar"></i> @Localizer["الفواتير الضريبية"]</a>
                    <a href="@Url.Action("Index", "PaymentReceipts")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PaymentReceipts" ? "active" : "")"><i class="fa-solid fa-hand-holding-dollar"></i> @Localizer["سندات القبض"]</a>
                }

                <a href="@Url.Action("Index", "Services")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Services" ? "active" : "")"><i class="fa-solid fa-tags"></i> @Localizer["دليل الخدمات والأسعار"]</a>
                <a href="@Url.Action("Index", "Tracking")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Tracking" ? "active" : "")"><i class="fa-solid fa-location-dot"></i> @Localizer["بوابة تتبع الشحنات"]</a>
                <a href="@Url.Action("Index", "Calculator")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Calculator" ? "active" : "")"><i class="fa-solid fa-mobile-screen"></i> @Localizer["حاسبة تكاليف الشحن"]</a>
                <a href="@Url.Action("Index", "Contact")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Contact" ? "active" : "")"><i class="fa-solid fa-headset"></i> @Localizer["اتصل بنا"]</a>

                @if (isAdmin || currentUser?.CanManageSettings == true)
                {
                    <div style="margin-top: 0.5rem; border-top: 1px solid #e2e8f0; padding-top: 0.5rem;"></div>
                    <a href="@Url.Action("Index", "Users")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")"><i class="fa-solid fa-users-gear"></i> @Localizer["إدارة الموظفين"]</a>
                    <a href="@Url.Action("Index", "Settings")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Settings" ? "active" : "")"><i class="fa-solid fa-gear"></i> @Localizer["إعدادات النظام والقواعد"]</a>
                }
            </nav>

            <div class="user-profile-bottom">
                <div class="user-info">
                    <span class="user-name">@(currentUser?.FullName ?? Localizer["المسؤول الرئيسي"].Value)</span>
                    <span class="user-role">@(isAdmin ? "ADMIN" : "STAFF")</span>
                </div>
                <div class="user-avatar">
                    @(string.IsNullOrEmpty(currentUser?.FullName) ? "A" : currentUser.FullName.Substring(0, 1).ToUpper())
                </div>
            </div>
        </aside>

        <main class="main-content">
            <header class="top-header">
                <div class="header-right">
                    <button class="mobile-toggle-btn" id="sidebarToggle"><i class="fa-solid fa-bars"></i></button>
                    <div class="lang-switch">
                        <form asp-controller="Home" asp-action="SetLanguage" method="post" asp-route-returnUrl="@Context.Request.Path">
                            @if (currentCulture.StartsWith("ar"))
                            {
                                <button type="submit" name="culture" value="en-US" class="lang-btn"><i class="fa-solid fa-globe" style="color: var(--primary-gold);"></i> <span>English</span></button>
                            }
                            else
                            {
                                <button type="submit" name="culture" value="ar" class="lang-btn"><i class="fa-solid fa-globe" style="color: var(--primary-gold);"></i> <span>العربية</span></button>
                            }
                        </form>
                    </div>
                </div>
                <div class="header-left">
                    <div class="date-box"><i class="fa-regular fa-calendar"></i> @DateTime.Now.ToString("D", new System.Globalization.CultureInfo(currentCulture))</div>
                    <a href="@Url.Action("Index", "Notifications")" class="notification-bell"><i class="fa-regular fa-bell"></i><span class="notification-badge" id="unreadNotifBadge" style="display:none;"></span></a>
                    <a href="@Url.Action("Logout", "Account")" class="btn-logout"><i class="fa-solid fa-arrow-right-from-bracket"></i> <span>@Localizer["تسجيل الخروج"]</span></a>
                </div>
            </header>

            <div class="page-body">
                @if (TempData["Success"] != null)
                {
                    <div style="background: #f0fdf4; border: 1px solid #16a34a; color: #16a34a; padding: 1rem 1.5rem; border-radius: 1rem; margin-bottom: 1.5rem; font-weight: 800; display: flex; align-items: center; gap: 10px; box-shadow: 0 4px 10px rgba(22, 163, 74, 0.1);">
                        <i class="fa-solid fa-circle-check" style="font-size: 1.2rem;"></i> @TempData["Success"]
                    </div>
                }

                <div class="content-area">
                    @RenderBody()
                </div>

                <footer class="system-footer">
                    <div>&copy; @DateTime.Now.Year - @Localizer["شركة الأرجان للشحن"]. @Localizer["جميع الحقوق محفوظة"].</div>
                    <div class="footer-attribution">
                        <span>@Localizer["تم التصميم والتطوير بواسطة"]</span>
                        <a href="https://gmtweb.online/" target="_blank">GMTWEB</a>
                    </div>
                </footer>
            </div>
        </main>
    }
    else
    {

        <header class="public-navbar">
            <a href="@Url.Action("Index", "Tracking")" class="public-logo">
                <img src="~/images/logo.jpg" alt="Logo" onerror="this.src='https://via.placeholder.com/50?text=Logo'" />
                ALARGAN
            </a>

            <nav class="public-nav-links">
                <a href="@Url.Action("Index", "Tracking")"><i class="fa-solid fa-magnifying-glass-location"></i> @Localizer["تتبع شحنتك"]</a>
                <a href="@Url.Action("Index", "Calculator")"><i class="fa-solid fa-calculator"></i> @Localizer["حاسبة التكاليف"]</a>
                <a href="@Url.Action("Index", "Services")"><i class="fa-solid fa-briefcase"></i> @Localizer["خدماتنا"]</a>
                <a href="@Url.Action("Index", "Contact")"><i class="fa-solid fa-headset"></i> @Localizer["فروعنا واتصل بنا"]</a>
                <a href="@Url.Action("Login", "Account")" class="btn-portal-login"><i class="fa-solid fa-user-lock"></i> @Localizer["بوابة الدخول"]</a>
            </nav>
        </header>

        <main style="min-height: calc(100vh - 200px);">
            @RenderBody()
        </main>

        <footer class="public-footer">
            <div style="font-size: 1.5rem; font-weight: 900; margin-bottom: 1rem; color: var(--primary-gold);">ALARGAN AUTO SHIPPING</div>
            <p>@Localizer["شريكك الموثوق في الخدمات اللوجستية واستيراد السيارات"]</p>
            <div style="margin-top: 2rem; font-size: 0.9rem; color: #94a3b8;">&copy; @DateTime.Now.Year Alargan Shipping. @Localizer["جميع الحقوق محفوظة"]</div>
        </footer>
    }

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggleBtn = document.getElementById('sidebarToggle'),
                  sidebar = document.getElementById('mainSidebar'),
                  overlay = document.getElementById('sidebarOverlay');

            if(toggleBtn && sidebar && overlay) {
                toggleBtn.addEventListener('click', () => {
                    sidebar.classList.add('open');
                    overlay.classList.add('show');
                });
                overlay.addEventListener('click', () => {
                    sidebar.classList.remove('open');
                    overlay.classList.remove('show');
                });
            }

            $.get('/Notifications/GetUnreadCount', function(data) {
                if(data && data > 0) {
                    $('#unreadNotifBadge').text(data).show();
                }
            });
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>