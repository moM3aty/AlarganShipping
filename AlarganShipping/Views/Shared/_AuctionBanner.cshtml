<style>
    /* Premium Auction Banner Component */
    .auction-banner-card {
        background: linear-gradient(135deg, var(--secondary-navy) 0%, var(--primary-navy) 100%);
        border-radius: 2.5rem;
        padding: 4rem;
        margin: 4rem 0;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
        box-shadow: 0 15px 40px rgba(26, 37, 47, 0.2);
    }

        .auction-banner-card::before {
            content: '\1F528';
            position: absolute;
            top: 50%;
            right: 5%;
            transform: translateY(-50%);
            font-size: 15rem;
            opacity: 0.1;
            color: var(--primary-gold);
        }

    .banner-content-left {
        max-width: 600px;
        position: relative;
        z-index: 2;
        text-align: right;
    }

        .banner-content-left h2 {
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 1.5rem;
            color: var(--primary-gold);
        }

        .banner-content-left p {
            font-size: 1.1rem;
            line-height: 1.8;
            font-weight: 700;
            opacity: 0.9;
        }

    .banner-btns {
        display: flex;
        gap: 1.5rem;
        position: relative;
        z-index: 2;
    }

    .btn-white-premium {
        background: var(--primary-gold);
        color: white;
        padding: 1rem 2rem;
        border-radius: 1rem;
        font-weight: 900;
        text-decoration: none;
        transition: 0.3s;
        box-shadow: 0 5px 15px rgba(184, 147, 90, 0.3);
    }

        .btn-white-premium:hover {
            background: var(--secondary-gold);
            transform: translateY(-2px);
        }
</style>

<div class="auction-banner-card" dir="rtl">
    <div class="banner-content-left">
        <h2>@Localizer["هل ترغب في الحصول على حساب مزاد؟"]</h2>
        <p>@Localizer["فريقنا المتواجد في صلالة أو نزوى أو مسقط وأمريكا مستعد لتزويدك بكافة الأدوات اللازمة لبدء استيراد سياراتك بأقل التكاليف."]</p>
    </div>
    <div class="banner-btns">
        <a href="@Url.Action("Index", "Contact")" class="btn-white-premium">@Localizer["اطلب حسابك الآن"]</a>
    </div>
</div>